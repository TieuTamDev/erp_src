<!-- Modal nằm ngoài bảng -->
<div class="modal fade" id="holidayDetailsModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="holidayDetailsModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl">
    <div class="modal-content">
      <div class="modal-header">
        <h4 class="modal-title" id="holidayDetailsModalLabel">Thông tin nghỉ phép</h4>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body row">
        <!-- Cột trái: Thông tin nhân sự và chi tiết đơn -->
        <div class="col-md-7">
          <div class="info-section">
            <p class="info-label">Nhân sự: <span class="fw-bold" id="modal-user-fullname">Không xác định</span> (<span class="fw-bold" id="modal-user-sid">Không xác định</span>)</p>
            <p class="info-label">Phòng ban: <span class="fw-bold" id="modal-department-name">Không xác định</span></p>
            <p class="info-label">Vị trí công việc: <span class="fw-bold" id="modal-positionjob-name">Không xác định</span></p>
          </div>
          <div id="leaveDetailsContainer"></div>
        </div>
        <!-- Cột phải: Quá trình xử lý -->
        <div class="col-md-5">
          <h6 class="timeline-title">Quá trình xử lý</h6>
          <ul class="timeline__create" id="processTimeline"></ul>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-primary btn-custom d-none" id="print_holpros">In phép</button>
        <button type="button" class="btn btn-secondary btn-custom" data-bs-dismiss="modal">Đóng</button>
      </div>
    </div>
  </div>
</div>

<style>
