<script>
  $(document).ready(function () {
    // Hàm định dạng ngày thành dd/MM/yyyy
    function formatDate(date) {
      const d = new Date(date);
      const day = String(d.getDate()).padStart(2, '0');
      const month = String(d.getMonth() + 1).padStart(2, '0');
      const year = d.getFullYear();
      return `${day}/${month}/${year}`;
    }

    // Chọn tất cả các nút "Chi tiết"
    $('.detail-btn').on('click', function () {
      const holproId = $(this).data('holpro-id');
      const holproStatus = $(this).data('holpro-status');

      if (holproStatus == "DONE"){
        $('#print_holpros').removeClass("d-none");
      }

      // Dữ liệu từ controller, sử dụng .to_json với escape_html
      const results = <%= @results.to_json.html_safe %>;
      const mandocDetails = <%= @mandoc_details.to_json.html_safe %>;
      const holprosdetailsData = <%= @holprosdetails_data.to_json.html_safe %>;
      const holtypesMap = <%= @holtypes_map.to_json.html_safe %>;
      const holproHandoverNames = <%= @holpro_handover_names.to_json.html_safe %>;
      const holproTypes = <%= @holpro_types.to_json.html_safe %>;
      const holproLocations = <%= @holpro_locations.to_json.html_safe %>;

      const holpro = results.find(r => r.holpro_id === parseInt(holproId));

      if (holpro) {
        // Hiển thị thông tin nhân sự
        $('#modal-user-fullname').text(holpro.user_fullname || "Không xác định");
        $('#modal-user-sid').text(holpro.user_sid || "Không xác định");
        $('#modal-positionjob-name').text(holpro.positionjob_name || "Không xác định");
        $('#modal-department-name').text(holpro.department_name || "Không xác định");

        // Hiển thị chi tiết đơn nghỉ phép (riêng cho từng holprosdetails)
        $('#leaveDetailsContainer').empty();
        const holidayDetails = holprosdetailsData.filter(detail => detail.holpros_id === parseInt(holproId));
        if (holidayDetails.length > 0) {
          $.each(holidayDetails, function (index, detail) {
            const holprosdetailsId = detail.id; // Sử dụng id của holprosdetails

            // Định dạng ngày dtfrom và dtto
            const dtFrom = detail.dtfrom ? formatDate(detail.dtfrom) : "Không xác định";
            const dtTo = detail.dtto ? formatDate(detail.dtto) : "Không xác định";

            // Chỉ hiển thị dtFrom nếu dtFrom = dtTo
            const timeRange = dtFrom === dtTo ? dtFrom : `${dtFrom} - ${dtTo}`;

            // Xử lý chuỗi chi tiết nghỉ (details)
            const detailSegments = detail.details ? detail.details.split('$$$') : [];
            const detailFormatted = detailSegments.length > 0 ? detailSegments.map(segment => {
              const [datePart, statusPart] = segment.split('-');
              const dateMatch = datePart.match(/\d{2}\/\d{2}\/\d{4}/);
              const date = dateMatch ? dateMatch[0] : "Không xác định";
              const status = statusPart ? statusPart.replace(/\(|\)/g, '') : "Không xác định";
              const statusMapping = {
                'ALL': 'Cả ngày',
                'AM': 'Buổi sáng',
                'PM': 'Buổi chiều'
              };
              return `${date} (${statusMapping[status] || status})`;
            }).join('<br>') : "Không có chi tiết nghỉ";

            // Lấy thông tin từ holproHandoverNames, holproTypes, holproLocations dựa trên holprosdetails_id
            const receiverFormatted = holproHandoverNames[holprosdetailsId] || "Không có người nhận bàn giao";
            const typeName = holproTypes[holprosdetailsId] || holtypesMap[detail.sholtype] || "Không xác định";
            const locationType = detail.issued_place === "IN-COUNTRY" ? "Trong nước" : "Nước ngoài";
            const nameLocation = detail.issued_place !== "IN-COUNTRY" ? holproLocations[holprosdetailsId] || "Nước ngoài không xác định" : "";
            

            const note = detail.note || "Không có nội dung";

            const leaveDetailHtml = `
              <div class="leave-details">
                  <h5 class="sholtype-tag">${typeName}</h5>
                <p>Thời gian nghỉ phép: <span class="fw-bold">${timeRange}</span></p>
                <div class="sub-details" style="font-size: 14px; color: #333; margin-left: 140px; padding-bottom: 8px;">
                  ${detailFormatted}
                </div>
                <p>Cá nhân hỗ trợ công việc: <span class="fw-bold">${receiverFormatted}</span></p>
                <p>Địa điểm: <span class="fw-bold">${locationType}</span></p>
                ${nameLocation ? `<p id="national_place">Quốc gia: <span class="fw-bold">${nameLocation}</span></p>` : '<p id="national_place" class="d-none"></p>'}
                <p>Nội dung nghỉ: <span class="fw-bold">${note}</span></p>
              </div>
            `;
            $('#leaveDetailsContainer').append(leaveDetailHtml);
          });
        } else {
          $('#leaveDetailsContainer').html('<p>Không có thông tin nghỉ phép.</p>');
        }

        // Hiển thị quá trình xử lý (chung cho holproId)
        $('#processTimeline').empty();
        const processDetails = mandocDetails[holproId] || [];
        if (processDetails.length > 0) {
          $.each(processDetails, function (index, step) {
            const time = new Date(step.created_at).toLocaleString('vi-VN', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });
            let status = "";
            let statusClass = "";
            let iconHtml = "";

            if (index === 0) {
              // Người đầu tiên: Đăng ký nghỉ phép
              status = "Đăng ký nghỉ phép";
              statusClass = "";
              iconHtml = "";
            } else if (index === processDetails.length - 1) {
              if (step.status === "DAXULY"){
                // Người cuối cùng: Dựa trên holproStatus
                if (holproStatus === "DONE") {
                  status = "Duyệt phép";
                  statusClass = "DONE";
                  iconHtml = '<i class="fas fa-check-circle" style="color: green; margin-left: 5px;"></i>'; // Icon tick xanh
                } else if (holproStatus === "REFUSE") {
                  status = "Từ chối";
                  statusClass = "REFUSE";
                  iconHtml = '<i class="fas fa-times-circle" style="color: red; margin-left: 5px;"></i>'; // Icon cancel đỏ
                } else if (holproStatus === "PENDING") {
                  status = "Đang chờ xử lý";
                  statusClass = "PENDING";
                  iconHtml = '';
                } else {
                  status = holproStatus || "Không xác định";
                  statusClass = "";
                  iconHtml = "";
                }
              } else {
                status = "Đang chờ xử lý";
                statusClass = "PENDING";
                iconHtml = '';
              }
            } else {
              // Những người trung gian: Duyệt đơn cấp phòng
              status = "Duyệt đơn cấp phòng";
              statusClass = "";
              iconHtml = "";
            }

            const userPosition = step.user_position || "Không xác định";
            const li = $('<li></li>').addClass(statusClass);
            li.html(`
              <div class="timeline__date">${time}</div>
              <div class="timeline__content">
                <div class="timeline__title">${status}${iconHtml}</div>
                <div class="timeline__description">
                  <span>Người xử lý: </span><span class="name fw-bold">${step.handler_name}</span><br>
                  <span>Chức vụ: </span><span class="fw-bold">${userPosition}</span>
                </div>
              </div>
            `);
            $('#processTimeline').append(li);
          });
        } else {
          $('#processTimeline').html('<li>Không có thông tin xử lý.</li>');
        }
      }
    });
  });
</script>

<script>
  function updatePerPage(value) {
    window.location.href = "<%= setting_holidays_manager_holiday_path(lang: session[:lang], search: session[:search]) %>?per_page=" + value + "&page=1";
  }

  function changeTab(uorg_scode) {
    document.body.style.cursor = 'wait';
    const urlParams = new URLSearchParams(window.location.search);
    urlParams.set('uorg_scode', uorg_scode);
    urlParams.set('page', '1');
    window.location.href = '<%= setting_holidays_manager_holiday_path %>?' + urlParams.toString();
  }
</script>