  }

  .leave-details h5 {
    font-size: 14px;
    font-weight: bold;
    color: #333;
    margin-bottom: 12px;
  }

  .leave-details p {
    font-size: 14px;
    color: #333;
    margin-bottom: 8px;
  }

  .leave-details .sub-details {
    margin-left: 20px;
    padding-left: 0;
    list-style: none;
  }

  .leave-details .sub-details li {
    font-size: 14px;
    color: #6C757D;
    margin-bottom: 4px;
  }

  .timeline-title {
    font-size: 14px;
    font-weight: bold;
    color: #333;
    border-bottom: 1px solid #E0E0E0;
    padding-bottom: 8px;
    margin-bottom: 16px;
