<% content_for :head do %>
  <%= stylesheet_link_tag "select2-bootstrap-5-theme.min" %>
  <%= stylesheet_link_tag "select2.min" %>
  <%= stylesheet_link_tag "https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" %>
<% end %>

<% content_for :bottombody do %>
  <%= javascript_include_tag "https://cdn.jsdelivr.net/npm/flatpickr" %>
  <%= javascript_include_tag '/assets/lib_hrm/moment-with-locales.js' %>
  <%= javascript_include_tag 'select2.full.min' %>
  <%= javascript_include_tag 'select2.min.js' %>
<% end %>

<div class="list_users">
  <div class="card mb-3">
    <div class="card-body pt-0">
      <div class="tab-content">
        <div class="row">
          <div class="col">
            <h3 class="mt-2 overview_text"><%= lib_translate("Danh sách nghỉ phép") %></h3>
          </div>
        </div>

        <div class="mt-3">
          <!-- Nav tabs -->
          <ul class="nav nav-tabs <%= current_user.uorgs.count > 1 ? '' : 'd-none' %>" role="tablist">
            <li class="nav-item">
              <a id="man_in_tab_1" 
                 class="nav-link <%= @uorg_scode == 'BMU' || @uorg_scode == 'BMTU' ? 'active' : '' %>" 
                 data-bs-toggle="tab" 
                 href="#setting_holidays_bmu" 
                 onclick='changeTab("BMU")'>
                <%= lib_translate("BMU") %>
              </a>
            </li>
            <li class="nav-item">
              <a id="man_in_tab_2" 
                 class="nav-link <%= @uorg_scode == 'BUH' ? 'active' : '' %>" 
                 data-bs-toggle="tab" 
                 href="#setting_holidays_buh" 
                 onclick='changeTab("BUH")'>
                <%= lib_translate("BUH") %>
              </a>
            </li>
          </ul>

          <div class="tab-content">
            <div id="setting_holidays_bmu" class="tab-pane fade <%= @uorg_scode == 'BMU' || @uorg_scode == 'BMTU' ? 'show active' : '' %>">
              <div class="d-flex" style="flex-direction: row; justify-content: space-between;">
                <form action="<%= setting_holidays_manager_holiday_path %>" accept-charset="UTF-8" method="get">
                  <div id="positonjob_table_filter" class="dataTables_filter row">
                    <div class="col-12 form_loc d-flex">
                      <input name="utf8" type="hidden" value="✓">
                      <input class="d-none" name="lang" value="vi">
                      <% if !params[:per_page].nil? %>
                        <input class="d-none" name="per_page" value="<%= params[:per_page] %>">
                      <% end %>
                      <input type="submit" hidden>
                      <div class="d-flex mt-2 align-items-end" style="flex-wrap: wrap;">
                        <div class="me-1">
                          <label style="margin-bottom: 0px !important;"><%= lib_translate("Phòng ban") %></label>
                          <select class="select-form selectpicker" name="department_bmu" id="department_bmu_select" onchange="this.form.submit()">
                            <option value="">Tất cả phòng ban</option>
                            <% @departments_bmu&.each do |department| %>
                              <option value="<%= department&.id %>" <%= params[:department_bmu] == department&.id.to_s ? 'selected' : '' %>>
                                <%= department&.name %>
                              </option>
                            <% end %>
                          </select>
                        </div>
                      </div>
                      <div class="d-flex mt-2 ms-2 align-items-end" style="flex-wrap: wrap;">
                        <div class="me-1">
                          <label style="margin-bottom: 0px !important;"><%= lib_translate("Loại phép") %></label>
                          <select class="select-form selectpicker" name="holtype_bmu" id="holtype_bmu_select" onchange="this.form.submit()">
                            <option value="">Tất cả</option>
                            <% @holtypes.each do |holtype| %>
                              <option value="<%= holtype&.code %>" <%= params[:holtype_bmu] == holtype&.code.to_s ? 'selected' : '' %>>
                                <%= holtype&.name %>
                              </option>
                            <% end %>
                          </select>
                        </div>
                      </div>
                      <div class="d-flex mt-2 ms-2 align-items-end" style="flex-wrap: wrap;">
                        <div class="me-1">
                          <label style="margin-bottom: 0px !important;"><%= lib_translate("Địa điểm") %></label>
                          <select class="select-form selectpicker" name="country_bmu" id="country_bmu_select" onchange="this.form.submit()">
                            <option value="">Tất cả</option>
                            <option value="IN-COUNTRY" <%= params[:country_bmu] == "IN-COUNTRY" ? 'selected' : '' %>>Trong nước</option>
                            <option value="OUT-COUNTRY" <%= params[:country_bmu] == "OUT-COUNTRY" ? 'selected' : '' %>>Nước ngoài</option>
                          </select>
                        </div>
                      </div>
                      <div class="d-flex mt-2 ms-2 align-items-end d-none" style="flex-wrap: wrap;">
                        <div class="me-1">
                          <label style="margin-bottom: 0px !important;"><%= lib_translate("Thời gian") %></label>
                          <select class="select-form selectpicker" name="date_range_bmu" id="date_range_bmu_select" onchange="this.form.submit()">
                            <option value="">Tất cả</option>
                            <option value="2025-01-01 - 2025-03-31" <%= params[:date_range_bmu] == "2025-01-01 - 2025-03-31" ? 'selected' : '' %>>Quý 1/2025</option>
                            <option value="2025-04-01 - 2025-06-30" <%= params[:date_range_bmu] == "2025-04-01 - 2025-06-30" ? 'selected' : '' %>>Quý 2/2025</option>
                            <option value="2025-07-01 - 2025-09-30" <%= params[:date_range_bmu] == "2025-07-01 - 2025-09-30" ? 'selected' : '' %>>Quý 3/2025</option>
                            <option value="2025-10-01 - 2025-12-31" <%= params[:date_range_bmu] == "2025-10-01 - 2025-12-31" ? 'selected' : '' %>>Quý 4/2025</option>
                          </select>
                        </div>
                      </div>
                      <div class="d-flex mt-2 ms-2 align-items-end" style="flex-wrap: wrap;">
                        <div class="me-1">
                          <label style="margin-bottom: 0px !important;"></label>
                          <button type="button" class="btn btn-outline-info">Xuất báo cáo</button>
                        </div>
                      </div>
                      <input type="hidden" name="uorg_scode" value="BMU">
                    </div>
                  </div>
                </form>
              </div>
              <div class="table-responsive scrollbar"> 
                <%= render_search_pagination(setting_holidays_manager_holiday_path).html_safe %>
                <table id="user_bmu" class="table table-bordered fs--1 mb-0" style="margin-top: 0px !important; margin-bottom: 0px !important">
                  <thead class="bg-200 text-900">
                    <tr>
                      <th class="sort" style="width:4%; text-align: center;"><%= lib_translate("STT") %></th>
                      <th class="sort"><%= lib_translate("Tên nhân viên") %></th>
                      <th class="sort"><%= lib_translate("Đơn vị") %></th>
                      <th class="sort text-center"><%= lib_translate("Loại ngày nghỉ") %></th>
                      <th class="sort text-center"><%= lib_translate("Tổng ngày nghỉ") %></th>
                      <th class="sort text-center"><%= lib_translate("Người duyệt") %></th>
                      <th class="sort text-center"><%= lib_translate("Trạng thái") %></th>
                      <th class="no-sort text-center"></th>
                    </tr>
                  </thead>
                  <tbody class="list_user_bmu">
                    <% @results.each_with_index do |holpro, index| %>
                      <tr>
                        <td class="text-center"><%= (index + 1) + (@page - 1) * @per_page %></td>
                        <td><%= holpro['user_fullname'] %> (<%= holpro['user_sid'] %>)</td>
                        <td><%= holpro['department_name'] %></td>
                        <td class="text-center"><%= @holpro_types[holpro['holpro_id']] || "" %></td>
                        <td class="text-center"><%= holpro['holiday_total_days'] %> ngày</td>
                        <td class="text-center">
                          <% approvers = @holpro_approvers[holpro['holpro_id']] || [] %>
                          <%= approvers.map { |a| a[:name] }.join(", ") %>
                        </td>
                        <td class="text-center">
                          <% if holpro['holiday_status'] == "TEMP" %>
                            <span class="text-secondary">Lưu nháp</span>
                          <% elsif holpro['holiday_status'] == "DONE" %>
                            <span class="text-success">Đã duyệt</span>
                          <% elsif holpro['holiday_status'] == "PENDING" %>
                            <span class="text-warning">Chờ duyệt</span>
                          <% elsif holpro['holiday_status'] == "REFUSE" %>
                            <span class="text-danger">Từ chối</span>
                          <% else %>
                            <span class="text-warning">Đang xử lý đơn</span>
                          <% end %>
                        </td>
                        <td class="text-center">
                          <button class="btn btn-sm btn-outline-primary detail-btn" data-bs-toggle="modal" data-bs-target="#holidayDetailsModal" data-holpro-id="<%= holpro['holpro_id'] %>"  data-holpro-status="<%= holpro['holiday_status'] %>">
                            Chi tiết
                          </button>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>

                <% if @results_total > 0 %>
                  <div class="d-flex justify-content-center mt-3">
                    <div class="col-auto">
                      <nav aria-label="Page navigation">
                        <ul class="pagination mb-0">
                          <li class="page-item <%= @page == 1 ? 'disabled' : '' %>">
                            <%= link_to "«", setting_holidays_manager_holiday_path(page: @page - 1, per_page: @per_page, lang: session[:lang], search: params[:search], uorg_scode: @uorg_scode, department_bmu: params[:department_bmu], country_bmu: params[:country_bmu], holtype_bmu: params[:holtype_bmu]), class: "page-link" %>
                          </li>
                          <% (1..@total_pages).each do |i| %>
                            <li class="page-item <%= @page == i ? 'active' : '' %>">
                              <%= link_to i.to_s, setting_holidays_manager_holiday_path(page: i, per_page: @per_page, lang: session[:lang], search: params[:search], uorg_scode: @uorg_scode, department_bmu: params[:department_bmu], country_bmu: params[:country_bmu], holtype_bmu: params[:holtype_bmu]), class: "page-link" %>
                            </li>
                          <% end %>
                          <li class="page-item <%= @page == @total_pages ? 'disabled' : '' %>">
                            <%= link_to "»", setting_holidays_manager_holiday_path(page: @page + 1, per_page: @per_page, lang: session[:lang], search: params[:search], uorg_scode: @uorg_scode, department_bmu: params[:department_bmu], country_bmu: params[:country_bmu], holtype_bmu: params[:holtype_bmu]), class: "page-link" %>
                          </li>
                        </ul>
                      </nav>
                    </div>
                    <div class="col-auto ms-2">
                      <form action="<%= setting_holidays_manager_holiday_path %>" accept-charset="UTF-8" method="get">
