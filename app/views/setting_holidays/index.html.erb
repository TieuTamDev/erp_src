<% content_for :head do %>
  <%= stylesheet_link_tag "select2-bootstrap-5-theme.min" %>
  <%= stylesheet_link_tag "select2.min" %>
  <%= stylesheet_link_tag "https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" %> <!-- Sử dụng CDN cho flatpickr CSS -->
<% end %>

<% content_for :bottombody do %>
  <%= javascript_include_tag "https://cdn.jsdelivr.net/npm/flatpickr" %> <!-- Sử dụng CDN cho flatpickr JS -->
  <%= javascript_include_tag '/assets/lib_hrm/moment-with-locales.js' %>
  <%= javascript_include_tag 'select2.full.min' %>
  <%= javascript_include_tag 'select2.min.js' %>
<% end %>

<div class="list_users">
  <div class="card mb-3">
    <div class="card-body pt-0">
      <div class="tab-content">
        <div class="row">
          <div class="col">
            <h3 class="mt-2 overview_text"><%= lib_translate("Cấu hình ngày nghỉ") %></h3>
          </div>
        </div>

        <div class="mt-3">
          <!-- Nav tabs -->
          <ul class="nav nav-tabs <%= current_user.uorgs.count > 1 ? '' : 'd-none' %>" role="tablist">
            <li class="nav-item">
              <a id="man_in_tab_1" 
                 class="nav-link <%= ['BMU', 'BMTU'].include?(@uorg_scode) ? 'active' : '' %>" 
                 data-bs-toggle="tab" 
                 href="#setting_holidays_bmu" 
                 onclick='changeTab("BMU")'>
                <%= lib_translate("BMU") %>
              </a>
            </li>
            <li class="nav-item">
              <a id="man_in_tab_2" 
                 class="nav-link <%= @uorg_scode == 'BUH' ? 'active' : '' %>" 
                 data-bs-toggle="tab" 
                 href="#setting_holidays_buh" 
                 onclick='changeTab("BUH")'>
                <%= lib_translate("BUH") %>
              </a>
            </li>
          </ul>

          <div class="tab-content">
            <div id="setting_holidays_bmu" class="tab-pane fade <%= ['BMU', 'BMTU'].include?(@uorg_scode) ? 'show active' : '' %>">
              <div class="row justify-content-end d-none">
                  <div class="dropdown font-sans-serif" style="height: 5px; width: 90px;">
                        <a style="cursor: pointer;" class="navbar-toggler-humburger-icon navbar-vertical-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            <span class="navbar-toggle-icon"><span class="toggle-line"></span></span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end p-3" aria-labelledby="dropdownMenuLink">
                            <div style="display:flex;flex-direction: column;width: max-content;">
                                
                                <button onclick="clickOpenImport()" class="btn btn-success mt-3" data-bs-toggle="modal" data-bs-target="#modal-import-file" id="btn-import-file">
                                    <%= lib_translate("Nhập dữ liệu")%> <span class="fas fa-file-excel"></span>
                                </button>
                                
                                <button data-bs-toggle="modal" data-bs-target="#modal-export-student" class="btn btn-warning mt-3 d-none" type="button">Xuất báo cáo - thống kê <img class="me-1" src="<%= image_path("/assets/image/icons8-microsoft-excel-2019-48.png") %>" alt="" width="23" /></button>
                                
                            </div>
                        </div>
                    </div>
                </div>
              <form action='<%= setting_holidays_index_path() %>' accept-charset='UTF-8' method='get'>
                <div id='positonjob_table_filter' class='dataTables_filter'>
                  <input name='utf8' type='hidden' value='✓'>
                  <input class="d-none" name="uorg_scode" value="BMU">
                  <input class='d-none' name='lang' value='vi'>
                  <% if !params[:per_page].nil?  %>
                  <input class='d-none' name='per_page' value='<%= params[:per_page] %>'>
                  <% end %>
                  <input type='submit' hidden>
                  <div class="d-flex" style="justify-content: space-between;">
                    <div class="me-1" style="width: 500px;">
                        <label style="margin-bottom: 0px !important;"><%= lib_translate("Phòng ban") %></label>
                        <select class="select-form selectpicker" name="department_bmu" id="department_bmu_select" onchange="this.form.submit()">
                          <option value="">Tất cả phòng ban</option>
                          <% @departments_bmu&.each do |department| %>
                            <option value="<%= department&.id %>" <%= params[:department_bmu] == department&.id.to_s ? 'selected' : '' %>>
                              <%= department&.name %>
                            </option>
                          <% end %>
                        </select>
                    </div>
                    <div class="btn_fillter d-none">
                        <div>
                            <button type="submit" class="btn btn-primary"><%= lib_translate("Tìm kiếm")  %></button>
                        </div>
                    </div>
                  </div>
                  <div class="row justify-content-end">
                    <div style="width: 500px;" >
                        <input type='text' name='search' id='search_user' value='<%= params[:search] %>' placeholder='<%= lib_translate('Search') %>' class='form-control form-control-sm'>
                        <input class='d-none' name='lang' value='vi'><input type='submit' hidden>
                    </div>
                  </div>
                </div>
              </form>
      
              <div class="table-responsive scrollbar mt-2"> 

                <table id="user_bmu" class="table table-bordered fs--1 mb-0" style="margin-top: 0px !important; margin-bottom: 0px !important">
                  <thead class="bg-200 text-900">
                    <tr>
                      <th class="sort" style="width:4%; text-align: center;"><%= lib_translate("Oder") %></th>
                      <th class="sort"><%= sort_link('user_sid', lib_translate("Mã nhân sự")) %></th>
                      <th class="sort"><%= sort_link('user_fullname', lib_translate("Họ và tên")) %></th>
                      <th class="sort"><%= sort_link('department_name', lib_translate("Phòng ban")) %></th>
                      <th class="sort"><%= sort_link('positionjob_name', lib_translate("Vị trí công việc")) %></th>
                      <th class="sort text-center" style="width: 6%;"><%= sort_link('hol_positionjob', lib_translate("Phép năm")) %></th>
                      <th class="sort text-center" style="width: 6%;"><%= sort_link('hol_seniority', lib_translate("Phép TN")) %></th>
                      <th class="sort text-center" style="width: 6%;"><%= sort_link('hol_exist', lib_translate("Phép tồn")) %></th>
                      <th class="sort text-center" style="width: 6%;"><%= sort_link('total_holiday', lib_translate("Tổng")) %></th>
                      <th class="sort text-center" style="width: 6%;"><%= sort_link('used_holiday', lib_translate("Đã dùng")) %></th>
                      <th class="sort text-center" style="width: 6%;"><%= sort_link('remain_holiday', lib_translate("Còn lại")) %></th>
                      <th class="no-sort text-center" style="width: 6%;"><%= lib_translate("Hành động") %></th>
                    </tr>
                  </thead>
                  <tbody class="list_user_bmu">
                    <% @results_bmu.each_with_index do |data, index| %>
                      <tr style="vertical-align: middle;" data-holiday-id="<%= data[:id_curent_holiday] %>">
                        <td style="text-align: center;"><%= (@page - 1) * @per_page + index + 1 %></td>
                        <td><%= data[:user_sid] %></td>
                        <td><%= data[:user_fullname] %></td>
                        <td><%= data[:department_name] %></td>
                        <td><%= data[:positionjob_name] %></td>
                        <td style="text-align: center; font-size: 14px;">
                          <input type="text" class="form-control hol-positionjob-input fw-bold" 
                                value="<%= data[:hol_positionjob].present? ? data[:hol_positionjob].to_f.round(1) : '0' %>" 
                                data-id="<%= data[:hol_positionjob_id] %>" 
                                data-original-value="<%= data[:hol_positionjob].present? ? data[:hol_positionjob].to_f.round(1) : '0' %>" 
                                style="width: 70px; margin: 0 auto; text-align: center; font-size: 14px;">
                        </td>
                        <td style="text-align: center; font-size: 14px; font-weight: bold;">
                          <%= data[:hol_seniority].present? ? data[:hol_seniority]&.to_f.round(1) : '0' %>
                          <input type="hidden" class="hol-positionjob-id" value="<%= data[:hol_seniority_id].present? ? data[:hol_seniority_id] : '' %>">
                          <input type="hidden" class="hol-seniority-value" value="<%= data[:hol_seniority].present? ? data[:hol_seniority]&.to_f.round(1) : '0' %>">
                        </td>
                        <td style="text-align: center;">
                          <%
                            deadline_exist = "31/03/#{Time.now.year}" # Sử dụng năm hiện tại (ví dụ: 31/03/2025)
                            if data[:deadline_exist].present?
                              begin
                                Date.strptime(data[:deadline_exist], '%d/%m/%Y')
                                deadline_exist = data[:deadline_exist]
                              rescue ArgumentError
                                deadline_exist = "31/03/#{Time.now.year}"
                              end
                            end
                            begin
                              deadline_date = Date.strptime(deadline_exist, '%d/%m/%Y')
                              is_expired = deadline_date <= Date.today - 1
                            rescue ArgumentError
                              is_expired = false
                            end
                          %>
                          <div class="d-flex align-items-center justify-content-center" style="flex-direction: column">
                            <input type="text" class="form-control hol-exist-input me-1 fw-bold" 
                                  value="<%= data[:hol_exist].present? ? data[:hol_exist].to_f.round(1) : '0' %>" 
                                  data-id="<%= data[:hol_exist_id] %>" 
                                  data-original-value="<%= data[:hol_exist].present? ? data[:hol_exist].to_f.round(1) : '0' %>" 
                                  style="width: 70px; text-align: center; font-size: 14px;">
                            <input type="text" class="form-control hol-exist-deadline mt-1" 
                                  title="<%= is_expired ? 'Ngày hạn đã qua' : '' %>"
                                  value="<%= deadline_exist %>" 
                                  data-id="<%= data[:hol_exist_id] %>" 
                                  data-original-value="<%= deadline_exist %>"
                                  style="width: 100px; text-align: center; font-size: 12px; <%= is_expired ? 'color: red;' : '' %>">
                          </div>
                        </td>
                        <td style="text-align: center;">
                          <input type="text" class="form-control total-holiday-input fw-bold" 
                                value="<%= data[:total_holiday].present? ? data[:total_holiday].to_f.round(1) : '0' %>" 
                                data-id="<%= data[:id_curent_holiday] %>" 
                                data-original-value="<%= data[:total_holiday].present? ? data[:total_holiday].to_f.round(1) : '0' %>" 
                                style="width: 70px; margin: 0 auto; text-align: center; font-size: 14px;">
                        </td>
                        <td style="text-align: center;">
                          <input type="text" class="form-control used-holiday-input fw-bold" 
                                value="<%= data[:used_holiday].present? ? data[:used_holiday].to_f.round(1) : '0' %>" 
                                data-id="<%= data[:id_curent_holiday] %>" 
                                data-original-value="<%= data[:used_holiday].present? ? data[:used_holiday].to_f.round(1) : '0' %>" 
                                style="width: 70px; margin: 0 auto; text-align: center; font-size: 14px;" readonly>
                        </td>
                        <td style="text-align: center; font-size: 14px; font-weight: bold;" class="remaining-value">
                          <% remaining = data[:remain_holiday].present? ? (data[:remain_holiday].to_f).round(1) : "0" %>
                          <%= remaining %>
                        </td>
                        <td style="text-align: center;">
                          <%if data[:check_contract].present?%>
                            <%if !data[:id_curent_holiday].present?%>
                              <button class="btn btn-primary btn-sm save-btn" onclick="onclickSaveData(this,<%=data[:user_id]%>)">Lưu</button>
                            <%else%>
                              <button class="btn btn-success btn-sm save-btn" onclick="onclickSaveData(this,<%=data[:user_id]%>)">Cập nhật</button>
                            <%end%>
                          <%else%>
                            <span style="text-wrap: auto;" class="text-warning">Nhân sự chưa có thông tin hợp đồng<span>
                          <%end%>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>

                <% if @results_bmu_total > 0 %>
                  <div class="d-flex justify-content-center mt-3">
                    <div class="col-auto">
                      <nav aria-label="Page navigation">
                        <ul class="pagination mb-0">
                          <li class="page-item <%= @page == 1 ? 'disabled' : '' %>">
                            <%= link_to "«", setting_holidays_index_path(
                              page: @page - 1, 
                              per_page: @per_page, 
                              lang: session[:lang], 
                              search: params[:search], 
                              uorg_scode: @uorg_scode, 
                              department_buh: params[:department_buh],
                              department_bmu: params[:department_bmu]
                              ), class: "page-link" %>
                          </li>
                          <% (1..@total_pages).each do |i| %>
                            <li class="page-item <%= @page == i ? 'active' : '' %>">
                              <%= link_to i.to_s, setting_holidays_index_path(
                                page: i, 
                              per_page: @per_page, 
                              lang: session[:lang], 
                              search: params[:search], 
                              uorg_scode: @uorg_scode, 
                              department_buh: params[:department_buh],
                              department_bmu: params[:department_bmu]
                                ), class: "page-link" %>
                            </li>
                          <% end %>
                          <li class="page-item <%= @page == @total_pages ? 'disabled' : '' %>">
                            <%= link_to "»", setting_holidays_index_path(
                              page: @page + 1, 
                              per_page: @per_page, 
                              lang: session[:lang], 
                              search: params[:search], 
                              uorg_scode: @uorg_scode, 
                              department_buh: params[:department_buh],
                              department_bmu: params[:department_bmu]
                              ), class: "page-link" %>
                          </li>
                        </ul>
                      </nav>
                    </div>
                    <div class="col-auto ms-2">
                      <form action="<%= setting_holidays_index_path %>" accept-charset="UTF-8" method="get">
                        <select class="form-select" name="per_page" id="per_page_select" onchange="this.form.submit()">
                          <option value="25" <%= @per_page == 25 ? 'selected' : '' %>>25</option>
                          <option value="50" <%= @per_page == 50 ? 'selected' : '' %>>50</option>
                          <option value="100" <%= @per_page == 100 ? 'selected' : '' %>>100</option>
                          <option value="200" <%= @per_page == 200 ? 'selected' : '' %>>200</option>
                        </select>
                        <input class="d-none" name="lang" value="<%= session[:lang] %>">
                        <input class="d-none" name="search" value="<%= params[:search] %>">
                        <input class="d-none" name="page" value="1">
                        <input class="d-none" name="uorg_scode" value="<%= @uorg_scode %>">
                        <input class="d-none" name="department_bmu" value="<%= params[:department_bmu] %>">
                      </form>
                    </div>
                  </div>
                <% else %>
                  <p class="text-center mt-3">Không có dữ liệu để hiển thị.</p>
                <% end %>
              </div>
            </div>

            <div id="setting_holidays_buh" class="tab-pane fade <%= @uorg_scode == 'BUH' ? 'show active' : '' %>">
                
              <form action='<%= setting_holidays_index_path() %>' accept-charset='UTF-8' method='get'>
                <div id='positonjob_table_filter' class='dataTables_filter'>
                  <input name='utf8' type='hidden' value='✓'>
