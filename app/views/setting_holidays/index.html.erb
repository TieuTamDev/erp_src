<script>
function changeTab(uorg_scode) {
  document.body.style.cursor = 'wait';
  const urlParams = new URLSearchParams(window.location.search);
  urlParams.set('uorg_scode', uorg_scode);
  urlParams.set('page', '1');
  // Giữ nguyên department hiện tại nếu có
  if (uorg_scode === 'BMU' || uorg_scode === 'BMTU') {
    urlParams.set('department_bmu', urlParams.get('department_bmu') || '');
  } else if (uorg_scode === 'BUH') {
    urlParams.set('department_buh', urlParams.get('department_buh') || '');
  }
  window.location.href = '<%= setting_holidays_index_path %>?' + urlParams.toString();
}
document.addEventListener('DOMContentLoaded', () => {
  const inputs = document.querySelectorAll(
    '.list_user_buh input[data-name="hol_positionjob"], ' +
    '.list_user_buh input[data-name="hol_exist"], ' +
    '.list_user_buh input[data-name="hol_exist_deadline"]'
  );

  function normalizeNumber(val) {
    const floatVal = parseFloat(val);
    return isNaN(floatVal) ? null : Math.round(floatVal * 10) / 10;
  }

  function isValueChanged(input) {
    const name = input.getAttribute('data-name');
    const current = input.value.trim();
    const original = input.getAttribute('data-original-value')?.trim() || '';

    if (name === 'hol_exist_deadline') {
      return current !== original;
    }

    const currentNum = normalizeNumber(current);
    const originalNum = normalizeNumber(original);

    return currentNum !== originalNum;
  }

  inputs.forEach(input => {
    ['input', 'paste'].forEach(eventType => {
      input.addEventListener(eventType, function () {
        const row = this.closest('tr');
        if (!row) return;

        const inputsToCheck = row.querySelectorAll(
          'input[data-name="hol_positionjob"], ' +
          'input[data-name="hol_exist"], ' +
          'input[data-name="hol_exist_deadline"]'
        );

        const isChanged = Array.from(inputsToCheck).some(isValueChanged);

        if (isChanged) {
          row.classList.add('table-warning');
        } else {
          row.classList.remove('table-warning');
        }
      });
    });
  });
});

</script>

<script>
  // Đặt mã trong IIFE để tránh xung đột scope
  (function() {
    let currentYear = new Date().getFullYear(); // Ví dụ: 2025
  let previousYear = currentYear - 1; // Ví dụ: 2024
  const today = new Date(); // Ngày hiện tại
  const yesterday = new Date(today);
  yesterday.setDate(today.getDate() - 1);

  document.addEventListener('DOMContentLoaded', function() {
    // Kiểm tra xem flatpickr đã được tải chưa
    if (typeof flatpickr === 'undefined') {
      console.error('Flatpickr is not loaded. Please ensure the library is included.');
      return;
    }

    // Khởi tạo datetime picker cho các ô hol-exist-deadline
    flatpickr(".hol-exist-deadline", {
      dateFormat: "d/m/Y", // Định dạng ngày
      defaultDate: function(elem) {
        return elem.value || `31/03/${previousYear}`; // Giá trị mặc định từ input hoặc 31/03/<previousYear>
      },
      enable: [
        {
          from: `01/01/${previousYear}`, // Ví dụ: 01/01/2024
          to: `31/12/${currentYear}`     // Ví dụ: 31/12/2025
        }
      ],
      onChange: function(selectedDates, dateStr, instance) {
        instance.input.value = dateStr; // Cập nhật giá trị input khi chọn ngày
        // Kiểm tra nếu deadline nhỏ hơn ngày hiện tại, đổi màu đỏ
        const deadlineDate = new Date(selectedDates[0]);
        if (deadlineDate <= yesterday) {
          instance.input.style.color = 'red';
        } else {
          instance.input.style.color = ''; // Reset về màu mặc định
        }
        const row = instance.input.closest('tr');
        const tableId = row.closest('table').id;
        if (tableId === 'user_bmu') {
          // Cập nhật phép hè khi thay đổi deadline (chỉ cho user_bmu)
          updateTotalHoliday(row, tableId);
        }
          updateTotalHoliday(row, tableId);
        // Cập nhật tổng khi thay đổi deadline
      },
      onReady: function(selectedDates, dateStr, instance) {
        // Kiểm tra ngay khi khởi tạo
        const deadlineDate = new Date(selectedDates[0]);
        if (deadlineDate <= yesterday) {
          instance.input.style.color = 'red';
        }
      }
    });

    function customRoundToHalf(val) {
      const intPart = Math.floor(val);
      const decimal = val - intPart;

      if (decimal < 0.5) {
        return intPart; // Làm tròn về 0
      } else if (decimal > 0.5) {
        return intPart + 1; // Làm tròn thành 1
      } else {
        return val; // Giữ nguyên nếu decimal = 0.5
      }
    }
    // Xử lý nhập số thập phân cho các input và thêm sự kiện cập nhật tổng
    const inputs = document.querySelectorAll('.hol-summer-input, .hol-exist-input, .total-holiday-input, .used-holiday-input, .hol-positionjob-input');
    inputs.forEach(input => {
      input.addEventListener('input', function () {
        let value = this.value;

        // Chỉ cho phép số và dấu chấm
        value = value.replace(/[^0-9.]/g, '');

        // Đảm bảo chỉ có một dấu chấm
        const parts = value.split('.');
        if (parts.length > 2) {
          value = parts[0] + '.' + parts[1];
        }

        // Gán lại giá trị đã làm sạch vào ô input, KHÔNG ép số ngay lúc này
        this.value = value;

        const row = this.closest('tr');
        const tableId = row.closest('table').id;

        if (tableId === 'user_bmu') {
          if (this.classList.contains('total-holiday-input')) {
            updateHolSummer(row);
          }
          if (this.classList.contains('hol-positionjob-input')  || this.classList.contains('hol-exist-input')) {
            updateTotalHoliday(row, tableId);
          }
        } else if (tableId === 'user_buh') {
          if (this.classList.contains('hol-positionjob-input') || this.classList.contains('hol-exist-input')) {
            updateTotalHoliday(row, tableId);
          }
        }

        if (this.classList.contains('total-holiday-input') || this.classList.contains('used-holiday-input')) {
          updateRemaining(row);
        }
      });

      // Tùy chọn: Làm tròn khi người dùng rời khỏi ô input (blur)
      input.addEventListener('blur', function () {
        let value = parseFloat(this.value);
        if (!isNaN(value)) {
          this.value = customRoundToHalf(value).toFixed(1);
        }
      });
    });


    // Hàm cập nhật Phép hè (chỉ áp dụng cho user_bmu)
    function updateHolSummer(row) {
      const totalInput = row.querySelector('.total-holiday-input');

      const holPositionjobInput = row.querySelector('.hol-positionjob-input');
      const holPositionjob = parseFloat(holPositionjobInput.value) || 0;

      const holSeniority = parseFloat(row.querySelector('td:nth-child(7)').textContent) || 0; // Phép thâm niên
      const holExistInput = row.querySelector('.hol-exist-input');
      const holExistDeadline = row.querySelector('.hol-exist-deadline');

      const total = parseFloat(totalInput.value) || 0;
      let holExist = parseFloat(holExistInput.value) || 0;

      // Kiểm tra deadline của phép tồn
      const deadlineParts = holExistDeadline.value.split('/');
      const deadlineDate = new Date(`${deadlineParts[2]}-${deadlineParts[1]}-${deadlineParts[0]}`);
      if (deadlineDate <= yesterday) {
        holExist = 0; // Không sử dụng phép tồn nếu đã hết hạn
      }

    }

    // Hàm cập nhật Tổng (total_holiday)
    function updateTotalHoliday(row, tableId) {
      const holSeniority = parseFloat(row.querySelector('td:nth-child(7)').textContent) || 0; // Phép thâm niên
      const holExistInput = row.querySelector('.hol-exist-input');
      const holExistDeadline = row.querySelector('.hol-exist-deadline');
      const totalInput = row.querySelector('.total-holiday-input');
      const totalFInput = row.querySelector('.total-fholiday-input');

      const holPositionjobInput = row.querySelector('.hol-positionjob-input');
      const holPositionjob = parseFloat(holPositionjobInput.value) || 0;

      let holExist = parseFloat(holExistInput.value) || 0;

      // Kiểm tra deadline của phép tồn
      const deadlineParts = holExistDeadline.value.split('/');
      const deadlineDate = new Date(`${deadlineParts[2]}-${deadlineParts[1]}-${deadlineParts[0]}`);
      if (deadlineDate <= yesterday) {
        holExist = 0; // Không sử dụng phép tồn nếu đã hết hạn
      }

      let total;
    
      total = holPositionjob + holSeniority + holExist;
      
      const totalCount = Math.max(0, total);

      totalInput.value = customRoundToHalf(total).toFixed(1); // Giới hạn tối đa 50
      totalInput.textContent = customRoundToHalf(total).toFixed(1);

      // Cập nhật Còn lại sau khi tổng thay đổi
      updateRemaining(row);
    }

    // Hàm cập nhật Còn lại
    function updateRemaining(row) {
      const totalInput = row.querySelector('.total-holiday-input');
      const usedInput = row.querySelector('.used-holiday-input');
      const usedfInput = row.querySelector('.used-fholiday-input');
      const remainingCell = row.querySelector('.remaining-value');

      const total = parseFloat(totalInput.value) || 0;
      const used = parseFloat(usedInput.value) || 0;
      const usedf = parseFloat(usedfInput.value) || 0;
      const remaining = Math.max(0, total - (used + usedf));
      remainingCell.textContent = customRoundToHalf(remaining).toFixed(1);
    }
  });
})();

</script>

<script>

  function onclickSaveData(btn, user_id) {
    // 1. Lấy đúng <tr> chứa nút
    var row = btn.closest('tr');
    if (!row) {
      alert("Không tìm thấy dòng dữ liệu để lưu.");
      return;
    }

    // 2. Lấy id holiday từ data-holiday-id
    var id = row.getAttribute('data-holiday-id') || null;

    // 3. Lấy input theo class, dùng DOM .value (không dùng attr)
    var holPositionInput   = row.querySelector('.hol-positionjob-input');
    var holSeniorityHidden = row.querySelector('.hol-seniority-value');
    var holExistInput      = row.querySelector('.hol-exist-input');
    var holExistDeadline   = row.querySelector('.hol-exist-deadline');
    var totalHolidayInput  = row.querySelector('.total-holiday-input');
    var usedHolidayInput   = row.querySelector('.used-holiday-input');

    var payload = {
      id_curent_holiday: id,
      user_id: user_id,
      hol_positionjob:    holPositionInput ? holPositionInput.value : '',
      hol_seniority:      holSeniorityHidden ? holSeniorityHidden.value : '',
      hol_exist:          holExistInput ? holExistInput.value : '',
      deadline_exist:     holExistDeadline ? holExistDeadline.value : '',
      total_holiday:      totalHolidayInput ? totalHolidayInput.value : '',
      used_holiday:       usedHolidayInput ? usedHolidayInput.value : ''
    };

    console.log("PAYLOAD gửi lên:", payload);

    $.ajax({
      url: '/mywork/setting_holidays/update_holiday_detail',
      method: 'POST',
      data: payload,
      success: function (res) {
        if (res.status === 'ok') {
          window.location.reload();
          alert('Cập nhật thành công');
        } else {
          alert(res.message || 'Có lỗi khi lưu dữ liệu');
        }
      },
      error: function (xhr) {
        let msg = "Có lỗi khi lưu dữ liệu";

        if (xhr.responseJSON && xhr.responseJSON.message) {
          msg = xhr.responseJSON.message;
        } else if (xhr.responseText) {
          msg = xhr.responseText;
        }

        alert(msg);
      }
    });
  }


  // Import file
  function initImportFile(){
    $("#file-import-setting-holidays-bmu").on('change',(e)=>{
      let file = $("#file-import-setting-holidays-bmu")[0].files[0];
      if(file != undefined && file != null){
        $("#import-file-containter").show();
        $("#button-upload-file").toggleClass("btn-secondary disabled",false);
        $("#file-process").css("width","0%");
        $("#import-file-size").html(formatBytes(file.size));
        $("#import-file-name").html(file.name);
      }
    })
  }
  initImportFile();

  function clickOpenImport(){
    // clean form
    let uploadBtn = $("#button-upload-file");
    let selectBtn = $("#label-select-file");
    let reUpload = $("#reupload-button");
    $("#import-file-containter").hide();
    uploadBtn.toggleClass("disabled",true);
    uploadBtn.show();
    selectBtn.toggleClass("disabled",false);
    selectBtn.show();
    reUpload.hide();

    $("#file-import-setting-holidays-bmu").val(null);
    $('input[name="authenticity_token"]').val($('meta[name="csrf-token"]').attr("content"));
    $('#import-result').collapse("hide");
    uploadBtn.find(".upload-text").show();
    uploadBtn.find(".upload-process").hide();

    $("#update_list").html("");
    $("#error_list").html("");
    $("#import-server-error").hide();
}

function clickImportFile(){
  let file = $("#file-import-setting-holidays-bmu")[0].files[0];
  if(file != undefined && file != null){
    
    let uploadBtn = $("#button-upload-file");
    let selectBtn = $("#label-select-file");
    
    // disable cancel when on process
    $(".button-cancel-import").toggleClass("disabled",true);

    // process state: 2
    uploadBtn.toggleClass("disabled",true);
    selectBtn.toggleClass("disabled",true);
    selectBtn.toggleClass("btn-secondary disabled",true);
    uploadBtn.find(".upload-text").html(trans_uploading);
    uploadBtn.find(".upload-process").show();

    // send file
    sendImportFile(file);
	}
}


/**
 * Send file to backend action
 * @param {File} file 
 */
function sendImportFile(file){
  let processItem = $("#file-process");
  let formdata = new FormData();
  formdata.append("file",file);
  formdata.append("authenticity_token",$('meta[name="csrf-token"]').attr("content"));

  var request = new XMLHttpRequest();
  request.onreadystatechange = function(){
    if(request.readyState == 4 && request.status >= 200 && request.status <= 299){
      try {
        let result = JSON.parse(request.responseText);
        if (result.code >= 400){
        console.log(result);

        showServerError();
        }else{
        console.log(result);
        renderResult(result);
        }
      } catch (e){
        console.log(e)
        showServerError();
      }
    }
    else if(request.status >= 400 && request.readyState == 4){
      try{
      let result = JSON.parse(request.responseText);
      console.log(result);
      }catch(e){
      console.log(e);
      }
      showServerError();
    }
  };

  request.upload.addEventListener('progress', function(e){
    var progress_width = Math.ceil(e.loaded/e.total * 100);
    processItem.css("width",`${progress_width}%`);
    if(progress_width == 100){
      setTimeout(() => {
      $("#import-file-containter").hide();
      processItem.css("width","0%");
      $("#button-upload-file").find(".upload-text").html(trans_processing);
      }, 400);
    }
  }, false);

  let action = $("#import-action").html();
  request.open('POST', action);
  request.send(formdata);
}

function showServerError(){
  $(".button-cancel-import").toggleClass("disabled",false);
  let uploadBtn = $("#button-upload-file");
  let selectBtn = $("#label-select-file");
  let resultShow = $('#import-result');
  let reUpload = $("#reupload-button");


  uploadBtn.toggleClass("btn-secondary disabled",true);
  uploadBtn.find(".upload-text").html(trans_upload);
  uploadBtn.find(".upload-process").hide();
  uploadBtn.hide();

  selectBtn.toggleClass("disabled",false);
  selectBtn.hide();

  reUpload.show();

  $("#file-import-setting-holidays-bmu").val(null);
  $("#update_list").html("");
  $("#error_list").html("");
  resultShow.collapse('hide');
  $("#import-server-error").show();
}

let import_update_list = [];
function renderResult(result){
import_update_list = result.updates;
  // disable cancel when upload done
  $(".button-cancel-import").toggleClass("disabled",false);
  let uploadBtn = $("#button-upload-file");
  let selectBtn = $("#label-select-file");
  let resultShow = $('#import-result');
  let reUpload = $("#reupload-button");

  uploadBtn.toggleClass("btn-secondary disabled",true);
  uploadBtn.find(".upload-text").html(trans_upload);
  uploadBtn.find(".upload-process").hide();
  uploadBtn.hide();

  selectBtn.toggleClass("disabled",false);
  selectBtn.hide();

  reUpload.show();

  $("#file-import-setting-holidays-bmu").val(null);
  //  load data
  $("#result_total").html(result.result_total);
  $("#success_count").html(result.success_count);
  let valids = result.valids;
  let error_count = $("#error_count");
  error_count.html(valids.length);
  error_count.toggleClass("text-400",valids.length <= 0);

  // update
  let update_count = $("#update_count");
  update_count.html(import_update_list.length);
  update_count.toggleClass("text-400",import_update_list.length <= 0);
  if(import_update_list.length > 0){
    $("#update-all-button").show();
  }else{
    $("#update-all-button").hide();
  }
  let updateContainer = $("#update_list");
  import_update_list.forEach(user=>{
    if (user.avatar_url == null){
    user.avatar_url = no_avatar_url;
    }
    updateContainer.append(`<div id="update-import-${user.id}" class="border rounded-1 p-2 update-import-item" style="display: flex;align-items: center;justify-content: space-between;">
                <div style="display: flex;">
                  <div class="avatar me-2" style="display: flex;justify-content: center;flex-direction: column;">
                  <div style="border: 1px solid var(--falcon-badge-soft-secondary-background-color);border-radius: 50%;background-image: url(${user.avatar_url});overflow: hidden;background-repeat: no-repeat;background-size: cover;height: 2.9rem;width: 2.9rem;">
                  </div>
                  </div>
                  <div>
                  <p class="m-0" style="font-size: 0.9em;font-weight: 600;color: var(--falcon-badge-soft-dark-color);">${user.origin_name}</p>
                  <p class="m-0" style="font-size: 0.8em;font-weight: 500;color: var(--falcon-badge-soft-info-color);">${user.origin_email}</p>
                  <p class="badge badge-soft-danger m-0 error-message" style="font-size: 0.75em;text-align: left;width: fit-content;display:none;"></p>
                  </div>
                </div>
                <div>
                  <div class="btn btn-secondary btn-sm btn-action" style="font-size: 0.7em;" onclick="skipUpdate(${user.id})">${trans_skip}</div>
                  <div class="btn btn-primary btn-sm btn-action btn-update" style="font-size: 0.7em;min-width: 65px;" onclick="updateImport(${user.id})">
                  <span class="text-update" >${trans_update}</span>
                  <span class="spinner-border spinner-border-sm process-update" role="status" aria-hidden="true" style="display:none;height: 13px;width: 13px;"></span>
                  </div>
                  <span class='fas fa-check text-success me-3 icon-done' style="width:18px; height:18px;display:none;"></span>
                </div>
                </siv>`)
  });

  // errors
  let error_list = $("#error_list");
  error_list.html("");
  valids.forEach(valid=>{
    error_list.append(`<p class="m-0">
              <span class="badge me-1 badge-soft-danger">${valid.line}</span>
            </p>`);
  })
  resultShow.collapse('show');

}


/**
 * Handle update duplicate import
 * @param {any} userId
 */
function updateImport(userId){
  // get user data
  let user = null
  import_update_list.forEach(item=>{
    if(item.id === userId){
    user = item;
    }
  })

  if(user == null){
    console.log("Not find :",userId)
    return;
  }
  submitUpdateImportForm(`#update-import-${userId}`,[user]);

}

function submitUpdateImportForm(itemId,data){
  // pass data to remote form
  let uploadForm = $("#update_import_form");
  uploadForm.find("#datas").attr("value", JSON.stringify(data))

  $('input[name="authenticity_token"]').val($('meta[name="csrf-token"]').attr("content"));
  // submit
  uploadForm.submit();

  // upload button effect
  if (itemId != null){
    let itemContainer = $(itemId);
    itemContainer.find(".text-update").hide();
    itemContainer.find(".process-update").show();

    // all button effect
    itemContainer.find(".btn-action").toggleClass("disabled",true);
    itemContainer.find(".error-message").hide();
  }else{
    let list_item = $("#update_list");

    list_item.find(".text-update").hide();
    list_item.find(".process-update").show();
    // all button effect
    list_item.find(".btn-action").toggleClass("disabled",true);
    list_item.find(".error-message").hide();
  } 
}

/**
 * Handle update all duplicate import
 */
function uploadAllImport(){
  submitUpdateImportForm(null,import_update_list);
}

/**
 * Onclick Skip update
 * @param {any} userId 
 */
function skipUpdate(userId){
  // remove store user
  for (let i = 0; i < import_update_list.length; i++) {
    if(userId == import_update_list[i].id){
    import_update_list.splice(i, 1);
    break;
    }
  }
  // remove element
  $(`#update-import-${userId}`).remove();

  // count
  $("#update_count").html(import_update_list.length);

  if(import_update_list.length > 0){
    $("#update-all-button").show();
  }else{
    $("#update-all-button").hide();
  }
}

/**
 * Call from back end
 */
function resultUpdateImport(result){
	result.updateds.forEach(update=>{

		for (let i = 0; i < import_update_list.length; i++) {
		if(update.id == import_update_list[i].id){
			import_update_list.splice(i, 1);
			break;
		}
		}

		let wrapContainer = $(`#update-import-${update.id}`);
		wrapContainer.find(".icon-done").show();
		wrapContainer.find(".btn-action").remove();
	});

	result.errors.forEach(item=>{
		
		let wrapContainer = $(`#update-import-${item.id}`);
		// update button
		wrapContainer.find(".text-update").show();
		wrapContainer.find(".process-update").hide();
		// all action button
		wrapContainer.find(".btn-action").toggleClass("disabled",false);
		// show error message
		wrapContainer.find(".error-message").show();
		wrapContainer.find(".error-message").html(item.message);
	})
}


/**
 * Fortmat file size
 * @param {*} a Fiel size
 * @param {*} b 
 * @param {*} k 
 * @returns 
 */
function formatBytes(a,b=2,k=1024){
	let d=Math.floor(Math.log(a)/Math.log(k));
	return 0 == a ? "0 Bytes" : parseFloat((a/Math.pow(k,d)).toFixed(Math.max(0,b)))+" "+["Bytes","KB","MB","GB","TB","PB","EB","ZB","YB"][d]
}

