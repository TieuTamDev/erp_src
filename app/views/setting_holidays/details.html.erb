<div class="list_users">
  <div class="card mb-3">
    <div class="card-body pt-0">
      <div class="tab-content">
        <div class="row">
          <div class="col">
            <h3 class="mt-2 overview_text">Chi tiết nghỉ phép của <%= @fullname %></h3>
          </div>
        </div>

        <div class="mt-3">
          <div class="table-responsive scrollbar mt-2">
            <!-- Thông tin tổng quan -->
            <div class="card mb-3">
              <div class="card-body">
                <p><strong>Mã nhân sự:</strong> <%= @user&.sid %></p>
                <p><strong>Phòng ban:</strong> <%= @user&.works&.first&.positionjob&.department&.name %></p>
                <p><strong>Vị trí công việc:</strong> <%= @user&.works&.first&.positionjob&.name %></p>
                <p><strong>Tổng phép:</strong> <%= @total_holiday %></p>
                <p><strong>Đã dùng:</strong> <%= @used_holiday %></p>
                <p><strong>Còn lại:</strong> <%= @remaining_holiday %></p>
              </div>
            </div>

            <!-- Bảng chi tiết Holprosdetail -->
            <table class="table table-bordered fs--1 mb-0">
              <thead class="bg-200 text-900">
                <tr>
                  <th>Loại phép</th>
                  <th>Ngày nghỉ</th>
                  <th>Bàn giao cho ai</th>
                  <th>Ai ký duyệt</th>
                  <th>Trạng thái</th>
                </tr>
              </thead>
              <tbody>
                <% if @datas.present? && !@datas.empty? %>
                  <% @datas.each do |detail| %>
                    <tr>
                      <td><%= detail[:leave_type] %></td>
                      <td><%= detail[:leave_date] %></td>
                      <td><%= detail[:assigned_to] %></td>
                      <td><%= detail[:approved_by] %></td>
                      <td><%= detail[:status] %></td>
                    </tr>
                  <% end %>
                <% else %>
                  <tr>
                    <td colspan="5" class="text-center">Không có dữ liệu chi tiết nghỉ phép.</td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>