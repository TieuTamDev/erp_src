              <button class="btn btn-secondary" type="button" data-bs-dismiss="modal"><%= lib_translate("Close")  %></button>
              <button class="btn btn-primary" id="submit_asign_stask_user" type="button" disabled><%= lib_translate("Asign_user")  %></button>
            </div>
          <% end %>
        </div>
      </div>
