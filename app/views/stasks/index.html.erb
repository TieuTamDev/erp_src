  let stask_id ="<%= session[:table_stask_id]%>"
  var delete_stask_delete_form = document.getElementById("delete_stask_delete_form")
  if (delete_stask_delete_form) {
    delete_stask_delete_form.onclick = function () {    
      document.getElementById("delete_stask_delete_form").style.display = "none"; 
      document.getElementById("close_stask_delete").style.display = "none"; 
      document.getElementById("loading_button_delete_stask").style.display = "block";
    };
  }

  document.addEventListener('readystatechange', event => { 
    if (event.target.readyState === "interactive") {  
        list = document.querySelectorAll("#collapseExample-<%= session[:table_stask_id] %>");
        for (var i = 0; i < list.length; ++i) {
          list[i].classList.add('show'); 
        }
    }

    if (event.target.readyState === "complete") { 
      '<%= session[:table_stask_id] = "" %>'
    }
  });
</script>
