<style>
  #calendar-workshilf{
    height: 466px;
    overflow: scroll;
    border: 1px solid #d1d1d1;
  }
  .calender-table thead th {
    position: sticky !important;
    top: -1px;
    background: #f9f9f9;
    z-index: 2;    
    padding: 0px;
    top: -1px;
    border-bottom: 1px solid #efefef !important;
  }
  .calender-table td{
    padding: 0px;
    overflow: unset;
  }
  .group-column-day{
    text-align: center;
  }
  .group-column{
    padding: 0px !important;
    width: 81px;
  }
  .event-item{
    background-color:white;
    border: 1px solid #d3cfcf;
    border-radius: 5px;
    padding: 2px 5px;
    z-index: 1;
    user-select:none;
    overflow: hidden;
    box-shadow: 0px 0px 4px 0px #00000040;
    text-align: start;
    text-wrap-mode: nowrap;
  }
  .event-item-month{
    background-color: #72A7EE;
    text-wrap-mode: nowrap;
    border-radius: 4px;
    overflow: hidden;
    color: white;
    margin-bottom: 3px;
    width: 100%;
    text-indent: 4px;
  }

  [data-cell-date]{
    display: flex;
    flex-direction: column;
    align-items: center;
    padding:0px 3px;
    user-select: none;
  }

  tr.row-hightlight td{
    border-top: 2px solid #0EA5E9;
    border-bottom: 2px solid #0EA5E9;
  }

  tr.row-hightlight td:first-child{
    border-left: 2px solid #0EA5E9;
  }

  tr.row-hightlight td:last-child{
    border-right: 2px solid #0EA5E9;
  }

</style>

<div class="attend-container">
  <div class="card mb-3">
    <div class="card-body pt-0">
      <div class="tab-content">
        <div class="row">
          <div class="col">
            <h5 class="mt-2 mb-3 overview_text"><%= lib_translate("Duyệt đề xuất") %></h5>
          </div>
        </div>
        <div class="mt-0">
          <div class="tab-content">
            <div class="d-flex justify-content-between align-items-end mb-2">
              <div class="d-flex">
                <div onclick="onClickStepTime(-1)" class="d-flex justify-content-center align-items-center me-2" style="font-size: 24px;cursor: pointer;width: 30px;">
                  <span class="fas fa-angle-left"></span>
                </div>
                <div class="d-flex justify-content-center align-items-center">
                  <span><b class="display-current-time" style="user-select: none;"></b></span>
                </div>
                <div onclick="onClickStepTime(1)" class="d-flex justify-content-center align-items-center ms-2" style="font-size: 24px;cursor: pointer;width: 30px;">
                  <span class="fas fa-angle-right"></span>
                </div>
              </div>
              <div>
                <select class="form-select" name="calender-week-month" onchange="onChangeTimeType(this)">
                  <option value="week">Tuần</option>
                  <option value="month">Tháng</option>
                </select>
              </div>
            </div>
            <div id="calendar-workshilf" class="mb-2" style="background-color: white;"></div>
            <div class="d-flex justify-content-between mb-2">
              <div class="d-flex gap-2 align-items-center flex-wrap">
                <%= form_tag get_process_attend_attends_path, method: :get, id: "form-search-attends", remote: true, authenticity_token: true do %>
                  <div class="form-input" style="max-width: 300px;">
                    <input type="text" onkeydown="onSearchUser(event,this)" 
                          name="search" placeholder="Mã/Tên nhân viên" 
                          class="form-control h-38" maxlength="50">
                  </div>
                  <input name="page" value="1" class="d-none" hidden/>
                  <input name="per_page" value="25" class="d-none" hidden/>
                  <input name="week_num" value="" class="d-none" hidden/>
                  <input name="year" value="" class="d-none" hidden/>
                <%end%>
                
                <div>
                  <select class="form-control" name="request_type" id="request-type">
                    <option value="">Tất cả loại đề nghị</option>
                    <option value="early-check-out">Về sớm</option>
                    <option value="late-check-in">Đi trễ</option>
                    <option value="shift-change">Đổi ca</option>
                    <option value="work-trip">Đi công tác</option>
                    <option value="additional-check-in">Chấm công vào làm bù</option>
                    <option value="additional-check-out">Chấm công tan làm bù</option>
                    <option value="update-shift">Cập nhật ca</option>
                    <option value="compensatory-leave">Nghỉ bù</option>
                    <option value="overtime">Tăng ca</option>
                    <!-- @author: trong.lq @date: 23/10/2025 - Option cho đề xuất chỉnh sửa kế hoạch làm việc -->
                    <option value="edit-plan">Chỉnh sửa kế hoạch làm việc</option>
                  </select>
                </div>
                
                <!-- Thêm các nút filter -->
                <div class="d-flex gap-1">
                  <button type="button" class="btn btn-outline-primary btn-sm" onclick="applyFilters()">
                    <i class="fas fa-filter me-1"></i>Lọc
                  </button>
                  <button type="button" class="btn btn-outline-secondary btn-sm" onclick="clearAllFilters()">
                    <i class="fas fa-times me-1"></i>Xóa lọc
                  </button>
                </div>
              </div>
              
              <div class="d-flex gap-2">
                <button class="btn btn-primary" onclick="clickApprovalSelected('APPROVED')">Duyệt nhóm</button>
                <button class="btn btn-danger" onclick="clickApprovalSelected('REJECTED')">Từ chối</button>
              </div>
            </div>
            <div class="table-responsive scrollbar">
              <table id="attend-request" class="table table-bordered fs--1 mb-0 mt-0">
                <thead class="bg-200 text-900">
                <tr>
                  <th class="text-center" style="width: 64px;">
                    <input class="form-check-input" type="checkbox" name="check_all" onchange="onCheckAllProcessAttend(this)"/>
                  </th>
                  <th><%= lib_translate("Mã nhân viên") %></th>
                  <th><%= lib_translate("Tên nhân viên") %></th>
                  <th><%= lib_translate("Loại đề nghị") %></th>
                  <th style="width: 236.625px;"><%= lib_translate("Ca đề xuất") %></th>
                  <th><%= lib_translate("Chi tiết") %></th>
                  <th><%= lib_translate("Ngày gửi") %></th>
                  <th><%= lib_translate("Lý do") %></th>
                  <th class="text-center"><%= lib_translate("Trạng thái") %></th>
                  <th class="text-center"></th>
                </tr>
                </thead>
                <tbody class="attend-request-tbody"></tbody>
              </table>
            </div>
            <div class="pagin-wrap d-flex justify-content-center mt-2"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

