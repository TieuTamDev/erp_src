<script>

  let selectItems = [];
  let currentTime = moment().startOf('isoWeek').add(1, 'weeks');
  let time_type = "week";

  let colors = [
              "#0EA5E9",
              "#FC953B",
              "#16A34A",
              "#AF52DE",
              "#0E37E8",
              "#510EE8",
              "#E80EA4",
              "#A5E80E",
              "#FCF53B",
              "#42F915",
              "#15F9CB",
              "#DE5180",
              "#0973A3",
              "#D66503",
              "#0F7233",
              "#8222B2",
              "#0926A2",
              "#3809A2",
              "#A20972",
              "#73A209",
              "#D6CE03",
              "#28B804",
              "#04B894",
              "#B22151"
            ];

  function initCalendar() {
    $("#calendar-workshilf").smallCalendar({
      currentTime: currentTime,
      renderWeekEvent: renderWeekEvent,
      week:{
        item_height: 48
      }
    });
  }

  function onChecShilfIssue(checkbox) {
    let checked = checkbox.checked;
    let input_count = $('.attend-request-tbody input[type="checkbox"]').length;
    let temp = checked ? ":checked" : ":not(:checked)";
    let check_count = $(`.attend-request-tbody input[type="checkbox"]${temp}`).length;

    $(`[name="switch-view-${checkbox.value}"]`).prop("checked",checked);

    if(input_count == check_count){
      $('input[name="check_all"]').prop("checked",checked);
    }else{
      $('input[name="check_all"]').prop("checked",false);
    }
    loadEventCalendar();
  }

  function onChangeTimeType(select) {
    time_type = select.value;
    $("#calendar-workshilf").smallCalendar("switchView", time_type);
  }

  function onClickStepTime(step) {
    gotoWeek(step);
  }

  function getDayRange() {
    const start = currentTime.clone().startOf("isoWeek");
    const end = start.clone().endOf("isoWeek");

    return {
      startDate: start.format("YYYY-MM-DD"),
      endDate: end.format("YYYY-MM-DD")
    };
  }

  function gotoWeek(step) {
      if(step == 1){
          currentTime.add(1, 'weeks');
      }else if(step == -1){
          currentTime.subtract(1, 'weeks');
      }
      displayTimeData();
      
      console.log('Week navigation - step:', step);
      submitFormGetProcessAttend(1);
      $("#calendar-workshilf").smallCalendar("updateDate",currentTime);
  }
  
  function gotoMonth(step) {
    if(step == 1){
      currentTime.add(1, 'months');
    }else if(step == -1){
      currentTime.subtract(1, 'months');
    }
    displayTimeData();
    submitFormGetProcessAttend(1);
    $("#calendar-workshilf").smallCalendar("updateDate",currentTime);
  }

  function displayTimeData() {
    let weekNum = currentTime.isoWeek();
    $(".display-current-time").html(`Tuần ${weekNum} năm ${currentTime.isoWeekYear()}`);
  }

  function loadEventCalendar() {
    let events = [];
    const seen = new Set();

    $('.attend-request-tbody input[type="checkbox"]:checked').each((index, element) => {
      let color = colors[index % colors.length];
      let id = element.value;

      let item = shiftissues.find(s => String(s.id) === String(id));
      if (!item) return;

      if (item.stype === "WORK-TRIP") {
        if (Array.isArray(item.grouped_work_trips)) {
          item.grouped_work_trips.forEach(trip => {
            let date = trip.work_date ? moment(trip.work_date).format("YYYY-MM-DD") : null;
            if (!date) return;

            let start = "07:30";
            let end = "17:00";

            let key = `${item.id}_${date}_${start}_${end}`;
            if (seen.has(key)) return;
            seen.add(key);

            events.push({
              id: key,
              original_id: item.id,
              user_id: item.user_id,
              title: item.stype_text || "Đi công tác",
              user_name: item.user_name || "",
              date: date,
              start: start,
              end: end,
              color: color,
            });
          });
        }
      } 
      /*
      @author: dat.nh @date: 14/03/2026
      Thêm phần hiển thị chi tiết ngày tháng cho đề xuất tăng ca
      */
      else if (item.type === "OVERTIME") {
        if (Array.isArray(item.grouped_overtimes)) {
          item.grouped_overtimes.forEach(overtime => {
            let date = overtime.work_date ? moment(overtime.work_date).format("YYYY-MM-DD") : null;
            if (!date) return;

            let start = "07:30";
            let end = "17:00";

            let key = `${item.id}_${date}_${start}_${end}`;
            if (seen.has(key)) return;
            seen.add(key);

            events.push({
              id: key,
              original_id: item.id,
              user_id: item.user_id,
              title: item.stype_text || "Tăng ca",
              user_name: item.user_name || "",
              date: date,
              start: start,
              end: end,
              color: color,
            });
          });
        }
      } else {
        let date = item.work_date ? moment(item.work_date).format("YYYY-MM-DD") : null;
        if (!date) return;

        let start = item.start_time || "00:00";
        let end = item.end_time || "23:59";

        let key = `${item.id}_${date}_${start}_${end}`;
        if (seen.has(key)) return;
        seen.add(key);

        events.push({
          id: key,
          original_id: item.id,
          user_id: item.user_id,
          title: item.stype_text || item.stype || "Event",
          user_name: item.user_name || "",
          date: date,
          start: start,
          end: end,
          color: color,
        });
      }
    });

    console.log("Events gửi vào calendar:", events);
    $("#calendar-workshilf").smallCalendar("loadEvents", events);
  }

  function onCheckAllProcessAttend(checkbox) {
    let checked = checkbox.checked;
    $('.attend-request-tbody input[type="checkbox"]').prop("checked",checked);
    loadEventCalendar();
  }

  function getDayRange() {
    const start = currentTime.clone().startOf("isoWeek");
    const end = start.clone().endOf("isoWeek");

    return {
      startDate: start.format("YYYY-MM-DD"),
      endDate: end.format("YYYY-MM-DD")
    };
  }
  
  function renderWeekEvent(event) {
    const showTime = event.start && event.start !== "00:00" && event.start !== "23:59";
    const timeHtml = showTime ? `<div style="font-size:12px;font-weight:600;color:${event.color}; margin-bottom:2px;">${event.start}</div>` : '';

    return `
      <div class="event-item" style="position: absolute; border-left: 4px solid ${event.color}; width: calc(100% - 8px); box-sizing: border-box;">
        ${timeHtml}
        <div style="font-weight:600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${event.user_name}</div>
        <div style="font-size: 13px; filter: brightness(85%); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
          ${event.title}
        </div>
      </div>
    `;
  }

  function onClickButtonPage(page) {
      let form = $("#form-get-process-attend");
      let searchValue = $("#form-search-attends input[name='search']").val() || '';
      let requestType = $('#request-type').val() || '';

      form.find('[name="search"]').val(searchValue);
      form.find('[name="request_type"]').val(requestType);
      form.find('[name="page"]').val(page);
      form.find('[name="week_num"]').val(currentTime.isoWeek());
      form.find('[name="year"]').val(currentTime.isoWeekYear());

      form.submit();
      showLoadding(true);
  }

  function getSelectData() {
    selectItems = [];
    let select_ids = [];
    $('.attend-request-tbody input[data-check-select][type="checkbox"]:checked').each((index,element)=>{
      selectItems.push(element.value);
    });
  }

  function clickApprovalSelected(status) {

    getSelectData();

    if (selectItems.length == 0) {
      alert("Vui lòng chọn đề xuất trước khi xử lý!");  
      return;
    }

    renderPopup(selectItems,status);
  }

  function renderPopup(ids,status) {
    let popupID = "modal-approval-shiftissue";
    let dialog = $("#" + popupID);
    let listwrap = dialog.find("#shiftissue-list");
    listwrap.html(``);
    ids.forEach(id=>{
      let shiftissue = shiftissues.find(item=>{return item.id == id});
      if(shiftissue){
        let item_html = renderShiftissueItem(shiftissue,status);
        listwrap.append(item_html);
      }
    });

    dialog.find(".confirm-btn").off().on('click',()=>{
      if(!IsValidFormApproval(ids,status)){
        alert("Vui lòng nhập lý do từ chối!");
        return;
      }
      submitUpdate(popupID,status);
    });
    dialog.find(".confirm-btn").html( status == "REJECTED" ? "Từ chối" : "Phê duyệt" );
    dialog.find(".confirm-btn").toggleClass("btn-danger",false);
    dialog.find(".confirm-btn").toggleClass("btn-primary",false);
    dialog.find(".confirm-btn").toggleClass( status == "REJECTED" ? "btn-danger" : "btn-primary" ,true);
    dialog.modal('show');
  }

  function IsValidFormApproval(ids,status) {
    if(status == "REJECTED"){
      for (let i = 0; i < ids.length; i++) {
        const id = ids[i];
        let reason = $("#reason-"+id).val().trim();
        if(reason == ""){
          return false;
        }
      }
    }
    return true;
  }

  function renderShiftissueItem(shiftissue, status) {

      let details = renderItemDetails(shiftissue);

      let inputReason = "";
      if (status === "REJECTED") {
          inputReason = `
              <div class="mb-2">
                  <label class="form-label" for="reason-${shiftissue.id}">Lý do từ chối:</label>
                  <textarea class="form-control" id="reason-${shiftissue.id}" rows="3"></textarea>
              </div>`;
      }

      let docHtml = "";
      let docText = "Không có";
      if (shiftissue.file_name) {
          docHtml = `<img style="max-width: 100%; border: 1px solid #ddd; border-radius: 4px; padding: 4px;" 
                        src="/mdata/hrm/${shiftissue.file_name}" alt="file">`;
          docText = "";
      }


      let dateHtml = "";

      if (shiftissue.stype === "WORK-TRIP" && Array.isArray(shiftissue.grouped_work_trips)) {
          // Gom nhóm dữ liệu theo ngày
          const byDate = {};
          shiftissue.grouped_work_trips.forEach((trip) => {
              const dateYmd = moment(trip.work_date).format("YYYY-MM-DD");
              if (!byDate[dateYmd]) byDate[dateYmd] = { morning: false, afternoon: false };

              const start = trip.start_time;
              const end = trip.end_time;

              // Xác định ca dựa vào giờ
              if (start && end) {
                  const startHour = parseInt(start.split(":")[0], 10);
                  if (startHour < 12) byDate[dateYmd].morning = true;
                  else byDate[dateYmd].afternoon = true;
              }
          });

          // Render HTML tương tự đoạn mẫu
          const entries = Object.keys(byDate)
              .sort()
              .map((dYmd) => {
                  const d = moment(dYmd).format("DD-MM-YYYY");
                  const f = byDate[dYmd];
                  let label = "";
                  if (f.morning && f.afternoon) label = "cả ngày";
                  else if (f.morning) label = "ca sáng";
                  else if (f.afternoon) label = "ca chiều";
                  else label = "ca";

                  return `<div class="mb-1">📅 <strong>${d}</strong>: <strong>${label}</strong></div>`;
              });

          const mid = Math.ceil(entries.length / 2);
          const col1 = entries.slice(0, mid).join("");
          const col2 = entries.slice(mid).join("");

          dateHtml = `
            <div class="mt-1">
              <div class="mb-2">Chi tiết công tác theo ngày:</div>
              <div class="row">
                <div class="col-12 col-md-6">${col1}</div>
                <div class="col-12 col-md-6">${col2}</div>
              </div>
            </div>`;
      }
      /*
      @author: dat.nh @date: 14/03/2026
      Thêm phần hiển thị chi tiết ngày tháng cho đề xuất tăng ca
      */ 
      else if (shiftissue.stype === "OVERTIME" && Array.isArray(shiftissue.grouped_overtimes)) {
          // Gom nhóm dữ liệu theo ngày
          const byDate = {};
          shiftissue.grouped_overtimes.forEach((overtime) => {
              const dateYmd = moment(overtime.work_date).format("YYYY-MM-DD");
              if (!byDate[dateYmd]) byDate[dateYmd] = { morning: false, afternoon: false };

              const start = overtime.start_time;
              const end = overtime.end_time;

              // Xác định ca dựa vào giờ
              if (start && end) {
                  const startHour = parseInt(start.split(":")[0], 10);
                  if (startHour < 12) byDate[dateYmd].morning = true;
                  else byDate[dateYmd].afternoon = true;
              }
          });

          // Render HTML tương tự đoạn mẫu
          const entries = Object.keys(byDate)
              .sort()
              .map((dYmd) => {
                  const d = moment(dYmd).format("DD-MM-YYYY");
                  const f = byDate[dYmd];
                  let label = "";
                  if (f.morning && f.afternoon) label = "cả ngày";
                  else if (f.morning) label = "ca sáng";
                  else if (f.afternoon) label = "ca chiều";
                  else label = "ca";

                  return `<div class="mb-1">📅 <strong>${d}</strong>: <strong>${label}</strong></div>`;
              });

          const mid = Math.ceil(entries.length / 2);
          const col1 = entries.slice(0, mid).join("");
          const col2 = entries.slice(mid).join("");

          dateHtml = `
            <div class="mt-1">
              <div class="mb-2">Chi tiết tăng ca theo ngày:</div>
              <div class="row">
                <div class="col-12 col-md-6">${col1}</div>
                <div class="col-12 col-md-6">${col2}</div>
              </div>
            </div>`;
      } else if (shiftissue.start_date && shiftissue.end_date) {
          // Trường hợp có start_date, end_date nhưng không có grouped_overtimes hoặc grouped_work_trips
          dateHtml = `
            <div class="mb-2">
              <span>Ngày: </span>
              <b><span>${moment(shiftissue.start_date).format("DD/MM/YYYY")} - ${moment(shiftissue.end_date).format("DD/MM/YYYY")}</span></b>
            </div>`;
      } else {
          // Trường hợp chỉ có work_date
          dateHtml = `
            <div class="mb-2">
              <span>Ngày: </span>
              <b><span>${moment(shiftissue.work_date).format("DD/MM/YYYY")}</span></b>
            </div>`;
      }

      let item = `
          <div class="shiftissue-item mb-3">
              <div class="mb-2">
                  <span>Tên nhân sự: </span> 
                  <b><span class="issue-user-name">${shiftissue.user_name}</span></b>
              </div>
              <div class="mb-2">
                  <span>Loại đề xuất: </span> 
                  <b><span>${shiftissue.stype_text}</span></b>
              </div>
              ${dateHtml}
              ${details}
              <div class="mb-2">
                  <span>Lý do đề xuất: </span> 
                  <b><span style="color: #f57557;">${shiftissue.note || "Không có"}</span></b>
              </div>
              <div class="mb-2">
                  <span>Minh chứng: </span> 
                  <b><span>${docText}</span></b>
                  <div class="issue-docs-wrap mt-1">
                      ${docHtml}
                  </div>
              </div>
              ${inputReason}
          </div>
          <hr class="divider">`;

      return item;
  }

  function renderItemDetails(shiftissue) {
    let details = "";
    switch (shiftissue.stype) {
      case "EARLY-CHECK-OUT":
        details = `<div class="mb-2">
                      <span>Giờ ra: </span><span style="color: #738ffb;"><b>${shiftissue.us_end}</b></span>
                    </div>`;
        break;
      case "LATE-CHECK-IN":
        details = `
          <div class="mb-2">
            <span>Giờ vào: </span><span style="color: #738ffb;"><b>${shiftissue.us_start}</b></span>
          </div>`;
        break;
      case "SHIFT-CHANGE":
        details = `
          <div class="mb-2 d-flex align-items-center">

            <div class="d-flex flex-column justify-content-center align-items-center" style="max-width: 40%;width: fit-content;">
              <div><span><b>${shiftissue.user_name}</b></span></div>
              <div style="color: #738ffb;">
                <span><b>${shiftissue.start_time} - ${shiftissue.end_time}</b></span>
              </div>
            </div>
            
            <div class="me-3 ms-3" style="font-size: 23px;color: #f3b668;">
              <span class="fas fa-arrows-alt-h"></span>
            </div>

            <div class="d-flex flex-column justify-content-center align-items-center" style="max-width: 40%;width: fit-content;">
              <div><span><b>${shiftissue.change_user_name}</b></span></div>
              <div style="color: #738ffb;">
                <span><b>${shiftissue.c_start_time} - ${shiftissue.c_end_time}</b></span>
              </div>
            </div>
          </div>
          
          `;
        break;
      case "UPDATE-SHIFT":
        details = `
          <div class="mb-2">
            <span>Giờ vào: </span><span style="color: #738ffb;"><b>${shiftissue.us_start}</b></span> <span class="me-2 ms-2">-</span> <span>Giờ ra: </span><span style="color: #738ffb;"><b>${shiftissue.us_end}</b></span>
          </div>`;
        break;
      case "ADDITIONAL-CHECK-IN":
        details = `
          <div class="mb-2">
            <span>Giờ vào: </span> <span style="color: #738ffb;"><b>${shiftissue.us_start}</b></span>
          </div>`;
        break;
      case "ADDITIONAL-CHECK-OUT":
        details = `
          <div class="mb-2">
            <span>Giờ ra: </span> <span style="color: #738ffb;"><b>${shiftissue.us_end}</b></span>
          </div>`;
        break;
      case "EDIT-PLAN":
        // @author: trong.lq
        // @date: 23/10/2025
        // Hiển thị thông tin chỉnh sửa kế hoạch làm việc
        details = `
          <div class="mb-2">
            <span>Tuần chỉnh sửa: </span><span style="color: #738ffb;"><b>${shiftissue.content || "-"}</b></span>
          </div>`;
        break;
      default:
        break;
    }
    return details;
  }

  function clickApprovalOne(id) {
    selectItems = [id];
    renderPopup([id],"APPROVED");
  }

  function submitUpdate(popupID, status) {
      let popup = $("#" + popupID);
      let data = [];
      
      selectItems.forEach(id => {
          let reason = $(`#reason-${id}`).val();
          
          
          data.push({
              id: id,
              reason: reason,
              is_work_trip_representative: true 
          });
      });
      
      let form = $("#form-update-process-attend");
      form.find('textarea[name="data"]').val(JSON.stringify(data));
      form.find('input[name="status"]').val(status);
      form.submit();
      showLoadding(true);
      popup.modal("hide");
  }

  function onApproval(success, errorMsg) {
    showLoadding(false);
    if(success){
      $(".modal").modal("hide");
      submitFormGetProcessAttend();
      showAlert("Cập nhật thành công","success");
    }else{
      showAlert("Lỗi khi duyệt","danger");
      console.error("❌ onApproval error:", errorMsg);
    }
  }

  function onSearchUser(e, input) {
      if (e.key === "Enter" || e.keyCode === 13) {
          e.preventDefault();
          
          // Reset về trang 1 khi search
          let form = $("#form-get-process-attend");
          form.find('[name="page"]').val(1);
          
          // Submit form với search mới
          submitFormGetProcessAttend();
      }
  }

  function searchWorkshifts(page = 1, per_page = 25) {
      let searchValue = $("#form-search-attends input[name='search']").val().trim();
      let requestType = $('#request-type').val() || '';
      
      let mainForm = $("#form-get-process-attend");
      mainForm.find('[name="search"]').val(searchValue);
      mainForm.find('[name="request_type"]').val(requestType);
      mainForm.find('[name="page"]').val(page);
      mainForm.find('[name="per_page"]').val(per_page);
      mainForm.find('[name="week_num"]').val(currentTime.isoWeek());
      mainForm.find('[name="year"]').val(currentTime.isoWeekYear());
      
      console.log('Search Workshifts - Request Type:', requestType);
      
      mainForm.submit();
      showLoadding(true);
  }

  function clearAllFilters() {
      $("#form-search-attends input[name='search']").val('');
      $('#request-type').val('');
      console.log('All filters cleared');
      
      let form = $("#form-get-process-attend");
      form.find('[name="page"]').val(1);
      submitFormGetProcessAttend();
  }

  function clearSearch() {
      $("#form-search-attends input[name='search']").val('');
      
      let form = $("#form-get-process-attend");
      form.find('[name="page"]').val(1);
      submitFormGetProcessAttend();
  }

  function clearRequestType() {
      $('#request-type').val('');
      console.log('Request type cleared');
      
      let form = $("#form-get-process-attend");
      form.find('[name="page"]').val(1);
      submitFormGetProcessAttend();
  }

  initCalendar();
  displayTimeData();
  submitFormGetProcessAttend();

  $(document).ready(function() {
      $('#request-type').on('change', function() {
          
          let form = $("#form-get-process-attend");
          form.find('[name="page"]').val(1);
          
          submitFormGetProcessAttend();
      });
  });


  function submitFormGetProcessAttend(page) {
      let form = $("#form-get-process-attend");
      
      // Lấy giá trị search từ form riêng biệt
      let searchValue = $("#form-search-attends input[name='search']").val() || '';
      
      // Lấy giá trị request type từ select riêng biệt  
      let requestType = $('#request-type').val() || '';
      
      // Set các giá trị vào form chính
      form.find('[name="search"]').val(searchValue);
      form.find('[name="request_type"]').val(requestType);
      form.find('[name="week_num"]').val(currentTime.isoWeek());
      form.find('[name="year"]').val(currentTime.isoWeekYear());
      if (page){
          form.find('[name="page"]').val(page);
      }
      form.submit();
      showLoadding(true);
  }

  function applyFilters() {
    let form = $("#form-get-process-attend");
    form.find('[name="page"]').val(1);
    submitFormGetProcessAttend();
  }

  function refreshData() {
    submitFormGetProcessAttend();
  }
</script>