<div class="attend-container">
  <div class="card mb-3">
    <div class="card-body pt-0">
      <div class="tab-content">
        <div class="row">
          <div class="col">
            <h3 class="mt-3 overview_text"><%= lib_translate("Thống kê chấm công") %></h3>
          </div>
          <% if (is_access(session["user_id"], "ATTEND-MANAGEMENT", "ADD") || is_access(session["user_id"], "ATTEND-MANAGEMENT","EDIT")) %>
            <div class="d-flex mt-2 align-items-end">
              <div class="me-1">
                <button type="button" class="btn btn-outline-info" id="export-excel">Xuất báo cáo</button>
              </div>
            </div>
          <% end %>
        </div>
        <div class="mt-0">
          <div class="tab-content">
            <form action='<%= management_attends_path() %>' accept-charset='UTF-8' method='get' class="mb-3">
              <div id='attend_table_filter' class='attend-table-container col-12'>
                <input name='utf8' type='hidden' value='✓'>
                <input class='d-none' name='lang' value='vi'>
                <% if !params[:per_page].nil? %>
                  <input class='d-none' name='per_page' value='<%= params[:per_page] %>'>
                <% end %>
                <input type='submit' hidden>
                <div class="d-flex flex-wrap justify-content-end gap-2">
                  <div class="form-input" style="max-width: 300px;">
                    <label class="mb-1"><%= lib_translate("Nhân viên") %></label>
                    <input type="text" name="search" id="search_input" value="<%= params[:search] %>" placeholder="Nhập mã nhân sự hoặc tên" class="form-control me-2 h-38" maxlength="100">
                  </div>
                  <% if (is_access(session["user_id"], "ATTEND-MANAGEMENT", "ADD")) %>
                    <div class="form-input" style="max-width: 300px;">
                      <label class="mb-1"><%= lib_translate("Phòng ban") %></label>
                      <select class="select-form selectpicker" name="department_id" id="attend_department_select">
                        <option value="">Tất cả phòng ban</option>
                        <% @departments&.each do |department| %>
                          <option value="<%= department&.id %>" <%= params[:department_id] == department&.id.to_s ? 'selected' : '' %>>
                            <%= department&.name %>
                          </option>
                        <% end %>
                      </select>
                    </div>
                  <% end %>
                  <div class="form-input" style="max-width: 300px;">
                    <label class="mb-1"><%= lib_translate("Trạng thái") %></label>
                    <select class="select-form selectpicker" name="attendance_type" id="attendance_type_select">
                      <option value="" <%= 'selected' if params[:attendance_type].blank? %>>Tất cả</option>
                      <option value="no-check-in-out" <%= 'selected' if params[:attendance_type] == 'no-check-in-out' %>>Không chấm công</option>
                      <option value="late-check-in" <%= 'selected' if params[:attendance_type] == 'late-check-in' %>>Đi trễ</option>
                      <option value="early-checkout-out" <%= 'selected' if params[:attendance_type] == 'early-checkout-out' %>>Về sớm</option>
                      <option value="work-trip" <%= 'selected' if params[:attendance_type] == 'work-trip' %>>Đi công tác</option>
                    </select>
                  </div>
                  <div class="form-input" style="max-width: 350px;">
                    <label class="mb-1"><%= lib_translate("Thời gian") %></label>
                    <div class="form-control d-flex align-items-center">
                      <span class="far fa-calendar-alt fs-2"></span>
                      <input class="ms-2 border-0" name="date" data-range="date" id="attendance_select_date" value="<%= params[:date] %>" style="outline: none;"/>
                    </div>
                  </div>
                  <div class="ms-3 d-flex align-items-end" style="max-width: 300px;">
                    <button id="btn-fillter-all" type="submit" class="btn btn-primary h-38"><%= lib_translate("Tìm kiếm") %></button>
                  </div>
                </div>
              </div>
            </form>
            <div class="table-responsive scrollbar">
              <table id="attend-request" class="table table-bordered fs--1 mb-0 mt-0 text-dark">
                <thead class="bg-200 text-900">
                <tr>
                  <th style="width: 5%;" class="sort text-center"><%= lib_translate("STT") %></th>
                  <th style="width: 10%;" class="sort text-center"><%= lib_translate("Mã nhân viên") %></th>
                  <th style="width: 11%;" class="sort text-center"><%= lib_translate("Tên nhân viên") %></th>
                  <th style="width: 15%;" class="sort text-center"><%= lib_translate("Đơn vị") %></th>
                  <th style="width: 10%;" class="sort text-center"><%= lib_translate("Ngày") %></th>
                  <th style="width: 22%;" class="sort text-center"><%= lib_translate("Ca sáng") %></th>
                  <th style="width: 22%;" class="sort text-center"><%= lib_translate("Ca chiều") %></th>
                  <th style="width: 10%;" class="no-sort text-center"></th>
                </tr>
                </thead>
                <tbody class="attend-request-tbody">
                <% @results.each_with_index do |item, idx| %>
                  <tr>
                    <td class="text-center align-middle"><%= (idx + 1) + (@page - 1) * @per_page %></td>
                    <td class="align-middle"><%= item[:user_id] %></td>
                    <td class="align-middle"><%= item[:user_name] %></td>
                    <td class="text-center align-middle"><%= item[:department] %></td>
                    <td class="text-center align-middle"><%= item[:work_date] %></td>
                    <%
                      parse_time = ->(s) { s.present? ? (Time.parse(s) rescue nil) : nil }
                      shiftselection  = (item[:shiftselection] || {})
                      split_noon = Time.parse('12:30')
                      ordered = shiftselection.sort_by { |_, v| parse_time.call(v[:start_time]) || Time.at(1<<62) }

                      morning   = nil
                      afternoon = nil

                      ordered.each do |ws_id, plan|
                        off_type = plan[:is_day_off].to_s.upcase
                        parse_time_start_time       = parse_time.call(plan[:start_time])
                        slot =
                          if parse_time_start_time
                            (parse_time_start_time < split_noon) ? :morning : :afternoon
                          elsif off_type.present?
                            morning.nil? ? :morning : :afternoon
                          else
                            nil
                          end

                        case slot
                        when :morning   then morning   ||= [ws_id, plan]
                        when :afternoon then afternoon ||= [ws_id, plan]
                        end
                      end

                      pairs = [morning, afternoon]
                    %>

                    <% pairs.each do |pair| %>
                      <% if pair.present? %>
                        <% ws_id, plan = pair
                           att = (item[:attend][ws_id] || {})
                           checkin  = att[:checkin]
                           checkout = att[:checkout]
                           off_type = plan[:is_day_off].to_s.upcase
                        %>
                        <% if off_type.blank? %>
                          <td class="text-center align-middle">
                            <div class="fw-bold mb-1"><%= plan[:start_time] %> – <%= plan[:end_time] %></div>
                            <div class="mb-1"><%= plan[:location] %></div>
                            <div>
                              Giờ vào:
                              <span class="fw-medium <%= 'text-danger' if checkin.present? && plan[:start_time].present? && Time.parse(checkin) > Time.parse(plan[:start_time]) + 15.minutes %>">
                                <%= checkin || '-' %>
                              </span>
                            </div>
                            <div>
                              Giờ ra:
                              <span class="fw-medium <%= 'text-danger' if checkout.present? && plan[:end_time].present? && Time.parse(checkout) < Time.parse(plan[:end_time]) - 15.minutes %>">
                                <%= checkout || '-' %>
                              </span>
                            </div>
                          </td>
                        <% else %>
                          <% label =
                               case off_type
                                 when 'OFF'       then 'Nghỉ'
                                 when 'HOLIDAY'   then 'Nghỉ lễ'
                                 when 'ON-LEAVE'  then 'Nghỉ phép'
                                 when 'TEACHING-SCHEDULE'  then 'Lịch giảng dạy'
                                 when 'WORK-TRIP' then 'Đi công tác'
                                 else 'Nghỉ'
                               end %>
                          <td class="text-center align-middle">
                            <div class="fw-bold text-success mb-1"><%= label %></div>
                            <% if off_type == 'WORK-TRIP' %>
                              <div>
                                Giờ vào:
                                <span class="fw-medium <%= 'text-danger' if checkin.present? && plan[:start_time].present? && Time.parse(checkin) > Time.parse(plan[:start_time]) + 15.minutes %>">
                                  <%= checkin || '-' %>
                                </span>
                              </div>
                              <div>
                                Giờ ra:
                                <span class="fw-medium <%= 'text-danger' if checkout.present? && plan[:end_time].present? && Time.parse(checkout) < Time.parse(plan[:end_time]) - 15.minutes %>">
                                  <%= checkout || '-' %>
                                </span>
                              </div>
                            <% end %>
                          </td>
                        <% end %>
                      <% else %>
                        <td class="text-center align-middle"></td>
                      <% end %>
                    <% end %>

                    <td class="text-center align-middle">
                      <button class="btn btn-sm btn-outline-primary attend-detail-btn"
                              data-shiftselection-ids="<%= item[:id] %>"
                              data-workdate="<%= item[:work_date] %>">
                        Chi tiết
                      </button>
                    </td>
                  </tr>
                <% end %>
                </tbody>
              </table>
              <% if @results_total > 0 %>
                <div class="d-flex justify-content-center mt-3">
                  <div class="col-auto">
                    <nav aria-label="Page navigation">
                      <ul class="pagination mb-0">
                        <li class="page-item <%= @page == 1 ? 'disabled' : '' %>">
                          <%= link_to "«", management_attends_path(page: @page - 1, per_page: @per_page, lang: session[:lang], search: params[:search], department_id: params[:department_id], attendance_type: params[:attendance_type], date: params[:date]), class: "page-link" %>
                        </li>
                        <% (1..@total_pages).each do |i| %>
                          <li class="page-item <%= @page == i ? 'active' : '' %>">
                            <%= link_to i.to_s, management_attends_path(page: i, per_page: @per_page, lang: session[:lang], search: params[:search], department_id: params[:department_id], attendance_type: params[:attendance_type], date: params[:date]), class: "page-link" %>
                          </li>
                        <% end %>
                        <li class="page-item <%= @page == @total_pages ? 'disabled' : '' %>">
                          <%= link_to "»", management_attends_path(page: @page + 1, per_page: @per_page, lang: session[:lang], search: params[:search], department_id: params[:department_id], attendance_type: params[:attendance_type], date: params[:date]), class: "page-link" %>
                        </li>
                      </ul>
                    </nav>
                  </div>
                  <div class="col-auto ms-2">
                    <form action="<%= management_attends_path %>" accept-charset="UTF-8" method="get">
                      <select class="form-select" name="per_page" id="per_page_select" onchange="this.form.submit()">
                        <option value="25" <%= @per_page == 25 ? 'selected' : '' %>>25</option>
                        <option value="50" <%= @per_page == 50 ? 'selected' : '' %>>50</option>
                        <option value="100" <%= @per_page == 100 ? 'selected' : '' %>>100</option>
                        <option value="200" <%= @per_page == 200 ? 'selected' : '' %>>200</option>
                      </select>
                      <input class="d-none" name="lang" value="<%= session[:lang] %>">
                      <input class="d-none" name="search" value="<%= params[:search] %>">
                      <input class="d-none" name="page" value="1">
                      <input class="d-none" name="department_id" value="<%= params[:department_id] %>">
                      <input class="d-none" name="attendance_type" value="<%= params[:attendance_type] %>">
                      <input class="d-none" name="date" value="<%= params[:date] %>">
                    </form>
                  </div>
                </div>
              <% else %>
                <p class="text-center mt-3">Không có dữ liệu để hiển thị.</p>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
