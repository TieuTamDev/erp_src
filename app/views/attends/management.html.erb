<div class="modal fade" id="exportModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="exportModal" aria-hidden="true">
  <div class="modal-dialog modal-custom modal-md">
    <div class="modal-content">
      <div class="modal-header">
        <h4 class="modal-title">Xuất thống kê</h4>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body row">
        <div class="mb-3">
          <div class="form-check">
            <input class="form-check-input export-type-radio" type="radio" name="export_type" id="export_detail_attends" value="detail_attends">
            <label class="form-check-label fw-bold" for="export_detail_attends">Bảng tổng hợp chấm công</label>
          </div>
          <div class="form-check">
            <input class="form-check-input export-type-radio" type="radio" name="export_type" id="export_attends" value="attends">
            <label class="form-check-label fw-bold" for="export_attends">Bảng chấm công chi tiết</label>
          </div>
          <div class="form-check mt-2">
            <input class="form-check-input export-type-radio" type="radio" name="export_type" id="export_by_summary" value="summary">
            <label class="form-check-label fw-bold" for="export_by_summary">Tổng hợp đi trễ, về sớm</label>
          </div>
          <div class="form-check mt-2">
            <input class="form-check-input export-type-radio" type="radio" name="export_type" id="export_by_list" value="list">
            <label class="form-check-label fw-bold" for="export_by_list">Danh sách đi trễ, về sớm</label>
          </div>
        </div>
        <div id="export-form-section" class="d-none">
          <div class="row mb-3">
            <div class="col-6">
              <label class="form-label mb-1">Năm</label>
              <select class="form-select" id="year_export_month_select">
                <% current_year = Date.today.year %>
                <% year_range = (current_year - 2..current_year + 2).to_a %>
                <%= options_for_select(year_range.map { |y| [y, y] }, selected: current_year) %>
              </select>
            </div>
            <div class="col-6">
              <label class="form-label mb-1">Tháng</label>
              <select class="form-select" id="month_export_month_select">
                <%= options_for_select((1..12).map { |m| [m, m] }, selected: Date.today.month) %>
              </select>
            </div>
          </div>
          <% if (is_access(session["user_id"], "ATTEND-MANAGEMENT", "ADD")) %>
            <div class="mb-3 d-none" id="export-filters-wrapper">
              <label class="form-label mb-1">Phòng ban</label>
              <select class="select-form" name="department_id" id="department_select">
                <option value="">Tất cả phòng ban</option>
                <% @departments&.each do |department| %>
                  <option value="<%= department&.id %>"><%= department&.name %></option>
                <% end %>
              </select>
              <div class="mt-3">
                <label class="form-label mb-1">Nhân viên</label>
                <select class="form-select" id="user_export_select" name="user_id">
                  <option value="">Tất cả nhân viên</option>
                </select>
              </div>
            </div>
          <% end %>
          <% if (is_access(session["user_id"], "ATTEND-MANAGEMENT", "EDIT")) %>
            <div class="mb-3 d-none" id="export-filters-wrapper">
              <div class="mt-3">
                <label class="form-label mb-1">Nhân viên</label>
                <select class="form-select" id="user_export_select" name="user_id">
                  <option value="">Tất cả nhân viên</option>
                </select>
              </div>
            </div>
          <% end %>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-primary btn-custom" id="export-btn">Xác nhận</button>
        <button type="button" class="btn btn-secondary btn-custom" data-bs-dismiss="modal">Đóng</button>
      </div>
    </div>
  </div>
</div>
<!-- End modal xuất báo cáo -->