      color:rgb(82, 119, 180);
    }

    #schedule-calendar .fc-toolbar-title {
      font-weight: 900 !important;
      font-size: 1.35rem; /* tuỳ chỉnh */
    }

    #toastContainer { z-index: 1080; }

    #toastContainer .toast{
      min-width: 380px;
      max-width: 560px;
      font-size: 16px;
      line-height: 1.5;
    }

    #toastContainer .toast .d-flex{ align-items: center; }

    /* body co giãn, chừa chỗ cho nút đóng */
    #toastContainer .toast .toast-body{
      flex: 1 1 auto;
      padding: .75rem 1rem;
    }

    /* luôn hiển thị rõ nút đóng */
    #toastContainer .toast .btn-close{
      opacity: .9;
      /* icon trắng trên nền màu */
      filter: invert(1) brightness(200%);
    }

    .attend-container table td{
      overflow: unset !important
    }

    /* CSS cho dropdown checkbox trong template shift */
    .location-dropdown-wrapper {
      position: relative;
      width: 100%;
      min-width: 120px;
    }

    .location-dropdown-toggle {
      width: 100%;
      text-align: left;
      padding: 4px 8px;
      font-size: 13px;
      background-color: #fff;
      border: 1px solid #ced4da;
      border-radius: 4px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
      gap: 4px;
    }

    .location-dropdown-toggle:hover {
      border-color: #86b7fe;
    }

    .location-dropdown-toggle.is-invalid {
      border-color: #dc3545 !important;
      box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.15);
    }

    .location-dropdown-toggle .selected-text {
      flex: 1 1 auto;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      min-width: 0;
    }

    .location-dropdown-toggle .caret {
      flex: 0 0 auto;
      width: 12px;
      transition: transform 0.2s;
      text-align: center;
    }

    .location-dropdown-toggle[aria-expanded="true"] .caret {
      transform: rotate(180deg);
    }

    .location-dropdown-menu {
      position: absolute;
      top: 100%;
      left: 0;
      right: auto;
      max-height: 250px;
      min-width: 180px;
      overflow-y: auto;
      background: #fff;
      border: 1px solid #ced4da;
      border-radius: 4px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.15);
      z-index: 1050;
      margin-top: 2px;
      padding: 4px 0;
    }

    .location-dropdown-menu.show {
      display: block;
    }

    .location-dropdown-menu.hide {
      display: none;
    }

    .location-dropdown-item {
      padding: 6px 12px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
    }

    .location-dropdown-item:hover {
      background-color: #f8f9fa;
    }

    .location-dropdown-item input[type="checkbox"] {
      cursor: pointer;
      margin: 0;
    }

    .location-dropdown-item label {
      cursor: pointer;
      margin: 0;
      flex: 1;
      user-select: none;
    }

    /* CSS cho dropdown trong bảng ca làm việc */
    td.row-workshift .location-dropdown-wrapper {
      min-width: 100px;
      max-width: 140px;
      flex: 0 1 auto;
      position: relative;
      z-index: 10;
    }

    td.row-workshift .location-dropdown-wrapper.is-open {
      z-index: 3000;
    }

    td.row-workshift .location-dropdown-toggle {
      padding: 2px 6px;
      font-size: 12px;
      min-height: 28px;
      position: relative;
      z-index: 101;
    }

    td.row-workshift .location-dropdown-menu {
      position: absolute;
      top: 100%;
      left: 0;
      right: auto;
      max-height: 250px;
      overflow-y: auto;      
      z-index: 3010;
      min-width: 180px;
      margin-top: 2px;
    }

    td.row-workshift.pending .location-dropdown-toggle,
    td.row-workshift.day-off .location-dropdown-toggle,
    td.row-workshift.off-holiday .location-dropdown-toggle,
    td.row-workshift.off-leave .location-dropdown-toggle {
      /* pointer-events: none; */
      opacity: 0.55;
    }

    /* Đảm bảo dropdown không bị ẩn */
    .table-responsive {
      overflow-x: auto;
      overflow-y: visible;
    }

    #weekTabContent .tab-pane.table-responsive {
      overflow-x: auto;
      overflow-y: visible;
    }

    td.row-workshift {
      position: relative;
      overflow: visible !important;
    }

    /* Điều chỉnh layout trong ô ca làm việc */
    td.row-workshift .d-flex {
      gap: 4px;
      flex-wrap: nowrap;
      align-items: center;
    }

    td.row-workshift .d-flex input[type="text"] {
      width: 65px;
      flex: 0 0 65px;
      padding: 4px 6px;
      font-size: 13px;
    }

    td.row-workshift .d-flex > span {
      flex: 0 0 20px;
      text-align: center;
    }

    td.row-workshift .d-flex .location-wrapper-ca-sang,
    td.row-workshift .d-flex .location-wrapper-ca-chieu {
      flex: 1 1 auto;
      min-width: 120px;
    }

    /* Tổng thể lưới & viền */
    #schedule-calendar .fc .fc-scrollgrid,
    #schedule-calendar .fc-theme-standard td,
    #schedule-calendar .fc-theme-standard th {
      border-color: #e5e7eb; /* tailwind gray-200 */
    }

    /* Chiều cao mỗi slot (áp dụng cho timeGrid) */
    #schedule-calendar .fc-timegrid-slot {
      height: 26px;               /* 15' -> bạn có thể 22–30 tuỳ ý */
    }

    /* Vạch phụ (giữa các slot) nhạt/dotted để đỡ rối */
    #schedule-calendar .fc-timegrid-slot.fc-timegrid-slot-minor {
      border-top-style: dotted;
      border-top-color: #e5e7eb;
      opacity: .6;
    }


    /* Nền ngày hiện tại (week view) cho rõ hơn */
    #schedule-calendar .fc-timegrid-col.fc-day-today .fc-timegrid-col-frame {
      background: rgba(33, 86, 172, 0.06);  /* blue-500 @ 6% */
    }

    /* Vạch 'Now' màu đỏ */
    #schedule-calendar .fc-timegrid-now-indicator-line {
      border-color: #ef4444; /* red-500 */
    }
    #schedule-calendar .fc-timegrid-now-indicator-arrow {
      border-color: transparent transparent #ef4444 transparent;
    }

    /* Sự kiện dạng pill */
    #schedule-calendar .fc-timegrid-event {
      border: 0;
      border-radius: 10px;
      box-shadow: 0 1px 3px rgba(0,0,0,.08);
      padding: 2px 6px;
      min-height: 7px;          /* các block 5' cũng nhìn rõ */
      background: #eef2ff;
      color: #3730a3;      
      line-height: 1.2;      
    }

    /* Chữ trong event: thời gian & tiêu đề */
    #schedule-calendar .fc-timegrid-event .fc-event-time,
    #schedule-calendar .fc-timegrid-event .fc-event-title {
      font-size: 12px;
      font-weight: 900;
      line-height: 1.2;
    }

    /* Ẩn “dot” nhỏ của event rất ngắn, luôn hiển thị như pill */
    #schedule-calendar .fc-timegrid-event .fc-event-main-frame::before {
      display: none !important;
    }

    /* Thanh header view week */
    #schedule-calendar .fc-col-header-cell-cushion {
      font-weight: 600;
    }
    #schedule-calendar .fc-header-toolbar {
        margin-bottom: 0px !important;
    }
    #schedule-calendar .fc-daygrid-day-frame {
        min-height: 11vh;
    }

    #schedule-legend .legend-item {
      display: inline-flex; align-items: center; gap: .5rem;
      padding: 2px 8px; border-radius: 9999px; background: #f8fafc;
      border: 1px solid #e5e7eb; font-size: .9rem;
    }
    #schedule-legend .legend-dot {
      width: 18px; height: 18px; border-radius: 50%;
      border: 2px solid #fff; box-shadow: 0 0 0 1px rgba(0,0,0,.15) inset;
    }

    .legend-square {
      display: inline-block;
      width: 14px;
      height: 14px;
      border-radius: 2px; /* hoặc 0 nếu bạn muốn góc vuông hoàn toàn */
      margin-right: 5px;
    }

    .hidden-row {
      display: none !important;
    }

    .shift-row {
      background-color: #f9f9fc; /* nhẹ, dịu mắt */
      border: 1px solid #e0e0e0; /* tạo khung rõ ràng */
      border-radius: 6px;
      padding: 0.75rem 1rem;
    }
    .shift-row:hover {
      background-color: #eef3ff;
      border-color: #b3c7ff;
    }

    .shift-row .form-control, .shift-row .form-select {
      border: 1px solid #ced4da;
      border-radius: 4px;
      padding: 6px 10px;
      font-size: 14px;
      transition: border-color .15s ease-in-out, box-shadow .15s ease-in-out;
    }

    .shift-row .form-control:focus, .shift-row .form-select:focus {
      border-color: #80bdff;
      box-shadow: 0 0 0 0.2rem rgba(0,123,255,.25);
      outline: none;
    }

    .shift-row .btn {
      padding: 4px 10px;
      font-size: 14px;
      border-radius: 4px;
      transition: background-color .15s ease-in-out, box-shadow .15s ease-in-out;
    }

    .shift-row .btn:hover {
      background-color: #0056b3;
      box-shadow: 0 4px 8px rgba(0,0,0,.1);
    } 
</style>

<script>
    let get_data_request_attend_attends_path = "<%= get_data_request_attend_attends_path %>";
    let fetch_all_attends_in_month_attends_path = "<%= fetch_all_attends_in_month_attends_path %>";
    let get_all_workshifts = "<%= workshifts_get_all_workshifts_path %>";
    let get_compensatory_leaves = "/attends/get_compensatory_leaves";
    let get_all_managers = "<%= workshifts_get_all_managers_path %>";
    let get_holidays = "<%= @CSVC_PATH + "api/v1/mapi_utils/get_holidays?organization=" + @uorg_scode %>";
    let get_user_on_leaves = "<%= @ERP_PATH + "api/v1/mapi_utils/get_employee_leave_days?id=" + @id.to_s %>";
    let get_available_dates = "<%= @ERP_PATH + "api/v1/mapi_utils/get_available_dates" %>";
    let get_campus = "<%= @CSVC_PATH + "api/v1/mapi_utils/get_all_campuses" %>";
    let get_teaching_schedules = "<%= @PMDT_PATH + "api/v1/mapi_utils/get_teaching_schedules?user_id=" + @id.to_s %>";
    let save_scheduleweeks = "<%= scheduleweeks_save_scheduleweeks_path %>";
    let get_scheduleweeks = "<%= scheduleweeks_get_scheduleweeks_path %>";
    let get_data_date_attend_attends_path = "<%= get_data_date_attend_attends_path %>";
    let avatar_url = "<%= image_url('no_avatar.jpg') %>";
</script>

<div class="attend-container">
  <div class="card">
    <div class="card-title mb-0">
      <div class="tab-content">
        <div class="mt-3">
          <div class="d-flex justify-content-between align-items-center flex-wrap mt-3">
            <div class="d-flex align-items-center ms-4">
              <h3 class="me-3 fs-2">
                <span class="far fa-calendar-alt me-2 fs-2"></span>
                <span><%= lib_translate("Lịch làm việc") %></span>
              </h3>
            </div>
            <div id="schedule-legend" class="d-flex flex-wrap align-items-center gap-2 me-4">
              <span class="legend-item"><span class="legend-dot" style="background:#000000"></span>Nghỉ hàng tuần</span>
              <span class="legend-item"><span class="legend-dot" style="background:#dc3545"></span>Nghỉ lễ</span>
              <span class="legend-item"><span class="legend-dot" style="background:#94a3b8"></span>Nghỉ phép</span>
              <span class="legend-item"><span class="legend-dot" style="background:#807579"></span>Nghỉ bù</span>
              <span class="legend-item"><span class="legend-dot" style="background:#125de7"></span>Lịch giảng dạy</span>
              <span class="legend-item"><span class="legend-dot" style="background:#fd7e14"></span>Ca làm việc đã duyệt</span>
              <span class="legend-item"><span class="legend-dot" style="background:#28a745"></span>Đã chấm công</span>
              <span class="legend-item"><span class="legend-square" style="background:#f59e0b"></span>Chưa duyệt</span>
              <span class="legend-item"><span class="legend-square" style="background:rgb(16, 185, 129)"></span>Đã duyệt</span>
            </div>
          </div>
          <div class="d-flex justify-content-between card-header pt-0">
            <div class="d-flex align-items-center">
              <div class="me-2 ms-2">
                <button class="btn btn-sm btn-falcon-default me-1" onclick="clickNextcalendar(0)"><span class="fas fa-chevron-left"></span></button>
                <button class="btn btn-sm btn-falcon-default" onclick="clickNextcalendar(1)"><span class="fas fa-chevron-right"></span></button>
              </div>
              <p class="m-0 fs-1" id="calendar-schedule-title"></p>
            </div>
            <div class="d-flex mt-2 align-items-end">
              <div class="dropdown font-sans-serif me-md-2">
                <button class="btn btn-falcon-default text-600 btn-sm dropdown-toggle dropdown-caret-none" type="button" id="email-filter" data-bs-toggle="dropdown" data-boundary="viewport" aria-haspopup="true" aria-expanded="false">
                  <span id="data-view-title">Tháng</span>
                  <span class="fas fa-sort ms-2 fs--1"></span>
                </button>
                <div class="dropdown-menu dropdown-menu-end border py-2" aria-labelledby="email-filter">
                  <a class="active dropdown-item d-flex justify-content-between cursor-pointer" data-fc-view="dayGridMonth">Tháng
                    <span class="icon-check">
                      <span class="fas fa-check" data-fa-transform="down-4 shrink-4"></span>
                    </span>
                  </a>
                  <a class="dropdown-item d-flex justify-content-between cursor-pointer" data-fc-view="timeGridWeek">Tuần
                    <span class="icon-check">
								        <span class="fas fa-check" data-fa-transform="down-4 shrink-4"></span>
							      </span>
                  </a>
                </div>
              </div>
              <div class="me-2">
                <button type="button" class="btn btn-primary btn-sm" id="register-workshift"><span class="fas fa-plus me-2 fs--1"></span>Kế hoạch</button>
              </div>
              <div class="me-1">
                <button type="button" class="btn btn-primary btn-sm" id="create-request"><span class="fas fa-plus me-2 fs--1"></span>Đề xuất</button>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
    <div class="card-body pt-0">
      <div id="schedule-calendar" style="position: relative;">
          <div id="day-tooltip" style="
          display: none;
          position: absolute;
          z-index: 999;
          background: white;
          border: 1px solid #ccc;
          border-radius: 4px;
          box-shadow: 0 2px 6px rgba(0,0,0,0.2);
          padding: 8px;
          font-size: 0.9rem;
          max-width: 300px;
        "></div>
      </div>
    </div>
  </div>
</div>
<!-- Modal Đề xuất chấm công -->
<div class="modal fade" id="requestModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border custom-modal-content">
      <div class="modal-header px-x1 bg-light border-bottom-0 custom-modal-header">
        <h5 class="modal-title">Đề xuất</h5>
        <button class="btn-close me-n1" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="<%= save_attend_request_attends_path %>" method="post" id="form_request_attend" enctype="multipart/form-data">
        <%= csrf_meta_tags %>
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <div class="modal-body p-x1">
          <div class="mt-3">
            <label class="fs-0 fw-bold" for="requestType"><%= lib_translate("Loại đề xuất") %>:</label>
            <select class="form-control" name="request_type" id="request-type">
              <option value="early-check-out">Về sớm</option>
              <option value="late-check-in">Đi trễ</option>
              <option value="shift-change">Đổi ca</option>
              <option value="work-trip">Đi công tác</option>
              <option value="additional-check-in">Chấm công vào làm bù</option>
              <option value="additional-check-out">Chấm công tan làm bù</option>
              <option value="update-shift">Cập nhật ca</option>
              <option value="edit-plan">Chỉnh sửa kế hoạch làm việc</option>
              <option value="compensatory-leave">Nghỉ bù</option>
              <!-- 
              @author: dat.nh
              @date: 17/03/2026 
              Thêm loại đề xuất tăng ca
              Phân quyền hiển thị dựa trên quyền "READ" của "OVERTIME-INDEX"
              -->
              <%if is_access(session["user_id"],"OVERTIME-INDEX","READ")%>
                <option value="overtime">Tăng ca</option>
              <%end%>
            </select>
          </div>
          <!-- === Thời gian chung cho Về sớm/Đi muộn === -->
          <div id="section-early-late" class="mt-3">
            <div div class="mt-3">
              <label class="fs-0 fw-bold" for="original-date">Ngày làm việc<span class="text-danger">*</span>:</label>
              <input class="form-control bg-light date-choose" id="original-date" type="text" name="original_date" />
            </div>  
            <div class="row">
              <div class="col-6">
                <label class="fs-0 fw-bold" for="shiftSelectChangecheck">Ca làm việc<span class="text-danger">*</span>:</label>
                <select name="workshift_id" class="form-control" id="shiftSelectChangecheck"></select>
              </div>
              <div class="col-6">
                <label class="fs-0 fw-bold" for="requestTime">Thời gian<span class="text-danger">*</span>:</label>
                <input class="form-control time-picker" id="request-time" type="time" name="time" />
              </div>
            </div>
          </div>
          
          <!-- === Đổi Ca === -->
        <div id="section-shift-change" class="mt-3 d-none">

            <%# Row 1: Ngày làm việc và ngày đăng ký đổi ca%>
            <div class="row mt-3">
              <div class="col-6">
                <label class="fs-0 fw-bold">Ngày làm việc<span class="text-danger">*</span>:</label>
                <input class="form-control bg-light t date-choose" id="original-date" type="text" name="original_date" placeholder="Ngày bạn muốn đổi" />
              </div>
              <div class="col-6">
                <label class="fs-0 fw-bold">Ngày đăng ký đổi ca<span class="text-danger">*</span>:</label>
                <input class="form-control bg-light t date-choose" id="request-date-new" type="text" name="target_date" placeholder="Ngày bạn muốn nhận" />
              </div>
            </div>

            <%# Row 2: Muốn đổi ca + Thành ca %>
            <div class="row mt-3">
              <div class="col-6">
                <label class="fs-0 fw-bold">Muốn đổi ca<span class="text-danger">*</span>:</label>
                <select name="my_workshift_id" class="form-control" id="my-workshift-select">
                  <option value="" disabled selected>— Chọn ngày trước —</option>
                </select>
                <small class="text-muted">Ca bạn đang có và muốn đổi</small>
              </div>
              <div class="col-6">
                <label class="fs-0 fw-bold">Thành ca<span class="text-danger">*</span>:</label>
                <select name="target_workshift_id" class="form-control" id="target-workshift-select">
                  <option value="" disabled selected>— Chọn ca muốn nhận —</option>
                </select>
                <small class="text-muted">Ca bạn muốn nhận</small>
              </div>
            </div>

            <%# Row 3: Preview tóm tắt %>
            <div id="shift-change-preview" class="mt-2 d-none">
              <div class="alert alert-info py-2 mb-0" style="font-size:13px;">
                <i class="fas fa-exchange-alt me-1"></i>
                <span id="shift-change-preview-text"></span>
              </div>
            </div>

            <%# Row 4: Đổi với %>
            <div class="mt-3">
              <label class="fs-0 fw-bold" for="swap-with-user-id">Đổi với<span class="text-danger">*</span>:</label>
              <select name="swap_with_user_id" class="form-control" id="swap-with-user-id" required>
                <option value="" selected disabled hidden>— Chọn người —</option>
              </select>
              <small class="text-muted" id="swap-candidate-hint"></small>
            </div>

          </div>

          <!-- === Đi công tác === -->
            <!-- Row 1: Ngày làm việc -->
          <div id="section-work-trip" class="mt-3 d-none">
            <div class="row">
              <div class="col-12">
                <label class="fs-0 fw-bold" for="business_trip_range">Ngày đi công tác <span class="text-danger">*</span>:</label>

                <!-- Thêm checkbox tại đây -->
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <!-- Checkbox: chọn khoảng liên tiếp -->
                  <div class="form-check mb-0">
                    <input class="form-check-input" type="checkbox" id="range_mode_toggle" checked>
                    <label class="form-check-label" for="range_mode_toggle">
                      Chọn khoảng thời gian liên tiếp
                    </label>
                  </div>

                  <!-- Nút xóa -->
                  <button type="button" id="clear_business_trip" class="btn btn-sm btn-outline-secondary" style="background-color: #518ddd; color: white;">
                    Xóa ngày chọn trên lịch
                  </button>
                </div>

                <input class="form-control bg-light t date-choose"
                      id="business_trip_range"
                      type="text"
                      name="business_trip_range" />

                <input type="hidden" id="trip_start" name="trip_start">
                <input type="hidden" id="trip_end" name="trip_end">
                <input type="hidden" id="trip_dates_filtered" name="trip_dates_filtered">
                <input type="hidden" id="trip_shift_data" name="trip_shift_data" value="[]">

                <div id="excluded-dates-container" class="mt-2"></div>
                
                <div id="business-trip-wrapper" class="p-2 rounded border bg-light-subtle d-none">
                  <!-- Hiển thị lựa chọn ca làm việc -->
                  <div id="business-trip-shift-container" class="mt-3" style="max-height: 320px; overflow-y: auto;"></div>

                  <!-- Tổng vùng điều khiển bên dưới lịch -->
                  <!-- Vùng footer điều khiển: phân trang + tổng số ngày -->
                  <div id="trip-footer-controls" class="d-flex align-items-center gap-3 mt-2 flex-wrap d-none">
                    <!-- Chọn số dòng hiển thị -->
                    <div class="d-flex align-items-center gap-2">
                      <select id="rowsPerPage" class="form-select form-select-sm w-auto">
                        <option value="5" selected>5</option>
                        <option value="10">10</option>
                        <option value="20">20</option>
                      </select>
                    </div>

                    <!-- Pagination kiểu << 1 / 3 >> -->
                    <div id="pagination-controls" class="d-flex align-items-center gap-2">
                      <button type="button" id="prev-page" class="btn btn-sm btn-outline-primary px-2">&laquo;</button>
                      <span><span id="current-page">1</span>/<span id="total-pages">1</span></span>
                      <button type="button" id="next-page" class="btn btn-sm btn-outline-primary px-2">&raquo;</button>
                    </div>

                    <!-- Tổng số ngày -->
                    <div class="d-flex align-items-center gap-2">
                      <label class="mb-0 fw-bold">Tổng ngày:</label>
                      <input type="text" id="total_days_selected" class="form-control form-control-sm" style="width: 50px;" readonly value="0">
                    </div>
                  </div>
                </div>

              </div>
            </div>
          </div>

          <!-- === Chỉnh sửa kế hoạch làm việc === -->
          <!-- @author: trong.lq -->
          <!-- @date: 22/10/2025 -->
          <div id="section-edit-plan" class="mt-3 d-none">
            <div class="row">
              <div class="col-12">
                <label class="fs-0 fw-bold" for="plan-week-select">Tuần chỉnh sửa<span class="text-danger">*</span>:</label>
                <select class="form-control" id="plan-week-select" name="plan_week_num" required>
                  <option value="">-- Chọn tuần --</option>
                </select>
              </div>
            </div>
          </div>

          <!-- === Chấm công bù === -->
          <div id="section-additional-check" class="mt-3 d-none">
            <!-- Row 1: Ngày làm việc -->
            <div class="row">
              <div class="col-12">
                <label class="fs-0 fw-bold" for="original-date">Ngày làm việc<span class="text-danger">*</span>:</label>
                <input class="form-control bg-light t date-choose"
                      id="original-date"
                      type="text"
                      name="original_date"
                       />
              </div>
            </div>

            <!-- Row 2: Ca làm việc + Giờ (vào/ra) -->
            <div class="row mt-3 align-items-end">
              <div class="col-6">
                <label class="fs-0 fw-bold" for="shiftSelectAdditional">Ca làm việc<span class="text-danger">*</span>:</label>
                <select name="workshift_id" class="form-control" id="shiftSelectAdditional"></select>
              </div>
              <div class="col-6">
                <label class="fs-0 fw-bold" required id="label-additional-time">Giờ vào<span class="text-danger">*</span>:</label>
                <!-- Dùng 1 input giờ duy nhất, đổi name theo type -->
                <input class="form-control time-picker"
                      id="additional-time"
                      type="time"
                      name="check_in_time" />
              </div>
            </div>
          </div>

          <!-- === Cập nhật ca === -->
          <div id="section-update-shift" class="mt-3 d-none">
            <div class="row">
              <div class="col-6">
                <label class="fs-0 fw-bold" for="original-date">Ngày làm việc<span class="text-danger">*</span>:</label>
                <input class="form-control bg-light t date-choose" id="original-date" type="text" name="original_date"  />
              </div>
              <div class="col-6">
                <label class="fs-0 fw-bold" for="shiftSelectUpdate">Ca làm việc<span class="text-danger">*</span>:</label>
                <select name="workshift_id" class="form-control" id="shiftSelectUpdate"></select>
              </div>
            </div>
            <div class="shift-morning">
              <label class="fs-0 mb-1 fw-bold">Ca sáng:</label>
              <div class="row">
                <div class="col-6">
                  <label class="fs--1 fw-bold" for="morning-check-in">Giờ vào<span class="text-danger">*</span>:</label>
                  <input class="form-control time-picker-update-shift" required id="morning-check-in" type="time" name="morning_check_in" readonly />
                </div>
                <div class="col-6">
                  <label class="fs--1 fw-bold" for="morning-check-out">Giờ ra<span class="text-danger">*</span>:</label>
                  <input class="form-control time-picker-update-shift" required id="morning-check-out" type="time" name="morning_check_out" readonly />
                </div>
              </div>
            </div>
            <div class="shift-afternoon">
              <label class="fs-0 mt-3 mb-1 fw-bold">Ca chiều:</label>
              <div class="row">
                <div class="col-6">
                  <label class="fs--1 fw-bold" for="afternoon-check-in">Giờ vào:</label>
                  <input class="form-control time-picker-update-shift" required id="afternoon-check-in" type="time" name="afternoon_check_in" readonly />
                </div>
                <div class="col-6">
                  <label class="fs--1 fw-bold" for="afternoon-check-out">Giờ ra:</label>
                  <input class="form-control time-picker-update-shift" required id="afternoon-check-out" type="time" name="afternoon_check_out" readonly />
                </div>
              </div>
            </div>
          </div>

          <!-- === Đăng ký nghỉ bù === -->
          <!--@author: an.cdb
              @date: 09/03/2026-->
          <div id="section-compensatory-leave" class="mt-3 d-none">
            <div class="alert alert-info">
              <i class="fas fa-info-circle"></i> 
              Vui lòng cung cấp minh chứng hình ảnh 
            </div>
            
            <div class="row mt-3">
              
                <div class="col-6">
                  <label class="fs-0 fw-bold" for="leave-date">Ngày nghỉ bù<span class="text-danger">*</span>:</label>
                  <input class="form-control date-choose" required id="leave-date" type="text" name="leave_date" />
                </div>
                <div class="col-6">
                  <label class="fs-0 fw-bold" for="comp-original-date">Ngày làm vượt giờ<span class="text-danger">*</span>:</label>
                  <input class="form-control bg-light date-choose" required id="comp-original-date" type="text" name="original_date" readonly />
                </div>

              <div class="col-12">
                 <label class="fs-0 fw-bold" for="leave-workshift">Ca nghỉ bù<span class="text-danger">*</span>:</label>
                <select class="form-control" required id="leave-workshift" name="leave_workshift_id"></select>
              </div>
            </div>


          </div>

          <!-- @author: dat.nh
               @date: 17/03/2026 
               Thêm loại đề xuất tăng ca -->
          <!-- === Tăng ca === -->
          <div id="section-overtime" class="mt-3 d-none">
            <div class="row">
              <div class="col-6">
                <label class="fs-0 fw-bold" for="original-date">Ngày tăng ca<span class="text-danger">*</span>:</label>
                <input class="form-control bg-light t date-choose" id="original-date" type="text" name="original_date"  />
              </div>
              <div class="col-6">
                <label class="fs-0 fw-bold" for="shiftSelectOvertime">Ca làm việc<span class="text-danger">*</span>:</label>
                <select name="workshift_id" class="form-control" id="shiftSelectOvertime"></select>
              </div>
            </div>
            <div class="morning-overtime">
              <label class="fs-0 mb-1 fw-bold">Ca sáng:</label>
              <div class="row">
                <div class="col-6">
                  <label class="fs--1 fw-bold" for="morning-overtime-check-in">Giờ vào<span class="text-danger">*</span>:</label>
                  <input class="form-control time-picker-update-shift" required id="morning-overtime-check-in" type="time" name="morning_overtime_check_in" readonly />
                </div>
                <div class="col-6">
                  <label class="fs--1 fw-bold" for="morning-overtime-check-out">Giờ ra<span class="text-danger">*</span>:</label>
                  <input class="form-control time-picker-update-shift" required id="morning-overtime-check-out" type="time" name="morning_overtime_check_out" readonly />
                </div>
              </div>
            </div>
            <div class="afternoon-overtime">
              <label class="fs-0 mt-3 mb-1 fw-bold">Ca chiều:</label>
              <div class="row">
                <div class="col-6">
                  <label class="fs--1 fw-bold" for="afternoon-overtime-check-in">Giờ vào:</label>
                  <input class="form-control time-picker-update-shift" required id="afternoon-overtime-check-in" type="time" name="afternoon_overtime_check_in" readonly />
                </div>
                <div class="col-6">
                  <label class="fs--1 fw-bold" for="afternoon-overtime-check-out">Giờ ra:</label>
                  <input class="form-control time-picker-update-shift" required id="afternoon-overtime-check-out" type="time" name="afternoon_overtime_check_out" readonly />
                </div>
              </div>
            </div>
          </div>

          <div class="mt-3">
            <label class="fs-0 fw-bold" for="requestApprovedBy"><%= lib_translate("Trưởng/phó phòng phê duyệt") %>:</label>
            <select name="approved_id" class="form-control" id="approverSelect" required></select>
            <input type="hidden" name="week_num" id="week_num" />
            <input type="hidden" name="shiftselection_id" id="shiftselection-id" />
          </div>
          <div class="mt-3">
            <label class="fs-0 fw-bold" for="requestReason"><%= lib_translate("Lý do") %><span class="text-danger">*</span>:</label>
            <textarea class="form-control" rows="3" name="reason"></textarea>
          </div>
          <div class="mt-3" id="upload-evidence">
            <label class="fs-0 fw-bold" for="image-evidence-edit"><%= lib_translate("Hình ảnh minh chứng") %>:</label>
            <div onclick="clickSelectEvidence()" class="evidence-container mt-3 pt-2">
              <div class="evidence-preview" id="evidence-preview"></div>
              <div><i class="fas fa-plus" style="margin-right:5px"></i><%= lib_translate("Update_avatar_select_hint")%></div>
            </div>
            <label id="valid-message" class="mt-2" style="color: var(--falcon-badges-soft-danger-color);"></label>
            <input name="image" id="image-evidence-edit" type="file" accept="image/*" onchange="onSelectEvidence(this)" hidden>
          </div>
        </div>
        <div class="modal-footer d-flex justify-content-end align-items-center bg-light border-0">
          <button class="btn btn-secondary" type="button" data-bs-dismiss="modal"><%= lib_translate("Đóng") %></button>
          <button class="btn btn-primary px-4" type="submit" id="saveRequest"><%= lib_translate("Gửi yêu cầu") %></button>
        </div>
      </form>
    </div>
  </div>
</div>
<!-- End modal gửi yêu cầu chấm công -->
<!-- Modal xem chi tiết yêu cầu chấm công đã gửi -->
