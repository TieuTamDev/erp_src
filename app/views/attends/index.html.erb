<% content_for :head do %>
  <%= stylesheet_link_tag '/assets/mystyle/fullcalendar_main.min.css' %>
  <%= javascript_include_tag '/assets/myjs/fullcalendar_main.min.js' %>
  <%= stylesheet_link_tag '/assets/mystyle/flatpickr.min.css' %>
