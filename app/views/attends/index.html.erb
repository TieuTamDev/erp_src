        justify-content: center;
        color: white;
    }

    .fc-daygrid-day-frame {
      position: relative; /* Bắt buộc để .shift-indicator dùng absolute */
    }

    select.form-control {
      appearance: auto !important; /* hiện mũi tên mặc định */
      -webkit-appearance: auto !important;
      -moz-appearance: auto !important;
      background-color: #fff;
