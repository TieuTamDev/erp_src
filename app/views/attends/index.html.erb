</div>
<!-- End modal xem chi tiết yêu cầu chấm công đã gửi -->
<!-- Modal đăng ký lịch làm viêc -->
<div class="modal fade" id="workshiftModal" tabindex="-1">
  <div class="modal-dialog modal-xl custom-modal-width">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Kế hoạch làm việc cá nhân – <span id="calendarTitle"></span></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
        <div class="modal-body d-flex gap-3 align-items-stretch" id="workshiftContent">
          <div id="calendar" class="flex-grow-1 col-4" ></div>
          <div class="flex-grow-1 col-8">
            <div class="d-flex align-items-center mb-2">
              <ul class="nav nav-tabs mb-auto me-2" id="weekTabs" role="tablist"></ul>
              <button id="btnAddWeek" type="button" class="btn btn-primary btn-sm me-2" title="Thêm tuần"><span class="fas fa-plus fs--1"></span></button>
            </div>
            <div id="reasonBox" class="alert alert-secondary mt-1 mb-2 me-2 d-none" role="alert"></div>
            <div id="templateShiftContainer" class="border rounded p-3 mb-3 me-2 d-none"></div>
            <div id="alertBox" class="alert alert-danger me-2 d-none" role="alert"></div>
            <div class="tab-content border rounded me-2" id="weekTabContent"></div>
            <div class="mt-4 me-2">
              <label class="fs-0" for="approvedBy"><%= lib_translate("Người phê duyệt") %>:</label>
              <select name="approved_id" class="form-control" id="approverWorkshift" required></select>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" id="save-draft">Lưu nháp</button>
          <button class="btn btn-primary px-4" type="button" id="save-selections"><%= lib_translate("Gửi") %></button>
        </div>
    </div>
  </div>
</div>
<!-- End modal đăng ký lịch làm việc -->
<!-- Modal hiển thị ca làm việc -->
<div class="modal fade" id="shiftModal" tabindex="-1" aria-labelledby="shiftModalLabel" aria-hidden="true" style="max-width: 500px; height: 90vh;">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="shiftModalLabel">Thông tin ca làm việc</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
      </div>
      <div class="modal-body" id="shiftModalBody">
        <!-- Nội dung sẽ được inject vào đây -->
      </div>
    </div>
  </div>
</div>


<!-- Modal hiển thị chi tiết đề xuất -->
<div class="modal fade" id="proposalModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-md">
    <div class="modal-content custom-modal-content">
      <div class="modal-header" style="background-color:#e8f0fe">
        <h5 class="modal-title" id="proposalTitle" ></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" id="proposalModalBody">
        <!-- Nội dung sẽ được render -->
      </div>
    </div>
  </div>
</div>


<!-- Toast container ở góc trên bên phải -->
<div id="toastContainer" class="toast-container position-fixed top-0 end-0 p-3" style="z-index:1080">
  <% if flash[:success].present? %>
    <div class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
      <div class="d-flex">
        <div class="toast-body"><%= flash[:success] %></div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
      </div>
    </div>
  <% end %>

  <% if flash[:notice].present? %>
    <div class="toast align-items-center text-bg-primary border-0" role="alert" aria-live="assertive" aria-atomic="true">
      <div class="d-flex">
        <div class="toast-body"><%= flash[:notice] %></div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
      </div>
    </div>
  <% end %>

  <% if flash[:alert].present? %>
    <div class="toast align-items-center text-bg-warning border-0" role="alert" aria-live="assertive" aria-atomic="true">
      <div class="d-flex">
        <div class="toast-body"><%= flash[:alert] %></div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
      </div>
    </div>
  <% end %>

  <% if flash[:error].present? %>
    <div class="toast align-items-center text-bg-danger border-0" role="alert" aria-live="assertive" aria-atomic="true">
      <div class="d-flex">
        <div class="toast-body"><%= flash[:error] %></div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
      </div>
    </div>
  <% end %>
</div>


<!-- Modal lỗi (nếu có flash[:error] hoặc flash[:alert]) -->
<div class="modal fade" id="errorModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Thông báo</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body"><%= flash[:error] || flash[:alert] %></div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
      </div>
    </div>
  </div>
</div>

