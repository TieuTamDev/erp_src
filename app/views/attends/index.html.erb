      color: white !important
    }

        /* Style cho proposalTitle */
    #proposalTitle {
      font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif; /* Font rõ ràng, hiện đại */
      font-size: 18px;             /* Kích thước tiêu đề */
      font-weight: 700;            /* Chữ đậm */
