    }

    /* Style cho tiêu đề "Đề xuất" */
    #requestModal .modal-header .modal-title {
      font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif; /* Font hiện đại, dễ đọc */
      font-size: 20px;             /* Kích thước chữ */
      font-weight: 700;            /* Chữ đậm */
      letter-spacing: .2px;       /* Giãn chữ nhẹ */
