                <div class="row g-0 mb-2" style=" justify-content: space-between; align-items: center; " >
                  <div class="col-auto col-sm-5 mb-1">
                  <h4><%= lib_translate("List_of_personnel") %></h4> 
                  </div>
                  <button onclick="" class="btn btn-primary btn-add-work mt-3" id="btn-add-work" data-bs-toggle="modal" data-bs-target="#modal-modal-work">
              <%= lib_translate("Add_work_primary")  %>
            </button>
            <!-- modal -->
            <div class="modal fade" id="modal-modal-work" tabindex="-1" role="dialog" aria-hidden="true" data-bs-focus="false">
