<%# Hai - appoint  %>
<% content_for :head do %>
  <%= stylesheet_link_tag "select2-bootstrap-5-theme.min" %>
  <%= stylesheet_link_tag "select2.min" %>
<% end %>

<% content_for :bottombody do %>
  <%= javascript_include_tag 'select2.full.min'%>
  <%= javascript_include_tag 'select2.min.js'%>

<% end %>
<style>
    .dataTables_wrapper {
      margin-top: 0 !important;
    }
</style>
<div class="mb-2 mt-1 d-flex justify-content-between align-items-center flex-wrap gap-2" >
  <!-- Bên trái: Các nút -->
  <div class="d-flex gap-2 ms-1">
    <button type="button" class="btn btn-outline-success d-none" data-bs-toggle="modal" data-bs-target="#importModal">
      📥 Import Excel
    </button>
  </div>
</div>
<div class="modal fade" id="importModal" tabindex="-1" aria-labelledby="importModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="importModalLabel">📁 Import Nhân sự</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <%= form_tag import_excel_appoints_path, method: :post, id: 'import-form', multipart: true, authenticity_token: true,class: "d-flex flex-column gap-3" do %>
          <%= file_field_tag :file, class: "form-control", accept: ".xlsx", required: true %>
          <%= submit_tag '📥 Xác nhận Import', class: 'btn btn-success' %>
        <% end %>
        <div id="import-result" class="mt-3"></div>
      </div>
    </div>
  </div>
</div>
<div id="alert-appoint" style="display: none;">
  <div class="alert alert-success border-2 d-flex align-items-center" role="alert" style="position: absolute; z-index: 20; top: 10; right: 0; top: 100px;">
    <div class="bg-success me-3 icon-item"><span class="fas fa-check-circle text-white fs-3"></span></div>
    <p class="mb-0 flex-1"><%= lib_translate("Delete_successfully")  %></p>
    <button class="btn-close" type="button" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
</div>
<div class="row ms-1" >
      <div class="card theme-wizard mb-5">
        <div class="card-header bg-light pt-3 pb-2 pt-3 mt-3">
          <ul class="nav justify-content-between nav-wizard" id="step-wrap">
            <li  class="nav-item"><a id="tabs_1" class="nav-link active fw-semi-bold" ><span class="nav-item-circle-parent"><span class="nav-item-circle"><span class="fas fa-user"></span></span></span><span class="d-none d-md-block mt-1 fs--1"><%= lib_translate("List_of_personnel")  %></span></a></li>
            <li  class="nav-item"><a id="tabs_2" class="nav-link fw-semi-bold" ><span class="nav-item-circle-parent"><span class="nav-item-circle"><span class="fas fa-user-cog"></span></span></span><span class="d-none d-md-block mt-1 fs--1"><%= lib_translate("appoint")  %></span></a></li>
            <li  class="nav-item"><a id="tabs_3" class="nav-link fw-semi-bold" ><span class="nav-item-circle-parent"><span class="nav-item-circle"><span class="fas fa-user-check"></span></span></span><span class="d-none d-md-block mt-1 fs--1"><%= lib_translate("resultAppoint")  %></span></a></li>
          </ul>
        </div>
        <div class="card-body py-4">
          <div class="tab-content" id="tab-wrap"> 
            

            <%# Danh sách nhân sự %>
            <div class="tab-pane active px-sm-3 px-md-5" role="tabpanel" aria-labelledby="bootstrap-wizard-tab1" id="bootstrap-wizard-tab1">
