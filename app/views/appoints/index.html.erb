                            </div>
                            <div class="row mb-3"> 
                              <label class="col-sm-4 col-lg-3 col-form-label"><%= lib_translate("Name_work") %>:</label>
                              <div class="col-sm-8 col-lg-9">
                                <select class="form-select selectpicker" name="positionjob_id_work" id="positionjob_id_work">
                                    <% 
                                      Positionjob.all.each do |positionjob| 
                                      nameDepart = Department.where(id: positionjob.department_id).first
                                      if !nameDepart.nil?
                                        nameDepartment = " (" + nameDepart.name + ")"
                                      else
                                        nameDepartment = ""
