<div style="width: 100%;">
	<%= @data[:content].html_safe %>
    <div>
		<h3 style='margin-bottom:5px;margin-top:80px;font-family: "Google Sans",Roboto,RobotoDraft,Helvetica,Arial,sans-serif;font-size: .875rem;'><%= @data[:count] > 0 ? "#{@data[:count]} tệp đính kèm:" : "" %></h3>
		<ul style="display: flex; flex-direction: column; padding-left: 0; margin-bottom: 0;">
            <% @data[:file_urls].each do |item| %>
                <li style="display:flex!important;display:block;padding: 0.5rem 0.8rem 0.1rem 0.5rem;color:#4d5969;background-color:#fff;margin:0;margin-bottom:5px;border:1px solid #d8e2ef;border-radius:0.5rem;margin-right: 5px;">
                    <div style="width: 41px;text-align:center">
                        <img src="<%= item[:icon_path] %>" style="width: 41px;text-align:center">
                    </div>
                    <div style="width: 100%;">
                        <% if ['excel', 'word', 'powerpoint'].include?(item[:file_type]) %>
							<a href="https://view.officeapps.live.com/op/view.aspx?src=<%= item[:path] %>&wdOrigin=BROWSELINK" target="_blank" style="font-weight: bold; white-space: normal;"><%= item[:name] %></a>
						<% else %>
							<a href="<%= item[:path] %>" style="font-weight: bold; white-space: normal;"><%= item[:name] %></a>
						<% end %>
                        <h5 style="margin: 0;opacity: 0.8;margin-top: 5px;"><%= item[:file_size] %></h5>
                    </div>
                </li>
            <% end %>
		</ul>
	</div>
</div>