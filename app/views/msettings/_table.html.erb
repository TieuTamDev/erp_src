<table class="table table-striped align-middle" id="table-settings">
    <thead class="bg-200">
        <tr>
            <th>Loại cấu hình</th>
            <th>Tên</th>
            <th>Mã</th>
            <th>Giá trị</th>
            <th>Ngày bắt đầu</th>
            <th>Ngày kết thúc</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    </tbody>
</table>
<script>
    $(document).ready(function () {
        let table_settings = $('#table-settings').DataTable({...optionTable,...{
            searching: true,
            pageLength: 5,
            lengthMenu: [ [5, 10, 20, 50], [5, 10, 20, 50] ],   
            lengthChange: true,
            paging: true,
            stateSave: false,        
            info: true,
            deferRender: true,
            ordering: false,
            processing: true,
            serverSide: true,
            language: {
                lengthMenu: "_MENU_",
                emptyTable: "Không có dữ liệu",
                paginate: {
                    previous: "Trước",
                    next: "Sau"
                },
                search: "Tìm kiếm:",
                info: "", // ẩn info mặc định
                infoEmpty: ""
            },
            "ajax": {
                "url": ERP_PATH + "msettings/get_settings", 
                "type": "GET",
                "data": function(d) {
                    d.page = d.start / d.length + 1;
                    d.per_page = d.length; 
                    d.search = $('input[type="search"]').val();
                }
            },
            // render input data
            columns: [
                { data: "stype"},
                { data: "name"},
                { data: "scode"},
                { data: "svalue"},
                { data: "valid_from" },
                { data: "valid_to" },
                { data: "button" },
            ],
        }});
    });
</script>