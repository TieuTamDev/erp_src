		$(document)
			// Auto generate scode khi nhập name (nếu scode đang trống hoặc bám theo name)
			.on('input', '#msetting_name', function() {
				var name = $(this).val();
				var $scode = $('#msetting_scode');
				// nếu user chưa tự sửa scode (giống prefix từ trước), cứ cập nhật theo name
				if (!$scode.data('touched')) {
					$scode.val(toKebabUpper(name));
				}
			})
			.on('input', '#msetting_scode', function() {
				// đánh dấu user đã can thiệp scode, không auto-override nữa
				$(this).data('touched', true);
				// chuẩn hoá ngay khi gõ
				var v = $(this).val();
				$(this).val(toKebabUpper(v));
			})
		;
	})();

</script>