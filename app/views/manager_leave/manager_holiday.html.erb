                          <button class="btn btn-sm btn-outline-primary detail-btn" data-bs-toggle="modal" data-bs-target="#holidayDetailsModal" data-uorg-scode="BMU" data-holpro-id="<%= holpro['holpro_id'] %>"  data-holpro-status="<%= holpro['holiday_status'] %>">
                            Chi tiết
                          </button>
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>

