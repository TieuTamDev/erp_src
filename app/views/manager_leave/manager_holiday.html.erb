<%# Xuất báo cáo theo ngày%>
  <div class="modal" id="export_data_excel_date" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="holidayDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog" style="max-width: 13%;">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Xuất TH nghỉ theo ngày</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <%= form_tag setting_holidays_export_data_holiday_date_path, id: "export_data_holiday_date_form", method: :get, authenticity_token: true do %>
            <input type="hidden" id="stype_uorg_id" name="stype_uorg">
            <div class="row mt-2 d-flex flex-direction-row">
              <div class="col-md-12">
                <div class="d-flex align-items-end" style="flex-wrap: wrap;">
                  <div class="me-1">
                    <label style="margin-bottom: 0px !important;"><%= lib_translate("Ngày") %></label>
                    <input class="form-control datetimepicker" id="date_export_select" name="date_export" type="text" data-options='{"disableMobile":true}' />
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
          <button type="button" class="btn btn-primary" onclick="submitExportExcelDate()">Xác nhận</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    function exportExcelDate(uorg_code) {
      const today = new Date().toISOString().slice(0, 10); // yyyy-mm-dd
      const formattedToday = today.split('-').reverse().join('/'); // dd/mm/yyyy

      // Set ngày hiện tại vào ô input
      $('#export_data_holiday_date_form #date_export_select').val(formattedToday);

      // Set uorg_code
      $('#export_data_holiday_date_form #stype_uorg_id').val(uorg_code);

      // Hiện modal
      $('#export_data_excel_date').modal('show');
    }

    function submitExportExcelDate() {
      $('#export_data_holiday_date_form').submit();   
      $('#export_data_excel_date').modal('hide');

      // Reset lại ngày sau submit (đề phòng mở lại form)
      const today = new Date().toISOString().slice(0, 10);
      const formattedToday = today.split('-').reverse().join('/');
      $('#export_data_holiday_date_form #date_export_select').val(formattedToday);
    }
  </script>
<%# END Xuất báo cáo theo ngày%>

<%# Xuất báo cáo theo nhân sự TODO %>
  <div class="modal" id="export_data_excel_user" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="holidayDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog" style="max-width: 23%;">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Xuất tổng hợp nghỉ theo nhân sự</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <%= form_tag setting_holidays_export_data_holiday_user_path, id: "export_data_holiday_user_form", method: :get, authenticity_token: true do %>
            <input type="hidden" id="stype_uorg_id" name="stype_uorg">
            <div class="row mt-2 d-flex flex-direction-row">
              <div class="col-md-5">
                <div class="d-flex align-items-end" style="flex-wrap: wrap;">
                  <div class="me-1">
                    <label style="margin-bottom: 0px !important;"><%= lib_translate("Năm") %></label>
                    <select class="select-form selectpicker" name="year_user_export" id="year_user_export_select">
                      <% current_year = Date.today.year %>
                      <% year_range = (current_year - 2..current_year + 2).to_a %>
                      <%= options_for_select(year_range.map { |y| [y, y] }, selected: current_year) %>
                    </select>
                  </div>
                </div>
              </div>
              <div class="col-md-7">
                <div class="d-flex align-items-end" style="flex-wrap: wrap;">
                  <div class="me-1">
                    <label style="margin-bottom: 0px !important;"><%= lib_translate("Mã nhân sự") %></label>
                    <input class="form-control" id="user_sid_export_input" name="user_sid_export" type="text" />
                    <small id="sid_error_message" class="text-danger" style="display: none;">Vui lòng nhập mã nhân sự.</small>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
          <button type="button" class="btn btn-primary" onclick="submitExportExcelUser()">Xác nhận</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    function exportExcelUser(uorg_code) {
      $('#export_data_holiday_user_form #stype_uorg_id').val(uorg_code);
      $('#export_data_excel_user').modal('show');
    }

    function submitExportExcelUser() {
      const userInput = $('#export_data_holiday_user_form #user_sid_export_input');
      const sid = userInput.val().trim();

      // Xóa class lỗi cũ (nếu có)
      userInput.removeClass('is-invalid');

      // Nếu không nhập mã nhân sự thì cảnh báo
      if (!sid) {
        userInput.addClass('is-invalid');
        $('#sid_error_message').show();
        return;
      } else {
        $('#sid_error_message').hide();
      }

      // Nếu hợp lệ thì submit form
      $('#export_data_holiday_user_form').submit();

      // Reset ô nhập mã sau khi submit
      userInput.val('');
      $('#export_data_excel_user').modal('hide');
    }
  </script>
<%# END Xuất báo cáo theo nhân sự%>

<%# Xuất báo cáo theo địa điểm nước ngoài%>
