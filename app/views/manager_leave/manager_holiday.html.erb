                              <%= link_to i.to_s, manager_leave_manager_holiday_path(page: i, per_page: @per_page, lang: session[:lang], search: params[:search], uorg_scode: @uorg_scode, department_bmu: params[:department_bmu], country_bmu: params[:country_bmu], holtype_bmu: params[:holtype_bmu]), class: "page-link" %>
                            </li>
                          <% end %>
