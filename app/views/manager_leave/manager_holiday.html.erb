<script>
  $(document).ready(function () {
    flatpickr(".datetimepicker", {
      dateFormat: "d/m/Y", // Định dạng ngày hiển thị
      disableMobile: true  // Không dùng native picker trên mobile
    });
    // Hàm định dạng ngày thành dd/MM/yyyy
    function formatDate(date) {
      const d = new Date(date);
      const day = String(d.getDate()).padStart(2, '0');
      const month = String(d.getMonth() + 1).padStart(2, '0');
      const year = d.getFullYear();
      return `${day}/${month}/${year}`;
    }

    // Hàm định dạng giờ thành HH:mm
    function formatTime(date) {
      const d = new Date(date);
      const hours = String(d.getHours()).padStart(2, '0');
      const minutes = String(d.getMinutes()).padStart(2, '0');
      return `${hours}:${minutes}`;
    }

    // Chọn tất cả các nút "Chi tiết"
    $('.detail-btn').on('click', function () {

      const holproId = $(this).data('holpro-id');
      const holproStatus = $(this).data('holpro-status');
      const uorgScode = $(this).data('uorg-scode');

      $('#holidayDetailsModal #holpro_id_form_detail').val(holproId);
      $('#holidayDetailsModal #uorg_scode_form_detail').val(uorgScode);

      $('#generated_leave_request_form #holpro_id_form').val(holproId);
      $('#generated_leave_request_form #uorg_scode_form').val(uorgScode);

      if (["DONE", "CANCEL-DONE"].includes(holproStatus) && uorgScode == "BUH"){
        $('#print_holpros').removeClass("d-none");
      }else {
        $('#print_holpros').addClass("d-none");
      }

      // Dữ liệu từ controller, sử dụng .to_json với escape_html
      const results = <%= @results.to_json.html_safe %>;
      const mandocDetails = <%= @mandoc_details.to_json.html_safe %>;
      const mandocDetailsCancel = <%= @mandoc_details_cancel.to_json.html_safe %>;
      const holprosdetailsData = <%= @holprosdetails_data.to_json.html_safe %>;
      const holtypesMap = <%= @holtypes_map.to_json.html_safe %>;
      const holproHandoverNames = <%= @holpro_handover_names.to_json.html_safe %>;
      const holproTypes = <%= @holpro_types.to_json.html_safe %>;
      const holproLocations = <%= @holpro_locations.to_json.html_safe %>;

      const holpro = results.find(r => r.holpro_id === parseInt(holproId));

      if (holpro) {
        
        // Hiển thị thông tin nhân sự
        $('#modal-user-fullname').text(holpro.user_fullname || "Không xác định");
        $('#modal-user-sid').text(holpro.user_sid || "Không xác định");
        $('#modal-positionjob-name').text(holpro.positionjob_name || "Không xác định");
        $('#modal-dttotal').text((holpro.holiday_total_days || "Không xác định") + " ngày");
        $('#modal-department-name').text(holpro.department_name || "Không xác định");

        const infoSection = $(".info-section");
        // Xóa trước nếu đã có (tránh thêm trùng)
        infoSection.find(".status-row, .reason-row").remove();
        if (holpro.holiday_status === "REFUSE") {
          const statusRow = `<p class="info-label status-row">Trạng thái đơn: <span class="fw-bold text-danger">Từ chối</span></p>`;
          const reasonRow = `<p class="info-label reason-row">Lý do: <span class="fw-bold">${holpro.note || "Không có"}</span></p>`;
          // Thêm vào ngay sau dòng "Vị trí công việc"
          infoSection.find("#modal-dttotal").closest("p").after(statusRow + reasonRow);
        } 
        if (holpro.holiday_status === "CANCEL" ) {
          const statusRow = `<p class="info-label status-row">Trạng thái đơn: <span class="fw-bold text-danger">Đã hủy</span></p>`;
          const reasonRow = `<p class="info-label reason-row">Lý do: <span class="fw-bold">${holpro.note || "Không có"}</span></p>`;
          // Thêm vào ngay sau dòng "Vị trí công việc"
          infoSection.find("#modal-dttotal").closest("p").after(statusRow + reasonRow);
        } 



        // Hiển thị chi tiết đơn nghỉ phép (riêng cho từng holprosdetails)
        $('#leaveDetailsContainer').empty();
        const holidayDetails = holprosdetailsData.filter(detail => detail.holpros_id === parseInt(holproId));
        if (holidayDetails.length > 0) {
          $.each(holidayDetails, function (index, detail) {
            const holprosdetailsId = detail.id; // Sử dụng id của holprosdetails

            // Định dạng ngày dtfrom và dtto
            const dtFrom = detail.dtfrom ? formatDate(detail.dtfrom) : "Không xác định";
            const dtTo = detail.dtto ? formatDate(detail.dtto) : "Không xác định";

            // Chỉ hiển thị dtFrom nếu dtFrom = dtTo
            const timeRange = dtFrom === dtTo ? dtFrom : `${dtFrom} - ${dtTo}`;

            // Xử lý chuỗi chi tiết nghỉ (details)
            const detailSegments = detail.details ? detail.details
                  .split('$$$') // Tách chuỗi thành mảng
                  .sort((a, b) => {
                    // Chuyển đổi định dạng ngày dd/mm/yyyy thành đối tượng Date để so sánh
                    const dateA = new Date(a.split("-")[0].split("/").reverse().join("-"));
                    const dateB = new Date(b.split("-")[0].split("/").reverse().join("-"));
                    return dateA - dateB; // Sắp xếp tăng dần
                  })
              : [];
            const detailFormatted = detailSegments.length > 0 ? detailSegments.map(segment => {
              const [datePart, statusPart] = segment.split('-');
              const dateMatch = datePart.match(/\d{2}\/\d{2}\/\d{4}/);
              const date = dateMatch ? dateMatch[0] : "Không xác định";
              const status = statusPart ? statusPart.replace(/\(|\)/g, '') : "Không xác định";
              const statusMapping = {
                'ALL': 'Cả ngày',
                'AM': 'Buổi sáng',
                'PM': 'Buổi chiều'
              };
              return `${date} (${statusMapping[status] || status})`;
            }).join('<br>') : "Không có chi tiết nghỉ";

            // Lấy thông tin từ holproHandoverNames, holproTypes, holproLocations dựa trên holprosdetails_id
            const receiverFormatted = holproHandoverNames[holprosdetailsId] || "Không có người nhận bàn giao";
            const typeName = holproTypes[holprosdetailsId] || holtypesMap[detail.sholtype] || "Không xác định";
            const locationType = detail.issued_place === "IN-COUNTRY" ? "Trong nước" : "Nước ngoài";
            const nameLocation = detail.issued_place !== "IN-COUNTRY" ? holproLocations[holprosdetailsId] || "Nước ngoài không xác định" : "";
            

            const note = detail.note || "Không có nội dung";

            const leaveDetailHtml = `
              <div class="leave-details">
                <h5 class="sholtype-tag">${typeName}</h5>
                <div class="col-12 d-flex justify-contend-space-between">
                  <div class="col-4">
                    <p>Thời gian nghỉ:</p>
                  </div>
                  <div class="sub-details col-8 fw-bold" style="font-size: 14px; color: #333; margin-left: 0;">
                    ${detailFormatted}
                  </div>
                </div>
                <p>Cá nhân hỗ trợ công việc: <span class="fw-bold">${receiverFormatted}</span></p>
                <p>Địa điểm: <span class="fw-bold">${locationType}</span></p>
                ${nameLocation ? `<p id="national_place">Quốc gia: <span class="fw-bold">${nameLocation}</span></p>` : '<p id="national_place" class="d-none"></p>'}
                <p>Lý do: <span class="fw-bold">${note}</span></p>
              </div>
            `;
            $('#leaveDetailsContainer').append(leaveDetailHtml);
          });
        } else {
          $('#leaveDetailsContainer').html('<p>Không có thông tin.</p>');
        }

        // Hiển thị quá trình xử lý (chung cho holproId)
        $('#processTimeline').empty();
        $('#processDetailsCancel').empty();
        const processDetails = mandocDetails[holproId] || [];
        const processDetailsCancel = mandocDetailsCancel[holproId] || [];
        console.log(processDetails);
        console.log(processDetailsCancel);
        
        if (processDetails.length > 0) {
          $('#processTimeline').addClass('stimeline'); // Thêm class timeline
          const ul = $('<ul style="list-style: none;"></ul>').appendTo('#processTimeline');
          $.each(processDetails, function (index, step) {
            const dateTime = new Date(step.updated_at);
            const date = formatDate(dateTime); // Định dạng ngày
            const time = formatTime(dateTime); // Định dạng giờ
            
            let status = "";
            let statusClass = "";
            let iconHtml = "";
            let titleUserHandle = "";

            if (index === 0) {
              // Người đầu tiên: Đăng ký nghỉ phép
              status = "Đăng ký nghỉ";
              statusClass = "DONE"; // Đã xử lý nên có màu xanh dương
              iconHtml = '';
              titleUserHandle = 'Người làm đơn: ';
            } else if (index === processDetails.length - 1) {
              titleUserHandle = 'Người xử lý: ';
              if (step.status === "DAXULY") {
                // Người cuối cùng: Dựa trên holproStatus
                if (holproStatus === "DONE" || holproStatus === "CANCEL-DONE") {
                  status = "Đã xử lý";
                  statusClass = "DONE";
                  iconHtml = '<i class="fas fa-check-circle" style="color: green; margin-left: 5px;"></i>';
                } else if (holproStatus === "REFUSE") {
                  status = "Đã xử lý";
                  statusClass = "REFUSE";
                  iconHtml = '<i class="fas fa-check-circle" style="color: green; margin-left: 5px;"></i>';
                } else if (holproStatus === "CANCEL") {
                  status = "Đã xử lý";
                  statusClass = "CANCEL";
                  iconHtml = '<i class="fas fa-check-circle" style="color: green; margin-left: 5px;"></i>';
                }
                 else if (holproStatus === "PENDING" || holproStatus === "CANCEL-PENDING" || holproStatus === "PROCESSING") {
                  status = "Đang chờ xử lý";
                  statusClass = "PENDING";
                  iconHtml = '';
                } else {
                  status = holproStatus || "Không xác định";
                  statusClass = "";
                  iconHtml = '';
                }
              } else {
                status = "Đang chờ xử lý";
                statusClass = "PENDING";
                iconHtml = '';
              }
              if (processDetailsCancel.length > 0) {
                status = "Đã xử lý";
                statusClass = "DONE";
                iconHtml = '<i class="fas fa-check-circle" style="color: green; margin-left: 5px;"></i>';
              }
            } else {
              // Những người trung gian: Duyệt đơn cấp phòng
              status = "Đã xử lý";
              statusClass = "DONE";
              iconHtml = '<i class="fas fa-check-circle" style="color: green; margin-left: 5px;"></i>';
              titleUserHandle = 'Người xử lý: ';
            }

            const userPosition = step.user_position || "Không xác định";
            const li = $('<li></li>').addClass(statusClass).appendTo(ul);
            li.html(`
              <div class="stimeline__date">
                <span>${date}</span>
                <span>${time}</span>
              </div>
              <div class="stimeline__content">
                <div class="stimeline__title fw-bold">${status}${iconHtml}</div>
                <div class="stimeline__description">
                  <span>${titleUserHandle}</span><span class="name">${step.handler_name}</span><br>
                  <span>Chức vụ: </span><span>${userPosition}</span>
                </div>
              </div>
            `);
          });
        } else {
          $('#processTimeline').html('<li>Không có thông tin xử lý.</li>');
        }
        if (processDetailsCancel.length > 0) {
          $('#processDetailsCancel').addClass('stimeline'); // Thêm class timeline
          $('.stimeline-title-cancel').removeClass('d-none');
          $('.stimeline__create-cancel').removeClass('d-none');

          const ul = $('<ul style="list-style: none;"></ul>').appendTo('#processDetailsCancel');
          $.each(processDetailsCancel, function (index, step) {
            const dateTime = new Date(step.updated_at);
            const date = formatDate(dateTime); // Định dạng ngày
            const time = formatTime(dateTime); // Định dạng giờ
            
            let status = "";
            let statusClass = "";
            let iconHtml = "";
            let titleUserHandle = "";

            if (index === 0) {
              // Người đầu tiên: Đăng ký nghỉ phép
              status = "Đăng ký nghỉ";
              statusClass = "DONE"; // Đã xử lý nên có màu xanh dương
              iconHtml = '';
              titleUserHandle = 'Người làm đơn: ';
            } else if (index === processDetailsCancel.length - 1) {
              titleUserHandle = 'Người xử lý: ';
              if (step.status === "DAXULY") {
                // Người cuối cùng: Dựa trên holproStatus
                if (holproStatus === "DONE" || holproStatus === "CANCEL-DONE") {
                  status = "Đã xử lý";
                  statusClass = "DONE";
                  iconHtml = '<i class="fas fa-check-circle" style="color: green; margin-left: 5px;"></i>';
                } else if (holproStatus === "REFUSE") {
                  status = "Đã xử lý";
                  statusClass = "REFUSE";
                  iconHtml = '<i class="fas fa-check-circle" style="color: green; margin-left: 5px;"></i>';
                } else if (holproStatus === "CANCEL") {
                  status = "Đã xử lý";
                  statusClass = "CANCEL";
                  iconHtml = '<i class="fas fa-check-circle" style="color: green; margin-left: 5px;"></i>';
                }
                 else if (holproStatus === "PENDING" || holproStatus === "CANCEL-PENDING" || holproStatus === "PROCESSING") {
                  status = "Đang chờ xử lý";
                  statusClass = "PENDING";
                  iconHtml = '';
                } else {
                  status = holproStatus || "Không xác định";
                  statusClass = "";
                  iconHtml = '';
                }
              } else {
                status = "Đang chờ xử lý";
                statusClass = "PENDING";
                iconHtml = '';
              }
            } else {
              // Những người trung gian: Duyệt đơn cấp phòng
              status = "Đã xử lý";
              statusClass = "DONE";
              iconHtml = '<i class="fas fa-check-circle" style="color: green; margin-left: 5px;"></i>';
              titleUserHandle = 'Người xử lý: ';
            }

            const userPosition = step.user_position || "Không xác định";
            const li = $('<li></li>').addClass(statusClass).appendTo(ul);
            li.html(`
              <div class="stimeline__date">
                <span>${date}</span>
                <span>${time}</span>
              </div>
              <div class="stimeline__content">
                <div class="stimeline__title fw-bold">${status}${iconHtml}</div>
                <div class="stimeline__description">
                  <span>${titleUserHandle}</span><span class="name">${step.handler_name}</span><br>
                  <span>Chức vụ: </span><span>${userPosition}</span>
                </div>
              </div>
            `);
          });
        } else {
          $('.stimeline-title-cancel').addClass('d-none');
          $('.stimeline__create-cancel').addClass('d-none');
        }
      }
    });
  });
</script>

<script>
  function changeTab(uorg_scode) {
    document.body.style.cursor = 'wait';
    const urlParams = new URLSearchParams(window.location.search);
    urlParams.set('uorg_scode', uorg_scode);
    urlParams.set('page', '1');
    // Giữ nguyên department hiện tại nếu có
    if (uorg_scode === 'BMU' || uorg_scode === 'BMTU') {
      urlParams.set('department_bmu', urlParams.get('department_bmu') || '');
      urlParams.set('country_bmu', urlParams.get('country_bmu') || '');
      urlParams.set('holtype_bmu', urlParams.get('holtype_bmu') || '');
    } else if (uorg_scode === 'BUH') {
      urlParams.set('department_buh', urlParams.get('department_buh') || '');
      urlParams.set('country_buh', urlParams.get('country_buh') || '');
      urlParams.set('holtype_buh', urlParams.get('holtype_buh') || '');
    }
    window.location.href = '<%= manager_leave_manager_holiday_path %>?' + urlParams.toString();
  }
  $(document).ready(function() {
    $('#importModal').on('show.bs.modal', function () {
      $('#file_input').val('');
      $('#modal_uorg_scode').val('');
      $('#import-result').html('');
    });
  });
  $(document).ready(function () {
    $('#submit-import-btn').click(function (e) {
      e.preventDefault();

      const fileInput = $('#file_input')[0].files[0];
      const uorg_scode = $('#modal_uorg_scode').val();

      if (!fileInput) {
        alert("Vui lòng chọn file Excel trước khi import!");
        return;
      }

      const formData = new FormData();
      formData.append('file', fileInput);
      formData.append('uorg_scode', uorg_scode);

      $.ajax({
        url: $('#import-form').attr('action'),
        type: 'POST',
        data: formData,
        contentType: false,
        processData: false,
        dataType: 'json',
        success: function (response) {
          pushSuccess(response);
        },
        error: function (xhr) {
          try {
            const res = JSON.parse(xhr.responseText);
            pushError(res);
          } catch (e) {
            alert("Lỗi không xác định!");
          }
        }
      });
    });
  });
  let importSuccess = false;
  function pushSuccess(data) {
    $('#import-result').html('<div class="alert alert-success">' + data.msg + '</div>');
    $('#file_input').val('');
    importSuccess = true;
  }
  function pushError(data) {
    $('#import-result').html('<div class="alert alert-danger">' + data.msg + '</div>');
    $('#file_input').val('');
  }
  $('#btn-close-import').on('click', function () {
  if (importSuccess) {
    importSuccess = false; // reset về lại ban đầu
    location.reload(); // reload lại trang
  }
});
</script>

