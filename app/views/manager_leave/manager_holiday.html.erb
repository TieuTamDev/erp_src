                        <option value="REFUSE" <%= params[:status] == "REFUSE" ? "selected" : "" %>>Đơn từ chối</option>
                        <option value="CANCEL" <%= params[:status] == "CANCEL" ? "selected" : "" %>>Đơn bị hủy</option>
                        <option value="CANCEL-DONE" <%= params[:status] == "CANCEL-DONE" ? "selected" : "" %>>Đã duyệt(điều chỉnh)</option>
                      </select>
                    </div>
                    <div class="btn_fillter d-none">
                        <div>
                            <button type="submit" class="btn btn-primary"><%= lib_translate("Tìm kiếm")  %></button>
                        </div>
                    </div>
                  </div>
                  <div class="row justify-content-end pb-2 mt-2">
                    <div style="width: 500px;" >
                        <input type='text' name='search' id='search_user' value='<%= params[:search] %>' placeholder='<%= lib_translate('Search') %>' class='form-control form-control-sm'>
                        <input class='d-none' name='lang' value='vi'><input type='submit' hidden>
                    </div>
                  </div>
                </div>
              </form>
              
              <div class="table-responsive scrollbar"> 
                <table id="user_buh" class="table table-bordered fs--1 mb-0" style="margin-top: 0px !important; margin-bottom: 0px !important">
                  <thead class="bg-200 text-900">
                    <tr>
                      <th class="sort" style="width:4%; text-align: center;"><%= lib_translate("STT") %></th>
                      <th class="sort"><%= lib_translate("Tên nhân viên") %></th>
                      <th class="sort"><%= lib_translate("Đơn vị") %></th>
                      <th class="sort text-center"><%= lib_translate("Loại ngày nghỉ") %></th>
                      <th class="sort text-center"><%= lib_translate("Tổng ngày nghỉ") %></th>
                      <th class="no-sort text-center"><%= lib_translate("Chi tiết ngày") %></th>
                      <th class="sort text-center"><%= lib_translate("Người duyệt") %></th>
                      <th class="sort text-center"><%= lib_translate("Trạng thái") %></th>
                      <th class="no-sort text-center"></th>
                    </tr>
                  </thead>
                  <tbody class="list_user_buh">
                    <% @results.each_with_index do |holpro, index| %>
                      <tr>
                        <td class="text-center"><%= (index + 1) + (@page - 1) * @per_page %></td>
                        <td><%= holpro['user_fullname'] %> (<%= holpro['user_sid'] %>)</td>
                        <td><%= holpro['department_name'] %></td>
                        <td class="text-center"><%= @holpro_types[holpro['holpro_id']] || "" %></td>
                        <td class="text-center"><%= holpro['holiday_total_days'] %> ngày</td>
                        <td class="text-start">
                          <span title="<%= holpro['details_holpros'] %>">
                            <%= truncate(holpro['details_holpros'], length: 50) %>
                          </span>
                        </td>
                        <td class="text-center">
                          <% approvers = @holpro_approvers[holpro['holpro_id']] || [] %>
                          <%= approvers.map { |a| a[:name] }.join(", ") %>
                        </td>
                        <td class="text-center">
                          <% if holpro['holiday_status'] == "TEMP" %>
                            <span class="text-secondary">Lưu nháp</span>
                          <% elsif holpro['holiday_status'] == "DONE" %>
                            <span class="text-success">Đã duyệt</span>
                          <% elsif holpro['holiday_status'] == "PENDING" %>
                            <span class="text-warning">Chờ duyệt</span>
                          <% elsif holpro['holiday_status'] == "REFUSE" %>
                            <span class="text-danger">Từ chối</span>
                          <% elsif holpro['holiday_status'] == "CANCEL" %>
                            <span class="text-danger">Đã hủy</span>
                          <% elsif holpro['holiday_status'] == "CANCEL-DONE" %>
                            <span class="text-success">Đã duyệt(điều chỉnh)</span>
                          <% else %>
                            <span class="text-warning">Đang xử lý đơn</span>
