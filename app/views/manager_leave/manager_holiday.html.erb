                          <% (1..@total_pages).each do |i| %>
                            <li class="page-item <%= @page == i ? 'active' : '' %>">
                              <%= link_to i.to_s, manager_leave_manager_holiday_path(page: i, status: params[:status], per_page: @per_page, lang: session[:lang], search: params[:search], uorg_scode: @uorg_scode, department_buh: params[:department_buh], country_buh: params[:country_buh], holtype_buh: params[:holtype_buh]), class: "page-link" %>
                            </li>
                          <% end %>
                          <li class="page-item <%= @page == @total_pages ? 'disabled' : '' %>">
                            <%= link_to "»", manager_leave_manager_holiday_path(page: @page + 1, status: params[:status], per_page: @per_page, lang: session[:lang], search: params[:search], uorg_scode: @uorg_scode, department_buh: params[:department_buh], country_buh: params[:country_buh], holtype_buh: params[:holtype_buh]), class: "page-link" %>
                          </li>
                        </ul>
                      </nav>
                    </div>
                    <div class="col-auto ms-2">
                      <form action="<%= manager_leave_manager_holiday_path %>" accept-charset="UTF-8" method="get">
                        <select class="form-select" name="per_page" id="per_page_select" onchange="this.form.submit()">
                          <option value="25" <%= @per_page == 25 ? 'selected' : '' %>>25</option>
                          <option value="50" <%= @per_page == 50 ? 'selected' : '' %>>50</option>
                          <option value="100" <%= @per_page == 100 ? 'selected' : '' %>>100</option>
                          <option value="200" <%= @per_page == 200 ? 'selected' : '' %>>200</option>
                        </select>
                        <input class="d-none" name="lang" value="<%= session[:lang] %>">
                        <input class="d-none" name="search" value="<%= params[:search] %>">
                        <input class="d-none" name="page" value="1">
                        <input class="d-none" name="uorg_scode" value="<%= @uorg_scode %>">
                        <input class="d-none" name="country_buh" value="<%= params[:country_buh] %>">
                        <input class="d-none" name="status" value="<%= params[:status] %>">
                        <input class="d-none" name="holtype_buh" value="<%= params[:holtype_buh] %>">
                        <input class="d-none" name="department_buh" value="<%= params[:department_buh] %>">
                      </form>
                    </div>
                  </div>
                <% else %>
                  <p class="text-center mt-3">Không có dữ liệu để hiển thị.</p>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
