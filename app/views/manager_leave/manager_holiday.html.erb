                      <nav aria-label="Page navigation">
                        <ul class="pagination mb-0">
                          <li class="page-item <%= @page == 1 ? 'disabled' : '' %>">
                            <%= link_to "«", manager_leave_manager_holiday_path(page: @page - 1, status: params[:status], per_page: @per_page, lang: session[:lang], search: params[:search], uorg_scode: @uorg_scode, department_buh: params[:department_buh], country_buh: params[:country_buh], holtype_buh: params[:holtype_buh]), class: "page-link" %>
