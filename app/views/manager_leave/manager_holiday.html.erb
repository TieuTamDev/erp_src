                        <td class="text-center"><%= (index + 1) + (@page - 1) * @per_page %></td>
                        <td><%= holpro['user_fullname'] %> (<%= holpro['user_sid'] %>)</td>
                        <td><%= holpro['department_name'] %></td>
                        <td class="text-center"><%= @holpro_types[holpro['holpro_id']] || "" %></td>
                        <td class="text-center"><%= holpro['holiday_total_days'] %> ngày</td>
                        <td class="text-center">
                          <% approvers = @holpro_approvers[holpro['holpro_id']] || [] %>
                          <%= approvers.map { |a| a[:name] }.join(", ") %>
                        </td>
                        <td class="text-center">
                          <% if holpro['holiday_status'] == "TEMP" %>
