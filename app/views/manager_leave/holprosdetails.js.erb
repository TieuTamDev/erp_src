showLoadding(false);
function mapStatus(status) {
  switch (status) {
    case "CHUAXULY": return "Đang chờ xử lý";
    case "DAXULY": return "Đã xử lý";
    default: return status;
  }
}


$("#holDetailModal").modal('show');
function formatDetailDays(detailString) {
  const map = {
    "ALL": "Cả ngày",
    "AM": "Buổi sáng",
    "PM": "Buổi chiều"
  };

  if (!detailString) return "";
  return detailString.split("$$$").map(detail => {
    const [day, part] = detail.split("-");
    return `${day} (${map[part] || part})`;
  }).join("<br>");
}

function formatReceivers(receiverString) {
  if (!receiverString) return "";
  return receiverString.split("|||")
    .map(item => item.split("$$$")[1] || "")
    .join("<br>");
}
function formatReceivers_first(receiverString) {
  if (!receiverString) return "";
  return receiverString.split("|||")
    .map(item => item.split("$$$")[0] || "")
    .join("<br>");
}

}
