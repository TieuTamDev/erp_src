var grouped_handle = {};
details_handle.forEach(item => {
  const type = item.sholtype || "Khác";
  if (!grouped_handle[type]) grouped_handle[type] = [];
  grouped_handle[type].push(item);
});

Object.keys(grouped_handle).forEach(type => {
  let html = `
    <div class="mb-4 border p-3 rounded shadow-sm">
      <div class="bg-light px-2 py-1 rounded fw-bold mb-2">${type}</div>
  `;

  grouped_handle[type].forEach(item => {
    const detailFormatted = formatDetailDays(item.details)
      ? formatDetailDays(item.details)
          .split('<br>')
          .filter(line => line.trim() !== '')
          .sort((a, b) => {
            const dateA = new Date(a.split(' ')[0].split('/').reverse().join('-'));
            const dateB = new Date(b.split(' ')[0].split('/').reverse().join('-'));
            return dateA - dateB;
          })
          .map(line => `<div>${line}</div>`)
          .join('')
      : '';

    const receiverFormatted_first = formatReceivers_first(item.handover_receiver);
    const receiverFormatted = formatReceivers(item.handover_receiver);
    $("#user_support").val(receiverFormatted_first);
    const location = item.place_before_hol || "Không rõ";
    const note = item.note || "Không có";
    const dtFrom = new Date(item.dtfrom).toLocaleDateString("vi-VN");
    const dtTo = new Date(item.dtto).toLocaleDateString("vi-VN");
    const locationType = item.issued_place === "IN-COUNTRY" ? "Trong nước" : "Ngoài nước";
    const country = item.country || "";
    const noteFormatted = note.replace(/\r?\n/g, '<br>');

    html += `
      <div class="row mb-2">
        <div class="col-12 col-sm-4 text-muted">Thời gian nghỉ:</div>
        <div class="col-12 col-sm-8 fw-bold">${detailFormatted}</div>
      </div>
      <div class="row mb-2">
        <div class="col-12 col-sm-4 text-muted">Người nhận bàn giao công việc:</div>
        <div class="col-12 col-sm-8 fw-bold">${receiverFormatted}</div>
      </div>
      <div class="row mb-2">
        <div class="col-12 col-sm-4 text-muted">Địa điểm:</div>
        <div class="col-12 col-sm-8 fw-bold">${locationType}</div>
      </div>
      <div class="row mb-2">
        <div class="col-12 col-sm-4 text-muted">Địa chỉ nghỉ:</div>
        <div class="col-12 col-sm-8 fw-bold">${location}</div>
      </div>
      ${country ? `
      <div class="row mb-2">
        <div class="col-12 col-sm-4 text-muted">Quốc gia:</div>
        <div class="col-12 col-sm-8 fw-bold">${country}</div>
      </div>` : ""}
      <div class="row mb-2">
        <div class="col-12 col-sm-4 text-muted">Lý do:</div>
        <div class="col-12 col-sm-8 fw-bold">${noteFormatted}</div>
      </div>
    `;
  });

  html += `</div>`;
  $("#leaveDetailContent").append(html);
});


var timeline = <%= @timeline_data.to_json.html_safe %>;
$("#processTimeline").empty();
var finalApprovedIndex = (function () {
  var lastIndex = -1;
  timeline.forEach((step, i) => {
    if (step.status === "Đã xử lý") {
      lastIndex = i;
    }
  });
  return lastIndex;
})();

timeline.forEach((step, i) => {
  var time = `<div>${step.time.split(" ")[0]}</div><div>${step.time.split(" ")[1]}</div>`;
  var separatorClass = `timeline__separator ${step.first ? "first" : ""} ${step.last ? "last" : ""} ${step.handled ? "handled" : ""}`.trim();
  var handlerLabel = step.first ? "Người làm đơn" : "Người xử lý";

  var isFinalApproved = step.status === "Đã xử lý" && i === finalApprovedIndex;
  var statusWithIcon = (i === 0)
    ? `Đăng ký nghỉ`
    : isFinalApproved
      ? `${step.status} <i class="fas fa-check-circle" style="color: green; margin-left: 6px;"></i>`
      : step.status;
  var noteHtml = '';
  if (step.note && step.note.trim() !== '') {
    const noteAssign = step.note.replace(/\r?\n/g, '<br>');
    noteHtml = `
      <div class="row mt-2">
        <div class="col-12 col-sm-4 text-muted">Nội dung cần xử lý:</div>
        <div class="col-12 col-sm-8 fw-bold">${noteAssign}</div>
      </div>
    `;
  }

  var item = `
    <div class="timeline__date">${time}</div>
    <div class="${separatorClass}"></div>
    <div class="timeline__content">
        <div class="timeline__title"><strong>${statusWithIcon}</strong></div>
        <div class="timeline__description">
            ${handlerLabel}: <br><span style="color: #005FBE;font-weight: bold;">${step.user}</span> <br>Chức vụ: <br><span style="color: #333; font-weight: bold;">${step.user_position}</span><br>${noteHtml}
        </div>
    </div>
  `;

  $("#processTimeline").append(item);
});
