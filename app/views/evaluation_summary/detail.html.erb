<%= breadcrumbs([
  { title: 'Trang chủ', path: root_path },
  { title: 'Bổ nhiệm', path: appointments_path },
  { title: @appointment.title, path: appointment_path(@appointment) },
  { title: "Phiếu khảo sát ý kiến tín nhiệm vị trí #{@appointment.positionjob.name} #{@appointment.department.name}", 
    path: appointment_evaluation_summary_index_path(@appointment, mandocuhandle_id: params[:mandocuhandle_id], lang: session[:lang]) },
  { title: "Tỉ lệ đồng ý bổ nhiệm", current: true }
]) %>
 
<style>
    .badges {
        display: inline-block;
        padding: 5px 20px;
        font-size: 12px;
        font-weight: 600;
        border-radius: 9999px; /* Full rounded */
    }

    .badges-approve {
        background-color: #D2F1FF;
        color: #2C7BE5;
    }

    .badges-reject {
        background-color: #fee2e2;
        color: #b91c1c;
    }
    
    .badges-pending {
        background-color: #DEE0E2;
        color: #61666F;
    }

</style>

<div class="card mb-3">
    <div class="card-header bg-body-tertiary">
        <h5 class="mb-2" data-anchor="data-anchor">Phiếu khảo sát ý kiến tín nhiệm vị trí <%= @appointment.positionjob.name%> <%= @appointment.department.name%></h5> 
        <p class="mb-1">(Ứng viên <%= @appointment.user.last_name%> <%= @appointment.user.first_name%>)</p>
    </div>

    <div class="card-body p-3 pt-0">
        <div class="card border h-100" style="box-shadow: none;">
            <div class="card-body">
                <div class="card-title">Tỉ lệ đồng ý bổ nhiệm</div>
                <div class="content-main">
                    <% @resultAppointSurvey[:evaluation_summary]&.each do |evaluation| %>  
                        <div class="card border mb-3" style="box-shadow: none;">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="card-title mb-0"><%= evaluation[:positionjob_name] %></div>
                                    <div class="item-details w-sm-50 w-md-25">
                                        <div class="mb-1 d-flex justify-content-between">
                                            <span class="text-info"><%= evaluation[:positionjob_name] %></span>
                                            <div class="process-bar">                                                      
                                                <span class="fw-semi-bold"><%= evaluation[:attend] %>/<%= evaluation[:total] %></span>
                                            </div>
                                        </div>
                                        <div class="progress" style="height: 6.5px" role="progressbar" aria-valuenow="<%= evaluation[:attend_ratio] %>" aria-valuemin="0" aria-valuemax="100">
                                            <div class="progress-bar" style="width: <%= evaluation[:attend_ratio] %>%; background-color: <%= "##{SecureRandom.hex(3)}" %>"></div>
                                        </div>
                                    </div>
                                </div>
                                <ul class="content-main mt-3">
                                    <% evaluation[:approves][:users].each do |user| %>
                                        <li class="mb-3">
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <div>
                                                    <div><%= user[:user_name] %></div>
                                                    <div class="text-muted"><%= user[:sid] %></div> 
                                                </div>
                                                <span class="badges badges-approve">Đồng ý</span> 
                                            </div>
                                        </li>  
                                    <% end %>
                                    <% evaluation[:rejects][:users].each do |user| %>
                                        <li class="mb-3">
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <div>
                                                    <div><%= user[:user_name] %></div>
                                                    <div class="text-muted"><%= user[:sid] %></div> 
                                                    <% if user[:note].present? %>
                                                        <div>Góp ý: <%= user[:note].to_s.gsub(/\r\n|\r|\n/, '<br>').html_safe %></div> 
                                                    <% end %>
                                                </div>
                                                <span class="badges badges-reject">Không đồng ý</span> 
                                            </div>
                                        </li>  
                                    <% end %>
                                    <% evaluation[:pendings][:users].each do |user| %>
                                        <li class="mb-3">
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <div>
                                                    <div><%= user[:user_name] %></div>
                                                    <div class="text-muted"><%= user[:sid] %></div> 
                                                </div>
                                                <span class="badges badges-pending">Chưa thực hiện</span> 
                                            </div>
                                        </li>  
                                    <% end %>
                                </ul>
                            </div>
                        </div>
                    <% end %>
                </div>
            </div>
        </div>
    </div>
</div>
