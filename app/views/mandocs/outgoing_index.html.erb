    'flatpickr.localize(flatpickr.l10ns.vn);'.html_safe
  end
  %>
  <%list_handle_file = [] 
  if !@list_file.nil?
      @list_file.each do |y|
        list_handle_file.push({
          id: y.id,
          relative_id: y.mandoc_id,
          file_name: y.mediafile.file_name,
          created_at: y.created_at.strftime("%d/%m/%Y"),
          file_owner: y.mediafile.owner
        })
    end
  end
  %>
</script>

<%= javascript_include_tag '/assets/myjs/options_mandoc_table.js' %>
