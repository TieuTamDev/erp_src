              <p style="min-height: 100px;" class="form-control" id="mandoc_dhandle_Proposal_of_the_TC-HC"  style="" placeholder="<%= lib_translate(session[:organization] ? "School_Administrator's_opinion" : "Management's_approval") %>" ></p>
