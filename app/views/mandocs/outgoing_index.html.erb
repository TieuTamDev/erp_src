<!-- Modal chọn nhân sự xử lý -->
<div class="modal modal-lg fade" id="modal_chosses_staff" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true" style=" background: rgba(0, 0, 0, 0.84); overflow-y: scroll;"  data-bs-focus="false">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><%= lib_translate("Choose_staff_handle")%></h5>
        <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form id="form_chosses_user">
          <label for="select_chosses_staff"><%= lib_translate("Staff")%></label>
          <select class="form-select selectpicker" id="select_chosses_staff">
            <% @users.each do |user| %> 
            <% 
            positionjobUser = ""
            work_user = Work.joins(:positionjob).where("works.user_id = #{user.id}").where.not("positionjobs.department_id = #{@department_leader_id_handel&.to_i}").last || Work.where(user_id: user.id).last
              if !work_user.nil?
                positionjobU = Positionjob.where(id: work_user.positionjob_id).last
                if !positionjobU.nil?
                  positionjobUser = positionjobU.name
                end
              end
            %>
              <option value="<%= user.id %>"><b><%= user.last_name %> <%= user.first_name %></b> (<span style="font-style: italic;"><%= positionjobUser%></span>)</option>
            <%end%>
          </select>
          <label class="mt-3" for="select_chosses_staff"><%= lib_translate("Permission_process")%></label>
          <div class="d-flex">
