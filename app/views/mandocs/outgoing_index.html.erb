<style>
          .hide-responsive-mobile {
            display: none;
        }
  input[name="search_terms"]{
    min-width: -webkit-fill-available !important;
    width: -webkit-fill-available !important;
  }
  p[aria-live="polite"] {
    margin-top: 13px !important;
    font-weight: 600 !important;
  }
  #loading_screen{
    position: fixed;
    z-index: 9999;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%; 
    background: rgb(0 0 0 / 51%);
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }
 table td{
    white-space: normal !important;
  }
  .choices[data-type*=select-multiple] .choices__button, .choices[data-type*=text] .choices__button {
    background-image: url(data:image/svg+xml;base64,) !important;
  }

  .select2-results__option.select2-results__option--disabled {
    color: #c9c9c9 !important;
    cursor: not-allowed;
    font-style: italic;
  }
  .tox-tinymce {
    border-radius: 5px !important;
    border: 1px solid var(--falcon-input-border-color);
  }
  .dropdown-indicator:after {
    right: 15px !important;
  }
  .btmu-notification-indicator-warning::before {
    background-color: #e63757;
  }
  .btmu-notification-indicator::before {
      position: absolute;
      content: "";
      margin-top: 2px;
      margin-left: 10px;
      height: 10px;
      width: 10px;
      border-radius: 50%;
      border: 2px solid var(--falcon-notification-indicator-border-color);
  }
</style>
<div style="display: none" id="loading_screen">
    <div class="spinner_handle"></div>
    <p style="color: var(--falcon-avatar-status-border-color);"><%= lib_translate("Inprogress_handle")  %>...</p>
</div>

<div class="list_users">
  <div class="card mb-3">
    <div class="card-body pt-0">
      <div class="tab-content">
        <div class="row">
            <div class="col">
                <h3 class="mt-2 overview_text"><%= lib_translate("MANDOCS-OUTGOING")%></h3>
            </div>
            <div class="col mt-2 ">
              <% if is_access(session["user_id"], "MANDOCS-OUTGOING","ADD") %>
                <button class="btn btn-primary float-end" data-bs-toggle="modal" data-bs-target="#staticBackdrop" onclick="openFormAddMandocPending()">
                  <%= lib_translate("Text_editor")%>
                </button>
              <% end %>
            </div>
            <!-- form modal create new mandoc -->
            <div class="modal fade" id="staticBackdrop" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="add_Form_Label" aria-hidden="true" data-bs-focus="false">
              <div class="modal-dialog" style="min-width: 90%;" id="form_add_mandoc_pending">
                <div class="modal-content border-0">
                  <div class="position-absolute top-0 end-0 mt-3 me-3 z-index-1">
                    <button class="btn-close btn btn-sm btn-circle d-flex flex-center transition-base" data-bs-dismiss="modal" aria-label="Close" id="btn_add_doc_pending_close"></button>
                  </div>
                  <div class="modal-body p-0">
                    <div class="bg-light rounded-top-lg py-3 ps-4 pe-6">
                      <h4 class="mb-1" id="add_Form_Label"><%= lib_translate('Add_outgoing_docs')%></h4>
                    </div>
                    <div class="p-3" >
                      <div class="row">
                        <%= form_for @mandoc, :url=> mandocs_outgoing_update_path, html: {method: :post, id:"form_add_document_infor", class:"mb-2 p-3" } do |f| %>
                          <%= f.text_field :id, class: 'form-control d-none' , name:'id_mandoc', id: 'id_mandoc',autocomplete: 'off'  %>
                          <div class="alert alert-warning border-2 align-items-center" role="alert" id="err_add" style="display:none">
                          </div>
                          <div class="row">
                              <div class="col-6 d-flex flex-column">
                                <!-- Loại sổ -->
                                <div class="col-12 d-flex flex-row mt-3">
                                  <div class="col-3 d-flex align-items-center justify-content-end me-3">
                                    <%= f.label :type_book, lib_translate("Type_book") ,class:'fw-semi-bold m-0'%> 
                                  </div>
                                  <select class="form-select selectpicker" name="type_book" id="type_book">
                                    <% @mandocbooks.each do |docbook| %>
                                      <option value="<%= docbook.scode %>"><%= docbook.name %></option>
                                    <% end %>
                                  </select>
                                  <div class="ms-2 d-flex align-items-center">
                                    <span class="fas fa-sync-alt" style="cursor: pointer;" id="mandocbook-reload-btn" onclick="clickRefreshOption(this,'get_mandocbook_form')"></span>
                                  </div>
                                  <a class="ms-2 pe-auto d-flex align-items-center" href="<%= mandocbook_index_path()%>"><span style="width:10px; color:#98a7b9" class="fas fa-database"></span></a>
                                </div>
                                <%# Hiện tại theo quy trình thì ẩn mục này %>
                                <!-- Số văn bản -->
                                <div class="col-12 d-flex flex-row mt-3 d-none">
                                  <div class="col-3 d-flex align-items-center justify-content-end me-3">
                                    <%= f.label :number_book, lib_translate('Number_book') ,class:'fw-semi-bold m-0'%> 
                                  </div>
                                  <%= f.text_field :sno, class: 'form-control' , name:'sno', id:"sno" %>
                                </div>
                                <!-- Số/Ký hiệu -->
                                <div class="col-12 d-flex flex-row mt-3 d-none">
                                  <div class="col-3 d-flex align-items-center justify-content-end me-3">
                                    <%= f.label :ssymbol, lib_translate("Sno_book") ,class:'fw-semi-bold m-0'%> 
                                  </div>
                                  <%= f.text_field :ssymbol, class: 'form-control' , name:'ssymbol',id:"ssymbol" %>
                                </div>
                                  <%#...  %>
                                <!-- Loại văn bản -->
                                <div class="col-12 d-flex flex-row mt-3">
                                  <div class="col-3 d-flex align-items-center justify-content-end me-3">
                                    <%= f.label :stype, lib_translate('Documents_type'),class:'fw-semi-bold m-0' %> 
                                  </div>
                                  <select class="form-select selectpicker" name="stype" id="stype">
                                    <% @mandoctypes.each do |doctype| %>
                                      <option value="<%= doctype.scode %>"><%= doctype.name %></option>
                                    <% end %>
                                  </select>
                                  <div class="ms-2 d-flex align-items-center">
                                    <span class="fas fa-sync-alt" style="cursor: pointer;" id="mandoctype-reload-btn" onclick="clickRefreshOption(this,'get_mandoctype_form')"></span>
                                  </div>
                                  <a class="ms-2 pe-auto d-flex align-items-center" href="<%= mandoctype_index_path() %>" ><span style="width:10px; color:#98a7b9" class="fas fa-database"></span></a>
                                </div>
                                <!-- Đơn vị tham mưu -->
                                <div class="col-12 d-flex flex-row mt-3">
                                  <div class="col-3 d-flex align-items-center justify-content-end me-3">
                                    <%= f.label :mdepartment,lib_translate("Advisory_unit") ,class:'fw-semi-bold m-0' %> 
                                  </div>
                                  <div id="select_mdepartment" class="w-100">
                                    <select class="form-select selectpicker"  name="mdepartment" id="mdepartment">
                                      <% if !@oDeparment_logins.nil? 
                                            @oDeparment_logins.each do |mdepartment| %>
                                        <option value="<%= mdepartment.id %>"><%= mdepartment.name %></option>
                                      <% end end %>
                                    </select>
                                  </div>
                                  <div id="select_edit_mdepartment" class="w-100">
                                    <select class="form-select selectpicker " name="mdepartment" id="mdepartment_edit">
                                    </select>
                                 </div>
                                </div>
                                <!-- Người ký -->
                                <div class="col-12 d-flex flex-row mt-3 d-none">
                                  <div class="col-3 d-flex align-items-center justify-content-end me-3">
                                    <%= f.label :signed_by, lib_translate("Signed_by"),class:'fw-semi-bold m-0'%>
                                  </div>
                                  <select class="form-select" name="signed_by" id="signed_by">
                                    <% if !@lists_leader_email.nil?
                                      @lists_leader_email.uniq.each do |name_ld|
                                      full_name_by_email = User.where(email: name_ld).first
                                      if !full_name_by_email.nil?
                                        fullname = full_name_by_email.last_name + " " + full_name_by_email.first_name
                                        work_user = Work.where(user_id: full_name_by_email.id).last
                                        if !work_user.nil?
                                          positionjobU = Positionjob.where(id: work_user.positionjob_id).first
                                          if !positionjobU.nil?
                                    %>
                                      <option value="<%= name_ld%>"> <b><%= fullname %></b> (<i><%= positionjobU.name %></i>)</option>
                                    <%end end end end end%>
                                  </select>
                                </div>
                                <!-- Liên kết văn bản -->
                                <div class="col-12 d-flex flex-row mt-3">
                                  <div class="col-3 d-flex align-items-center justify-content-end me-3">
                                    <%= f.label :slink, lib_translate('Documents_link'),class:'fw-semi-bold m-0' %> <span class="red d-none">*</span>
                                  </div>
                                  <%= f.text_field :slink, class: 'form-control' , name: 'slink',id:'slink' %>
                                </div>
                              </div>
                              <div class="col-6 d-flex flex-column" >
                                <!-- Người soạn -->
                                <div class="col-12 d-flex flex-row mt-3">
                                  <div class="col-4 d-flex align-items-center justify-content-end me-3">
                                    <%= f.label :created_by,lib_translate("Docs_Writer"), class:'fw-semi-bold m-0'%>
                                  </div>
                                  <input class= "form-control" id="created_by_view" value="<%=@user.last_name%> <%=@user.first_name%>" disabled/>
                                  <%= f.text_field :created_by, class: 'form-control d-none' , name: 'created_by',id:'created_by',value: @user.last_name + " " + @user.first_name %>
                                </div>
                                <!--Ngày hiệu lực văn bản-->
                                <div class="col-12 d-flex flex-row mt-3">
                                  <div class="col-4 d-flex align-items-center justify-content-end me-3">
                                    <%= f.label :received_at, lib_translate("Documents_date"),class:'fw-semi-bold m-0' %> 
                                  </div>
                                  <div id="datepicker-container" class="datepicker-container col-8 pe-3">
                                    <span style="position: relative;" class="outline-element-container"> 
                                      <input id="dt_document_date" type="text" name="received_at"  value="<%=Date.today.strftime('%d/%m/%Y')%>" class="form-control datepicker openemr-datepicker input-textbox outline-element incorrect" objtype="7" name="action_element" objindex=""  aria-label="Select Date"> 
                                      <span class="correct-incorrect-icon"> </span>
                                    </span>
                                  <div id="datepicker"></div>
                                  </div>
                                </div>
                                <!-- Độ khẩn -->
                                <div class="col-12 d-flex flex-row mt-3">
                                  <div class="col-4 d-flex align-items-center justify-content-end me-3">
                                    <%= f.label :spriority, lib_translate('Urgency'),class:'fw-semi-bold m-0' %> 
                                  </div>
                                  <select class="form-select selectpicker" name="spriority" id="spriority">
                                    <% @mandocpriorities.each do |mandocpriority| %>
                                      <option value="<%= mandocpriority.name %>"><%= mandocpriority.name %></option>
                                    <% end %>
                                  </select>
                                  <div class="ms-2 d-flex align-items-center">
                                    <span class="fas fa-sync-alt" style="cursor: pointer;" id="mandocpriority-reload-btn" onclick="clickRefreshOption(this,'get_mandocpriority_form')"></span>
                                  </div>
                                  <a class="ms-2 pe-auto d-flex align-items-center" href="<%=mandocpriority_index_path() %>" ><span style="width:10px; color:#98a7b9" class="fas fa-database"></span></a>
                                </div>
                                <!-- Số trang -->
                                <div class="col-12 d-flex flex-row mt-3">
                                  <div class="col-4 d-flex align-items-center justify-content-end me-3">
                                    <%= f.label :number_pages, lib_translate("Number_pages"),class:'fw-semi-bold m-0' %> 
                                  </div>
                                  <%= f.number_field :number_pages, class: 'form-control' , name: 'number_pages',id:'number_pages' %>
                                </div>
                                
                              </div>  
                            </div>
                            <!-- Notes -->
                            <div class="mb-3 mt-3">
                                <%= f.label :notes ,lib_translate('Excerpts_from_content'),class:'fw-semi-bold' %><span class="red">*</span>
                                <%= f.text_field :notes, class:'form-control',name:"notes",id:'notes'%>
                            </div>
                            <!-- Content -->
                            <div class="mb-3 mt-3 d-none">
                              <div id="collapse-control" class="collapse-control bg-300" onclick="clickCollapse(this)" data-bs-toggle="collapse" data-bs-target="#collapse-content-editer-1">
                                <span class="fw-semi-bold form-label" ><%=lib_translate('Content')%></span>
                                <i id="collapse-icon" style="font-size: 20px;pointer-events: none;transition: 200ms ease-in;rotate: -90deg" class="fas fa-chevron-circle-left"></i>
                              </div>
                              <div class="collapse show" id="collapse-content-editer-1">
                                <%= f.text_area :contents, class:'form-control',name:"contents",id:'contents'%>
                              </div>
                            </div>
                            <%# Upload media view %>
                            <div class="row mt-3">
                              <div class="collapse show" id="add-file-medias_mandocsfile">
                                <div class="card">
                                  <div class="card-header">
                                    <h5 class="mb-0"><%= lib_translate('Attached_files')%><span class="red">*</span></h5>
                                  </div>
                                  <div class="card-body bg-light" id="upload_file_mandocfile"></div>
                                </div>
                              </div>
                            </div>
                            <input type="text" id="status_doc" name="status" value="INPROGRESS" hidden>
                            <%# ==== %>
                            <div class="row mt-3 m-auto">
                              <div class="d-flex flex-row col-12 justify-content-center">
                                <div class="m-2 element_add">
                                  <button class="handle_file_btn ps-4 pe-4 btn btn-primary" type="button" id="btn_add_doc"><%=lib_translate('Save_and_send_to_unit_leader')%></button>
                                  <div id="loading_button_add_doc_out" class= "ps-4 pe-4 btn btn-primary" style="opacity: 0.8;display:none;" >
                                    <i class ="fa fa-spinner fa-spin"> </i>  <%=lib_translate("Save_and_send_to_unit_leader")%> 
                                  </div>
                                </div>
                                <div class="m-2 element_add">
                                  <button class="ps-6 pe-6 btn btn-info" id="btn_add_doc_pending" type="button"><%=lib_translate('Save_pending')%></button>
                                  <div id="loading_button_add_doc_pending_out" class= "ps-6 pe-6 btn btn-info" style="opacity: 0.8;display:none;" >
                                    <i class ="fa fa-spinner fa-spin"> </i> <span id="btn_add_label_mandoc"><%=lib_translate("Save_pending")%> </span> 
                                  </div>
                                </div>
                                <div class="m-2 element_update">
                                  <button class="handle_file_btn ps-4 pe-4 btn btn-primary" type="button" id="btn_update_doc"><%=lib_translate('Cập nhật')%></button>
                                  <div id="loading_button_edit_doc_out" class= "ps-4 pe-4 btn btn-primary" style="opacity: 0.8; display:none;" >
                                    <i class ="fa fa-spinner fa-spin"> </i>  <%=lib_translate("Cập nhật")%> 
                                  </div>
                                </div>
                                <div class="m-2">
                                  <button type="button" class="ps-4 pe-4 btn btn-danger" data-bs-dismiss="modal" aria-label="Close" id="btn_add_doc_pending_exit"><%=lib_translate('Close')%></button>
                                </div>
                              </div>
                            </div>  
                        <% end %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
        </div>
        <div class="mt-3">
            <!-- Nav tabs -->
            <ul class="nav nav-tabs" role="tablist">
                <li onclick='save_current_tab("tab_1")' class="nav-item">
                  <a id="out_going_tab_1" class="nav-link active" data-bs-toggle="tab" href="#page_documents_processed"><%= lib_translate("Documents_to_be_processed")%></a>
                </li>
                <li id="li_in_tab_2" class="nav-item">
                  <a id="out_going_tab_2" class="nav-link" data-bs-toggle="tab" href="#page_process_2"><%= lib_translate("Status_doccuments")%></a>
                </li>
                <li onclick='save_current_tab("tab_3")' class="nav-item">
                  <a id="out_going_tab_3" class="nav-link" data-bs-toggle="tab" href="#page_pending"><%= lib_translate("Document_pending")%></a>
                </li>
            </ul>
            <!-- Tab panes -->
            <div class="tab-content">
                <div id="page_documents_processed" class="tab-pane active"><br>
                    <div class="table-responsive scrollbar">
                        <%= render_search_pagination(mandocs_outgoing_index_path()).html_safe %>
 
                        <table id="documents_outgoing" class="table table-bordered fs--1 mb-0 " style="margin-top: 0px !important; margin-bottom: 0px !important">
                            <thead class="bg-200 text-900" class="display: none;">
                                <tr>
                                    <th class="sort" style="width:4%; text-align: center;"><%= lib_translate("Oder")%></th>
                                    <th class="sort" style="width:20%"><%= lib_translate("Received_date")%>/<%= lib_translate("Urgency")%></th>
                                    <th class="sort" style="width:50%"><%= lib_translate("Content")%></th>
                                    <th class="no-sort col-4 col-md-3 p-0" style="width: 40%;"></th>
                                </tr>
                            </thead>                         
                            <tbody class="list">
                                <% @arrMandoc.each_with_index do |mandoc, i| 
                                strClassShow = ""
                                if !mandoc.comment.nil? && mandoc.comment != ""
                                    strClassShow = "btmu-notification-indicator-warning btmu-notification-indicator"
                                end
                                if mandoc.status == "INPROGRESS" 
                                get_department_id=Node.where(nfirst: "YES").first&.department_id
                                  if !get_department_id.nil?
                                      get_name_department= Department.where(id: get_department_id).first&.name
                                      get_id_department= Department.where(id: get_department_id).first&.id
                                      if !get_name_department.nil? && !get_id_department.nil? %>
                                     <% 
                                          dhandle_last = ''
                                          dhandle_last_department = ''
                                          uhandle_last = ''
                                          get_department_mail = ''
                                          madhandle = Mandocdhandle.where(mandoc_id: mandoc.id).last
                                          if !madhandle.nil?
                                            dhandle_last = madhandle.id
                                            dhandle_last_department = madhandle.department_id
                                            mauhandle = Mandocuhandle.where(mandocdhandle_id: dhandle_last).last
                                            if !mauhandle.nil?
                                              uhandle_last = mauhandle.status
                                            end
                                            odeparment = Department.where(id: dhandle_last_department).first
                                            if !odeparment.nil?
                                              get_department_mail = odeparment.leader
                                            end
                                          end
                                          %>
                                      <% get_email_user_login = User.where(id: session[:user_id]).first&.email%>
                                    <tr>  
                                        <td style="vertical-align: middle; text-align: center;"><%= i+1 %></td>
                                        <td style="vertical-align: middle;">
                                            <div style="text-align: start; cursor:pointer; display: flex;flex-direction: column;">
                                                <label style=" cursor:pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0 text-overlap"><%= lib_translate("Documents_type")%>:<span style="font-weight: normal;white-space: normal !important;"><%= mandoc.stype.present? ? Mandoctype.where(scode: mandoc.stype).first&.name : "" %> </span></label>
                                                <label style=" cursor:pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0 text-overlap" ><%= lib_translate("Received_date")%>:<span style="font-weight: normal;white-space: normal !important;"> <%= mandoc.created_at.strftime('%k:%M %d/%m/%Y')%></span></label>
                                                <label style=" cursor:pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0 text-overlap"><%= lib_translate("Urgency")%>: <span style="font-weight: bold; color: <%= Mandocpriority.where(name: mandoc.spriority).first.note%>"><%= mandoc.spriority%></span></label>
                                            </div>
                                        </td>
                                        <%
                                          uUser = User.where(email: mandoc.signed_by).first
                                          if !uUser.nil?
                                              fullnameU = uUser.last_name + " " + uUser.first_name
                                          end
                                        %>
                                        <td style="vertical-align: middle;">
                                            <div style="text-align: start; cursor:pointer; display: flex;flex-direction: column; ">
                                                <label style=" cursor:pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0 text-overlap" ><%=lib_translate('Excerpts_from_content')%>: <span style="font-weight: normal; white-space: normal !important;"><%= mandoc.notes %></span></label>
                                                <label style=" cursor:pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0 text-overlap" ><%=lib_translate('Department')%>: <span style="font-weight: normal; white-space: normal !important;"><%= mandoc.mdepartment %></span></label>
                                                <label style=" cursor:pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0 text-overlap" ><%=lib_translate('Signed_by')%>: <span style="font-weight: normal; white-space: normal !important;"><%= fullnameU %></span></label>
                                                <label style=" cursor:pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0 text-overlap" ><%=lib_translate('Docs_Writer')%>: <span style="font-weight: normal;white-space: normal !important;"><%= mandoc.created_by %></span></label>
                                                <label style=" cursor:pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0 text-overlap"><%= lib_translate('Documents_date')%>: <span style="font-weight: normal;white-space: normal !important;"><%= mandoc.received_at&.in_time_zone('Asia/Ho_Chi_Minh')&.strftime('%d/%m/%Y') %></span>
