                            <span class="correct-incorrect-icon"> </span>
                        </span>
                        <div id="datepicker" ></div>
                      </div>
                  </div>
              </div>
              <div class="row align-items-center mt-3 m-0 p-0">
                  <div class="col-2 ">
                      <label for="" class="form-label fw-bold"><%= lib_translate("Coordination_Unit") %></label>
                  </div>
                  <div class="col">
                      <select class="form-select js-choice-my" id="department_help_ids" multiple="multiple" size="1" name="department_help_ids[]" data-options='{"removeItemButton":true,"placeholder":true}'>
                      <% @departments.each do |department| %>
                          <option value="<%= department.id %>"><%= department.name %></option>
                      <%end%>
                      </select>
                  </div>
              </div>
          </div>
