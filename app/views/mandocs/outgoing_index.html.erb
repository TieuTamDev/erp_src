            <button type="submit" class="btn btn-primary pe-5 ps-5 handle_btn"><%= lib_translate("Handle") %></button>
            <button type="button" class="btn btn-warning  pe-5 ps-5" data-bs-dismiss="modal"><%= lib_translate("Cancle") %></button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div> 
