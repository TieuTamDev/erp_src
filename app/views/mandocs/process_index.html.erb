                <div id="page_process_2" class="tab-pane fade"><br>
                  <table id="documents_processed_follow" class="table table-bordered fs--1 mb-0 " style="margin-top: 0px !important; margin-bottom: 0px !important">
                    <thead class="bg-200 text-900" class="display: none;">
