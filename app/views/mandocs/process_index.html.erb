<style>
          .hide-responsive-mobile {
            display: none;
        }
  #loading_screen{
    position: fixed;
    z-index: 9999;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%; 
    background: rgb(0 0 0 / 51%);
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }
  table td{
    white-space: normal !important;
  }
  
</style>
<div style="display: none" id="loading_screen">
    <div class="spinner_handle"></div>
    <p style="color: var(--falcon-avatar-status-border-color);"><%= lib_translate("Inprogress_handle")  %>...</p>
</div>

<div class="list_users">
  <div class="card mb-3">
    <div class="card-body pt-0">
      <div class="tab-content">
        <div class="row">
            <div class="col">
              <h3 class="mt-2 overview_text"><%= lib_translate("Documents_to_be_processed")%></h3>
            </div>
            <div class="col mt-2 ">
            </div> 
        </div>
        <div class="mt-3">
            <!-- Nav tabs -->
            <ul class="nav nav-tabs" role="tablist">
                <li onclick='save_current_tab("tab_1")' class="nav-item">
                <a id="processes_tab_1" class="nav-link active" data-bs-toggle="tab" href="#page_documents_processed"><%= lib_translate("Documents_to_be_processed")%></a>
                </li>
                <li id="li_in_tab_2"  class="nav-item">
                <a id="processes_tab_2" class="nav-link" data-bs-toggle="tab" href="#page_process_2"><%= lib_translate("Status_doccuments")%></a>
                </li>
            </ul>
            <!-- Tab panes -->
            <div class="tab-content">
                <div id="page_documents_processed" class="tab-pane active"><br>
                    <div class="table-responsive scrollbar">
                      <%= render_search_pagination(mandocs_process_index_path()).html_safe %>
                        <table id="documents_processed" class="table table-bordered fs--1 mb-0 " style="margin-top: 0px !important; margin-bottom: 0px !important">
                              <thead class="bg-200 text-900" class="display: none;">
                                  <tr>
                                      <th class="sort" style="width:4%; text-align: center;"><%= lib_translate("Oder")%></th>
                                      <th class="sort" style="width:20%"><%= lib_translate("Received_date")%></th>
                                      <th class="sort" style="width:50%"><%= lib_translate("Content")%></th>
                                      <th class="no-sort col-4 col-md-3 p-0" ></th>
                                  </tr>
                              </thead>
                              <tbody class="list">
                                  <% @arrMandoc.each_with_index do |mandoc, i| %>                             
                                      <tr>  
                                          <td style="vertical-align: middle; text-align: center;"><%= i+1 %></td>
                                          <td style="vertical-align: middle;">
                                              <div style="text-align: start;  display: flex;flex-direction: column;">
                                                  <label style="  white-space: normal; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0" ><%= lib_translate("Received_date")%>: <span style="font-weight: normal;"> <%= mandoc.created_at&.strftime('%k:%M %d/%m/%Y')%></span></label>
                                                  <label style="  white-space: normal; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0"><%= lib_translate("Urgency")%>: <span style="font-weight: bold; color: <%= Mandocpriority.where(name: mandoc.spriority).first.note%>"><%= mandoc.spriority%></span></label>
                                                  <label style=" cursor:pointer; white-space: normal; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0 "><%= lib_translate("Type_book")%>:<span style="font-weight: normal;"><%= mandoc.type_book.present? ? Mandocbook.where(scode: mandoc.type_book).first&.name : "" %></span></label>
                                                  <label style=" cursor:pointer; white-space: normal; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0 "><%= lib_translate("Documents_type")%>:
                                                    <span style="font-weight: normal;">
                                                      <% if mandoc.stype.present? && Mandoctype.where(scode: mandoc.stype).exists? %>
                                                        <%= Mandoctype.where(scode: mandoc.stype).first&.name %>
                                                      <% else %>
                                                        
                                                      <% end %>
                                                    </span>
                                                  </label>
                                              </div>
                                          </td>
                                          <td style="vertical-align: middle;">
                                            <% if !mandoc.sfrom.nil? %>
                                              <div style="text-align: start;  display: flex;flex-direction: column;">
                                                <label style="  white-space: normal; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0" ><%=lib_translate('Excerpts_from_content')%>: <span style="font-weight: normal;"><%= mandoc.contents %></span></label>
                                                <label style="  white-space: normal; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0"><%= lib_translate("Sent_from")%>: <span style="font-weight: normal;"><%= mandoc.sfrom %></span></label>
                                                <label style="  white-space: normal; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0"><span style="font-weight: bold !important;"><%=lib_translate("Sno_book")%>: </span><span style="font-weight: normal;"><%= mandoc.ssymbol%></span></label>
                                                <%if !mandoc.effective_date.nil?%>
                                                  <label style="  white-space: normal; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0"><%= lib_translate('Ngay_ban_hanh')%>: <span style="font-weight: normal;"><%= mandoc.effective_date&.in_time_zone('Asia/Ho_Chi_Minh')&.strftime('%d/%m/%Y') %></span></label>
                                                <%else%>
                                                  <label class="m-0 d-none"></label>
                                                <%end%>
                                              </div>
                                            <% else %>
                                                <%
                                                uUser = User.where(email: mandoc.signed_by).first
                                                if !uUser.nil?
                                                  fullNameU = uUser.last_name + ' ' + uUser.first_name
                                                end
                                                %>
                                              <div style="text-align: start;  display: flex;flex-direction: column;">
                                                <label style="  white-space: normal; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0" ><%=lib_translate('Excerpts_from_content')%>: <span style="font-weight: normal;"><%= mandoc.notes %></span></label>
                                                <label style="  white-space: normal; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0" ><%=lib_translate('Department')%>: <span style="font-weight: normal;"><%= mandoc.mdepartment %></span></label>
                                                <label style="  white-space: normal; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0" ><%=lib_translate('Signed_by')%>: <span style="font-weight: normal;"><%= fullNameU %></span></label>
                                                <label style="  white-space: normal; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0" ><%=lib_translate('Docs_Writer')%>: <span style="font-weight: normal;"><%= mandoc.created_by %></span></label>
                                                <label style="  white-space: normal; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0"><%= lib_translate('Documents_date')%>: <span style="font-weight: normal;"><%= mandoc.received_at&.in_time_zone('Asia/Ho_Chi_Minh')&.strftime('%d/%m/%Y') %></span>&nbsp&nbsp<span style="font-weight: bold !important;"><%=lib_translate("Sno_book")%>: <%= mandoc.ssymbol%></span></label>
                                              </div>
                                            <% end %>
                                          </td>  
                                          <td style="vertical-align: middle; text-align: center; padding:0">
                                            <% if !is_access(session["user_id"], "SP-BANGIAMHIEU","READ") %>
                                              <% if !mandoc.sfrom.nil? %>
                                                  <button class="btn btn-light" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= lib_translate("XULY")%>" onclick="open_form_assign_departments_in_user(this,'<%= mandoc.id %>', '<%= oMandocdhandle = Mandocdhandle.where(mandoc_id: mandoc.id, department_id:  @oDeparment_login.id).last
                                                      if !oMandocdhandle.nil?
                                                          oMandocuhandle = Mandocuhandle.where(mandocdhandle_id: oMandocdhandle.id, user_id: @user.id).last
                                                          if !oMandocuhandle.nil?
                                                            manUhandleId = oMandocuhandle.id 
                                                          else
                                                            manUhandleId = ""
                                                          end 
                                                      end 
                                                      %>')" style="cursor: pointer; color: var(--falcon-btn-falcon-primary-color);">
                                                    <span class="fas fa-users-cog text-warning"></span>
                                                  </button>
                                                  <%
                                                  idDepartmant = ''
                                                  getId = Mandocdhandle.where(mandoc_id:mandoc.id).offset(1).last
                                                  if !getId.nil?
                                                      idDepartmant = getId.department_id
                                                  end     
                                                   oMandocdhandle = Mandocdhandle.where(mandoc_id: mandoc.id, department_id:  @oDeparment_login.id).last
                                                  if !oMandocdhandle.nil?
                                                      oMandocuhandle = Mandocuhandle.where(mandocdhandle_id: oMandocdhandle.id, user_id: @user.id).last
                                                      if !oMandocuhandle.nil?
                                                        manUhandleId = oMandocuhandle.id 
                                                      else
                                                        manUhandleId = ""
                                                      end 
                                                  end    
                                                  mandoc_dhandle_contents_in = ""
                                                  if !mandoc.dhandle_contents.nil?
                                                    mandoc_dhandle_contents_in = URI.encode_www_form_component(mandoc.dhandle_contents)
                                                  end                                       
                                                  %>
                                                  <button type="button" class="btn btn-light" style="background-color: #d0dae7;" data-bs-toggle="tooltip" data-bs-placement="top" title="<%=lib_translate('Confirm_receipt_of_text')%>" onclick="openCheckMandocHandle(this,'<%= mandoc.id %>','<%= mandoc_dhandle_contents_in %>' ,`<%= mandoc.contents%>`,'<%= manUhandleId%>', '<%= idDepartmant%>' )">
                                                    <span class="fas fa-file-signature text-info">
                                                  </button>     
                                              <% else%>
                                              <!-- cHỌN PB HOẶC CHUYỂN VỀ VT XỬ LÍ VĂN BẢN - BLĐ -->
                                              <button class="btn btn-light open_form_assign_process" data-mandoc-id="<%= mandoc.id %>" type="button" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= lib_translate("XULY")%>" onclick="openFormChon(this)"><span class="fas fa-users-cog text-warning">
                                              </button>
                                              <!-- END -->
                                                  <% mandoc_dhandle_contents_out = ""
                                                      if !mandoc.dhandle_contents.nil?
                                                        mandoc_dhandle_contents_out = URI.encode_www_form_component(mandoc.dhandle_contents)
                                                      end  %>
                                                  <button class="btn btn-light update-mandocuhandle_process open_form_assign_vt d-none" data-form-code="FORM-ASSIGN-VT" data-mandoc-id="<%= mandoc.id %>"  onclick="open_form_assign_departments('<%= mandoc.id %>', '<%= mandoc_dhandle_contents_out %>', '<%= mandoc.sfrom %>'
                                                , '<%= if !mandoc.received_at.nil?
                                                      (mandoc.received_at + 15.days)&.strftime('%d/%m/%Y')
                                                      else 
                                                      ''
                                                      end %>'
                                                , '<%= if !mandoc.effective_date.nil?
                                                      (mandoc.effective_date + 15.days)&.strftime('%d/%m/%Y')
                                                      else 
                                                      ''
                                                      end %>'
                                                , '<%= oMandocdhandle = Mandocdhandle.where(mandoc_id: mandoc.id, department_id:  @oDeparment_login.id).last
                                                      if !oMandocdhandle.nil?
                                                          oMandocuhandle = Mandocuhandle.where(mandocdhandle_id: oMandocdhandle.id, user_id: @user.id).last
                                                          if !oMandocuhandle.nil?
                                                            manUhandleId = oMandocuhandle.id 
                                                          else
                                                            manUhandleId = ""
                                                          end  
                                                      end 
                                                      %>', '<%= if !Department.where(name: mandoc.mdepartment).first.nil?
                                                                  Department.where(name: mandoc.mdepartment).first.id
                                                                end
                                                      %>')" data-uhandle-process-id="<%= manUhandleId %>" data-toggle="tooltip" data-placement="top" title='<%= lib_translate("XULY")%>' style="cursor: pointer; padding-right: 2%; color: var(--falcon-btn-falcon-primary-color);">
                                                    <span class="fas fa-users-cog text-warning"></span>
                                                  </button>
                                                  <button class="open_form_assign_pb d-none" data-form-code="FORM-ASSIGN-PB" data-mandoc-id="<%= mandoc.id %>" onclick="open_form_assign_departments_vt('<%= mandoc.id %>', '<%= mandoc_dhandle_contents_out %>', '<%= mandoc.sfrom %>'
                                                    , '<%= if !mandoc.received_at.nil?
                                                          (mandoc.received_at + 15.days)&.strftime('%d/%m/%Y')
                                                          else 
                                                          ''
                                                          end %>'
                                                    , '<%= if !mandoc.effective_date.nil?
                                                          (mandoc.effective_date + 15.days)&.strftime('%d/%m/%Y')
                                                          else 
                                                          ''
                                                          end %>'
                                                    , '<%= oMandocdhandle = Mandocdhandle.where(mandoc_id: mandoc.id, department_id:  @oDeparment_login.id).last
                                                          if !oMandocdhandle.nil?
                                                              oMandocuhandle = Mandocuhandle.where(mandocdhandle_id: oMandocdhandle.id, user_id: @user.id).last
                                                              if !oMandocuhandle.nil?
                                                                manUhandleId = oMandocuhandle.id 
                                                              else
                                                                manUhandleId = ""
                                                              end  
                                                          end 
                                                          %>', '<%= if !Department.where(name: mandoc.mdepartment).first.nil?
                                                                      Department.where(name: mandoc.mdepartment).first.id
                                                                    end
                                                          %>')" class="btn btn-light" type="button" data-bs-toggle="modal" data-bs-target="#form_xu_ly_phan_PB_VBD"><span class="fas fa-users-cog text-warning"></button>
                                                  
                                              <%end%>
                                            <%end%>
                                              <%# Nút xem văn bản %>   
                                              <button class="btn btn-light preview-mandoc" onclick=openModal(this) data-id="<%= mandoc.id%>" data-toggle="tooltip" data-placement="top" title="<%=lib_translate('View_document')%>">
                                                <span class="fas fa-folder-open icon text-warning"></span>
                                              </button>

                                              <% oFile = Mandocfile.where(mandoc_id: mandoc.id)
                                              arrFileDowload = []
                                              if !oFile.nil?
                                                oFile.each do |file_mandoc|
                                                  oMefiafile = Mediafile.where(id: file_mandoc.mediafile_id).first
                                                  if !oMefiafile.nil?  
                                                    arrFileDowload.push("#{request.base_url}/mdata/hrm/#{oMefiafile.file_name}")
                                                  end
                                                end
                                              end %>
                                            <a target="_blank" class="btn btn-light" data-toggle="tooltip" title="<%=lib_translate('Tải toàn bộ tài liệu')%>"
                                              onclick="zipFileAfterDownload(<%= arrFileDowload %>, '<%= !mandoc.contents.nil? && !mandoc.contents.empty? ? mandoc.contents : mandoc.notes %>')">
                                                <span class="fas fa-download">
                                              </a>
                                              <% if !is_access(session["user_id"], "SP-BANGIAMHIEU","READ") %>
                                                <button type="button" class="btn btn-light" data-bs-toggle="modal" data-bs-target="#check_mandocs_cancel" onclick="openCheckMandoc('<%= mandoc.id %>','<%= oMandocdhandle = Mandocdhandle.where(mandoc_id: mandoc.id, department_id:  @oDeparment_login.id).last
                                                        if !oMandocdhandle.nil?
                                                            oMandocuhandle = Mandocuhandle.where(mandocdhandle_id: oMandocdhandle.id, user_id: @user.id).last
                                                            if !oMandocuhandle.nil?
                                                              manUhandleId = oMandocuhandle.id 
                                                            else
                                                              manUhandleId = ""
                                                            end 
                                                        end 
                                                        %>', `<%=mandoc.contents%>` )" data-toggle="tooltip" data-placement="top" title="<%=lib_translate('Xác nhận hủy')%>">
                                                    <span class="fas fa-file-excel text-danger">
                                                </button>
                                              <%end%>

                                              <button class="btn btn-light"  onclick=openModal(this) data-target="#tinh_trang_<%=mandoc.id%>" data-toggle="tooltip" data-placement="top" title='<%= lib_translate("View_status") %>' >
                                                <span class="fas fa-list-ol text-success">
                                              </button>
                                              <div class="modal fade" id="tinh_trang_<%=mandoc.id%>" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true" style=" background: rgba(0, 0, 0, 0.84); overflow-y: scroll;">
                                                <div class="modal-dialog" style="max-width: 80%; width: 100%; display: flex; align-items: center;">
                                                  <div class="modal-content p-3" style=" background: var(--falcon-avatar-status-border-color);">
                                                      <div class="position-absolute top-0 end-0 mt-2 me-2 z-index-1">
                                                      <button class="btn-close btn btn-sm btn-circle d-flex flex-center transition-base" data-bs-dismiss="modal" aria-label="Close"></button>
                                                    </div>
                                                    <div class="modal-header d-flex justify-content-left" >                                                   
                                                      <p class="fs-1 fw-bold"><%= lib_translate("Document_processing") %></p>                                                       
                                                    </div> 
                                                    <div style=" background: var(--falcon-avatar-status-border-color);padding: 20px;">
                                                      <h5 style="float:left; opacity: .5;"><span class="fw-bold"><%= lib_translate("Status") %>: </span>
                                                        <% if mandoc.status != "INACTIVE"%>
                                                            <span class="text-warning" ><%= lib_translate("Document_processing_status") %></span>
                                                        <% else%>
                                                            <span class="text-success"  ><%= lib_translate("Document_processed_status") %></span>
                                                        <%end%>   
                                                      </h5>
                                                      <table class="table table-bordered fs-0 mb-0 table-hover ">
                                                          <thead class="text-white" style="background: var(--falcon-bg-circle-shape-bg);">
                                                                <tr>
                                                                    <th ><%= lib_translate("Handler") %></th>
                                                                    <th style="width: 6%;"><%= lib_translate("Role") %> <a id="onclick_customs_table" class="ms-3" tabindex="0" role="button" data-bs-toggle="popover" title="Cấu hình hiển thị vai trò xử lý" data-bs-content=" "><span class="fas fa-caret-down text-100"></span></a></th>
                                                                    <th style="width: 12%;"><%= lib_translate("Day_Process") %></th>
                                                                    <th style="width: 7%;"><%= lib_translate("Deadline_process") %></th>
                                                                    <th style="width: 15%;"><%= lib_translate("Content_process") %></th>
                                                                    <th style="width: 7%;"><%= lib_translate("Status") %></th>
                                                                    <th style="width: 4%;"><%= lib_translate("Read") %></th>
                                                                </tr>
                                                          </thead>
                                                          <tbody>
                                                            <%  mandoc = Mandoc.where(id: mandoc.id).first
                                                                    if !mandoc.nil? %>
                                                                          <tr style="text-align: left" data-show="TIEPNHAN">
                                                                            <td class="text-success"> <%= mandoc.created_by %> <b>[<%= if mandoc.sfrom.nil?
                                                                              mandoc.mdepartment
                                                                            else
                                                                              id_department_first = Mandocdhandle.where(mandoc_id: mandoc.id).first&.department_id
                                                                              Department.where(id: id_department_first).first&.name
                                                                            end%>]</b></td>
                                                                            <td> <%= !mandoc.contents.nil? && !mandoc.contents.empty? ? lib_translate("TIEPNHAN") : lib_translate("SOANTHAO") %></td>
                                                                            <td><%= mandoc.created_at&.strftime("%k:%M %d/%m/%Y")%></td>
                                                                            <td></td> 
                                                                            <td><div style="white-space: pre-line;">Thiết lập văn bản</div></td>
                                                                            <td><%= lib_translate("DAXULY")%></td>
                                                                            <td><%= lib_translate("CO")%></td>
                                                                          </tr>
                                                                          <%
                                                                            
                                                                            mandoc&.mandocuhandles&.order(created_at: :asc).each do |uhan|
                                    
                                                                          %>  
                                                                         
                                                                            <tr style="text-align: left" data-show="<%= uhan.srole == "TIEPNHAN" ? "XULY" : uhan.srole %>">
                                                                              <td style="white-space: pre-line;"> <span class="fas fa-grip-lines"></span><span class="fas fa-chevron-right"></span> <%= uhan.user.last_name%> <%= uhan.user.first_name%>  <b>[<%= uhan&.mandocdhandle&.department&.name%>]</b></td>
                                                                              <td><%= uhan.srole == "XULY" ? lib_translate("XULY") : uhan.srole == "DEBIET" ? lib_translate("DEBIET") : uhan.srole == "PHOIHOPXL" ? lib_translate("PHOIHOPXL") : lib_translate("XULY")%></td>
                                                                              <td><%= uhan.created_at&.strftime("%k:%M %d/%m/%Y")%></td>
                                                                              <%if !uhan.deadline.nil?%>
                                                                              <td><%= uhan.deadline&.strftime(" %d/%m/%Y")%></td>
                                                                              <%else%>
                                                                                <td></td>
                                                                              <%end%>
                                                                              <td><div style="white-space: pre-line;"><%= uhan.contents %></div></td>
                                                                              <td><%= uhan.sothers == "HUYBOXULY" ? "Thay thế" : uhan.status == "DAHUY" ? lib_translate("Cancel_handle") : uhan.status == "CHUAXULY" ? lib_translate("CHUAXULY") : uhan.status == "PHOIHOPXL" ? lib_translate("PHOIHOPXL") : uhan.status == "DAXULY" && uhan.srole != "PHOIHOPXL" ? lib_translate("DAXULY") : lib_translate("PHOIHOPXL") %></td> 
                                                                              <td><%= uhan.sothers == "HUYBOXULY" ? "" : uhan.sread == "KHONG" ? lib_translate("KHONG") : uhan.sread == "CO" ? lib_translate("CO") : lib_translate("KHONG") %></td>  
                                                                            </tr> 
                        
                                                                        <% end %>
                                                                  <% end %>
                                                          </tbody>
                                                      </table>
                                                    </div>
                                                  </div>
                                                </div>
                                              </div>
                                          </td>                          
                                      </tr>
                                  <% end %>
                              </tbody>
                        </table>
                     <%= render_pagination_limit_offset(mandocs_process_index_path(lang: session[:lang], per_page: session[:per_page], search: session[:search]), 10, @arrMandoc.count).html_safe %>

                    </div>
                </div>
                <!-----form xem tất cả văn bản kèm trạng thái đang xử lí
