<% content_for :head do %>
  <%= stylesheet_link_tag "select2-bootstrap-5-theme.min" %>
  <%= stylesheet_link_tag "select2.min.css" %>
  <%= stylesheet_link_tag "/assets/mystyle/flatpickr.min.css" %>
  <%= stylesheet_link_tag "/assets/mystyle/mandoc_search.css" %>
<% end %>

<% content_for :bottombody do %>
    <%= javascript_include_tag 'select2.full.min.js'%>
    <%= javascript_include_tag '/assets/myjs/flatpickr.js'%>
  <%= javascript_include_tag '/assets/myjs/flatpickr_local/vn.js' %>
    <%= javascript_include_tag '/assets/myjs/mandoc_search.js' %>
<% end %>

<div class="card mb-3 p-3">
    <h5 class="mt-1 mb-2"><%= lib_translate("Search_mandoc")%></h5>
    <%= form_tag 'search_mandoc',controller: 'mandocs',method:'GET',id:'form-search-mandoc',remote:true,authenticity_token: true do %>
        <div style="display: flex; flex-wrap: wrap;">
            <div class="form-group me-3">
                <label for="type_book"><%= lib_translate("Type_book")%></label>
                <select name="type_book" class="form-select selectpicker">
                    <option value=''><%= lib_translate("All")%></option>
                    <% @mandocbooks.each do |mandoc_book|%>
                        <option value="<%= mandoc_book.scode%>"><%= mandoc_book.name%></option>
                    <%end%>
                </select>
            </div>
            <div class="form-group me-3">
                <label for="mandoc_stype"><%= lib_translate("Mandoc_Type")%></label>
                <select name="mandoc_stype" class="form-select selectpicker">
                    <option value=''><%= lib_translate("All")%></option>
                    <% @mandoctypes.each do |mandoc_type|%>
                        <option value="<%= mandoc_type.scode%>"><%= mandoc_type.name%></option>
                    <%end%>
                </select>
            </div>
        </div>
        <div class="mt-3" style="display:flex; ">
            <div class="form-group me-3">
                <label class="form-label"><%= lib_translate("Date_from")%></label>
                <div class="form-control calendar-wrap">
                    <span class="far fa-calendar-alt"></span>
                    <label for="dt_from" class="calendar-display" id="start_date_display" data-display="dt_from" ></label>
                </div>
                <input class="form-control datetimepicker" id="dt_from" name="dt_from" type="text" style="width: 0;height: 0;padding: 0;opacity: 0;" placeholder="dd/mm/yyyy" data-options='{"disableMobile":true}' />
            </div>
            <div class="form-group">
                <label class="form-label"><%= lib_translate("Date_to")%></label>
                <div class="form-control calendar-wrap">
                    <span class="far fa-calendar-alt"></span>
                    <label for="dt_to" class="calendar-display" id="start_date_display" data-display="dt_to" ></label>
                </div>
                <input class="form-control datetimepicker" id="dt_to" name="dt_to" type="text" style="width: 0;height: 0;padding: 0;opacity: 0;" placeholder="dd/mm/yyyy" data-options='{"disableMobile":true}' />
            </div>
            <% if is_access(session["user_id"], "MANDOCS-SEARCH","EDIT")%>
                <div class="form-group ms-3">
                    <label for=""><%=lib_translate("Status")%></label>
                    <div class="form-check form-switch" style="user-select: none;">
                        <input style="cursor: pointer;" name="in_work" class="form-check-input" id="filter-efect" type="checkbox" checked="true" />
                        <label style="cursor: pointer;" class="form-check-label" for="filter-efect"><%= lib_translate("Still_validated")%></label>
                    </div>
                </div>
            <% end%>
        </div>
        <div class="form-group mt-3" style="width:50%;">
            <label><%= lib_translate("Keyword")%></label>
            <input name="search" class="form-control" type="text" placeholder="Số văn bản / Nội dung / Mô tả" />
        </div>
        <div class="mt-3">
            <button id="btn-submit-search" class="btn btn-primary" type="submit" onclick="clickSearch(this)">
                <span class="submit-text"><%= lib_translate("Search")%></span>
                <span class="submit-loadding" style="display:none;">
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> <%= lib_translate("Loading")%>...
                </span>
            </button>
        </div>
        <table id="table_mandoc_search" class="table table-bordered table-striped fs--1 mb-0 mt-3">
            <thead class="bg-200 text-900">
                <tr>
                    <th class="no-sort" style="text-align: center;width: 89px;"><%= lib_translate("STT") %></th>
                    <th class="no-sort" style="width: 250px;"><%=lib_translate("Sno_book")%></th>
                    <th class="no-sort" style="cursor: unset;"><%=lib_translate("Content")%></th>
                    <th class="no-sort" style="width: 260px;text-align: center;"><%=lib_translate("Effect")%></th>
                    <th class="no-sort" style="text-align: center;width: 145px;"></th>
                </tr>
            </thead>
            <tbody class="list"></tbody>
        </table>
        <input type="text" name="page" value="1" hidden>
        <input type="text" name="per_page" value="10" hidden>
        <div id="pagin-wrap"></div>
    <%end%>
</div>

<div class="modal fade" id="modal-un-mandoc" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" role="document" style="min-width: 50%">
    <div class="modal-content position-relative">
      <div class="position-absolute top-0 end-0 mt-2 me-2 z-index-1">
        <button class="btn-close btn btn-sm btn-circle d-flex flex-center transition-base" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-0">
        <div class="rounded-top-lg py-3 ps-4 pe-6 bg-light">
          <h4 class="mb-1"><%= lib_translate("Stop_mandoc_effect")%></h4>
        </div>
        <div class="p-2 ps-4 pe-4">
            <%= form_tag 'mandoc_un_effect',controller: 'mandocs',method:'PUT',id:'form-un-effect-mandoc',remote:true,authenticity_token: true do %>
                <div class="form-group me-3">
                    <label class="form-label"><%= lib_translate("Date_expire")%></label>
                    <div class="form-control calendar-wrap">
                        <div>
                            <span class="far fa-calendar-alt"></span>
                            <input class="form-control datetimepicker" id="date_expire_picker" type="text" style="width: 0;height: 0;padding: 0;opacity: 0;" placeholder="dd/mm/yyyy" data-options='{"disableMobile":true}' />
                        </div>
                        <label for="date_expire_picker" style="width: 100%;" class="calendar-display" data-display="date_expire_picker" ></label>
                    </div>
                </div>
                <div class="form-check mt-2">
                    <input style="cursor: pointer;" class="form-check-input" id="type_child_end" type="checkbox" name="select_dchild" value="child"/>
                    <label style="cursor: pointer;" class="form-check-label" for="type_child_end">Văn bản đã được thay thế</label>
                </div>

                <div id="dchild_wrap" class="mb-3 collapse">
                    <label class="form-label"><%=lib_translate("Mandoc")%></label>
                    <select class="form-select" id="dchild-select" size="1" name="dchild"></select>
                </div>

                <input type="text" id="mandoc_id" name="mandoc_id" style="display:none" hidden>
                <input type="text" id="date_expire" name="date_expire" style="display:none" hidden>
                <div style="text-align: center;">
                    <span class="badge badge-soft-danger mb-3" id="valid-msg" style="font-size: 0.8em;padding: 7px 12px;"></span>
                </div>
            <%end%>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" type="button" data-bs-dismiss="modal"><%=lib_translate("Close")%></button>
            <button id="btn-submit-un-effect" class="btn btn-primary" type="button" onclick="clickSubmitUnEffect(this)">
                <span class="submit-text"><%=lib_translate("Confirm")%></span>
                <span class="submit-loadding" style="display:none;">
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> <%= lib_translate("Processing")%>...
                </span>
            </button>
        </div>
      </div>
    </div>
  </div>
</div>

<div id="translate" hidden>
    <p data-key="Download" data-trans="<%=lib_translate('Download')%>"></p>
    <p data-key="View_document" data-trans="<%=lib_translate('View_document')%>"></p>
    <p data-key="Still_validated" data-trans="<%=lib_translate('Still_validated')%>"></p>
    <p data-key="Expire" data-trans="<%=lib_translate('Expire')%>"></p>
    <p data-key="Ngay_ban_hanh" data-trans="<%=lib_translate('Ngay_ban_hanh')%>"></p>
    <p data-key="Effective_date" data-trans="<%=lib_translate('Effective_date')%>"></p>
    <p data-key="Is_replaced_by" data-trans="<%=lib_translate("Is_replaced_by")%>"></p>
    <p data-key="Loading" data-trans="<%=lib_translate("Loading")%>"></p>
    <p data-key="Loading_more" data-trans="<%=lib_translate("Loading_more")%>"></p>
    <p data-key="Choose_document" data-trans="<%=lib_translate("Choose_document")%>"></p>
</div>

<script>
    let search_ajax_path = '<%= mandocs_select_search_mandoc_path%>';
    let datepick_local = '<%= session[:lang] == 'vi' ? "vn" : "default" %>';
</script>