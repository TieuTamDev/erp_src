<style>
    body{
        font-family: 'Inter';
    }
    .contaner{
        display: flex;
        width: 100vw;
        height: 100vh;
        justify-content: center;
        align-items: center;
    }
    .layout-left,.layout-right{
        display: flex;
        flex: 1;
    }
    .layout-left{
        justify-content: end;
        padding-right: 10px;
    }
    .layout-right{
        flex-direction: column;
        align-items: baseline;
        padding-left: 10px;
    }
    .message-1,.message-2{
        font-size: 24px;
        font-weight: 600;
        color:#333333;
    }
    .message-2{
        font-size: 24px;
        color:#4A63AE;
    }
    .message-link{
        color:#0066FF;
        margin-bottom: 17px;
    }
    .message-link a{
        color:#0066FF;
        text-decoration: none;
    }
    .link-text{
        font-size: 18px;
        font-weight: 500;
    }
    .home-button{
        padding: 10px 15px 10px 15px;
        color: white;
        font-size: 20px;
        background-color: #3E8BFF;
        text-decoration: none;
        border-radius: 10px;
    }

</style>
