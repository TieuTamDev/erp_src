            <button class="btn btn-success" onclick="saveSurvey()">Lưu</button>
            <button class="btn btn-primary" onclick="addGroup()"><span class="fas fa-plus"> </span> Thêm nhóm</button>
        </div>
  </div>
<%end%>

<div style="background: #F9FAFD;" class="card mt-2">
