<% content_for :head do %>
  <%= stylesheet_link_tag "/assets/mystyle/resourcestyle/resource.css" %>
<% end %>
<div class="list_users">
  <div class="bmtu_header_dashboard">
    <h3 class="mt-2 overview_text"><%= lib_translate("List_resource")  %></h3>
  </div>
  <div class="card mb-3">
    <div class="card-body pt-0">
      <div class="tab-content">
           <% if is_access(session["user_id"], "RESOURCE","ADD") %>
        <button onclick="openFormAddResource()" class="btn btn-primary btn-add-user mt-3" id="btn-add-user" data-bs-toggle="modal" data-bs-target="#modal-religions">
          <%= lib_translate("Add_resource")  %>
        </button>          
        <% end %>
        <%= render_search_pagination(resource_edit_path()).html_safe %>
        <table id="table_resource" class="table table-bordered fs--1 mb-0 table-hover" style="margin-top: 0px !important; margin-bottom: 0px !important">
          <thead class="bg-200 text-900">
            <tr>
              <th data-sort="id" style="display: none;">ID</th>
              <th class="sort" data-sort="url" style="text-align: center; cursor: pointer;"><%= lib_translate("Url")  %></th>
              <th class="sort" data-sort="scode" style="text-align: center; cursor: pointer;"><%= lib_translate("Scode")  %></th>
              <th class="sort" data-sort="app" style="text-align: center; cursor: pointer;"><%= lib_translate("App")  %></th>
              <th style="text-align: center; cursor: pointer;" class="sort" data-sort="status"><%= lib_translate("Status")  %></th>
             <% if (is_access(session["user_id"], "RESOURCE","EDIT") || is_access(session["user_id"], "RESOURCE","DEL")) %>
                <th class="no-sort" style="text-align: center"></th>
                <% end %>
            </tr>
          </thead>
          <tbody class="list">
            <% @resources.each do |resource| %>
                <tr>
                    <td style="display: none;">
                        <%= resource.id %>
                    </td>
                    <td class="url" >
                      <% if resource.status=="ACTIVE"  %>
                            <a href="<%= resource.url %>" target="blank" style="color: blue;"><%= resource.url %></a>
                      <%else%>
                            <%= resource.url %>
                      <%end%>
                    </td>
                    <td class="scode">
                        <%= resource.scode %>
                    </td>
                    <td class="app">
                        <%= resource.app %>
                    </td>
                    <td style="text-align: center" class="status">
                    
                      <%= (if resource.status=="ACTIVE" 
                        lib_translate("ac_icon")
                      else 
                        lib_translate("inac_icon")
                      end ) %>
                    </td>
                   <% if (is_access(session["user_id"], "RESOURCE","EDIT") || is_access(session["user_id"], "RESOURCE","DEL")) %>
                    <td style="min-width: 100px; text-align: center;">
                        <% if is_access(session["user_id"], "RESOURCE","EDIT") %>
                          <a class="edit_resource" style="text-decoration: none;"
                          onclick="openFormUpdateResource('<%= resource.id %>', '<%= resource.url %>', '<%= resource.scode %>',
                          '<%= resource.app %>', '<%= resource.status %>')" data-bs-toggle="modal" data-bs-target="#modal-religions">
                          <span class="text-primary fas fa-edit me-3" style="width: 15px"></span>
                          </a>
                        <% end %>
                           <% if is_access(session["user_id"], "RESOURCE","DEL") %>
                          <!-- Button trigger modal -->
                          <a data-toggle="modal" data-target="#modal-resource-delete-<%= resource.id %>" style="cursor: pointer;">
                          <span class="text-danger fas fa-trash" style="width: 12px;"></span>
                          </a>
                        <% end %>
                        <!-- Modal -->
                        <div class="modal fade" id="modal-resource-delete-<%= resource.id %>" tabindex="-1" role="dialog"
                        aria-labelledby="exampleModalLabel" aria-hidden="true">
                        <div class="modal-dialog" role="document">
                            <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title" id="exampleModalLabel"><%= lib_translate("Are_you_sure")  %></h5>
                                <button type="button" class="close" data-dismiss="modal" aria-label="Close" style=" border: none;background: none;">
                                <span aria-hidden="true" style="font-size: 20px;">&times;</span>
                                </button>
                            </div>
                            <div class="modal-body">
                                <%= lib_translate("Are_you_sure_to_delete_this_resource_url")  %><p style="font-weight:bold; color:red;"> <%= resource.url %> </p>?
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-dismiss="modal"><%= lib_translate("Close")  %></button>
                                <%= link_to lib_translate("Delete"), url_for(action: :del, id: resource.id), method: :delete, class: "btn btn-danger", id: "btn_delete_resource", onclick: "delete_loading_resource(this)" %>
                                <div id="loading_button_delete_resource" class= "btn btn-danger" style="opacity: 0.8; display:none;" >
                                  <i class ="fa fa-spinner fa-spin"> </i>  <%=lib_translate("Deleting")%> 
                                </div>
                            </div>
                            </div>
                        </div>
                        </div>
                    </td>
                <% end %>
                </tr>
            <% end %>
          </tbody>
        </table>
        <%= render_pagination_limit_offset(resource_edit_path(lang: session[:lang], per_page: session[:per_page], search: session[:search]), 10, @resources.count).html_safe %>
      </div>
    </div>
  </div>

</div>
<!-- modal -->
<div class="modal fade" id="modal-religions" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
    <div class="modal-content position-relative">
      <div class="position-absolute top-0 end-0 mt-2 me-2 z-index-1">
        <button class="btn-close btn btn-sm btn-circle d-flex flex-center transition-base" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-0">
        
        <div class="rounded-top-lg py-3 ps-4 pe-6 bg-light">
          <h4 class="mb-1" id="cls_bmtu_form_add_title"><%= lib_translate("CREATE_RESOURCE")  %></h4>
        </div>
        <div class="p-4 pb-0">
          <div id="error_explanation" class="text-danger" style="text-align: center;font-size: 13px;"></div>
          <div class="form-add-resource">
            <%= form_for @resource, :url=> resource_update_path, html: {method: :post, id:"form_add_resource",class:'col-12' } do |f| %>
              <div class="erro_labble mb-2">
                  <p style="display:none; color: rgb(197 82 82);border: 1px solid rgb(199 136 136 / 23%);background: rgb(255 54 54 / 16%);border-radius: 5px;padding: 10px"
                  id="erro_labble_content">
                  </p>
              </div>
              <div class="row mb-3" style="display:none;">
                <%= f.label :id, class: "col-sm-3 col-form-label" %>
                <div class="col-sm-9">
                      <%= f.text_field :id, class: 'form-control' , name: 'resource_id_add' %>
                </div>
              </div>
              <div class="row mb-3"> 
                    <label class="col-sm-4 col-lg-3 col-form-label" for="inputEmail3"><%= lib_translate("Url") %>:<span style="color:red;" class="red">*</span></label>
                <div class="col-sm-8 col-lg-9 ">
                <%= f.text_field :url, class: 'form-control',  name:'resource_url_add' %>
                </div>
              </div>
              <div class="row mb-3"> 
                    <label class="col-sm-4 col-lg-3 col-form-label" for="inputEmail3"><%= lib_translate("Scode") %>:<span style="color:red;" class="red">*</span></label>
                <div class="col-sm-8 col-lg-9 ">
                            <%= f.text_field :scode, class: 'form-control' , name: 'resource_scode_add' %>
                </div>
              </div>
              <div class="row mb-3">
                <label  class="col-sm-4 col-lg-3 col-form-label"><%= lib_translate("App") %>:<span style="color:red;" class="red">*</span></label>
                <div class="col-sm-8 col-lg-9 ">
                  <select class="form-select" id="resource_app" size="1" required="required" name="resource_app_add" data-options='{"removeItemButton":true,"placeholder":true}'>
                    <option>BMTU HRM</option>
                    <option>Website BMTU</option>
                    <option>Happiness Foundation</option>
                    <option>Phần mềm khảo thí</option>
                    <option>Phần mềm E-learning BMTU</option>
                  </select>
                  <div class="invalid-feedback">Please select one</div>
                </div>
              </div>
              <fieldset>
                <div class="row mb-3" style="align-items: center;">
                  <label class="col-sm-4 col-lg-3 col-form-label" for="inputEmail3"><%= lib_translate("Status") %>:</label>
                  <div class="col-sm-8 col-lg-9">
                    <div class="row">
                      <div class="col-auto">
                        <input checked type="radio" id="resource_status_active" class="form-check-input" value="ACTIVE" name="resource_status_add" /> <label class="form-check-label" for="resource_status_active" style="cursor: pointer"> ACTIVE</label>
                      </div>
                      <div class="col-auto">
                        <input  type="radio" id="resource_status_inactive" class="form-check-input" value="INACTIVE" name="resource_status_add" /> <label class="form-check-label" for="resource_status_inactive" style="cursor: pointer"> INACTIVE</label>
                      </div>
                    </div>
                  </div>
                </div>
              </fieldset>
              <div class="modal-footer border-0 p-0 mb-2">
                <%= f.submit "" , type:"button" , id:"btn_add_new_resource_buttton",
                  class: "btn btn-warning border-red border-pink-600 cls-bmtu-text-red md:group-hover:bg-pink-50 btn-block btn-block text-uppercase "%>
                  <div id="loading_button_resource" class= "btn btn-warning border-red border-pink-600 cls-bmtu-text-red md:group-hover:bg-pink-50 btn-block btn-block text-uppercase " style="opacity: 0.8;display:none;" >
                        <i class ="fa fa-spinner fa-spin"> </i>  <%=lib_translate("Save")%> 
                  </div>
              </div>
            <% end %>
            </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
  // Translate
    let translate_error_scode_1 = "<%= lib_translate("Ma_scode_da_ton_tai")  %>";
    let translate_btn_create = "<%= lib_translate("CREATE_RESOURCE")  %>";
    let translate_btn_update = "<%= lib_translate("UPDATE_RESOURCE")  %>";
    let translate_error1 = "<%= lib_translate("ERROR1")  %>";
    let translate_error3 = "<%= lib_translate("ERROR3")  %>";
    let url_resource_required_path = "<%= resource_required_path %>";
</script>  

<%= javascript_include_tag "/assets/myjs/resourcejs/resource.js" %>
<!-- Lê Ngọc Huy -->
<%= javascript_include_tag '/assets/lib_hrm/jquery-3.2.1.slim.min.js', integrity: 'sha384-KJ3o2DKtIkvYIK3UENzmM7KCkRr/rE9/Qpg6aAZGJwFDMVNA/GpGFF93hXpG5KkN', crossorigin: 'anonymous' %>
<%= javascript_include_tag '/assets/lib_hrm/popper.min.js', integrity: 'sha384-ApNbgh9B+Y1QKtv3Rn7W3mgPxhU9K/ScQsAP7hUibX39j7fakFPskvXusvfa0b4Q', crossorigin: 'anonymous' %>
<%= javascript_include_tag '/assets/lib_hrm/bootstrap.min.js', integrity: 'sha384-JZR6Spejh4U02d8jOt6vLEHfe/JQGiRRSQQxSfFWpi1MquVdAyjUar5+76PVCmYl', crossorigin: 'anonymous'%>
<script src="<%= javascript_path "/assets/lib_hrm/jquery-3.1.1.min.js" %>"></script>
