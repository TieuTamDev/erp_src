<div class="list_gsurvey">
  <div class="bmtu_header_dashboard">
    <h3 class="mt-2 overview_text"><%= lib_translate("Dánh sách nhóm khảo sát")  %></h3>
  </div>
  <div class="card mb-3">
    <div class="card-body pt-0">
      <div class="tab-content">
        <button onclick="openFormAddGsurvey()"  class="btn btn-primary btn-add-user mt-3 mb-2" id="btn-add-user" data-bs-toggle="modal" data-bs-target="#modal-gsurvey">
        <%= lib_translate("Thêm nhóm khảo sát")  %>
        </button>
      <%= render_search_pagination(gsurveys_index_path()).html_safe %>
      <table id="table_gsurvey" class="table table-bordered fs--1 table-hover mt-2 mb-2">
        <thead class="bg-200 text-900">
          <tr>
            <th class="sort" data-sort="url" style=""><%= lib_translate("Tên")  %></th>
            <th class="sort" data-sort="url" style=""><%= lib_translate("Thứ tự")  %></th>
            <th style="" class="sort" data-sort="status"><%= lib_translate("Status")  %></th>
            <th class="no-sort" style="text-align: center"></th>
          </tr>
        </thead>
        <tbody class="list">
          <% @gsurveys.each do |gsurvey| 
            oQuestion = Qsurvey.where(gsurvey_id: gsurvey.id).first
            is_use = false
            if !oQuestion.nil?
              is_use = true
            end
          %>
                      <tr>
                          <td class="name"> <%= gsurvey.name %> </td>                          
                          <td class="name"> <%= gsurvey.iorder %> </td>                          
                          <td style="text-align: center" class="status">
                            <%= (if gsurvey.status=="ACTIVE" 
                              lib_translate("ac_icon")
                            else 
                              lib_translate("inac_icon")
                            end ) %>
                          </td>
                          <td style="min-width: 100px; text-align: center;"> 
                              <%if !is_use%>                                                 
                                <a style="cursor: pointer;" class="edit_form" style="text-decoration: none;"
                                    onclick='openFormUpdateform(
                                      `<%=   gsurvey.id %>`, 
                                      `<%= escape_javascript(gsurvey.name.to_s) %>`, 
                                      `<%= escape_javascript(gsurvey.code.to_s) %>`,
                                      `<%= escape_javascript(gsurvey.iorder.to_s) %>`,
                                      `<%= escape_javascript(gsurvey.note.to_s) %>`, 
                                      `<%= escape_javascript(gsurvey.status.to_s) %>`)'
                                      data-bs-toggle="modal" data-bs-target="#modal-gsurvey">
                                    <span class="text-primary fas fa-edit me-3" style="width: 15px"></span>
                                </a>
                                <!-- Button trigger modal -->
                                <a data-toggle="modal" data-target="#modal-gsurvey-delete-<%= gsurvey.id %>" style="cursor: pointer;">
                                  <span class="text-danger fas fa-trash" style="width: 12px;"></span>
                                </a>
                              <%else%>
                                <a style="opacity:0" >
                                    <span class="text-primary fas fa-edit me-3" style="width: 15px"></span>
                                </a>
                                <!-- Button trigger modal -->
                                <a style="opacity:0">
                                  <span class="text-danger fas fa-trash" style="width: 12px;"></span>
                                </a>
                              <%end%>    
                              <!-- Modal -->
                              <div class="modal fade" id="modal-gsurvey-delete-<%= gsurvey.id %>" tabindex="-1" role="dialog"
                              aria-labelledby="exampleModalLabel" aria-hidden="true">
                              <div class="modal-dialog" role="document">
                                  <div class="modal-content">
                                  <div class="modal-header">
                                      <h5 class="modal-title" id="exampleModalLabel"><%= lib_translate("Are_you_sure")  %></h5>
                                      <button type="button" class="close" data-dismiss="modal" aria-label="Close" style=" border: none;background: none;">
                                      <span aria-hidden="true" style="font-size: 20px;">&times;</span>
                                      </button>
                                  </div>
                                  <div class="modal-body">
                                      <%= lib_translate("Bạn có chắc muốn xóa")  %><span style="font-weight:bold; color:red;"> <%= gsurvey.name %> </span>?
                                  </div>
                                  <div class="modal-footer">
                                      <button type="button" class="btn btn-secondary" data-dismiss="modal"><%= lib_translate("Close")  %></button>
                                      <%= link_to lib_translate("Delete"), url_for(action: :del, id: gsurvey.id), method: :delete, class: "btn btn-danger", id: "btn_delete_gsurvey", onclick: "delete_loading_gsurvey(this)" %>
                                      <div id="loading_button_delete_gsurvey" class= "btn btn-danger" style="opacity: 0.8; width: 100%; display:none;" >
                                        <i class ="fa fa-spinner fa-spin"> </i>  <%=lib_translate("Deleting")%> 
                                      </div>
                                  </div>
                                  </div>
                              </div>
                              </div>
                          </td>
                      </tr>
                  <% end %>
          
       
        </tbody>
      </table>
      <%= render_pagination_limit_offset(gsurveys_index_path(lang: session[:lang], per_page: session[:per_page], search: session[:search]), 10, @gsurveys.count).html_safe %>
      </div>
    </div>
  </div>
  
</div>

<!-- modal -->
<div class="modal fade" id="modal-gsurvey" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
    <div class="modal-content position-relative">
      <div class="position-absolute top-0 end-0 mt-2 me-2 z-index-1">
        <button class="btn-close btn btn-sm btn-circle d-flex flex-center transition-base" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-0">
        
        <div class="rounded-top-lg py-3 ps-4 pe-6 bg-light">
          <h4 class="mb-1" id="cls_bmtu_form_add_title"><%= lib_translate("Thêm khảo sát")  %></h4>
        </div>
        <div class="p-4 pb-0">
          <div id="error_explanation" class="text-danger" style="text-align: center;font-size: 13px;"></div>
            <div class="survey-add-survey">
              <%= form_for "", :url=> gsurveys_update_path(), html: {method: :post, id:"form_add_gsurvey",class:'col-12' } do |f| %>
                <div class="erro_labble mb-2">
                    <p style="display:none; color: rgb(197 82 82);border: 1px solid rgb(199 136 136 / 23%);background: rgb(255 54 54 / 16%);border-radius: 5px;padding: 10px"
                    id="erro_labble_content">
                    </p>
                </div>
                <div class="row mb-3" style="display:none;">
                    <div class="col-sm-8 col-lg-9">
                        <input class="form-control" name="gsurvey_id_add" id="gsurvey_id_add">
                    </div>
                </div>
                <div class="row mb-3"> 
                    <label class="col-sm-4 col-lg-4  col-form-label"><%= lib_translate("Tên nhóm khảo sát") %><span style="color:red">* </span>:</label>
                    <div class="col-sm-8 col-lg-8">
                        <input class="form-control" name="gsurvey_name_add" id="gsurvey_name_add">
                    </div>
                </div>
                <div class="row mb-3"> 
                    <label class="col-sm-4 col-lg-4  col-form-label"><%= lib_translate("Mã nhóm khảo sát") %>:</label>
                    <div class="col-sm-8 col-lg-8">
                        <input class="form-control" name="gsurvey_code_add" id="gsurvey_code_add">
                    </div>
                </div>
                <div class="row mb-3"> 
                    <label class="col-sm-4 col-lg-4  col-form-label"><%= lib_translate("Độ ưu tiên") %><span style="color:red">* </span>:</label>
                    <div class="col-sm-8 col-lg-8">
                      <input class="form-control" name="gsurvey_iorder_add" id="gsurvey_iorder_add" type="number" min="1" step="1" pattern="\d+" onkeypress="restrictDecimal(event)">                     
                    </div>
                </div>
                <div class="row mb-3"> 
                    <label class="col-sm-4 col-lg-4  col-form-label"><%= lib_translate("Ghi chú") %>:</label>
                    <div class="col-sm-8 col-lg-8">
                        <textarea class="form-control" name="gsurvey_note_add" id="gsurvey_note_add" rows="3"></textarea>
                    </div>
                </div>
                <fieldset>
                  <div class="row mb-3" style="align-items: center;">
                    <label class="col-sm-4 col-lg-4  col-form-label"><%= lib_translate("Status") %>:</label>
                    <div class="col-sm-8 col-lg-8">
                      <div class="row">
                        <div class="col-auto">
                          <input checked type="radio" id="gsurvey_status_active" class="form-check-input" value="ACTIVE" name="gsurvey_status_add" /> <label class="form-check-label" for="gsurvey_status_active" style="cursor: pointer"> HOẠT ĐỘNG</label>
                        </div>
                        <div class="col-auto">
                          <input  type="radio" id="gsurvey_status_inactive" class="form-check-input" value="INACTIVE" name="gsurvey_status_add" /> <label class="form-check-label" for="gsurvey_status_inactive" style="cursor: pointer"> KHÔNG HOẠT ĐỘNG</label>
                        </div>
                      </div>
                    </div>
                  </div>
                </fieldset>

                <div class="modal-footer border-0 p-0 mb-2">
                    <%= f.submit "Lưu" , type:"button" , id:"btn_add_new_gsurvey_buttton",
                    class: "btn btn-warning border-red border-pink-600 cls-bmtu-text-red md:group-hover:bg-pink-50 btn-block btn-block text-uppercase " %>
                    <div id="loading_button_gsurvey" class= "btn btn-warning border-red border-pink-600 cls-bmtu-text-red md:group-hover:bg-pink-50 btn-block btn-block text-uppercase " style="opacity: 0.8;display:none;" >
                          <i class ="fa fa-spinner fa-spin"> </i>  <%=lib_translate("Save")%> 
                    </div>
                </div>
              <% end %>
            </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
    let update_translate = "<%= lib_translate("Cập nhật nhóm khảo sát")%>";
    let create_translate = "<%= lib_translate("Thêm nhóm khảo sát")%>";
</script>
<%= javascript_include_tag '/assets/myjs/gsurveys_index.js'%>
<%= javascript_include_tag '/assets/lib_hrm/jquery-3.2.1.slim.min.js', integrity: 'sha384-KJ3o2DKtIkvYIK3UENzmM7KCkRr/rE9/Qpg6aAZGJwFDMVNA/GpGFF93hXpG5KkN', crossorigin: 'anonymous' %> 
<%= javascript_include_tag '/assets/lib_hrm/bootstrap.min.js', integrity: 'sha384-JZR6Spejh4U02d8jOt6vLEHfe/JQGiRRSQQxSfFWpi1MquVdAyjUar5+76PVCmYl', crossorigin: 'anonymous'%>
