<!-- Vũ: translate dùng chung cho các media upload -->
<script>

  var media_trans = {
    upload_guide_1:'<%= lib_translate("upload_guide_1") %>',
    upload_guide_2:'<%= lib_translate("upload_guide_2") %>',
    upload_guide_3:'<%= lib_translate("upload_guide_3") %>',
    confirm_delete:'<%= lib_translate("confirm_delete") %>',
    confirm_delete_all:'<%= lib_translate("confirm_delete_all") %>',
    select_files:'<%= lib_translate("select_files") %>',
    cancel:'<%= lib_translate("Cancel") %>',
    confirm:'<%= lib_translate("Confirm") %>',
    message:'<%= lib_translate("Message") %>',
    remove:'<%= lib_translate("Remove") %>',
    upload:'<%= lib_translate("Upload") %>',
    error: '<%= lib_translate("error") %>',
    try_again:'<%= lib_translate("try_again") %>',
    file_name: '<%= lib_translate("File_name") %>',
    create_date:'<%= lib_translate("Create_date") %>',
    created_by:'<%= lib_translate("created_by") %>',
  }

  const formMediaDiscipline = new FormMedia("upload_file_discipline");
  formMediaDiscipline.setIconPath('<%= root_path%>assets/image/');
  formMediaDiscipline.setTranslate(media_trans);
  formMediaDiscipline.init();
  formMediaDiscipline.addEventListener("confirmdel",(data)=>{
      console.log(data);
      let action = '<%= url_for(action: :del, ck_action: "document")%>';
      action += `&id=${data.relative_id}&did=${data.id}`;
      doClick(action,'delete');
  });
  

  function clickOpenDocs(discipline_id){

    if($('#media-dis-doc-'+discipline_id).attr("data-loaded") == "false"){

      $('#media-dis-doc-'+discipline_id).html("");
      $('#tr-media-dis-doc-'+discipline_id).show();

      var mediaform = new FormMedia('media-dis-doc-'+ discipline_id);

      mediaform.setIconPath('<%= root_path%>assets/image/');
      mediaform.setTranslate(media_trans);
      mediaform.init();

      mediaform.setAction('<%= url_for(action: :discipline_upload_mediafile)%>' + "?discipline_id="+ discipline_id);

      mediaform.addEventListener("confirmdel",(data)=>{
          let action = '<%= url_for(action: :del, ck_action: "document")%>';
          action += `&id=${data.relative_id}&did=${data.id}`;
          doClick(action,'delete');
      });
      $('#media-dis-doc-'+discipline_id).attr("data-loaded","true");
      $.ajax({
        type: "POST",
        url: "<%= discipline_update_path%>",
        data: { idDiscipline: discipline_id },
        dataType: "JSON",
        success: function (response) {
        mediaform.removeTableItemAll();
        mediaform.tableAddItems(response.listAr);
        }
      });


    }else{
      $('#tr-media-dis-doc-'+discipline_id).toggle();
    }
    


  }

// 
  function clickCollapseDiscipline(element){
    document.getElementById('colapse-icon-discipline').style.rotate = element.className.includes('collapsed') ? "unset" : "-90deg";
  }


  document.getElementById("name-btn-discipline").onclick = function () {    
    document.getElementById("name-btn-discipline").style.display = "none"; 
    document.getElementById("loading_button_discipline").style.display = "block";
  };

// 
  //datepicker
    $(function () {		
        $( ".datepicker" ).datetimepicker({
          format: 'DD/MM/YYYY'
        });
  });

    $(function () {
        $(".datepicker").on('keydown', function (e) {
            IsNumeric(this, e.keyCode);
        });
        var isShift = false;
        var seperator = "/";
        function IsNumeric(input, keyCode) {
            if (keyCode == 16) {
                isShift = true;
            }
            //Allow only Numeric Keys.
