<script defer>
    $("#loading").css("display", "flex");
    let form = $("#form_redirect_to_masset");
    if (form.length > 0) {
        $("#form_redirect_to_masset").append(`<input type="hidden" name="page" value="/exims/import_warehouse">`)
        $("#form_redirect_to_masset").submit();
    }else{
        window.location.href = "<%= @CSVC_PATH %>exims/import_warehouse?lang=<%= session[:lang] %>";
    }
</script>