<% content_for :head do %>
  <%= stylesheet_link_tag '/assets/mystyle/benefit.css' %>
<% end %>
<% content_for :bottombody do %>
  <%= javascript_include_tag '/assets/myjs/_family.js' %>
<% end %>
<style>

</style>

<div class="chart_benefit">
    <%= render partial: "users/layouts/layout_chart_benefit"%>  
</div>

    <hr class="mt-4 mb-3" style="width: 100%; height: 4px; background:  var(--falcon-badge-soft-secondary-background-color);">
    <div class="row ">
        <div class="col-12 col-sm-12 col-md-12 col-lg-12 col-xl-12 col-xxl-12 tag d-flex align-items-center">
            <h5 class="m-0 mb-2" style="font-size: 17px;"><%= lib_translate("Benefit") %></h5> 
        </div>
        <div class=" mb-3 col-12 col-sm-12 col-md-12 col-lg-12 col-xl-12 col-xxl-12 action-right-top d-flex align-items-center justify-content-end">
            <% if is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","ADD") && request.env["PATH_INFO"] != "/user/profile" %> 
                <a id="id_add_benefit" class="nav-link ps-2 pe-2 border-end border-2" onclick="clickAddNewBenefit()" style="font-size: 13px; color: var(--falcon-orange);font-weight:600" data-bs-toggle="collapse" href="#form_add_benefit_other" role="button" aria-expanded="false" aria-controls="form_add_benefit_other">
                    <%= lib_translate("Add_Benefit") %> 
                </a>
            <% end %>
            <a id="id_cancel_add_benefit" class=" nav-link ps-2 pe-2 border-end border-2" onclick="clickCloseAddNewBenefit()"  style="display:none; font-size: 13px;font-weight:600" data-bs-toggle="collapse" href="#form_add_benefit_other" role="button" aria-expanded="false" aria-controls="form_add_benefit_other">
                <%= lib_translate("Cancle") %> 
            </a>  
            <a id="id_add_benefit_orther" class=" d-none nav-link ps-2 pe-2 border-end border-2" onclick="clickAddNewBenefitOther(this)" style="font-size: 13px; color: var(--falcon-orange);font-weight:600" data-bs-toggle="collapse" href="#collapse-form-benefit-other" role="button" aria-expanded="false" aria-controls="collapse-form-benefit-other">
                <%= lib_translate("Benefit_other") %> 
            </a>
            <a id="id_cancel_add_benefit_orther " class=" d-none nav-link ps-2 pe-2 border-end border-2"  style="display:none; font-size: 13px;font-weight:600" data-bs-toggle="collapse" href="#collapse-form-benefit-other" role="button" aria-expanded="false" aria-controls="collapse-form-benefit-other">
                <%= lib_translate("Cancle") %> 
            </a>  
            <a  onclick="clickCollapseBenefit(this)" class="nav-link ms-3 me-2" role="button"  data-bs-toggle="collapse" href="#cls-benefit-collapse" role="button" aria-expanded="false" aria-controls="cls-benefit-collapse">
            <span id="collapse-benefit" class="fas fa-caret-down"></span>    </a>
        </div>
    </div>

    
    <div id="form_add_benefit_other" class="collapse">
            <%= form_for @add_benefit, :url=> user_benefit_update_path, html: {method: :post,id:'form_add_benefit',class:"mb-2 card p-3 "} do |f| %>
                <div class="d-flex" style="justify-content: space-between;align-items: center;">
                    <h3 class="m-0" id="title_form_benefit">
                        <%= lib_translate("Benefit_other_add") %>
                    </h3>
                </div>  
                <p style=" display: none; color: rgb(197 82 82); border: 1px solid rgb(199 136 136 / 23%); background: rgb(255 54 54 / 16%); border-radius: 5px; padding: 10px;" id="erro_lable_benefit"></p>
                <div class="form-group" style="display:none;">
                    <%= f.label :id %> <span class="red">*</span>
                    <%= f.text_field :id, class: 'form-control' , name: 'benefit_id' %>
                </div>
                <div class="form-group" style="display:none;">
                    <%= f.label :id %> <span class="red">*</span>
                    <%= f.text_field :id, class: 'form-control' , name: 'benefit_add', value:"add" %>
                </div>
                <div class="form-group" id="id_add_sid" style="display: none;">
                    <%= f.label :user_id %>
                    <span style="color: red" class="red">* </span>
                    <%= f.text_field :user_id, class: 'form-control' ,name:'benefit_user_id', :value=> @user.id %>
                </div>
                <div class="col-xl-6 col-sm-12 d-none">
                    <div class="form-group">
                        <label ><%= lib_translate("Benefits_type") %></label>
                        <input type="text" class="form-control d-none" name="benefit_stype_add_other" value= "<%=@user.benefit_type%>"  >
                        <!-- <input type="text" class="form-control" id="benefit_stypes" name="" disabled> -->
                    </div>
                </div>
                <div class="row">
                        <div class="form-group">
                            <div class="alert alert-warning" id="err_add_benefit_other" style="display: none;width: 97.5%;">
                            </div>
                        </div>
                        <div class="form-group">
                            <label style="text-transform: capitalize;"><%= lib_translate("year") %></label>
                            <!-- <input type="text" class="form-control" id="benefit_year_add_others" name="benefit_year_add_other" > -->
                            <select class="form-select " name="benefit_year_add_other" id="benefit_year_add_others">
                                <%(Time.zone.now.year.to_i - 1..Time.zone.now.year.to_i + 3).each do |year| %>
                                      <option value="<%= year %>" ><%= year %></option>
                                 <%end %>  
                            </select>
                        </div>
                        <div class="form-group">
                            <%= f.label lib_translate("Benefit_name") %> 
                            <span style="color: red" class="red">* </span>
                            <input class="form-control" name="benefit_name" type="text" id="benefit_name" pattern=".{6,}"  >
                            <div class="invalid-feedback"><%= lib_translate("vaild_benefit_name_size")%></div>
                        </div> 
                        <div class="form-group">
                            <label ><%= lib_translate("amount_sbenefits") %></label>
                            <input type="text" class="form-control" id="benefit_amount" name="benefit_amount" onkeyup="on_amount_change(this)" />
                            <div class="invalid-feedback"><%= lib_translate("vaild_required")%> <%= lib_translate("Benefit_amount")%></div>
                        </div> 
                        
                        <div class="form-group">
                            <%= f.label lib_translate("Description") %>
                            <%= f.text_area  :desc, class: 'form-control' ,name:'benefit_desc',id:"benefit_desc" %>
                        </div>
                </div> 
                <div class="mt-4" style="display: flex;justify-content: end;">
                    <button class="btn btn-primary text-uppercase me-2" onclick="saveBenefitOther()"  type="button"><%=lib_translate("Save")%></button>
                </div>
                <div class="mt-2 d-none" style="border-radius: 5px;overflow: hidden;border: 1px solid var(--falcon-border-color);" id="benefit-collapse-container">
                    <div class="bg-200" onclick="clickCollapse(this,'collapse-benefit-file-icon')" data-bs-toggle="collapse" data-bs-target="#collapse-benefit-media" aria-expanded="true" style="padding: 4px 10px;cursor: pointer;">
                        <i id="collapse-benefit-file-icon" class="fas fa-chevron-circle-right" style="font-size: 20px; pointer-events: none; transition: all 200ms ease-in 0s; rotate: unset;"></i> Files (<span id="benefit-files-count"></span>)
                    </div>
                    <div class="collapse" id="collapse-benefit-media">
                        <div class="mt-2" id="upload_file_benefit_form" style="padding: 0px 10px;"></div>
                    </div>
                </div>
            <%end%>
    </div>
