    function openFormUpdateBenefit(benefit,docs = []) {
        // id, name, amount, stype, dtfrom, dtto, status
        // fill data
        let form = $('#form_add_benefit');
        form.find('#title_form_benefit').html('<%= lib_translate("Update_Benefit") %>');
        form.find('#sel_benefit_status_active').checked = benefit.status == "0";
        form.find('#benefit_id').val(benefit.id);
        // console.log(benefit.name);
        form.find('#benefit_amount').val(benefit.amount);
        form.find('#benefit_dtfrom').val(benefit.dtfrom);
        form.find('#benefit_dtto').val(benefit.dtto);
        form.find('#benefit_year').val(benefit.syear);
        form.find('#benefit_desc').val(benefit.desc);
        form.find('#benefit_stype').val(benefit.stype);
        document.getElementById('benefit').innerHTML =`<option value='${benefit.name}'>${benefit.name}  </option>`;

        document.getElementById("id_add_benefit").style.display = "none";
        document.getElementById("id_cancel_add_benefit").style.display = "block";
        // documents
        $('#collapse-benefit-media').collapse('hide');
        $('#benefit-collapse-container').show();
        $('#benefit-files-count').html(docs.length);
        formMediaBenefit.removeAllFiles();
        formMediaBenefit.removeTableItemAll();
        formMediaBenefit.setAction('<%= url_for(action: :benefit_upload_mediafile)%>' + `?benefit_id=${benefit.id}`);
        formMediaBenefit.tableAddItems(docs);
        // show form
        $('#collapse-form-benefit').collapse("show");
    }

    function clickSaveBenefit(button,formId){
        let form = document.getElementById(formId);
        let inputs = form.querySelectorAll('input[check-valid="true"]');
        let valid = true;

        for (let i = 0; i < inputs.length; i++) {
            const element = inputs[i];
            element.classList.toggle('is-invalid',false);
            if(!element.checkValidity()){
                valid = false;
                element.classList.toggle('is-invalid',true);
                break;
            }
        }

        if(valid){
            // form.submit();
            button.classList.toggle("disabled",true);
            button.innerHTML = `<span class="spinner-border spinner-border-sm" style="width: 20px;height: 20px;margin-right: 7px;"></span><%=lib_translate("Save")%>`;
        }
    }

