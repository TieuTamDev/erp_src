    <!-- table benefit -->
    
    <div class="card card-body mb-3 tb_benefit" >
        <div style="display:flex;justify-content: space-between;align-items: center;padding: 0px 0px 0px 0px;">
            <h3><%= lib_translate("Benefit")%></h3>
        </div>
        <table class="table table-bordered" style="border: none; border-color: var(--falcon-bg-navbar-glass);" id="table_benefits">
            <thead style="color: var(--falcon-btn-falcon-success-active-color); font-size: 13px;" class="bg-200 text-900">
                <tr>
                        <th style="text-align:center;" scope="col"><%= lib_translate("Name") %> </th>
                        <%(Time.zone.now.year.to_i - 1..Time.zone.now.year.to_i+3).each do |year| %>
                            <th style="text-align:center;width:12%" id="<%= year %>" scope="col"><%= year %> </th>
                        <%end %>  
                        <% if is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","DEL") && request.env["PATH_INFO"] != "/user/profile" %> 
                        <th style="text-align:start;width: 5%;" scope="col" class="no-sort"></th>
                        <% end %>
                </tr>
            </thead>
            <tbody id="item_benefit">
                <% @list_benefit.each do |benefit|%>
                    <tr>
                        <td style="text-align:start;">
                            <%=benefit[:name]%>
                        </td>
    
                        <%(Time.zone.now.year.to_i - 1..Time.zone.now.year.to_i+3 ).each do |year| %>
                            <td style="text-align:end;">
                                <%Benefit.where(name: benefit[:name], user_id: @user.id, status: "ACTIVE", syear: year).each do |amount| %>
                                    <%if amount.amount != "0" && amount.amount != "" && !amount.amount.nil? %>  
                                        <%=number_to_currency(amount.amount).to_s.gsub('$','').gsub('.00','')%> VND
                                    <%end %>  
                                <%end %>  
                            </td>
                        <%end %>  
                        <% if is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","DEL") && request.env["PATH_INFO"] != "/user/profile" %> 
                        <td style="padding-right: 0.5rem !important;text-align: center;">
                            <a onclick="clickDeleteBenefit('<%= benefit[:name] %>','<%= @user.id%>')" style="cursor: pointer" >
                                <span class="text-danger fas fa-trash"  style="width: 12px" ></span>
                            </a>
                        </td>
                        <% end %>
                    </tr>
                <% end %>
            </tbody>
            <% if is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","EDIT") && request.env["PATH_INFO"] != "/user/profile" %> 
            <tfoot>
                <tr>
                    <td></td>
                    <%(Time.zone.now.year.to_i - 1..Time.zone.now.year.to_i+3 ).each do |year| %>
                        <td style="text-align:center;"><button class="btn btn-primary text-uppercase me-2" onclick="addBenefit('<%=year%>')" data-bs-toggle="modal" data-bs-target="#collapse-form-benefit"><span class="text-light  fas fa-plus"  style="width: 12px" ></span></button></td>
                    <%end %>  
                    <% if is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","DEL") && request.env["PATH_INFO"] != "/user/profile" %> 
                    <td></td>
                    <% end %>
                </tr>
            </tfoot>
            <% end %>
        </table>
    </div>

    <!-- table benefit other -->
