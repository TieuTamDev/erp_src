                                    <input class="form-check-input cursor-pointer" id="<%= organization.id %>" type="checkbox" value="<%= organization.id %>" name="organization_user[]" />
                                    <label class="form-check-label cursor-pointer mb-0" for="<%= organization.id %>"><%= organization.name  %></label>
                                </div>  
                            <% end %>
                        </div> 
                    </div>
                </div> 
            </div> 
            
            <div class="contract_user mt-4">
                <h6 class="m-0" style="color: var(--falcon-badge-soft-secondary-color);margin-top: 2.6rem !important;">
                    <%= lib_translate("Current_contract") %>: 
