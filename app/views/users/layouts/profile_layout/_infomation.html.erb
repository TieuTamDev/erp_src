                    <%= lib_translate("Stype_HR") %>
                    </h6>
                    <h6 class="mt-2" style="font-size: 15px;color: rgb(0, 195, 255)">
                        <%= 
                            if @user.stype == "MEMBER"
                            lib_translate("MEMBER")
                            else
                            lib_translate("APPLYER")
                            end
                        %>
                    </h6>
                </div> 
                <div id="feild_stype_hr_user" class="d-none">
                    <div>
                        <%= f.label lib_translate("Stype_HR") %> 
                        <div class="" style="border: none;box-shadow: none; height: 36px;">
                            <input checked type="radio" id="user_style_member" class="form-check-input me-1" value="MEMBER" name="user_stype_add" ></option><label class="form-check-label" for="user_style_member" style="cursor: pointer"><%= lib_translate("MEMBER")%></label>
                            <input  type="radio" id="user_style_applyer" class="form-check-input ms-2 me-1" value="APPLYER" name="user_stype_add" ></option><label class="form-check-label" for="user_style_applyer" style="cursor: pointer"><%= lib_translate("APPLYER")%></label>
                        </div>
                    </div>
                </div> 
            </div> 
            <%
            name = ""
            job_name = ""
              work = @user.works.where("positionjob_id IS NOT NULL").last
             if !work&.positionjob.nil? && !work&.positionjob&.department.nil?
               name = work&.positionjob&.department&.name
               job_name = work&.positionjob&.name
             end
            %>
            <div class="marriage_user mt-4">
                <div>
                    <h6 class="m-0" style="color: var(--falcon-badge-soft-secondary-color);">
                        <%= lib_translate("Vị trí công việc") %>:
                    </h6>
                    <h6 class="mt-2" style="font-size: 15px;"><%= job_name %></h6>
                </div> 
            </div> 

