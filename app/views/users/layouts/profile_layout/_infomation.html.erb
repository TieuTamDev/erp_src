                    <div class="form-group">
                        <%= f.label lib_translate("Staff_type") %>:
                        <select class="form-select " name="user_staff_type_add" id="user_staff_type_add">
                            <option value=1>Bệnh Viên - Trường - Viện</option>
                            <option selected value=2>Tất cả</option>                                                     
                        </select>   
                    </div>
                </div> 
            </div> 

            <div class="marriage_user mt-4">
