                    @arrUr = []
                    @uorgs.each do |uorg|
                    @arrUr.push(Organization.where(id: uorg.organization_id).first.name, " /")
                    end
                    %>
                    <%=  @arrUr.to_s.gsub('[','').gsub(']','').gsub('"','').gsub(',','').chomp("/")%>
                    </h6>
                </div> 
