                            <input type="radio" id="user_benefit_type_1" class="form-check-input ms-2 me-1" value="2" name="user_benefit_type_add" ></option><label class="form-check-label" for="user_benefit_type_1" style="cursor: pointer">2</label>
                            <input checked type="radio" id="user_benefit_type_2" class="form-check-input ms-2 me-1" value="3" name="user_benefit_type_add" ></option><label class="form-check-label" for="user_benefit_type_2" style="cursor: pointer">3</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-md-6 col-lg-6 col-xl-4 col-xxl-4">
            <div class="firstname_user">
                <div id="lable_first_name_user">
