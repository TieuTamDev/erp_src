                        <%= f.label lib_translate("Host_unit") %>: <a class="ms-2" href="<%= organization_index_path() %>" type="button" data-bs-toggle="tooltip" data-bs-placement="top" data-bs-title="<%= lib_translate('Add_organization') %>"><span style="width:10px; color:#98a7b9" class="fas fa-database"></span></a>
                        <div id="select_add_organization_bd" class="stype mb-0"> 
                            <% @organizations.each do |organization| %>  
