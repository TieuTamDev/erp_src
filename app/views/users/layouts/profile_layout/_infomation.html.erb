                </div>
                <div id="feild_scode_user_details" class="d-none">
                        <div class="form-group" id="id_add_sid">
                            <%= f.label lib_translate("employee_code") %>: 
                            <%= f.text_field :sid, class: 'form-control' , name:'user_sid_add'  %>
                        </div>
                </div>
            </div>

            <div class="birtday_user mt-4">
