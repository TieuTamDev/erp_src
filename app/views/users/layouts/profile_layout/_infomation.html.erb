<%= stylesheet_link_tag "/assets/mystyle/userstyle/infomation.css" %>
<%= form_for @user, :url=> user_update_path, html: {method: :post, id:"form_add_user" } do |f| %>
    <div class="title mt-3">
    <h4 class="mb-1" style="color: var(--falcon-btn-falcon-success-active-color);"><%= lib_translate("Personal_information") %> </h4>
    <h6 class="m-0" style="color: var(--falcon-badge-soft-secondary-color);"><%= lib_translate("Personal_information_contact_education_and_work_schedule") %> </h6>
    </div>
    <% list_uorg_user = []
    @uorgs.each do |uorg|
    list_uorg_user.push(uorg.organization_id ? uorg.organization_id : "") 
    end %>
    <hr class="mt-4 mb-3" style="width: 100%; height: 4px; background:  var(--falcon-badge-soft-secondary-background-color);">
    <div class="row">
        <div class="col-12 col-sm-12 col-md-12 col-lg-12 col-xl-12 col-xxl-12 tag d-flex align-items-center">
            <h5 class="m-0 mb-2" style="font-size: 17px;"><%= lib_translate("main_information") %></h5> 
        </div>
        <div class="col-12 col-sm-12 col-md-12 col-lg-12 col-xl-12 col-xxl-12 action-right-top d-flex align-items-center justify-content-end">
        <% if is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","EDIT") && request.env["PATH_INFO"] != "/user/profile" %> 
            <label class="nav-link pe-2 border-end border-2 cursor-pointer mb-0" id="lable_edit_info" onclick="show_feild_checked('info', <%= list_uorg_user %>)" for="show_feild" style="font-size: 13px; font-weight: 700; color: var(--falcon-orange)">
                    <%=  lib_translate("Edit_infomation") %>
            </label>
        <% end %>            
            <label class="nav-link pe-2 border-end border-2 cursor-pointer mb-0 d-none" id="lable_cancel_edit_info" onclick="show_feild_checked('info', <%= list_uorg_user %>)" for="show_feild" style="font-size: 13px; font-weight: 700">
                <%=  lib_translate("Cancel_edit_infomation") %> 
            </label>
            <input class="d-none" type="checkbox" name="show_feild" id="show_feild">
            <a  onclick="clickCollapseMainInfo(this)" class="nav-link ms-3 me-2" data-bs-toggle="collapse" href="#open_form_infor" role="button" aria-expanded="false" aria-controls="open_form_infor">
                <span id="collapse-main-icon-info" class="fas fa-caret-down"></span>
            </a>
        </div>
    </div>
    <div class="collapse show row mt-2 justify-content-center" id="open_form_infor" style="padding-bottom: 20px;border-radius: 5px;">
        <div class="mb-3">

            <div class="form-group txt_update_id d-none">
            <%= f.label :id %> <%= f.text_field :id, class: 'form-control' , name: 'user_id' %>
            </div>
            <div class="form-group d-none">
                <input value="2" type="text" id="type_upadte" name="type_upadte"><br>
            </div> 

            <div class="form-group d-none" id="id_bmtu_pwd">
                <%= f.text_field :password_digest , class: 'form-control' , name: 'user_password_add' ,id: 'user_password_add',autocomplete: 'new-password' %>
            </div>
        </div>
        <div class="erro_labble">
            <p style=" display: none; color: rgb(197 82 82); border: 1px solid rgb(199 136 136 / 23%); background: rgb(255 54 54 / 16%); border-radius: 5px; padding: 10px; margin-left: 15px; margin-right: 15px;" id="erro_labble_content_usser_info" ></p>
        </div>
        <div class="col-12 col-sm-6 col-md-6 col-lg-6 col-xl-4 col-xxl-4">
            <div class="lastname_user">
                <div id="lable_lastname_user">
                    <h6 class="m-0" style="color: var(--falcon-badge-soft-secondary-color);">
                    <%= lib_translate("Last_name") %>:
                    </h6>
                    <h6 class="mt-2" style="font-size: 15px;text-transform: capitalize;"><%= @user.last_name ? @user.last_name : " " %></h6>
                </div>
                <div id="feild_lastname_user" class="d-none">
                    <div class="form-group" id="id_add_sid">
                    <%= f.label lib_translate("Last_name") %><span style="color:red;" class="red">* </span>:
                    <%= f.text_field :last_name, class: 'form-control',  id:'user_last_name_add' ,  name:'user_last_name_add', autocomplete: 'off', style:"text-transform:capitalize" %>
                    </div>
                </div>
            </div>

            <div class="scode_user mt-4">
                <div id="lable_scode_user_details">
                    <h6 class="m-0" style="color: var(--falcon-badge-soft-secondary-color);">
