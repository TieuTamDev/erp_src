                                        <span style="position: relative;" class="outline-element-container"> <input value ="<%=@user.birthday.strftime('%d/%m/%Y')%>"  id="user_birthday_add" type="text" name="user_birthday_add" class="form-control datepicker openemr-datepicker input-textbox outline-element incorrect" objtype="7" name="action_element" objindex=""  aria-label="Select Date"> <span class="correct-incorrect-icon"> </span></span>
                                        <div id="datepicker"></div>
                                    </div>
                            </div> 
                </div>
            </div>

            <div class="stype_hr_user mt-4">
