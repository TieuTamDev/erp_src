<style>
#id_add_review:hover, #id_cancel_add_review:hover{
  color: var(--falcon-btn-falcon-success-color) !important;
}
</style> 
<div class="row">
    <div class="col-12 col-sm-12 col-md-12 col-lg-8 col-xl-8 col-xxl-8 tag d-flex align-items-center title mt-3">
        <h4 class="mb-1" style="color: var(--falcon-btn-falcon-success-active-color);"><%= lib_translate('Review')%></h4>
    </div>
    <div class="col-12 col-sm-12 col-md-12 col-lg-4 col-xl-4 col-xxl-4 action-right-top d-flex align-items-center justify-content-end">
      <% if is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","ADD") && request.env["PATH_INFO"] != "/user/profile" %> 
            <a id="id_add_review" class="nav-link pe-2 " role="button" style="font-size: 13px; font-weight: 700;color: var(--falcon-orange)" onclick="openFormAddReview()" class="btn btn-primary mt-3" data-bs-toggle="collapse" data-bs-target="#form_add_review" aria-expanded="false" aria-controls="form_add_review">
              <%= lib_translate("Add_review") %> </a> 
      <% end %>
              <a id="id_cancel_add_review" class=" nav-link ps-2 pe-2 border-end border-2"  style="display:none; font-size: 13px; font-weight: 700" data-bs-toggle="collapse" href="#form_add_review" role="button" aria-expanded="false" aria-controls="form_add_review">
                <%= lib_translate("Cancle") %> 
              </a> 
    </div>
</div>
<hr class="mt-2 mb-3" style="width: 100%; height: 4px;">
<div class="mb-2">
    <div class="collapse" id="form_add_review">
      <div class="card p-3 capp-form-bg">
          <div class="form-add">
            <%= form_for @review, :url=> user_review_update_path, html: {method: :post } do |f| %>
              <p  id="cls_bmtu_form_add_review_title"></p>
              <div class="erro_labble mb-2" style="height: 40px;">
                <p style="display:none; color: rgb(197 82 82);border: 1px solid rgb(199 136 136 / 23%);background: rgb(255 54 54 / 16%);border-radius: 5px;padding: 10px;" id="erro_labble_content_review"></p>
              </div>
              <div class="form-group" style="display:none;" class="txt_update_id">
                <%= f.label :id %> 
                  <%= f.text_field :id, class: 'form-control' , name: 'review_id_add', id: 'review_id_add' %>
              </div>
              <div class="form-group" id="id_add_sid" style="display:none;" >
                <%= f.label "user_id:" %>  <span style="color:red;"> * </span>
                  <%= f.text_field :user_id, class: 'form-control' ,  name:'review_sid_add', id:'review_sid_add',:value => @user.id %>
              </div>
              <div class="row">
                <div class="col">
                  <div class="form-group">
                    <%= f.label lib_translate("Reviewed_by") %>                               
                      <select style="text-transform: capitalize;" class="form-control selectpicker" name="review_reviewed_by_add" id="review_reviewed_by_add">
                      <% @users.where.not(id: @user.id).each do |user| %>
                        <option  value="<%= user.last_name%> <%= user.first_name%>">
                          <%= user.last_name%> <%= user.first_name%>
                        </option>
                      <%end%>
                      </select>
                  </div>

                  <div class="form-group ">
                    <%= f.label lib_translate("Reviewed_place") %> 
                      <select style="text-transform: capitalize;" class="form-control" name="review_reviewed_place_add" id="review_reviewed_place_add">
                      <% @departments.each do |department| %>
                        <option  value="<%= department.name%>">
                          <%= department.name%>
                        </option>
                      <%end%>
                      </select>                   
                  </div>

                  <div class="form-group" >
                    <%= f.label lib_translate("Review_date")  %>                     
                    <div id="datepicker-container" class="datepicker-container">
                    <span style="position: relative;" class="outline-element-container"> <input value="<%=Date.today.strftime("%d/%m/%Y")%>" id="review_reviewed_date_add" maxlength="10" type="text" name="review_reviewed_date_add" class="form-control datepicker openemr-datepicker input-textbox outline-element incorrect" placeholder="dd/mm/yyyy" objtype="7" name="action_element" objindex=""  aria-label="Select Date"> <span class="correct-incorrect-icon"> </span></span>
                    <div id="datepicker"></div>
                  </div>  
                  </div>

                  <div class="form-group">
                    <%= f.label lib_translate("Result") %>
                      <%= f.text_field :result, :class=> "form-control", name: 'review_result_add' , id: 'review_result_add'%>
                </div>

                  <div style="display: flex;white-space: nowrap;" class="mt-3">
                    <%= f.label lib_translate("Status") %>                      

                      <div class="form-control" style="border: none;box-shadow: none; padding: 0 !important;background:transparent;">
                        <input checked type="radio" id="review_status_ACTIVE" class="form-check-input ms-2 me-1" value="ACTIVE" name="review_status_add" /><label class="form-check-label" for="review_status_ACTIVE" style="cursor: pointer">ACTIVE</label>
                        <input  type="radio" id="review_status_INACTIVE" class="form-check-input ms-3 me-1" value="INACTIVE" name="review_status_add" /><label class="form-check-label" for="review_status_INACTIVE" style="cursor: pointer">INACTIVE</label>
                      </div>
                  </div>
            
                </div>
                <div style="display:none" class="col">
                  <div class="form-group">
                    <%= f.label lib_translate("Document")  %>   
                    <div class="img_review">
                      
                    </div>
                    
                      <%= f.file_field :mediafile_id, class: 'form-control' , name: 'review_mediafile_id_add' , :id=> "review_mediafile_id_add" ,:accept=>"image/x-png,image/gif,image/jpeg", onchange: "readURLReviewFile(this);"  %>
                  </div>
                </div>
              </div>
              <div class="form-group">
                  <%= f.label lib_translate("Content") %>
                  <%= f.text_area :content, :class=> "form-control", name: 'review_content_add', id: 'review_content_add'%>
              </div>
              <div class="form-group" style="margin-left: 15px;margin-right: 15px;">
                <%= f.submit "" , type:"submit" , id:"btn_add_new_review", class: "btn btn-primary  mt-3 mb-5 border-red border-pink-600 cls-bmtu-text-red md:group-hover:bg-pink-50 btn-block btn-block text-uppercase d-none", style: "width: 100%;" %>
                
              </div>
              
            <% end %>  
            <label onclick="clickCollapseReview(this)" id= "btn-colapse-review-label" class= "card p-2 mt-3 d-flex ps-3 pe-3" style= "width: 100%; background: var(--falcon-badge-soft-dark-background-color); flex-direction: row; align-items: center; justify-content: space-between;" type="button" data-bs-toggle="collapse" data-bs-target="#add-file-medias_review" aria-expanded="false" aria-controls="add-file-medias_review">
              <%=lib_translate("List_review")%> 
              <i id="colapse-icon-review" style="transition: all 100ms ease 0s; font-size: 20px;" class="fas fa-angle-left"></i>
            </label>  
            <%# Upload media view %>
              <div class="collapse" id="add-file-medias_review">
                  <div class="card">
                    <div class="card-header">
                      <h5 class="mb-0"><%=lib_translate("Upload_files")%></h5>
                    </div>
                    <div class="card-body bg-light" id="upload_file_review">
                      
                    </div>
                  </div>
              </div>
              <%# ==== %>
            <div class="collapse" id="form-list-file-review">
              <div  id="card-upload-mediafile_review">
                <div class="p-3">
                  <div id="table-file-review" >
                    <div class="table-responsive scrollbar">
                      <table class="table table-bordered table-striped fs--1 mb-0">
                        <thead class="bg-200 text-900">
                          <tr>
                            <th class="sort" data-sort="name" style="text-align:center"><%=lib_translate("File_name")%></th>
                            <th class="sort" data-sort="create_date" style="text-align:center"><%=lib_translate("Create_date")%></th>
                            <th class="sort" data-sort="owner" style="text-align:center"><%=lib_translate("Created_by")%></th>
                            <th data-sort="age"></th>
                          </tr>
                        </thead>
                        <tbody class="" id="list-mediafile-review">
                          <% @review.revdocs.each do |revdoc| %>
                            <tr>
                              <td class="name" style="text-align: left" ><%= revdoc.mediafile.file_name %></td>
                              <td class="create_date" style="text-align: center" ><%= revdoc.mediafile.created_at.strftime("%d/%m/%Y") %>
                              <td class="owner" style="text-align: left" ><%= revdoc.mediafile.owner %></td>
                              <td style="text-align: center; min-width: 100px; white-space:nowrap;">
                                <a download href="<%= request.base_url %>/mdata/hrm/<%= revdoc.note %>" target="_blank" class="me-3" style="text-decoration: none; cursor: pointer;" title="Download" >
                                  <i class = "fas fa-file-download icon"></i>
                                </a>
                                <a onclick="showModalDelete(this)" data-name="<%= revdoc.mediafile.file_name %>" data-action="<%= url_for(action: :review_del, id: @review.id, uid: @review.user_id, did: revdoc.id, ck_action: "document")%>"  style="cursor: pointer;">
                                    <span class="text-danger fas fa-trash" style="width : 15px"></span>
                                </a>
                              </td>
                            </tr>
                          <% end %>
                        </tbody>
                      </table>
                    </div>
                    
                  </div>
                  <div class="d-flex justify-content-end mt-2">
                      <button class="btn btn-primary" style="background: var(--falcon-orange);color: white;border: none;" type="button" data-bs-toggle="collapse" data-bs-target="#add-file-medias_review" aria-expanded="false" aria-controls="add-file-medias_review"><%=lib_translate("Add_doccuments")%></button>
                  </div>  
                </div>
              </div> 
              


          </div>
          <label id="name-btn-review" for="btn_add_new_review" class= "btn btn-primary mt-3  border-red border-pink-600 cls-bmtu-text-red md:group-hover:bg-pink-50 btn-block text-uppercase" style= "width: 100%;">
        
        </label>
        <div id="loading_button_review" class= "btn btn-primary mt-3 mb-5 border-red border-pink-600 cls-bmtu-text-red md:group-hover:bg-pink-50 btn-block btn-block text-uppercase" style="opacity: 0.8;width: 100%;display:none;" >
            <i class ="fa fa-spinner fa-spin"> </i>  <%=lib_translate("Save")%> 
        </div>
      </div>
    </div>
</div>

<div class="card mb-3">
  <div class="card-body pt-0">
    <div class="tab-content">
      <table id="table_review" class="table table-bordered fs--1 mb-0 table-hover" style="margin-top: 0px !important; margin-bottom: 0px !important">
              <thead class="bg-200 text-900">
                <tr>
                  <th data-sort="id" style="display: none;">ID</th>
                  <th class="sort" style="display: none;" data-sort="Employee_code"><%= lib_translate("employee_code")  %></th>
                  <th class="sort" style="display: none; " data-sort="Mediafile_Id"><%= lib_translate("Mediafile")  %></th>
                  <th class="sort" style="text-align: center; white-space: nowrap;" data-sort="Reviewed_by"><%= lib_translate("Reviewed_by")  %></th>
                  <th class="sort" style="text-align: center; white-space: nowrap;"data-sort="Reviewed_place"><%= lib_translate("Reviewed_place")  %></th>
                  <th class="sort" style="text-align: center; white-space: nowrap;"data-sort="Reviewed_date"><%= lib_translate("Review_date")  %></th>
                  <th class="sort" style="text-align: center; white-space: nowrap;"data-sort="Result"><%= lib_translate("Result")  %></th>
                  <th class="sort" style="text-align: center; white-space: nowrap;"data-sort="Status"><%= lib_translate("Status")  %></th>
                  <% if (is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","EDIT") || is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","DEL")) && (request.env["PATH_INFO"] != "/user/profile") %> 
                    <th class="no-sort" style="text-align: center; white-space: nowrap;cursor: pointer;"></th>
                  <% end %>
                </tr>
              </thead>
                <tbody class="list">
                  <% @reviewEachUser.each do |review| %>
                    <tr id="id_edit_btn_review" myidReview = '<%= review.id %>'>
                      <td style="display: none; vertical-align: middle;  ">
                        <%= review.id %>
                      </td>
                    
                      <td  class="user_id" style="cursor: pointer; vertical-align: middle; display: none;">
                          <%= User.where("id = '#{review.user_id}' ").first.sid%>
                      </td>

                      <td  class="Mediafile_Id" style="cursor: pointer; text-align: center; display:none;" style="cursor: pointer; vertical-align: middle;">  
                        <% if review.mediafile_id.nil? %>
                          <p>N/A</p>      
                        <%else%>                                      
                          <a href="<%= request.base_url %>/mdata/hrm/<%= Mediafile.where("id = '#{review.mediafile_id}' ").first.file_name%>" target="blank"><img width="50" src='<%= request.base_url %>/mdata/hrm/<%= Mediafile.where("id = '#{review.mediafile_id}' ").first.file_name%>' alt=""></a> 
                        <%end%>
                      </td>

                      <td  class="Reviewed_by" style="cursor: pointer; vertical-align: middle;text-transform: capitalize;" >
                          <%= review.reviewed_by %>
                      </td>

                      <td  class="Reviewed_place" style="cursor: pointer; vertical-align: middle;" >
                          <%= review.reviewed_place %>
                      </td> 

                      <td  class="Reviewed_date" style="cursor: pointer; vertical-align: middle;" >
                          <%= review.reviewed_date&.strftime('%d/%m/%Y') %>
                      </td>  

                      <td  class="Result" style="cursor: pointer; vertical-align: middle;">
                          <%= review.result %>
                      </td>  

                      <td  class="status" style="text-align: center;cursor: pointer; vertical-align: middle; white-space: nowrap;">
                        
                          <%= (if review.status=="ACTIVE" 
                            lib_translate("ac_icon")
                          else 
                            lib_translate("inac_icon")
                          end ) %>
                      
                      </td>
                  <% if (is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","EDIT") || is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","DEL")) && (request.env["PATH_INFO"] != "/user/profile") %> 
                      <td style="white-space:nowrap;min-width: 100px; text-align: center; vertical-align: middle; cursor: pointer;" >
                        <% if is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","EDIT") && request.env["PATH_INFO"] != "/user/profile" %> 
                        <a class="edit_user" myidReview = '<%= review.id %>' style="text-decoration: none;cursor: pointer;" data-bs-toggle="collapse" data-bs-target="#form_add_review" aria-expanded="false" aria-controls="form_add_review"
                          onclick="openFormUpdateReview(
                            `<%= review.id %>`,
                            `<%= review.user_id %>`,
                            `<%= review.reviewed_by %>`,
                            `<%= review.reviewed_place %>`,
                            `<%= review.reviewed_date&.strftime('%d/%m/%Y') %>`,
                            `<%= review.content %>`,`<%= review.result %>`,
                            `<%= review.status %>`,
                            `<%= session[:id_review_user] = review.id %>`)">
                          <span class="text-primary far fa-edit me-2" style="width: 15px"></span>
                        </a>
                        <% end %>
                        <!-- Button trigger modal -->
                          <% if is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","DEL") && request.env["PATH_INFO"] != "/user/profile" %> 
                          <a onclick="clickDeleteReview(`<%= review.id %>`,'',`<%= review.user_id %>`)" style="cursor: pointer" >
                            <span class="text-danger fas fa-trash"  style="width: 12px" ></span>
                          </a> 
                          <% end %>
                        <%# thêm ở đây %>
                          <% if is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","EDIT") && request.env["PATH_INFO"] != "/user/profile" %> 
                          <a id="openuploadmedia" onclick="clickEditMediaReview(`<%= review.id%>`,<%= review.user_id%>)" href="#file-review-<%= review.id  %>" role="button" aria-expanded="false" aria-controls="file-review-<%= review.id  %>" data-bs-toggle="collapse" data-bs-target="#upload_review-<%= review.id  %>" aria-expanded="false" aria-controls="upload_review-<%= review.id  %>" class="m-0 ms-3">
                              <span class="fas fa-folder-open me-4 icon text-warning"></span>
                          </a> 
                          <% end %>
                      </td>
                <% end %>
                    </tr>
                    <%# sửa ở đây %>
                      <% if is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","EDIT") && request.env["PATH_INFO"] != "/user/profile" %> 
                          <tr style="background: var(--falcon-border-color);" class="collapse" id="upload_review-<%= review.id  %>" >
                            <td style="display: none;   ">
                                <%= review.id %>
                              </td>
                            
                              <td  class="user_id" style="display: none;">
                                  <%= User.where("id = '#{review.user_id}' ").first.sid%>
                              </td>

                              <td  class="Mediafile_Id" style="display:none;" style="cursor: pointer; ">  
                                <% if review.mediafile_id.nil? %>
                                  <p>N/A</p>      
                                <%else%>                                      
                                  <a href="<%= request.base_url %>/mdata/hrm/<%= Mediafile.where("id = '#{review.mediafile_id}' ").first.file_name%>" target="blank"><img width="50" src='<%= request.base_url %>/mdata/hrm/<%= Mediafile.where("id = '#{review.mediafile_id}' ").first.file_name%>' alt=""></a> 
                                <%end%>
                              </td>

                              <td  class="Reviewed_by" style="display: none;" >
                                  <%= review.reviewed_by %>
                              </td>

                              <td  class="Reviewed_place" style="display: none;" >
                                  <%= review.reviewed_place %>
                              </td> 

                              <td  class="Reviewed_date" style="display: none;" >
                                  <%= review.reviewed_date&.strftime('%d/%m/%Y') %>
                              </td>  

                              <td  class="Result" style="display: none;">
                                  <%= review.result %>
                              </td>  

                              <td  class="status" style="display: none;">
                                
                                  <%= (if review.status=="ACTIVE" 
                                    lib_translate("ac_icon")
                                  else 
                                    lib_translate("inac_icon")
                                  end ) %>
                              
                              </td>
                              <td colspan="6" class="line_upload">
                                <div id="file-upload-review-<%= review.id  %>"></div>
                              </td>
                          </tr>
                      <% end %>
                  <% end %>
              </tbody>
            </table>
    </div>
  </div>
</div>
</div>
<%# modal delete review details %>
    <div class="modal fade" id="review-confirm" tabindex="-1" role="dialog" aria-hidden="true">
      <div class="modal-dialog" role="document">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">
              <%= lib_translate("Message") %>
            </h5>
            <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close" style="border: none; background: none">
              <span aria-hidden="true" style="font-size: 20px">&times;</span>
            </button>
          </div>
          <div class="modal-body">
            <%= lib_translate("confirm_delete_message") %>
            <span id="modal-mesasge-delete-name" style="font-weight: bold; color: red"></span>?
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" id="button_close_delete"> <%= lib_translate("Close") %> </button>
            <a class="btn btn-danger" id="button_delete" rel="nofollow" data-method="delete" href="#"><%=lib_translate("Delete")%></a>
            <div id="loading_button_delete_review_details" class= "btn btn-danger" style="opacity: 0.8; width: 100%; display:none;" >
              <i class ="fa fa-spinner fa-spin"> </i>  <%=lib_translate("Deleting")%> 
            </div>
          </div> 
        </div>
      </div>
    </div>
  

<script>
  function clickCollapseReview(element){
        document.getElementById('colapse-icon-review').style.rotate = element.className.includes('collapsed') ? "unset" : "-90deg";
    }
    function delete_loading_review(element){
      element.style.display = "none"
      element.previousElementSibling.style.display = "none"
      element.nextElementSibling.style.display = "block"
    }


    function openFormAddReview(){

        document.getElementById("id_add_review").style.display = "none";
        document.getElementById("id_cancel_add_review").style.display = "block";
        document.getElementById("cls_bmtu_form_add_review_title").innerHTML = "<%= lib_translate("Add_review")  %>";
        document.getElementById("review_reviewed_by_add").selectedIndex = "0";
        document.getElementById("review_reviewed_place_add").selectedIndex = "0";
        document.getElementById("review_id_add").value = "";

        document.getElementById("name-btn-review").innerHTML = "<%= lib_translate('Add_review')  %>";

        document.getElementById("btn-colapse-review-label").classList.add("d-none"); 
        document.getElementById("card-upload-mediafile_review").style.display = "none"; 
    }


    function openFormUpdateReview(id, user_id, reviewed_by, reviewed_place, reviewed_date,content,result,status, session_id_review){
        $("html, body").animate({scrollTop: 0}, 100);
        document.getElementById("form_add_review").classList.add("show");
        document.getElementById("cls_bmtu_form_add_review_title").innerHTML = "<%= lib_translate("Update_review")  %>"
        document.getElementById("name-btn-review").innerHTML = "<%= lib_translate('Update_review')  %>";
        document.getElementById("id_add_review").style.display = "none";
        document.getElementById("id_cancel_add_review").style.display = "block";

        if(status == "ACTIVE"){
        document.getElementById("review_status_ACTIVE").checked = true;
        }
        else {
        document.getElementById("review_status_INACTIVE").checked = true;
        }
        document.getElementById("review_id_add").value = id;
        document.getElementById("review_sid_add").value = user_id;
        document.getElementById("review_reviewed_by_add").value = reviewed_by;
        $("#review_reviewed_by_add").trigger("change");
        document.getElementById("review_reviewed_place_add").value = reviewed_place;
        document.getElementById("review_reviewed_date_add").value = reviewed_date;
        document.getElementById("review_content_add").value = content;
        document.getElementById("review_result_add").value = result;
        document.getElementById("card-upload-mediafile_review").style.display = "block"; 

        document.getElementById("list-mediafile-review").value = "";
        document.getElementById("btn-colapse-review-label").classList.remove("d-none"); 
        $("#list-mediafile-review tr").remove();
      let arrReviewFile = [];

        let action_upload_review = '<%= url_for(action: :review_upload_mediafile)%>';
      
        formMediaReview.setAction(action_upload_review + "?review_id="+ id);
        let idReview = document.getElementById("id_edit_btn_review").getAttribute("myidReview");
 
      // start show filemedia list
            $.ajax({
              type: "GET",
              url: "<%= user_review_edit_path%>",
              data: { idReview: id },
              dataType: "JSON",
              success: function (response) {
                formMediaReview.removeTableItemAll();
                    formMediaReview.tableAddItems(response.docs);
                  
              }
          });
      //end
    }
      // ở đây thêm mới
    function clickEditMediaReview(review_id, user_id){
      
      if($('#file-upload-review-'+review_id).html().length == 0){

        let action_upload = '<%= url_for(action: :review_upload_mediafile)%>';
          var formmedia_edit_doc = new FormMedia("file-upload-review-" + review_id);
          formmedia_edit_doc.setAction(action_upload + "?review_id="+ review_id);
          formmedia_edit_doc.setIconPath('<%= root_path%>assets/image/');
          formmedia_edit_doc.setTranslate(media_trans);
          formmedia_edit_doc.init();
          formmedia_edit_doc.addEventListener("confirmdel",(data)=>{
            deleteRevDoc(data.id, user_id);
          });
              
            $.ajax({
              type: "GET",
              url: "<%= user_review_edit_path%>",
              data: { idreview: review_id },
              dataType: "JSON",
              success: function (response) {
                  formmedia_edit_doc.removeTableItemAll();
                  formmedia_edit_doc.tableAddItems(response.docs);
              }
          });
        }else{

        }

    }
    // ở đây thêm mới
    function deleteRevDoc(doc_id,user_id){
      let action = '<%= url_for(action: :review_del, ck_action: "document")%>';
      action += `&did=${doc_id}&uid=${user_id}`;
      let link = document.createElement('a');
      link.setAttribute('data-action',"delete");
      link.setAttribute('href',action);
      link.click();
    }
    document.getElementById("name-btn-review").onclick = function () {
        
        document.getElementById("name-btn-review").style.display = "none";
        document.getElementById("loading_button_review").style.display = "block";
    };

    const formMediaReview = new FormMedia("upload_file_review");
    formMediaReview.setIconPath('<%= root_path%>assets/image/');
    formMediaReview.setTranslate(media_trans);
    formMediaReview.init();
    formMediaReview.addEventListener("confirmdel",(data)=>{
      deleteRevDoc(data.id, data.uid);
    });



    document.getElementById("id_cancel_add_review").onclick = function() {
      document.getElementById("id_add_review").style.display = "block";
      document.getElementById("id_cancel_add_review").style.display = "none";
    }

    function showModalDeleteReview(element) {
      let href = element.getAttribute("data-action");
      let name = element.getAttribute("data-name");
      $("#review-confirm").find('#button_delete').attr('href',href);
      $("#review-confirm").find('#modal-mesasge-delete-name').text(name);
      // show modal
      $("#review-confirm").modal('show');

    }

    function clickDeleteReview(id,name,user_id){
    let href = '<%= url_for(action: :review_del)%>';
    href += `?id=${id}&uid=${user_id}`;

    let html = `<%= lib_translate("Confirm_delete")%> <%= lib_translate("Review")%> <span style="font-weight: bold; color: red">${name}</span>?`
    openConfirmDialog(html,(result )=>{
      if(result){
        doClick(href,'delete')
      }
    });

  }
</script>
