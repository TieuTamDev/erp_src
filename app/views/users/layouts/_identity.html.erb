  <!-- Identity -->
<script> 
    // datepicker
      $( ".datepicker" ).datepicker({
          showButtonPanel: true,
          dateFormat: "dd/mm/yy",
          changeMonth: true,
          changeYear: true,
          yearRange: "c-100:c+10",
          // defaultDate: +1,
          buttonImageOnly: true,
          buttonImage: "<%= image_path('icon-calender-datepicker.png') %>",
          showOn: "button",
          buttonText: "<%= lib_translate("Choose_date") %>",
          closeText: "<%= lib_translate("closeText") %>",
          prevText: "<%= lib_translate("prevText") %>",
          nextText: "<%= lib_translate("nextText") %>",
          currentText: "<%= lib_translate("currentText") %>",
          monthNamesShort: ["<%= lib_translate("Jan") %>", "<%= lib_translate("Feb") %>", "<%= lib_translate("Mar") %>", "<%= lib_translate("Apr") %>",
          "<%= lib_translate("May") %>", "<%= lib_translate("Jun") %>", "<%= lib_translate("Jul") %>", "<%= lib_translate("Aug") %>", 
          "<%= lib_translate("Sep") %>", "<%= lib_translate("Oct") %>", "<%= lib_translate("Nov") %>", "<%= lib_translate("Dec") %>"],
          dayNamesMin: ["<%= lib_translate("Sun") %>", "<%= lib_translate("Mon") %>", "<%= lib_translate("Tue") %>", "<%= lib_translate("Wed") %>", 
          "<%= lib_translate("Thu") %>", "<%= lib_translate("Fri") %>", "<%= lib_translate("Sat") %>"],
          firstDay: 1,
          isRTL: false,
          showMonthAfterYear: false,
          yearSuffix: "",
      });
      $(function () {
          $(".datepicker").on('keydown', function (e) {
              IsNumeric(this, e.keyCode);
          });
          var isShift = false;
          var seperator = "/";
          function IsNumeric(input, keyCode) {
              if (keyCode == 16) {
                  isShift = true;
              }
              //Allow only Numeric Keys.
              if (((keyCode >= 48 && keyCode <= 57) || keyCode == 8 || keyCode <= 37 || keyCode <= 39 || (keyCode >= 96 && keyCode <= 105)) && isShift == false) {
                  if ((input.value.length == 2 || input.value.length == 5) && keyCode != 8) {
                      input.value += seperator;
                  }
                  return true;
              }
              else {
                  return false;
              }
          };
          $(".datepicker").keyup(function(e) {
            // var datecheck = /^([1-9]|0[1-9]|[12][0-9]|3[0-1])\/([1-9]|0[1-9]|1[0 -2])\/\d{4}$/g;
            var datecheck = /^(?:(?:31(\/|-|\.)(?:0?[13578]|1[02]|(?:Jan|Mar|May|Jul|Aug|Oct|Dec)))\1|(?:(?:29|30)(\/|-|\.)(?:0?[1,3-9]|1[0-2]|(?:Jan|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec))\2))(?:(?:1[6-9]|[2-9]\d)?\d{2})$|^(?:29(\/|-|\.)(?:0?2|(?:Feb))\3(?:(?:(?:1[6-9]|[2-9]\d)?(?:0[48]|[2468][048]|[13579][26])|(?:(?:16|[2468][048]|[3579][26])00))))$|^(?:0?[1-9]|1\d|2[0-8])(\/|-|\.)(?:(?:0?[1-9]|(?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep))|(?:1[0-2]|(?:Oct|Nov|Dec)))\4(?:(?:1[6-9]|[2-9]\d)?\d{2})$/g;
            var textcheck = /[A-Za-z]/g;
            var special = /[!"`'#%&.,:;<>=@{}~\$\(\)\*\+\-\\\?\[\]\^\|]+/;
            var unikey = /^[a-zA-Z_ÀÁÂÃÈÉÊÌÍÒÓÔÕÙÚĂĐĨŨƠàáâãèéêìíòóôõùúăđĩũơƯĂẠẢẤẦẨẪẬẮẰẲẴẶẸẺẼỀỀỂưăạảấầẩẫậắằẳẵặẹẻẽềềểỄỆỈỊỌỎỐỒỔỖỘỚỜỞỠỢỤỦỨỪễệỉịọỏốồổỗộớờởỡợụủứừỬỮỰỲỴÝỶỸửữựỳỵỷỹ]+$/;
              if (!datecheck.test(this.value))
                {
                  this.value = this.value.replace(textcheck, '');
                  this.value = this.value.replace(special, '');
                  this.value = this.value.replace(unikey, '');
                }
                // else if (textcheck.test(this.value) || special.test(this.value) || unikey.test(this.value)) {
                //   this.value = this.value.replace(textcheck, '');
                //   this.value = this.value.replace(special, '');
                //   this.value = this.value.replace(unikey, '');
                // }
                else {
                  // return false;
                }
            // }
          });       
  
      });
    // end datepicker
    function selectChanged(obj) {
        var erro_lable_identity = document.getElementById('erro_lable_indentity');  
        var identity_name_error = document.getElementById('sel_stype');
        
        var message = document.getElementById('show_message');
        var value = obj.value;
        if (value === ''){
            message.innerHTML = "";
        }
        else if (value === 'CMND'){
            message.innerHTML = "<%= lib_translate('Identity_card_number')  %> ";
            erro_lable_identity.style.display = "none";
            identity_name_error.style.border = "1px solid #ced4da";  
        }
        else if (value === 'CCCD'){
            message.innerHTML = "<%= lib_translate('Citizen_ID_No')  %> ";
            erro_lable_identity.style.display = "none";
            identity_name_error.style.border = "1px solid #ced4da";  
        }
        else if (value === 'GPLX'){
            message.innerHTML = "<%= lib_translate('Driving_license_number')  %> ";
            erro_lable_identity.style.display = "none";
            identity_name_error.style.border = "1px solid #ced4da";  
        }
        else {
            message.innerHTML = "<%= lib_translate('Passport_#')  %> ";
            erro_lable_identity.style.display = "none";
            identity_name_error.style.border = "1px solid #ced4da";  
        }
    } 
    document.getElementById("id_cancel_add_identity").onclick = function() {
      document.getElementById("id_add_identity").style.display = "block";
      document.getElementById("id_cancel_add_identity").style.display = "none";
    }
    

    function clickCollapseIdentity(element){
        document.getElementById('colapse-icon-identity').style.rotate = element.className.includes('collapsed') ? "unset" : "90deg";
    } 
    function openFormAddIdentity(arrayStypeIdentity) {
            document.getElementById("id_add_identity").style.display = "none";
            document.getElementById("id_cancel_add_identity").style.display = "block";
            let selectElement = document.getElementById("sel_stype");
            let options =  selectElement.options;
            for (let i = 0; i < options.length; i++) {
              const option = options[i];
              if (arrayStypeIdentity.includes(option.value)) {
                option.classList.add("d-none");
              }
            }
        $('#form_add_identity').trigger("reset");

          var date = new Date();
          var day = date.getDate();
          var month = date.getMonth() + 1;
          var year = date.getFullYear();

          if (month < 10) month = "0" + month;
          if (day < 10) day = "0" + day;

          var today = day + "/" + month + "/" + year;
          var today1 = day + "/" + month + "/" + (year+40);

          document.getElementById("identity_issued_date").value = today;
          document.getElementById("identity_issued_expired").value = today1;
          document.getElementById("sel_identity_status_active").checked = true;
          document.getElementById("identity_issued_by").value = "";
          document.getElementById("identity_issued_place").value = "";
          document.getElementById("identity_name").value = "";

          document.getElementById("cls_bmtu_form_add_identity_title").innerHTML = "<%= lib_translate('New_Identity')  %> ";
          document.getElementById("name-btn-identity").innerHTML = "<%= lib_translate('New_Identity')  %>";
          document.getElementById("button-identity-file").classList.add("d-none");
          document.getElementById("form-list-file-identity").classList.add("d-none");
    
        }
    
    function openFormUpdateIdentity(id, user_id, name, issued_date, issued_by, issued_place, issued_expired, stype, status, arrayStypeIdentity, session_id_identity) {
            $("html, body").animate({scrollTop: 0}, 100);
            document.getElementById("collapse_form_add_identity").classList.add("show");
            document.getElementById("id_add_identity").style.display = "none";
            document.getElementById("id_cancel_add_identity").style.display = "block";
            document.getElementById("sel_stype").value = stype;
            var message = document.getElementById('show_message');
            if (stype === ''){
            message.innerHTML = "";
            }
            else if (stype === 'CMND'){
                message.innerHTML = "<%= lib_translate('Identity_card_number')  %> ";
            }
            else if (stype === 'CCCD'){
                message.innerHTML = "<%= lib_translate('Citizen_ID_No')  %> ";
            }
            else if (stype === 'GPLX'){
                message.innerHTML = "<%= lib_translate('Driving_license_number')  %> ";
            }
            else {
                message.innerHTML = "<%= lib_translate('Passport_#')  %> ";
            }
            document.getElementById("list-mediafile-identity").value = "";
            let arridentityFile  = [];
            document.getElementById("form-list-file-identity").classList.remove("d-none");
            document.getElementById("button-identity-file").classList.remove("d-none");
            $("#list-mediafile-identity tr").remove();
            let selectElement = document.getElementById("sel_stype");
            let options =  selectElement.options;
            for (let i = 0; i < options.length; i++) {
              const option = options[i];
              if (arrayStypeIdentity.includes(option.value)) {
                option.classList.add("d-none");
              }
               
            }
            document.getElementById('erro_lable_indentity').style.display = "none";  
            document.getElementById("identity_name").style.border = "";
            document.getElementById('sel_stype').style.border = "1px solid #d8e2ef";


            document.getElementById("cls_bmtu_form_add_identity_title").innerHTML = "<%= lib_translate('Update_Identity')  %>"
            document.getElementById("name-btn-identity").innerHTML = "<%= lib_translate('Update_Identity')  %>"
            document.getElementById("name-btn-identity").disabled = false;
            if(status == "ACTIVE"){
              document.getElementById("sel_identity_status_active").checked = true;
            }
            else {
              document.getElementById("sel_identity_status_inactive").checked = true;
            }

            document.getElementById("identity_id").value = id;
            document.getElementById("identity_name").value = name;
            document.getElementById("identity_issued_date").value = issued_date;
            document.getElementById("identity_issued_by").value = issued_by;
            document.getElementById("identity_issued_place").value = issued_place;
            document.getElementById("identity_issued_expired").value = issued_expired;            

            let action_upload_identity = '<%= url_for(action: :identity_upload_mediafile)%>';
      
          formMediaIdentity.setAction(action_upload_identity + "?identity_id="+ id);
          let idIdentity = document.getElementById("id_iden_btn").getAttribute("myidIdentity");
          // ở đây sửa form
          // start show filemedia list
              $.ajax({
                type: "GET",
                url: "<%= user_identity_edit_path%>",
                data: { idIdentity: session_id_identity },
                dataType: "JSON",
                success: function (response) {
                    formMediaIdentity.removeTableItemAll();
                    formMediaIdentity.tableAddItems(response.docs);
                }
            });
            
    }
      // ở đây thêm mới
    function clickEditMediaIdentity(identity_id, user_id){
      
      if($('#file-upload-identity-'+identity_id).html().length == 0){

        let action_upload = '<%= url_for(action: :identity_upload_mediafile)%>';
          var formmedia_edit_doc = new FormMedia("file-upload-identity-" + identity_id);
          formmedia_edit_doc.setAction(action_upload + "?identity_id="+ identity_id);
          formmedia_edit_doc.setIconPath('<%= root_path%>assets/image/');
          formmedia_edit_doc.setTranslate(media_trans);
          formmedia_edit_doc.init();
          formmedia_edit_doc.addEventListener("confirmdel",(data)=>{
            deleteDoc(data.id, user_id);
          });
              
            $.ajax({
              type: "GET",
              url: "<%= user_identity_edit_path%>",
              data: { idIdentity: identity_id },
              dataType: "JSON",
              success: function (response) {
                  formmedia_edit_doc.removeTableItemAll();
                  formmedia_edit_doc.tableAddItems(response.docs);
              }
          });
        }else{

        }

    }
    // ở đây thêm mới
    function deleteDoc(doc_id,user_id){
      let action = '<%= url_for(action: :identity_del, ck_action: "document")%>';
      action += `&did=${doc_id}&uid=${user_id}`;
      let link = document.createElement('a');
      link.setAttribute('data-action',"delete");
      link.setAttribute('href',action);
      link.click();
    }

    var erro_lable_identity = document.getElementById('erro_lable_indentity');

    document.getElementById("identity_name").addEventListener("keyup", function () {
      var identity_name_error = document.getElementById('identity_name');
      var identity_name = document.getElementById('identity_name').value;
      var pId = document.getElementById('identity_id').value;

      jQuery.ajax({
          data: { check_idenname: identity_name, identity_id: pId},
          type: 'GET',
          url: "<%= user_check_unique_iden_path%>",
          dataType:"JSON",
          success: function (response) {
                  if (response.msg == 'true' && response.scode !='') {
                      erro_lable_identity.innerHTML= "<%= lib_translate('Identity_already_exists')  %>";
                      erro_lable_identity.style.display = "block";
                      identity_name_error.style.border="1px solid red";
                      // document.getElementById("name-btn-identity").disabled = true;
                      document.getElementById("name-btn-identity").classList.add("disable-identity");
                  }else if (response.results == 'true'){
                      erro_lable_identity.innerHTML= "<%= lib_translate('Identity_already_exists')  %>";
                      erro_lable_identity.style.display = "block";
                      identity_name_error.style.border="1px solid red";
                      // document.getElementById("name-btn-identity").disabled = true;
                      document.getElementById("name-btn-identity").classList.add("disable-identity");
                  }else if (response.result == 'false'){
                      // document.getElementById('name-btn-identity').submit();
                  }else if(response.results == 'false'){
                      // document.getElementById('name-btn-identity').submit();
                  }else {
                      // document.getElementById('name-btn-identity').submit();
                  }
          }
        });
      erro_lable_identity.style.display = "none";
      identity_name_error.style.border = "1px solid #ced4da";
      // document.getElementById("name-btn-identity").disabled = false;
      document.getElementById("name-btn-identity").classList.remove("disable-identity");
    });
    function delete_loading_identity(element){
      element.style.display = "none"
      element.previousElementSibling.style.display = "none"
      element.nextElementSibling.style.display = "block"
    }

    document.getElementById('btn_add_new_identity').onclick = function () {
      var stype_iden = document.getElementById('sel_stype').value;
      var stype_scode_error = document.getElementById('sel_stype');
      if (stype_iden == "") {
          erro_lable_identity.innerHTML = "<%= lib_translate("Please_select_identifier_type")  %>";
          erro_lable_identity.style.display = "block";
          stype_scode_error.style.border = "1px solid red";
          return;
      } else {
          stype_scode_error.style.border = "1px solid #d8e2ef";
          erro_lable_identity.style.display = "none";    
      }

      document.getElementById("name-btn-identity").style.display = "none";
      document.getElementById("loading_button_identity").style.display = "block";
      document.getElementById("btn_add_new_identity").type = "submit";
    };

    const formMediaIdentity = new FormMedia("upload_file_identity");
    formMediaIdentity.setIconPath('<%= root_path%>assets/image/');
    formMediaIdentity.setTranslate(media_trans);
    formMediaIdentity.init();

    // ở đây thay đổi
    formMediaIdentity.addEventListener("confirmdel",(data)=>{
        deleteDoc(data.id, data.uid);
    });


    function showModalDeleteIdentity(element) {
        let href = element.getAttribute("data-action");
        let name = element.getAttribute("data-name");
        $("#identity-confirm").find('#button_delete').attr('href',href);
        $("#identity-confirm").find('#modal-mesasge-delete-name').text(name);
        // show modal
        $("#identity-confirm").modal('show');

    }
    function clickDeleteIdentity(id,name,user_id){
      let href = '<%= url_for(action: :identity_del)%>';
      href += `?id=${id}&uid=${user_id}`;

      let html = `<%= lib_translate("confirm_delete_message")%>  <span style="font-weight: bold; color: red">${name}</span>?`
      openConfirmDialog(html,(result )=>{
        if(result){
          doClick(href,'delete')
        }
      });

    }
</script>
