    <h4 class="mb-1" style="color: var(--falcon-btn-falcon-success-active-color);"><%= lib_translate("Identity") %></h4>
    <h6 class="m-0" style="color: var(--falcon-badge-soft-secondary-color);"> <%= lib_translate("CMND_CCCD_passport") %></h6>
</div>

    </div>
                <% 
                arrayStypeIdentityADD = []
                @identitys.each do |identity|
                arrayStypeIdentityADD.push(identity.stype ? identity.stype : "")
                %>
                <% end %>
