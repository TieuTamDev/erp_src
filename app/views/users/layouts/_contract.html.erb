<%= stylesheet_link_tag '/assets/mystyle/contract.css'%>
<div class="content-user">
    <div class="row">
        <div class="col-12 col-sm-12 col-md-12 col-lg-8 col-xl-7 col-xxl-7  tag d-flex align-items-center title mt-3">
            <h4 class="mb-1" style="color: var(--falcon-btn-falcon-success-active-color);"><%=lib_translate("List_Contract")%></h4>            
        </div>
        <div class="col-12 col-sm-12 col-md-12 col-lg-4 col-xl-5 col-xxl-5 action-right-top d-flex align-items-center justify-content-end">
              <% if is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","ADD") && request.env["PATH_INFO"] != "/user/profile" %>
            <a id="id_add_contract" class="nav-link pe-2 " role="button" style="font-size: 13px; font-weight: 700;color: var(--falcon-orange)" onclick="openFormAddContract()" class="btn btn-primary mt-3"  data-bs-toggle="collapse" data-bs-target="#collapse_form_add_contract" aria-expanded="false" aria-controls="collapse_form_add_contract">
                <%= lib_translate("New_Contract") %> </a> 
            <a id="id_cancel_add_contract" class=" nav-link ps-2 pe-2 border-end border-2"  style="display:none; font-size: 13px; font-weight: 700;color: var(--falcon-orange)" data-bs-toggle="collapse" href="#collapse_form_add_contract" role="button" aria-expanded="false" aria-controls="collapse_form_add_contract">
                <%= lib_translate("Cancle") %> 
            </a> 
               <% end %>
        </div>
    </div>
    <div class="row">
        <div class="collapse" id="collapse_form_add_contract">
            <div class="card p-3 capp-form-bg">
                <div class="form_add">
                    <%= form_for @contract, :url=> user_contract_update_path, html: {method: :post,id:"form_add_contract" } do |f| %>
                        <div class="d-flex justify-content-center">
                            <h3 class="m-0" id="cls_bmtu_form_add_contract_title">
                                <%= lib_translate("New_Contract") %>
                            </h3>
                        </div> 
                        <div class="erro_labble_contract mb-2">
                            <p style=" display: none; color: rgb(197 82 82); border: 1px solid rgb(199 136 136 / 23%); background: rgb(255 54 54 / 16%); border-radius: 5px; padding: 10px;" id="erro_lable_contract"></p>
                        </div>
                        <div class="form-group" style="display:none;">
                            <%= f.label :id %> <span class="red">* </span>
                            <%= f.text_field :id, class: 'form-control' , name: 'contract_id' , id: 'contract_id' %>
                        </div>
                        <div class="form-group" id="id_add_sid" style="display: none;">
                            <%= f.label :user_id %>
                            <span style="color: red" class="red">* </span>
                            <%= f.text_field :user_id, class: 'form-control' ,name:'contract_user_id', :value=> @user.id,id:'contract_user_id' %>
                        </div>
                        <div class="row">                        
                            <div class="form-group pd-20px">
                                <%= f.label lib_translate("Contract_name")%>: <a class="ms-2" href="<%= contracttype_index_path() %>"><span style="width:10px; color:#98a7b9" class="fas fa-database"></span></a>
                                <select style="text-transform:capitalize;" class="form-select selectpicker" id="contract_name" size="1" name="contract_name" data-options='{"removeItemButton":true,"placeholder":true}'>
                                    <% contracttypes = Contracttype.where.not(status: 'INACTIVE')
                                        contracttypes.each do |conType| %>
                                        <option style="text-transform:capitalize;" value="<%= conType.name %>"><%= conType.name %></option>                                    
                                    <% end %>
                                </select>  
                            </div>
                            <div class="form-group" style="display: flex; text-transform: capitalize;">
                                <div class="col-xs-12 col-sm-6 pe-2">
                                    <%= f.label lib_translate("Contract_issued_by")%>
                                    <%
=begin%>
 <select style="text-transform:capitalize;" class="form-select selectpicker" id="contract_issued_by" size="1" name="contract_issued_by" data-options='{"removeItemButton":true,"placeholder":true}'>
                                        <% @users.where.not(id: @user.id).each do |users| %>
                                            <option style="text-transform:capitalize;" value="<%= users.last_name %> <%= users.first_name %>"><%= users.last_name %> <%= users.first_name %></option>
                                        <% end %>
                                    </select>   
<%
=end%>                          
                                <%= f.text_field :issued_by , class: 'form-control' ,:id=> "contract_issued_by",:name=> "contract_issued_by"%>
                                </div>
                                <div class="col-xs-12 col-sm-6 ">
                                    <%= f.label lib_translate("Contract_issued_date")%>
                                    <div id="datepicker-container" class="datepicker-container">
                                        <span style="position: relative;" class="outline-element-container"> <input id="contract_issued_date" maxlength="10" type="text" name="contract_issued_date" class="form-control datepicker openemr-datepicker input-textbox outline-element incorrect" placeholder="dd/mm/yyy" objtype="7" name="action_element" objindex=""  aria-label="Select Date"> <span class="correct-incorrect-icon"> </span></span>
                                        <div id="datepicker"></div>
                                    </div>  
                                </div>
                            </div>                   
                            <div class="form-group" style="display: flex;">
                                <div class="col-xs-12 col-sm-6 pe-2">
                                    <%= f.label lib_translate("Date_from") %>
                                    <div id="datepicker-container" class="datepicker-container">
                                        <span style="position: relative;" class="outline-element-container">
                                         <input id="dt_dtfrom" maxlength="10" type="text" name="dt_dtfrom" class="form-control datepicker openemr-datepicker input-textbox outline-element incorrect" placeholder="Type Name" objtype="7" name="action_element" objindex=""  aria-label="Select Date"> 
                                         <span class="correct-incorrect-icon"> </span>
                                        <div id="datepicker"></div>
                                    </div>  
                                </div>   
                                <div class="col-xs-12 col-sm-6" >
                                    <%= f.label lib_translate("Contract_time")%>: <a class="ms-2" href="<%= contracttime_index_path() %>"><span style="width:10px; color:#98a7b9" class="fas fa-database"></span></a>
                                    <select style="text-transform:capitalize;" class="form-select selectpicker" id="contract_issued_place" size="1" name="contract_issued_place" data-options='{"removeItemButton":true,"placeholder":true}' onchange="updateDtto(this)">
                                        <% contracttimes = Contracttime.where.not(status: 'INACTIVE')
                                         contracttimes.each do |conTime| %>
                                            <option style="text-transform:capitalize;" data-id="<%= conTime.scode %>" value="<%= conTime.name %>"><%= conTime.name %></option>
                                        <% end %>
                                    </select>
                                </div>
                            </div>
                            <div class="mt-3" style="display: flex; flex-direction: row; ">
                                <%= f.label lib_translate("Status_1") %>
                                <div class="form-check form-switch ms-3">
                                    <input style="font-size: 1.05rem;text-transform: uppercase;cursor: pointer;" class="form-check-input" id="contract_status" onchange="onChangeStatus(this)" type="checkbox" name="status"/>
                                    <label id="status_label" style="font-size: 1.05rem;text-transform: uppercase;cursor: pointer;" for="contract_status"></label>
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            <%= f.label lib_translate("Contract_base_salary") %>
                            <%= f.text_field :base_salary , class: 'form-control' ,:id=> "contract_base_salary",:name=> "contract_base_salary", :onkeyup=>"on_amount_change(this)", :maxlength =>11, :onkeypress=>"on_amount_change(this)"%>
                            
                        </div>
                        <div class="form-group">
                            <%= f.label lib_translate("Note") %>
                            <%= f.text_area :note , class: 'form-control' ,:id=> "contract_note",:name=> "contract_note"%>
                        </div>
                        <div class="foprm_group" style="display:none;">
                            <%= f.label lib_translate("Date_to")%>                                    
                            <div id="datepicker-container" class="datepicker-container">
                                <span style="position: relative;" class="outline-element-container"> <input id="dt_dtto" maxlength="10" type="text" name="dt_dtto" class="form-control datepicker openemr-datepicker input-textbox outline-element incorrect" placeholder="Type Name" objtype="7" name="action_element" objindex=""  aria-label="Select Date"> <span class="correct-incorrect-icon"> </span></span>
                                <div id="datepicker"></div>
                            </div> 
                        </div>
                        <div class="form-group hidden"> 
                                <%= f.text_field :note, :id=> "file",:name=> "arr_file", :class => "form-control height validate  input-lg", :accept=>" text/txt, text/pdf"  %>
                        </div>
                            <%= f.submit "" , type:"button" , id:"btn_add_new_contract", class: "btn btn-primary mt-3 mb-5 border-red border-pink-600 cls-bmtu-text-red md:group-hover:bg-pink-50 btn-block btn-block text-uppercase d-none" , style: "width: 100%;" %>
                    <% end %>
                    
                    <label onclick="clickCollapseContract(this)" id="button-contract-file" class= "card p-2 mt-3 d-flex" style= "width: 100%; background: var(--falcon-badge-soft-dark-background-color); flex-direction: row; align-items: center; justify-content: space-between;" type="button" data-bs-toggle="collapse" data-bs-target="#add-file-medias" aria-expanded="false" aria-controls="add-file-medias">
                        <%=lib_translate("List_Contract")%> 
                    <span id="colapse-icon-contract" class="fas fa-chevron-circle-down"></span>
                    </label>  
                    <%# Upload media view %>
                    <div class="collapse" id="add-file-medias">
                        <div class="card">
                            <div class="card-header">
                            <h5 class="mb-0"><%=lib_translate("Upload_files")%></h5>
                            </div>
                            <div class="card-body bg-light" id="upload_file_contract">
                            
                            </div>
                        </div>
                    </div>
                    <%# ==== %>                    

                    <label id="name-btn-contract" for="btn_add_new_contract" class= "btn btn-primary mt-3  border-red border-pink-600 cls-bmtu-text-red md:group-hover:bg-pink-50 btn-block text-uppercase" style= "width: 100%;">
                    </label>                   
                    <div id="loading_button_contract" class= "btn btn-primary mt-3 mb-5 border-red border-pink-600 cls-bmtu-text-red md:group-hover:bg-pink-50 btn-block text-uppercase" style="opacity: 0.8;width: 100%; display:none;" >
                        <i class ="fa fa-spinner fa-spin"> </i>  <%=lib_translate("Save")%> 
                    </div>                                       
                </div>
            </div>
        </div>
    </div>
    <hr class="mt-2 mb-3" style="width: 100%">  
    <div class="row">
        <div class="card-body pt-0">
            <div class="tab-content">
                <table id="table_contract" class="table table-bordered  fs--1 mb-0 "style="margin-top: 0px !important; margin-bottom: 0px !important">
                    <thead class="bg-200 text-900">
                        <tr>
                            <th class="sort" style="text-align: center; width: 15%;" data-sort="contract_name">
                                <%= lib_translate("Contract_name") %>
                            </th>
                            <th class="sort" style="text-align: center; width: 10%;" data-sort="contract_issued_date">
                                <%= lib_translate("Contract_issued_date") %>
                            </th>
                            <th class="sort" style="text-align: center;  width: 13%;" data-sort="contract_issued_by">
                                <%= lib_translate("Contract_issued_by") %>
                            </th>
                            <th class="sort" style="text-align: center; width: 13%;" data-sort="contract_issued_place">
                                <%= lib_translate("Contract_time") %>
                            </th>
                            <th class="sort" style="text-align: center; width: 7%;" data-sort="contract_status">
                                <%= lib_translate("Signed") %>
                            </th>
                            <th class="sort" style="text-align: center; width: 9%;" data-sort="contract_base_salary">
                                <%= lib_translate("Contract_base_salary") %>
                            </th>

                           <% if (is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","EDIT") || is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","DEL")) && (request.env["PATH_INFO"] != "/user/profile") %>
                            <th class="no-sort" style="text-align: center; width: 15%;">
                            </th>
                            <% end %>
                        </tr>
                    </thead>
                    <tbody class="list">
                        <% @contracts_data.each do |contract| %>
                            <%
                                tr_style = ""
                                if contract[:status] == "ACTIVE"
                                   if !contract[:dtto].nil?
                                    if Date.today <= contract[:dtto]&.to_date || contract[:dtto].nil? || contract[:dtto] == ""
                                        tr_style = "color: #54B435;font-weight: 600;"
                                    elsif Date.today > contract[:dtto]&.to_date
                                        tr_style = "color: #bcbcbc;font-style: italic;"
                                    end
                                   else
                                        tr_style = "color: #54B435;font-weight: 600;"
                                   end                                 
                                else
                                    tr_style = "color: #000;"
                                end
                            %>

                            <tr myidContract=`<%= contract[:id] %>' style="<%= tr_style%>" id="id_cont_btn">
                                <td style=" text-align: center; vertical-align: middle;" class="contract_name">
                                    <%= contract[:name] %>
                                </td>
                                <td style=" text-align: center; vertical-align: middle;" class="contract_issued_date">
                                    <%= contract[:issued_date] %>
                                </td>
                                <td style=" text-align: center; vertical-align: middle;text-transform: capitalize;" class="contract_issued_by">
                                    <%= contract[:issued_by] %>
                                </td>
                                <td style=" text-align: center; vertical-align: middle;" class="contract_issued_place">
                                    <%= contract[:issued_place]%>
                                </td>
                                <td style=" text-align: center; " class="contract_status">
                                    <%if contract[:status] == "ACTIVE"  %>
                                        <span style="font-size:1rem" class="fas fa-check-circle text-success"></span>
                                    <%else%>
                                           
                                    <%end %>
                                </td>
                                <td style=" text-align: center; vertical-align: middle;" class="contract_base_salary" >
                                    <%= number_to_currency(contract[:base_salary] ? contract[:base_salary] : 0, :unit => "đ", :delimiter => ",", precision: 0, format: "%n%u")%>
                                </td>
                                  <% if (is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","EDIT") || is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","DEL")) && (request.env["PATH_INFO"] != "/user/profile") %>
                                <td style="text-align: center; white-space: nowrap;">
                                 <% if is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","EDIT") && request.env["PATH_INFO"] != "/user/profile" %>
                                    <a  class="edit_contract " myidContract='<%= contract[:id] %>' style="text-decoration: none; cursor:pointer;"  data-bs-toggle="collapse" data-bs-target="#collapse_form_add_contract" aria-expanded="false" aria-controls="collapse_form_add_contract"
                                    onclick="openFormUpdateContract(`<%= contract[:id] %>`,
                                                                    `<%= contract[:user_id] %>`,
                                                                    `<%= contract[:name] %>`,
                                                                    `<%= contract[:issued_date] %>`,
                                                                    `<%= contract[:issued_by] %>`, 
                                                                    `<%= contract[:issued_place] %>`, 
                                                                    `<%= contract[:dtfrom] %>`,
                                                                    `<%= contract[:dtto]%>`, 
                                                                    `<%= contract[:status] %>`,  
                                                                    `<%= contract[:base_salary] %>`,  
                                                                    `<%= contract[:note] %>`,
                                                                    `<%= session[:id_contract_user] = contract[:id] %>`)">
                                        <span  class="text-primary far fa-edit  me-2 "></span>
                                    </a>
                                      <% end %> 
                                         <% if is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","DEL") && request.env["PATH_INFO"] != "/user/profile" %>
                                    <a onclick="clickDeleteContract(`<%= contract[:id] %>`,`<%= contract[:name] %>`,`<%= contract[:user_id] %>`)" style="cursor: pointer">
                                        <span class="text-danger fas fa-trash"  style="width: 12px" ></span>
                                    </a>
                                     <% end %>

                                      <% if is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","EDIT") && request.env["PATH_INFO"] != "/user/profile" %>
                                    <a style="text-decoration: none; cursor: pointer"onclick="clickEditMediaContract(`<%= contract[:id]%>`,`<%= contract[:user_id]%>`)" href="#file-contract-<%= contract[:id]  %>" role="button" aria-expanded="false" aria-controls="file-contract-<%= contract[:id]  %>" data-bs-toggle="collapse" data-bs-target="#upload_contract-<%= contract[:id]  %>" aria-expanded="false" aria-controls="upload_contract-<%= contract[:id]  %>" class="m-0 ms-2">
                                        <span class="fas fa-folder-open icon text-warning"></span>
                                    </a>
                                    <% end %>
                                    <% if is_access(session["user_id"], request.env["PATH_INFO"] == "/user/details" ? "USER-DETAILS" : request.env["PATH_INFO"] == "/user/profile" ? "USER-PROFILE" : "","EDIT") && request.env["PATH_INFO"] != "/user/profile" %>
                                    <% if contract[:temp_valid]%>
                                 
                                    <a onclick='window.location="<%= user_contract_preview_path(id: contract[:id], lang: session[:lang]) %>";' class="m-0 ms-2" style="cursor: pointer"  data-bs-placement="top" >
                                        <span class="fa fa-file-signature icon text-twitter"></span>
                                    </a>
                                    <%else%>
                                    <a type="button" data-bs-toggle="modal" data-bs-target="#select-contract-type-modal"><span class="fa fa-file-signature icon text-twitter"></span></a>
                                    <%end%>
                                      <% end %> 
                                </td>
                                  <% end %>  
                            </tr>
                            <tr style="background: var(--falcon-border-color);" class="collapse" id="upload_contract-<%= contract[:id]  %>" >
                                <td style="display: none;" class="contract_name">
                                    <%= contract[:name] %>
                                </td>
                                <td style="display: none;" class="contract_issued_date">
                                    <%= contract[:issued_date] %>
                                </td>
                                <td style="display: none;" class="contract_issued_by">
                                    <%= contract[:issued_by] %>
                                </td>
                                <td style="display: none;" class="contract_issued_place">
                                    <%= contract[:issued_place]%>
                                </td>
                                <td style="display: none;" class="contract_status">
                                    <%= contract[:status]%>
                                </td>
                                <td style="display: none;" class="contract_base_salary">
                                    <%= number_to_currency(contract[:base_salary] ? contract[:base_salary] : 0, :unit => "đ", :delimiter => ",", precision: 0, format: "%n%u") %>
                                </td>
                                <td colspan="7" class="line_upload">
                                    <div id="file-upload-contract-<%= contract[:id]  %>"></div>
                                </td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<%# modal delete contract details %>
<div class="modal fade" id="contract-confirm" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
    <div class="modal-content">
        <div class="modal-header">
        <h5 class="modal-title">
            <%= lib_translate("Message") %>
        </h5>
        <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close" style="border: none; background: none">
            <span aria-hidden="true" style="font-size: 20px">&times;</span>
        </button>
        </div>
        <div class="modal-body">
        <%= lib_translate("confirm_delete_message") %>
        <span id="modal-mesasge-delete-name" style="font-weight: bold; color: red"></span>?
        </div>
        <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" id="button_close_delete"> <%= lib_translate("Close") %> </button>
        <a class="btn btn-danger" id="button_delete" rel="nofollow" data-method="delete" href="#"><%=lib_translate("Delete")%></a>
        <div id="loading_button_delete_contract_details" class= "btn btn-danger" style="opacity: 0.8; width: 100%; display:none;" >
            <i class ="fa fa-spinner fa-spin"> </i>  <%=lib_translate("Deleting")%> 
        </div>
        </div> 
    </div>
    </div>
</div>
<%# Model generate contract file - testing %>
<div class="modal fade" id="select-contract-type-modal" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" role="document" style="max-width: 500px">
    <div class="modal-content position-relative">
      <div class="position-absolute top-0 end-0 mt-2 me-2 z-index-1">
        <button class="btn-close btn btn-sm btn-circle d-flex flex-center transition-base" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-0">
        <div class="rounded-top-lg py-3 ps-4 pe-6 bg-light">
          <h4 class="mb-1" id="modalExampleDemoLabel"><%=lib_translate("Update_tempcontract")%></h4>
        </div>
        <div class="p-4 pb-0">
          <p><%= lib_translate("Update_tempcontract_confirm")%></p>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" type="button" data-bs-dismiss="modal"><%=lib_translate("Cancel")%></button>
        <a onclick='window.location="<%= tmpcontracts_index_path(lang: session[:lang]) %>";' class="btn btn-primary m-0 ms-2" style="cursor: pointer" ><%=lib_translate("Update")%></a>
      </div>
    </div>
  </div>
</div>
<%# Model generate contract file - testing end %>
<script>
    var newContract = "<%= lib_translate('New_Contract') %>";
    var upContract = "<%= lib_translate('Update_Contract') %>";
    var actionUp =  "<%= url_for(action: :contract_upload_mediafile)%>";
    var urlContract =   "<%= user_contract_edit_path%>";
    var iconImg = '<%= root_path%>assets/image/';
    var delMed = '<%= url_for(action: :contract_del, ck_action: "document")%>';
    var conDel = '<%= url_for(action: :contract_del)%>';
    var messDel = "<%= lib_translate("confirm_delete_message")%>";
</script>
<%= javascript_include_tag "/assets/myjs/contract.js" %>

