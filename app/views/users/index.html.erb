            <span class="badge badge-soft-danger">Lỗi khi xử lý dữ liệu. Vui lòng kiểm tra và thử lại.</span>
          </div>
          <%# Import result %>
          <div id="import-result-stu-info" class="border rounded-1 mt-2 collapse">
            <h5 class="p-2 fs-0 bg-200"><%= lib_translate("Processing_result")%>:<span id="result-total-stu-info"></span></h5>
            <div class="p-2">
              <p class="m-0">
                <span style="font-weight: 500;font-size: 17px;"><%= lib_translate("Total")%>:</span>
                <span id="result_total_stu_info" style="font-size: 18px;color: black;font-weight: 800;">0</span>
              </p>
              <p class="m-0">
                <span style="font-weight: 500;font-size: 17px;"><%= lib_translate("Success")%>:</span>
                <span id="success_count_stu_info" class="text-success" style="font-size: 18px;color: black;font-weight: 800;">0</span>
              </p>
              <p class="m-0 d-none" >
                <span style="font-weight: 500;font-size: 17px;"><%= lib_translate("Duplicate")%>:</span>
                <span id="update_count_stu_info" class="text-info" style="font-size: 18px;color: black;font-weight: 800;">0</span>
                <span id="update-all-button-stu-info" onclick="uploadAllImportStuInfo()" class="btn btn-primary btn-sm ms-4" style="padding: 0px 7px;font-size: 0.7em;display:none;"><%= lib_translate("Update_all")%></span>
              </p>
              <div id="update_list_stu_info" class="ps-2 mt-2 scrollbar" style="max-height: 300px;"></div>
              <p class="m-0">
                <span style="font-weight: 500;font-size: 17px;"><%= lib_translate("Not_Success")%>:</span>
                <span id="error_count_stu_info" class="text-danger" style="font-size: 18px;color: black;font-weight: 800;">0</span>
              </p>
              <div id="error_list_stu_info" class="ps-3 scrollbar" style="max-height: 300px;"></div>
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary button-cancel-import" type="button" data-bs-dismiss="modal"><%= lib_translate("Close")%></button>
      </div>
    </div>
  </div>
</div>

<div style="display:none;">
