                                                            `<%= user.insurance_reg_place %>`,
                                                            `<%= user.place_of_birth %>`,
                                                            `<%= user.m_place_of_birth %>`,
                                                            `<%= user.email1 %>`,
                                                            `<%= user.phone %>`,
                                                            `<%= user.mobile %>`,
                                                            `<%= user.staff_type %>`,
                                                            `<%= user.staff_status %>`, 
                                                            <%= user.benefit_type %>,
                                                            <%= list_uorg_user %>,
                                                            `<%= user.twofa %>`,
                                                            `<%= user.twofa_exam %>`,
                                                            `<%= user.ignore_attend %>`,
                                                            `<%= user&.termination_date&.strftime('%Y-%m-%d') %>`,
                                                            )">
                                                            <span class="text-primary fas fa-user-edit me-1" ></span>
                                                          </a>
                                                        <% end %>
                                                        <!-- Button trigger modal --> 
                                                        <% if is_access(session["user_id"], "USERS","DEL") %> 
                                                          <a data-toggle="tooltip" data-placement="top" title="Xóa nhân sự" data-bs-toggle="modal" data-bs-target="#modal-list-user-<%= user.id %>" style="cursor: pointer;">
