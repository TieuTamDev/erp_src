                                                                  </button>
                                                                </div>
                                                                <div class="modal-body">
                                                                  <%= lib_translate("Are_you_sure_to_delete_this_staff")  %> <span style="font-weight:bold; color:red; text-transform: capitalize;"> <%= user.last_name %> <%= user.first_name %> </span>?
