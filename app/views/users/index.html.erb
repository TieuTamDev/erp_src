                                                            `<%= user.marriage %>`, 
                                                            `<%= user.insurance_no %>`, 
                                                            `<%= user.education %>`,
                                                            `<%= user.academic_rank %>`, 
                                                            `<%= user.status %>`, 
                                                            `<%= user.stype %>`,
                                                            `<%= user.note %>`,
                                                            `<%= user.first_name %>`,
                                                            `<%= user.last_name %>`,
                                                            `<%= user.birthday&.strftime('%d/%m/%Y') %>`,
