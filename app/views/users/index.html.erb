                                                        # Lấy positionjob và phòng ban hiện tại
                                                        positionjob = latest_work&.positionjob
                                                        positionjob_name = positionjob&.name

                                                        # Phòng ban hiện tại (ví dụ: sub a.1)
                                                        department = positionjob&.department
                                                        department_name = department&.name

                                                        # Truy ngược để tìm phòng ban gốc
                                                        main_department = department
                                                        while main_department&.parents.present?
                                                          main_department = Department.find_by(id: main_department.parents)
                                                        end

                                                        main_department_name = main_department&.name
                                                    %>
                                                    
                                                    <% if positionjob_name.present? %>
