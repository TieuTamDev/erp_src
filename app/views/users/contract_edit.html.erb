<div class="bmtu_header_dashboard">
    <h3 class="mt-2 overview_text"><%= lib_translate("List_Contract")  %></h3>
    <div class="d-flex flex-row-reverse bd-highlight ">
        <button onclick="openFormAddContract()" class="btn btn-primary mb-1">
            <%= lib_translate("New_Contract")  %>
        </button>
    </div>

</div>
<div class="card mb-3">
    <div class="card-body pt-0">
        <div class="tab-content">
            <div class="tab-pane preview-tab-pane active" role="tabpanel" aria-labelledby="tab-dom-5a3c857c-8deb-4307-af64-a62f27089443" id="dom-5a3c857c-8deb-4307-af64-a62f27089443">
                <div id="tableExample91"
                    data-list='{"valueNames":["id","contract_user_username","contract_name","contract_issued_date","contract_issued_by","contract_issued_place","contract_dtfrom","contract_dtto","contract_status","contract_mediafile_id","contract_note"],"page":20,"pagination":true}'>
                    <div class="row justify-content-end g-0">
                        <div class="col-auto col-sm-5 mb-3">
                            <form>
                                <div class="input-group mt-3">
                                    <input class="form-control form-control-sm shadow-none search" type="search"
                                        placeholder="Search..." aria-label="search" />
                                    <div class="input-group-text bg-transparent"><span
                                            class="fa fa-search fs--1 text-600"></span></div>
                                </div>
                            </form>
                        </div>
                    </div>
                    <div class="table-responsive scrollbar">
                        <table class="table table-bordered table-striped fs--1 mb-0 table-hover" style="width: 100%;        
                        border-collapse: collapse;">
                            <thead class="bg-200 text-900">
                                <tr>
                                    <th data-sort="id" style="display: none;">ID</th>
                                                                        
                                    <th class="sort" style="text-align: center;" data-sort="contract_user_username"><%= lib_translate("Employee_name")  %></th>                                    
                                    <th class="sort" style="text-align: center;" data-sort="contract_name"><%= lib_translate("Contract_name")  %></th>                                    
                                    <th class="sort" style="text-align: center;" data-sort="contract_issued_date"><%= lib_translate("Contract_issued_date")  %></th>
                                    <th class="sort" style="text-align: center;" data-sort="contract_issued_by"><%= lib_translate("Contract_issued_by")  %></th>
                                    <th class="sort" style="text-align: center;" data-sort="contract_issued_place"><%= lib_translate("Contract_issued_place")  %></th>
                                    <th class="sort" style="text-align: center;" data-sort="contract_dtfrom"><%= lib_translate("Date_from")  %></th>
                                    <th class="sort" style="text-align: center;" data-sort="contract_dtto"><%= lib_translate("Date_to")  %></th>
                                    <th class="sort" style="text-align: center;" data-sort="contract_status"><%= lib_translate("Status")  %></th>
                                    <th class="sort" style="text-align: center;" data-sort="contract_mediafile_id"><%= lib_translate("Mediafile")  %></th>
                                    <th class="sort" style="text-align: center;" data-sort="contract_note"><%=  lib_translate("Note")%> </th>
                                    <th style="text-align: center;"><%= lib_translate("Action")  %></th>

                                </tr>
                            </thead>
                            <tbody class="list">
                                <% @contracts.each do |contract| %>
                                    <tr>
                                        <td class="contract_name">
                                            <%= User.where("id = '#{contract.user_id}' ").first.last_name%>
                                            <%= User.where("id = '#{contract.user_id}' ").first.first_name%>
                                        </td>
                                        <td class="contract_name">
                                            <%= contract.name %>
                                        </td>
                                        <td class="contract_issued_date">
                                            <%= contract.issued_date&.strftime('%d-%m-%Y') %>
                                        </td>
                                        <td class="contract_issued_by">
                                            <%= contract.issued_by %>
                                        </td>
                                        <td class="contract_issued_place">
                                            <%= contract.issued_place %>
                                        </td>
                                        <td class="contract_dtfrom">
                                            <%= contract.dtfrom&.strftime('%d-%m-%Y') %>
                                        </td>
                                        <td class="Date_t_contract">
                                            <%= contract.dtto&.strftime('%d-%m-%Y') %>
                                        </td>
                                        <td class="contract_status">
                                            <%= ( if contract.status=="0"
                                            lib_translate("ACTIVE") 
                                            else contract.status=="1" 
                                            lib_translate("INACTIVE") 
                                            end ) %>
                                        </td>
                                        <td>
                                            <img width="30" src='https://capp.bmtu.edu.vn/mdata/hrm/<%= Mediafile.where("id = '#{contract.mediafile_id}' ").first.file_name%>' alt=""> </td>
                                        </td>
                                        <td class="contract_note">
                                            <%= contract.note %>
                                        </td>
                                        <td>
                                            <a style="cursor:pointer;" onclick="openFormUpdateContract(    '<%= contract.id %>',
                                                                                    '<%= User.where("id = '#{contract.user_id}' ").first.username%>',
                                                                                    '<%= contract.name %>',
                                                                                    '<%= contract.issued_date&.strftime('%Y-%m-%d') %>',
                                                                                    '<%= contract.issued_by %>', 
                                                                                    '<%= contract.issued_place %>', 
                                                                                    '<%= contract.dtfrom&.strftime('%Y-%m-%d') %>',
                                                                                    '<%= contract.dtto&.strftime('%Y-%m-%d') %>', 
                                                                                    '<%= contract.status %>', 
                                                                                    '<%= Mediafile.where("id = '#{contract.mediafile_id}' ").first.file_name%>', 
                                                                                    '<%= contract.note %>')">
                                                <span class="far fa-edit me-2"></span>
                                            </a>
                                            <a data-toggle="modal" data-target="#exampleModal-#{<%= contract.id %>}"
                                                style="cursor: pointer;">
                                                <span class="fas fa-trash" style="width : 15px"></span>
                                            </a>
                                            <div class="modal fade" id="exampleModal-#{<%= contract.id %>}"
                                                tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel"
                                                aria-hidden="true">
                                                <div class="modal-dialog" role="document">
                                                    <div class="modal-content">
                                                        <div class="modal-header">
                                                            <h5 class="modal-title" id="exampleModalLabel">Are you sure?
                                                            </h5>
                                                            <button type="button" class="close" data-dismiss="modal" aria-label="Close" style="border: none; background: none" >
                                                                <span aria-hidden="true" style="font-size: 20px"  >&times;</span>
                                                              </button>
                                                        </div>
                                                        <div class="modal-body">
                                                            <%= lib_translate("Are_you_sure_to_delete_this_contract")  %>: <%= contract.id %>?
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-secondary"
                                                                data-dismiss="modal"><%= lib_translate("Close")  %></button>
                                                            <%= link_to link_to lib_translate("Delete") , url_for(action: :contract_del, id:
                                                                contract.id, ck_action: "contract/edit"), method: :delete, class: "btn btn-danger"
                                                                %>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                    <% end %>
                            </tbody>
                        </table>
                    </div>
                    <div class="d-flex justify-content-center mt-3">
                        <button class="btn btn-sm btn-falcon-default me-1" type="button" title="Previous"
                            data-list-pagination="prev"><span class="fas fa-chevron-left"></span></button>
                        <ul class="pagination mb-0"></ul>
                        <button class="btn btn-sm btn-falcon-default ms-1" type="button" title="Next"
                            data-list-pagination="next"><span class="fas fa-chevron-right"> </span></button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="form-add-contract-container"class="modal" style="background-color: rgba(0, 0, 0, 0.84);">
    <div class="modal-dialog" style="max-width: 1100px;">
        <div class="modal-content">
            <div class="form-add-user">
                <a onclick="closeFormAddContract()" class="btn fw-bold btn ml-3  d-flex flex-row-reverse bd-highlight"
                    id="">X</a>

                <%= form_for @contract, :url=> "/mywork/user/contract/update", html: {method: :post, id:"form_add_contract" } do  |f| %>

                    <p id="cls_bmtu_form_add_contract_title" class=" mt-3 fw-bold fs-3 d-flex justify-content-center">
                        <%= lib_translate(" New_Contract")  %>
                    </p>

                    <!-- báo lỗi  -->
                    <div class="erro_labble">
                        <p style="color:red" id="erro_lable_contract">
                        </p>
                    </div>
                    <br>
                    <div class="form-group" style="display:none;">
                        <%= f.label :id %> <span class="red">* </span>
                        <%= f.text_field :id, class: 'form-control' , name: 'contract_id' %>
                    </div>
                    <div class="row">
                        <div class="col-6">
                            <div class="form-group" >
                                <%= f.label :user_id %> <span class="red">* </span>
                                <input class="form-control" type="text" name="contract_user_username" id="contract_user_username"  placeholder="" list="ds_user_from_id">
                                <datalist id="ds_user_from_id" style="display: none;">
                                    <% @users.each do |users| %>
                                        <option value="<%= users.username %>"><%= users.username %></option>
                                    <% end %>
                                </datalist>
                            </div>
                            <div class="form-group">
                                <%= f.label lib_translate("Contract_name") %>
                                <%= f.text_field :name, class: 'form-control' , name: 'contract_name' %>
                            </div>
                            <div class="form-group">
                                <%= f.label lib_translate("Contract_issued_date") %>
                                <%= f.date_field :issued_date.to_s.slice(0,10), :id=> "contract_issued_date",:name=> "contract_issued_date", min:Date.today,value: "--/--/----", :class => "form-control height validate input-lg " %>
                            </div>
                            <div class="form-group">
                                <%= f.label lib_translate("Contract_issued_by") %>
                                <%= f.text_field :issued_by , class: 'form-control' ,:id=> "contract_issued_by",:name=> "contract_issued_by" %>
                            </div>      
                            <div class="form-group">
                                <%= f.label lib_translate("Contract_issued_place") %>
                                <%= f.text_field :issued_place , class: 'form-control' ,:id=> "contract_issued_place",:name=> "contract_issued_place" %>
                            </div>
                            <div class="form-group">
                                <%= f.label lib_translate("Date_from") %>
                                <%= f.date_field :dtfrom.to_s.slice(0,10), :id=> "dt_dtfrom",:name=> "dt_dtfrom", min:Date.today,value: "--/--/----", :class => "form-control height validate input-lg " %>
                            </div>
                            <div class="form-group">
                                <%= f.label lib_translate("Date_to")%>
                                <%= f.date_field :dtto.to_s.slice(0,10), :id=> "dt_dtto",:name=> "dt_dtto", min:Date.today ,value: "--/--/----", :class => "form-control height validate input-lg " %>
                            </div>
                            <div class="form-group">
                                <%= f.label lib_translate("Status") %>  <span style="color:red;" class="red">* </span>
                                <input checked type="radio" id="sel_contract_status_active" class="form-check-input ms-3 me-1" value="0" name="sel_status" /><%= lib_translate("ACTIVE")%></label>
                                <input  type="radio" id="sel_contract_status_inactive" class="form-check-input ms-3 me-1" value="1" name="sel_status" /><%= lib_translate("INACTIVE")%></label>
                            </div>                    
                            <div class="form-group">
                                <%= f.label  lib_translate("Note") %>
                                <%= f.text_area :note , class: 'form-control' ,:id=> "contract_note",:name=> "contract_note" %>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-group">
                                <%= f.label lib_translate("Mediafile") %> <span style="color:red;" class="red">* </span>
                                <div class="img_review">
                                <img id="con_img" src="#" alt="your image" />
                                </div>
                                <%= f.file_field :mediafile_id, class: 'form-control ', name: 'contract_mediafile_id', :id=> "contract_mediafile_id" ,:accept=>"image/x-png,image/gif,image/jpeg" , onchange: "readImg(this);" %>
                            </div>
                        </div>
                    </div>
                    <div class="form-group d-flex justify-content-end mt-3 mb-3 ">
                        <%= f.submit "Add Contract" , type:"button" , id:"btn_add_new_contract", class: "btn btn-primary " %>
                    </div>
                    <% end %>
                    <div>
                </div>
            </div>
        </div>
    </div>
</div>
