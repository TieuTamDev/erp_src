        <script>
            // form contract  
            function readImg(input) {
              if (input.files && input.files[0]) {
                var reader = new FileReader();
          
                reader.onload = function (e) {
                  $('#con_img').attr('src', e.target.result).width(150).height(200);
                };
          
                reader.readAsDataURL(input.files[0]);
              }
            }
            function openFormAddContract() {
                  document.getElementById("form-add-contract-container").style.display = "block";
                  document.getElementById("cls_bmtu_form_add_contract_title").innerHTML = "<%= lib_translate("New_Contract")  %> ";
                  document.getElementById("btn_add_new_contract").value = "<%= lib_translate("New_Contract")  %>";
                  document.getElementById("con_img").src = "https://archive.org/download/no-photo-available/no-photo-available.png";
          
              }
          
            function closeFormAddContract() {
                document.getElementById("form-add-contract-container").style.display = "none";
                document.getElementById("contract_id").value = "";
                document.getElementById("contract_name").value = "";
                document.getElementById('erro_lable_contract').value = "";
                document.getElementById('erro_lable_contract').style.display = "none";
                document.getElementById('contract_mediafile_id').style.border = "1px solid #ced4da"
        
            }
        
            function openFormUpdateContract(id, user_id, name, issued_date, issued_by, issued_place, dtfrom, dtto, status, mediafile_id, note) {
                document.getElementById('erro_lable_contract').value = "";
                document.getElementById("form-add-contract-container").style.display = "block";        
                document.getElementById("cls_bmtu_form_add_contract_title").innerHTML = "<%= lib_translate("Update_Contract")  %>"
                document.getElementById("btn_add_new_contract").value = "<%= lib_translate("Update_Contract")  %>"
                document.getElementById("con_img").src = "https://capp.bmtu.edu.vn/mdata/hrm/"+ mediafile_id;
        
                document.getElementById("contract_id").value = id;
                document.getElementById("contract_user_username").value = user_id;
                document.getElementById("contract_name").value = name;
                document.getElementById("contract_issued_date").value = issued_date;
                document.getElementById("contract_issued_by").value = issued_by;
                document.getElementById("contract_issued_place").value = issued_place;
                document.getElementById("dt_dtfrom").value = dtfrom;
                document.getElementById("dt_dtto").value = dtto;
                document.getElementById("sel_status").value = status;
                document.getElementById("contract_note").value = note;
                console.log(user_id);
            }
        
            var erro_labble_contract = document.getElementById('erro_lable_contract');
            document.getElementById("contract_user_username").addEventListener("change", function () {

                var userName_erro = document.getElementById('contract_user_username');
                var userName = document.getElementById('contract_user_username').value;


                jQuery.ajax({
                data: { check_username: userName},
                    type: 'GET',
                    url: "/mywork/user/check_username_exists",
                    success: function (result) {
                    console.log(JSON.stringify(result));
                    if (result == false ) {
                        erro_labble_contract.innerHTML = "Username không tồn tại";
                        userName_erro.style.border= "1px solid red";
                        erro_labble_contract.style.display="block";
                        document.getElementById("btn_add_new_contract").disabled = true;

                    }
                    }
                });

                erro_labble_contract.style.display = "none";
                userName_erro.style.border = "1px solid #ced4da";
                document.getElementById("btn_add_new_contract").disabled = false;
            });
            document.getElementById('btn_add_new_contract').onclick = function () {
        
                var mediafile_id = document.getElementById('contract_mediafile_id').value;
                var mediafile_id_erro = document.getElementById('contract_mediafile_id');
                    var name_button = document.getElementById("btn_add_new_contract");
                    if (name_button.value != "<%= lib_translate("Update_Contract")  %>") {
                    console.log(name_button.value);
                    if (mediafile_id == "") {
                    erro_labble_contract.innerHTML = "Please Choose a file";
                    erro_labble_contract.style.display = "block";
                    mediafile_id_erro.style.border = "1px solid red";
                    return;
                    } else {
                    mediafile_id_erro.style.border = "1px solid #ced4da";
                    erro_labble_contract.style.display = "none";
                    }
                }
                document.getElementById("btn_add_new_contract").type = "submit";
            };

            $("#myModal").on("shown.bs.modal", function () {
                $("#myInput").trigger("focus");
            });
          </script>
