<style>
  .badges {
      display: inline-block;
      padding: 1px 15px;
      font-size: 11px;
      font-weight: 600;
      border-radius: 9999px; 
  }
  .badges-pending {
      background-color: #DEE0E2;
      color: #61666F;
  } 
  .badges-primary {
      background-color: #d9e7fa; 
      color: #215cac; 
  } 
  .badges-info {
      background-color: #d8f3ff; 
      color: #197aa4;  
  }  
  .badges-success {
      color: #14AE5C;
      background-color: #C8F9DF;
  } 
  .badges-warning {
      background-color: #FEE9D7;
      color: #FC953B;
  } 
  .badges-rejected {
      background-color: #fee2e2;
      color: #b91c1c;
  }    
  .badges-danger {
      background-color: #fee2e2;
      color: #b91c1c;
  } 
  .notifications {
    color: var(--falcon-gray-1000);
    text-decoration: none;
    background-color: var(--falcon-notification-bg);
    display: -webkit-box;
    display: -ms-flexbox;
    display: flex;
    font-size: .8333333333rem;
    font-family: "Open Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
    -webkit-transition: all .2s ease-in-out;
    transition: all .2s ease-in-out;
  }
  .dropdown-menu-notification {
    min-width: 19rem;
    max-width: 22rem;
  }
  @media(min-width: 576px) {
      .dropdown-menu-notification {
          min-width: 40rem;
      }
  } 

  .bell-shake {
    animation: shake 0.8s ease-in 0s infinite; 
  }

  @keyframes shake {
    0% { transform: translateX(0); }
    25% { transform: rotate(-10deg); }
    50% { transform: rotate(10deg); }
    75% { transform: rotate(-10deg); }
    100% { transform: translateX(0); }
  } 

  .ripple-effect {
    position: relative;
    display: inline-block; 
  }

  .ripple-effect::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%; 
    height: 100%;
    background: rgb(255 0 0);
    border-radius: 20px;
    transform: translate(-50%, -50%) scale(1); 
    animation: ripple 1.5s ease-out infinite;
    z-index: -1; 
  }


  @keyframes ripple {
    0% {
      transform: translate(-50%, -50%) scale(0); 
      opacity: 1;
    }
    100% {
      transform: translate(-50%, -50%) scale(3); 
      opacity: 0;
    }
  }

  .ripple-effect span {
    position: relative;
    z-index: 1;
  }
 
  .notification-body .fw-semi-bold {
    display: -webkit-box;
    -webkit-line-clamp: 2; 
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 0; 
  }

  .notification-body .content-notice {
    display: -webkit-box;
    -webkit-line-clamp: 3; 
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 0.25rem; 
  }

  .notification-body {
    max-width: 100%; 
  }
  
  #loading_notification {
        position: absolute;
        z-index: 2;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgb(0 0 0 / 90%);
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        box-sizing: border-box;
    }
</style>
