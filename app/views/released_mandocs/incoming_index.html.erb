          <!-- If we need scrollbar -->
          <div class="swiper-scrollbar"></div>
        </div>
      </div>
    </div>
  </div>
</div>
<div class="modal fade" id="upload_mandoc_file_update" tabindex="-1" style=" background: rgba(0, 0, 0, 0.84); overflow-y: scroll;">
    <div class="modal-dialog" style="max-width: 70%; width: 100%; height: 100%; display: flex; align-items: center;">
        <div class="modal-content">
            <div class="modal-header d-flex justify-content-center ">
                <h5 class="mb-0"><%= lib_translate('Attached_files')%></h5>
                <button type="button" class="btn-close btn btn-sm btn-circle d-flex flex-center transition-base" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="card-body bg-light" id="upload_mandoc_file_update"></div>
            </div>
        </div>
    </div>
</div>
<!-- modal add documents -->
<div class="modal fade" id="staticBackdrop" data-bs-keyboard="false" data-bs-backdrop="static" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true" data-bs-focus="false">
  <div class="modal-dialog modal-xl mt-6" role="document">
    <div class="modal-content border-0">
      <div class="position-absolute top-0 end-0 mt-3 me-3 z-index-1">
        <button class="btn-close btn btn-sm btn-circle d-flex flex-center transition-base" data-bs-dismiss="modal" id="btn_add_doc_pending_in_close" aria-label="Close" onclick="close_modal_add()"></button>
      </div>
      <div class="modal-body p-0">
        <div class="bg-light rounded-top-lg py-3 ps-4 pe-6">
          <h4 class="mb-1" id="staticBackdropLabel_add"><%= lib_translate('Add_document_to')%></h4>
        </div>
        <div class="p-3">
          <div class="row">
