  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="preview-title"></h5>
        <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div id="preview-content" class="modal-dialog-scrollable mt-0 text-black preview-contents" style="padding-left: 40px; padding-right: 40px; padding-bottom: 10px; padding-top: 10px;">
