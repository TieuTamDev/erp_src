  <%= javascript_include_tag '/assets/myjs/choices.js' %>
  <%= stylesheet_link_tag '/assets/lib_hrm/formmedia.css' %>
  <%= stylesheet_link_tag '/assets/mystyle/incoming_index.css'%>
  <%= stylesheet_link_tag 'jquery-ui.css' %>  
  <%= stylesheet_link_tag '/assets/mystyle/choices.min.css'%>
  <%= javascript_include_tag '/assets/myjs/flatpickr.js' %>
  <%= javascript_include_tag '/assets/myjs/flatpickr_local/vn.js' %>
  <%= stylesheet_link_tag '/assets/mystyle/flatpickr.min.css' %>
  <%= javascript_include_tag '/assets/myjs/tinymcev6.min.js' %>
