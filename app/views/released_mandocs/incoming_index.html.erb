                  <option value="<%= depart.name %>" <%= name_department.include?(depart.name) ? "selected" : "" %>><%= depart.name %></option>
                <% end %>
              </select>
            </div>
            <div class="mt-3"> 
              <label for="subject_email" style="font-size: 1rem" class="mb-0"><%= lib_translate("Subject_email") %><span class="red">*</span>:</label>
              <input type="text" class="form-control" id="subject_email" name="subject_email">
            </div>
            <div class="mt-3 pb-3"> 
              <label for="content_email"  style="font-size: 1rem" class="mb-0"><%= lib_translate("Content_email") %>:</label>
              <div class="mt-0">
                <textarea name="content_email" id="content_email"></textarea>
              </div>
            </div>
          </div>
        </div>

        <!-- File đính kèm -->
        <div class="mt-3" style="border-radius: 5px; box-shadow: rgba(0, 0, 0, 0.1) 0px 4px 12px;">
          <a class="nav-link dropdown-indicator" id="compose_meida_file_collapse" href="#media_file_content" role="button" data-bs-toggle="collapse"  aria-expanded="false" aria-controls="media_file_content">
            <div class="p-2 d-flex align-items-center"><span class="nav-link-icon"></span><h5 class="nav-link-text ps-1 text-600"><%= lib_translate("File đính kèm")  %><span class="red">*</span> </h5>
            </div>
          </a>
          <div class="p-3 pt-0 pb-0 collapse show" id="media_file_content">
              <div id="upload_mandoc_file_release_mandoc"></div>
          </div>
        </div>

        <!-- Chọn phòng ban/đơn vị -->
        <div class="mt-3" id="div_choose_release_department">
          <%= f.label :ssymbol, lib_translate("Chọn đơn vị nhận email") ,class:'fw-semi-bold m-0'%> 
          <select class="form-select selectpicker" id="select_release_department" multiple="multiple" size="1" name="select_release_department[]" data-options='{"removeItemButton":true,"placeholder":true}'>
            <option value="all">Tất cả phòng ban <%= @organization_name != "" ? "[#{@organization_name}]" : "" %></option>
            <% @departments.each do |department| %>
              <option value="<%= department.id %>"><%= department.name %></option>
            <% end %>
          </select>
        </div>
        <!-- Chọn nhân sự -->
        <div class="mt-3">
          <%= f.label :ssymbol, lib_translate("Chọn nhân sự nhận email") ,class:'fw-semi-bold m-0'%> 
          <select class="form-select selectpicker" multiple="multiple" size="1" id="select_release_staff" name="select_release_staff[]" data-options='{"removeItemButton":true,"placeholder":true}'>
            <option value="all">Tất cả nhân sự <%= @organization_name != "" ? "[#{@organization_name}]" : "" %></option>
            <% @list_users_uorg.each do |user| 
                @name_department = ""
                @job_name = ""
                works = user.works
                works.each do |work|
                    if !work.positionjob.nil? && !work.positionjob.department.nil?
                      @name_department = work.positionjob.department.name
                      @job_name = work.positionjob.name
                    end
                end
            %>
              <option value="<%= user.id %>"><%= user.last_name %> <%= user.first_name %> <%= @name_department != "" ? "- [#{@name_department}]" : "" %></option>
            <% end %>
          </select>
        </div>
        <div class="mt-3 row " style="display: flex; justify-content: space-evenly;">
          <button type="button" id="vt_ban_hanh" class="btn btn-primary col-3"><%= lib_translate("Ban_Hanh_Bo_Sung")%></button>
          <button class="btn btn-warning col-3" onclick="backFormRelease()" type="button"> <%=lib_translate("Cancel")%> </button>
        </div>
      <%end%>
    </div>
  </div>
</div>

