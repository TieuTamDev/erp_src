<% content_for :bottombody do %>
  <%= javascript_include_tag '/assets/lib_hrm/moment-with-locales.js' %>  
  <%= javascript_include_tag '/assets/lib_hrm/bootstrap-datetimepicker.min.js' %>
  <%= javascript_include_tag '/assets/myjs/jquery_ujs.js' %>
  <%= javascript_include_tag 'select2.full.min'%>
  <%= javascript_include_tag 'select2.min.js'%>
<% end %>
<div class="row">
    <div class="col">
        <h3 class="mt-2 overview_text"><%= lib_translate("Document_to")%></h3>
    </div>
    <div class="col mt-2 ">
        <button class="btn btn-primary float-end" data-bs-toggle="modal" onclick="choose_user()" data-bs-target="#staticBackdrop"  >
          <%= lib_translate("Import_old_text")%>
        </button>
        <button onclick="clickOpenImport()" class="btn btn-warning float-end me-1" data-bs-toggle="modal" data-bs-target="#import_mandoc_excel" id="btn-import-file">
            <%= lib_translate("Import_from_file")%> <span class="fas fa-file-excel"></span>
        </button>
    </div>
</div>
<div class="list_users">
    <div class="card mb-3">
        <div class="card-body pt-0">
            <div class="tab-content">
            <%= render_search_pagination(released_mandocs_incoming_index_path()).html_safe %>
                <table id="documents_released_incoming" class="table table-bordered fs--1 mb-0 " style="margin-top: 0px !important; margin-bottom: 0px !important">
                    <thead class="bg-200 text-900" class="display: none;">
                        <tr>
                            <th class="sort" style="width: 4%; text-align: center;"><%= lib_translate("Oder")%></th>
                            <th class="sort" style="width: 15%; text-align: center;"><%= lib_translate("Sno_symbol")%></th>
                            <th class="sort" style="width: 30%; text-align: center;"><%= lib_translate("Content")%></th>
                            <th class="sort" style="width: 13%; text-align: center;"><%= lib_translate("Ngay_ban_hanh")%></th>
                            <th class="sort" style="width: 15%; text-align: center;"><%= lib_translate("Status_handle")%></th>
                            <th class="no-sort col-4 col-md-3 p-0" style="width: 20%;"></th>
                        </tr>
                    </thead>
                    <tbody class="list">
                        <% @incoming.each_with_index do |mandoc, i| %>
                            <tr>  
                                <td style="vertical-align: middle; text-align: center;"><%= i+1 %></td>
                                <td style="vertical-align: middle;">
                                    <%( if (mandoc.sno.nil?)%>
                                    <div style="text-align: start;  display: flex;flex-direction: column;">
                                        <label style="  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0" ><%= lib_translate("Documents_date")%>: <span style="font-weight: normal;"> <%= mandoc.received_at&.strftime('%d/%m/%Y')%></span></label>
                                    </div>
                                    <%else%>
                                    <div style="text-align: start;  display: flex;flex-direction: column;">
                                        <label style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0 text-overlap"><%= lib_translate("Mandoc_Type")%>:<span style="font-weight: normal;"> <%= mandoc.stype.present? ? Mandoctype.where(scode: mandoc.stype).first&.name : ""%></span></label>
                                        <label style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0 text-overlap"><%= lib_translate("Incoming_number")%>:<span style="font-weight: normal;"> <%= mandoc.sno %></span></label>
                                        <label style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0 text-overlap"><%= lib_translate("Sno_book")%>:<span style="font-weight: normal;"> <%= mandoc.ssymbol %></span></label>
                                    </div>
                                    <%end)%>
                                </td> 
                                <td style="vertical-align: middle;">
                                    <div style="text-align: start;  display: flex;flex-direction: column;">
                                        <label style="  white-space: normal; font-weight: bold !important;" class="m-0" ><%=lib_translate('Excerpts_from_content')%>: <span style="font-weight: normal;"><%= mandoc.contents %></span></label>
                                        <label style="  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0"><%= lib_translate("Sent_from")%>: <span style="font-weight: normal;"><%= mandoc.sfrom %></span></label>
                                        <label style="  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0"><%= lib_translate("Receive_handle")%>: <span style="font-weight: normal;"><%= mandoc.created_by %></span></label>
                                        <label style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0" ><%= lib_translate("Documents_date")%>: <span style="font-weight: normal;"> <%= mandoc.received_at&.strftime('%d/%m/%Y')%></span></label>
                                   
                                    </div>
                                </td>                         
                                <td style="vertical-align: middle; text-align: center;">                                  
                                    <%= if !mandoc.effective_date.nil?
                                          mandoc.effective_date.strftime('%d/%m/%Y')
                                        else
                                          mandoc.effective_date
                                        end
                                    %>
                                </td>                         
                                <td style="vertical-align: middle; text-align: center;">
                                    <% if mandoc.status == "RECEIVE"%>
                                    <span class="text-info" style="font-weight: bold;"> <%=lib_translate('Receive_handle')%></span>
                                    <% elsif mandoc.status == "INPROGRESS"%>
                                    <span class="text-warning" style="font-weight: bold;"> <%=lib_translate('Inprogress_handle')%></span>
                                    <% elsif mandoc.status == "DELETE"%>
                                    <span class="text-danger" style="font-weight: bold;"> <%=lib_translate('Cancel_handle')%></span>
                                    <%else%>
                                    <span class="text-success" style="font-weight: bold;"> <%=lib_translate('Success_handle')%></span>
                                    <% end %>
                                </td>                         
                                <td style="vertical-align: middle; text-align: center; padding:0">
                                 <%# Nút xem văn bản %>
                                    <% oMandocDhandleRelease = Mandocdhandle.where(mandoc_id: mandoc.id ).first
                                      check_dhandle = ""
                                      if !oMandocDhandleRelease.nil?
                                      check_dhandle = oMandocDhandleRelease.id
                                      end
                                     %>
                                    <%# Nút view media%>
                                      <button  class="btn btn-light p-0 " style="padding: 6px 17px !important" id="btn_again_release" onclick='clickAgainRelease(<%= mandoc.to_json %>, <%= mandoc.stype.present? ? Mandoctype.where(scode: mandoc.stype).first&.name.to_json : ""%>,<%= mandoc.publish_to_departments&.include?("all") ? ["Tất cả phòng ban #{@organization_name != "" ? "[#{@organization_name}]" : "" }"].push(Department.where(id: mandoc.publish_to_departments&.split(",")).pluck(:name)) : Department.where(id: mandoc.publish_to_departments&.split(",")).pluck(:name) %>, <%= mandoc.publish_to_staffs == "all" ? [{"last_name":"Tất cả nhân sự","first_name":"#{@organization_name != "" ? "[#{@organization_name}]" : ""}"}].to_json : User.select("id, last_name, first_name").where(id: mandoc.publish_to_staffs&.split(",")).to_json %>)' data-toggle="tooltip" data-placement="top" title="Ban hành văn bản đến các đơn vị/ nhân sự">
                                              <span class="fas fa-paper-plane text-info"></span>
                                      </button>
                                      <button class="btn btn-light" onclick="clickEditMandocMedias(this,<%=mandoc.id%>)" data-check-dhandle="<%=check_dhandle%>" data-toggle="tooltip" data-placement="top" title="<%=lib_translate('Upload_file')%>">
                                        <span class="fas fa-folder-open icon text-warning"></span>
                                      </button>
                                      <button class="btn btn-light preview-mandoc d-none" data-id="<%= mandoc.id%>" data-toggle="tooltip" data-placement="top" title="<%=lib_translate('View_document')%>">
                                          <span class="far fa-eye">
                                      </button>
                                   
                                      <button class="btn btn-light" data-bs-toggle="modal" data-bs-target="#tinh_trang_outgoing_TT_<%=mandoc.id%>" data-toggle="tooltip" data-placement="top" title="<%=lib_translate('View_status')%>">
                                          <span class="fas fa-list-ol text-success">
                                      </button>

                                      <div class="modal fade" id="tinh_trang_outgoing_TT_<%=mandoc.id%>" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true" style=" background: rgba(0, 0, 0, 0.84); overflow-y: scroll;">
                                              <div class="modal-dialog" style="max-width: 70%; width: 100%; display: flex; align-items: center;">
                                                <div class="modal-content p-3" style=" background: var(--falcon-avatar-status-border-color);">
                                                    <div class="position-absolute top-0 end-0 mt-2 me-2 z-index-1">
                                                    <button class="btn-close btn btn-sm btn-circle d-flex flex-center transition-base" data-bs-dismiss="modal" aria-label="Close"></button>
                                                  </div>
                                                  <div class="modal-header d-flex justify-content-left" >
                                                    <p class="fs-1 fw-bold"><%= lib_translate("Document_processing") %></p> 
                                                  </div> 
                                                  <div style=" background: var(--falcon-avatar-status-border-color);padding: 20px;">
                                                    <h5 style="float:left; opacity: .5;"><span class="fw-bold"><%= lib_translate("Status") %>: </span>
                                                        <% if mandoc.status == "RECEIVE"%>
                                                        <span class="text-info" style="font-weight: bold;"> <%=lib_translate('Receive_handle')%></span>
                                                        <% elsif mandoc.status == "INPROGRESS"%>
                                                        <span class="text-warning" style="font-weight: bold;"> <%=lib_translate('Inprogress_handle')%></span>
                                                        <% elsif mandoc.status == "DELETE"%>
                                                        <span class="text-danger" style="font-weight: bold;"> <%=lib_translate('Cancel_handle')%></span>
                                                        <%else%>
                                                        <span class="text-success" style="font-weight: bold;"> <%=lib_translate('Success_handle')%></span>
                                                        <% end %>   
                                                    </h5>
                                                    <table class="table table-bordered fs-0 mb-0 table-hover " >
                                                        <thead class="text-white" style="background: var(--falcon-bg-circle-shape-bg);">
                                                              <tr>
                                                                <th style="width: 30%;"><%= lib_translate("Handler") %></th>
                                                                <th style="width: 6%;"><%= lib_translate("Role") %></th>
                                                                <th style="width: 10%;"><%= lib_translate("Day_Process") %></th>
                                                                <th style="width: 10%;"><%= lib_translate("Deadline_process") %></th>
                                                                <th style="width: 20%;"><%= lib_translate("Content_process") %></th>
                                                                <th style="width: 8%;"><%= lib_translate("Status") %></th>
                                                                <th style="width: 6%;"><%= lib_translate("Read") %></th>
                                                              </tr>
                                                        </thead>
                                                        <tbody>
                                                            <%  mandoc = Mandoc.where(id: mandoc.id).first
                                                                    if !mandoc.nil? %>
                                                                          <tr style="text-align: left">
                                                                            <td class="text-success"> <%= mandoc.created_by %> <b>[<%= if mandoc.sfrom.nil?
                                                                              mandoc.mdepartment
                                                                            else
                                                                              id_department_first = Mandocdhandle.where(mandoc_id: mandoc.id).first&.department_id
                                                                              Department.where(id: id_department_first).first&.name
                                                                            end%>]</b></td>
                                                                            <td><%= lib_translate("Người soạn")%></td>
                                                                            <td><%= mandoc.created_at&.strftime("%k:%M %d/%m/%Y")%></td>
                                                                            <td></td> 
                                                                            <td><div style="white-space: pre-line;"><%= mandoc.contents %></div></td>
                                                                            <td><%= lib_translate("DAXULY")%></td>
                                                                            <td><%= lib_translate("CO")%></td>
                                                                          </tr>
                                                                          <%
                                                                            
                                                                            mandoc.mandocuhandles&.order(created_at: :asc).each do |uhan|
                                    
                                                                          %>  
                                                                         
                                                                            <tr style="text-align: left">
                                                                                <td> <span class="fas fa-grip-lines"></span><span class="fas fa-chevron-right"></span> <%= uhan&.user&.last_name%> <%= uhan&.user&.first_name%>  <b>[<%= uhan&.mandocdhandle&.department&.name%>]</b></td>
                                                                                <td><%= uhan.srole == "XULY" ? lib_translate("XULY") : uhan.srole == "DEBIET" ? lib_translate("DEBIET") : uhan.srole == "PHOIHOPXL" ? lib_translate("PHOIHOPXL") : lib_translate("XULY")%></td>
                                                                                <td><%= uhan.created_at&.strftime("%k:%M %d/%m/%Y")%></td>
                                                                                <%if !uhan.deadline.nil?%>
                                                                                <td><%= uhan.deadline&.strftime("%d/%m/%Y")%></td>
                                                                                <%else%>
                                                                                  <td></td>
                                                                                <%end%>
                                                                                <td><div style="white-space: pre-line;"><%= uhan.contents %></div></td>
                                                                                <td><%= uhan.sothers == "HUYBOXULY" ? "Thay thế" : uhan.status == "DAHUY" ? lib_translate("Cancel_handle") : uhan.status == "CHUAXULY" ? lib_translate("CHUAXULY") : uhan.status == "PHOIHOPXL" ? lib_translate("PHOIHOPXL") : uhan.status == "DAXULY" ? lib_translate("DAXULY") : lib_translate("CHUAXULY") %></td>
                                                                                <td><%= uhan.sothers == "HUYBOXULY" ? "" : uhan.sread == "KHONG" ? lib_translate("KHONG") : uhan.sread == "CO" ? lib_translate("CO") : lib_translate("KHONG") %></td> 
                                                                            </tr> 
                        
                                                                        <% end %>
                                                                   <% end %>
                                                        </tbody>
                                                    </table>
                                                  </div>
                                                </div>
                                              </div>
                                      </div>
                                      <% if mandoc.publish_to_departments.nil? && mandoc.publish_to_staffs.nil? %>
                                      <a class="btn btn-light" onclick="clickDeleteMandoc('<%= mandoc.id %>',`<%= !mandoc.notes.nil? &&  mandoc.notes != '' ? mandoc.notes : mandoc.contents %>`)" style="cursor: pointer;" data-toggle="tooltip" data-placement="top" title="<%=lib_translate('Delete')%>">
                                        <span class="text-danger fas fa-trash" style="width: 12px;"></span>
                                      </a>
                                      <% end %>
                                </td>                        
                            </tr>
                        <% end %>
                    </tbody>
                </table>
              <%= render_pagination_limit_offset(released_mandocs_incoming_index_path(lang: session[:lang], per_page: session[:per_page], search: session[:search]), 10, @incoming.count).html_safe %>
            
            </div>
        </div>
    </div>
</div>
<div style="display:none;">
  <p id="import-action" hidden><%= url_for(released_mandocs_import_mandoc_path)%></p>
</div><%# Model inport file %>
<div class="modal fade" data-bs-keyboard="false" data-bs-backdrop="static" id="import_mandoc_excel" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" role="document" style="max-width: 500px">
    <div class="modal-content position-relative">
      <div class="position-absolute top-0 end-0 mt-1 me-2 z-index-1">
        <button id="btn_X" class="btn-close btn btn-sm btn-circle d-flex flex-center transition-base button-cancel-import" style="width: 2rem;height: 2rem;" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-0">
        <div class="rounded-top-lg py-3 ps-4 pe-6 bg-light">
          <h5 class="mb-1"><%= lib_translate("Import_from_file")%></h5>
        </div>
        <%# File preview/process %>
          <div class="border rounded-1 mt-2 me-2 ms-2" id="import-file-containter" style="display:none;">
            <div class="ps-2" style="display: flex;align-items: center;">
                <%= image_tag("/assets/image/excel.png") %>
                <div class="ms-2">
                    <p class="m-0" id="import-file-name" style="font-size: 0.9em;font-weight: 600;">...</p>
                    <p class="m-0" id="import-file-size" style="font-size: 0.8em;">...</p>
                </div>
            </div>
            <div class="progress me-2 ms-2 mb-1" style="height:7px">
                <div class="progress-bar bg-success" id="file-process" role="progressbar" style="transition: width 0.2s ease; width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
                </div>
            </div>
          </div>
        <div class="pe-3 ps-3 pt-3 pb-2">
          <%# Form import file user %>
          <div>
            <input id="file-import-user" accept=".csv, application/vnd.openxmlformats-officedocument.spreadsheetml.sheet, application/vnd.ms-excel" type="file" name="file" hidden>
            <label for="file-import-user" id="label-select-file" class="btn btn-warning m-0"><%= lib_translate("select_files")%></label>
            <button class="btn btn-primary btn-secondary disabled" onclick="clickImportFile()" id="button-upload-file" type="submit">
              <%# icon %>
              <span class="spinner-border spinner-border-sm upload-process" role="status" aria-hidden="true"></span>
              <%# text %>
              <span class="upload-text"><%= lib_translate("Upload")%><span class="fas fa-upload ms-1"></span></span>
            </button>
            <div class="btn btn-primary" id="reupload-button" style="display: none;" onclick="clickReupload()"><%= lib_translate("Continue_import")%></div>
          </div>
          <div id="import-server-error" style="display:none;">
            <span class="badge badge-soft-danger">Lỗi khi xử lý dữ liệu. Vui lòng kiểm tra và thử lại.</span>
          </div>
          <%# Import result %>
          <div id="import-result" class="border rounded-1 mt-2 collapse">
            <h5 class="p-2 fs-0 bg-200"><%= lib_translate("Processing_result")%>:<span id="result-total"></span></h5>
            <div class="p-2">
              <p class="m-0">
                <span style="font-weight: 500;font-size: 17px;"><%= lib_translate("Total")%>:</span>
                <span id="result_total" style="font-size: 18px;color: black;font-weight: 800;">0</span>
              </p>
              <p class="m-0">
                <span style="font-weight: 500;font-size: 17px;"><%= lib_translate("Success")%>:</span>
                <span id="success_count" class="text-success" style="font-size: 18px;color: black;font-weight: 800;">0</span>
              </p>
              <p class="m-0">
                <span style="font-weight: 500;font-size: 17px;"><%= lib_translate("Update")%>:</span>
                <span id="update_count" class="text-info" style="font-size: 18px;color: black;font-weight: 800;">0</span>
                <span id="update-all-button" onclick="uploadAllImport()" class="btn btn-primary btn-sm ms-4" style="padding: 0px 7px;font-size: 0.7em;display:none;"><%= lib_translate("Update_all")%></span>
              </p>
              <div id="update_list" class="ps-2 mt-2 scrollbar" style="max-height: 300px;"></div>
              <p class="m-0">
                <span style="font-weight: 500;font-size: 17px;"><%= lib_translate("Not_Success")%>:</span>
                <span id="error_count" class="text-danger" style="font-size: 18px;color: black;font-weight: 800;">0</span>
              </p>
              <div id="error_list" class="ps-3 scrollbar" style="max-height: 300px;"></div>
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button id="btn_close" class="btn btn-secondary button-cancel-import" type="button" data-bs-dismiss="modal"><%= lib_translate("Close")%></button>
      </div>
    </div>
  </div>
</div>
<%# Form upload file mandoc %>
<div class="modal fade" id="upload_file_mandoc" tabindex="-1" style=" background: rgba(0, 0, 0, 0.84); overflow-y: scroll;">
  <div class="modal-dialog" style="max-width: 70%; width: 100%; height: 100%; display: flex; align-items: center;">
    <div class="modal-content">
      <div class="modal-header d-flex justify-content-center ">
        <h5 class="mb-0"><%= lib_translate('Attached_files')%></h5>
        <button type="button" class="btn-close btn btn-sm btn-circle d-flex flex-center transition-base" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="card-body bg-light p-3" id="upload_mandoc_file"></div>
      </div>

    </div>
  </div>
</div>
<%# Preview %>
