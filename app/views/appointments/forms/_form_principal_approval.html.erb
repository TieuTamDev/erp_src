<style>
    .pdf-container{
        margin:0 auto;
        position:relative;
        width: fit-content;
    }
    .pdf-sign-list{
        padding: 5px;
        border: 1px solid #c1c1c1;
        overflow: hidden;
        background: #858585;
    }
    .pdf-sign-list .pdf-sign-image{
        cursor: grab;
        max-width: 130px;
        margin-bottom:4px;
    }
    .pdf-sign-list .pdf-sign-image:hover{
        box-shadow: 0px 0px 6px 0px #6e6d6d;
        border-radius: 5px;
    }
    .pdf-page-list{
        display:flex;
        flex-direction:column;
        background: #8f8f8f;
        padding: 12px;
        max-height: 700px;
        overflow-y: scroll;
        border: 1px solid #c1bdbd;
    }
    .pdf-page-wrap{
        position:relative;
    }
    .pdf-page-space{
        height:5px;
    }
    .pdf-canvas{

    }
    .pdf-page-edit-wrap{
        position: absolute;
        top:0;
        left:0;
        z-index:1;
        width:100%;
        height:100%;
    }
    .pdf-page-edit-area{
        position:relative;
        width:100%;
        height:100%;
        overflow: hidden;
    }
    .grap-preview{
        position:absolute;
        top:0;
        left:0;
        z-index: 1;
        pointer-events: none;
        box-shadow: 0px 0px 0px 2px #dfa43d;
    }
    .pdf-edit-element{
        position:absolute;
        top:0;
        left:0;
        cursor:move;
    }

    .pdf-edit-element-container{
        display:flex;
    }
    .pdf-edit-element-wrap{
        position: relative;
    }
    .element-selected .pdf-edit-element-wrap{
        box-shadow: 0px 0px 0px 2px #3edf3d;
    }
    .pdf-edit-element-tool-wrap{
        display:none;
    }
    .element-selected .pdf-edit-element-tool-wrap{
        display: flex;
        margin-bottom: 4px;
        align-items: baseline;
        width: fit-content;
        position: absolute;
        top: -29px;
    }
    .element-selected .scale-button{
        display:flex;
    }
    .scale-button{
        display:none;
        justify-content: center;
        align-items: center;
        position: absolute;
        top: 100%;
        left: 100%;
        transform: translate(-50%, -50%);
        cursor: nwse-resize;
    }
    .tool-delete{
        background: #ef5656;
        border: 1px solid #db8585;
        display: flex;
        color: white;
        font-size: 13px;
        cursor: pointer;
        padding:5px;
        border-radius: 5px;
        justify-content: center;
        align-items: center;
    }

    .page-state{
        display: flex;
        position: absolute;
        top: 0;
        left: 0;
        padding: 5px 5px 5px 5px;
        border-bottom-right-radius: 5px;
        justify-content: center;
        align-items: center;
        background: #28272794;
        color: white;
        z-index: 3;
        pointer-events: none;
    }

    .image-container {
        position: relative;
        width: 200px;
    }

    .image {
        display: block;
        width: 100%;
        height: auto;
        transition: transform 0.5s;
    }

    .image-container:hover .image {
        transform: scale(1.2);
    }

    .preview {
        display: flex;
        flex-wrap: wrap;
    }

    .preview-item {
        position: relative;
        border-radius: 4px;
        overflow: hidden;
        border: 1px solid #c5c5c5;
        width: 100px;
        height: 100px;
    }

    .container-image {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
        grid-gap: 10px;
    }

    .remove-btn {
        position: absolute;
        top: 0;
        right: 0;
        background-color: #ff0000;
        color: #ffffff;
        border: none;
        padding: 2px 6px;
        cursor: pointer;
        font-size: 12px;
    }

    .inputfile {
        width: 0.1px;
        height: 0.1px;
        opacity: 0;
        overflow: hidden;
        position: absolute;
        z-index: -1;
    }

    .preview-item-add img {
        position: relative;
        margin: 5px;
        width: 50%;
        cursor: pointer;
    }

    .hiddenRow {
        padding: 0 !important;
    }
    .hidden-style{
        display:none !important;
    }

    .accordian-body {
        padding: 10px;
    }

    /* Chrome, Safari, Edge, Opera */
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    /* Firefox */
    input[type=number] {
        -moz-appearance: textfield;
    }
</style>
<%  
    is_survey = @form_data[:appointment].is_survey == "YES"
    is_dismiss =  @appointment.stype == "MIEN_NHIEM"
    stype_text = lib_translate("appointment.#{@appointment.stype}")
%>
<div class="modal-body px-4 pt-2">
    <div class="d-flex mb-2" id="btn-handle">
        <% if !@form_data[:bSigned]%>
            <button class="btn btn-primary me-2" type="button" onclick="AddSignToPage()" id="sign-btn" disabled><span class="fas fa-feather-alt"></span> Ký duyệt</button>
            <%= render "appointments/buttons/submit_buttons"%>
        <%end%>
    </div>
    <div class="p-2 mb-2" style="background:#EFF3F6">
        <span class="fas fa-info-circle me-2"></span>
        <span>Vui lòng kéo chữ ký của bạn vào tờ trình bên dưới để thực hiện ký điện tử</span>
    </div>
    <div id="pdf-container" class="pdf-container"></div>

    <%= form_tag appointment_path(id: @form_data[:appointment_id]),method: :patch,id:'form-update-process',remote:true,authenticity_token: true do %>
        <input name="mandocuhandle_id" value="<%= @form_data[:mandocuhandle_id]%>" hidden/>
        <input name="signdoc_id" value="<%= @form_data[:signdoc_id]%>" hidden/>
        <input name="appointment_id" value="<%= @form_data[:appointment_id]%>" hidden/>
        <input name="status" value="<%= @form_data[:status]%>" hidden/>
        <div id="extra-inputs"></div>
    <%end%>

</div>

<script>
    $("#btn-handle").find('[data-result="finished"]').attr("disabled",true);
    $("#btn-handle").find('[data-result="finished"]').attr("data-bs-dismiss","modal");
    $("#btn-handle").find('[data-result="stoped"]').attr("data-bs-dismiss","modal");

    function initPopups() {
        $("#popupConfirmForm .modal-content").html(`
            <div class="modal-header">
                <h5 class="modal-title m-0">Duyệt <%= stype_text%></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="p-2 pb-4 pt-4 d-flex" style="user-select: none;">
                <span>Xác nhận duyệt Duyệt <%= stype_text%>!</span>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary close-btn" type="button" data-bs-dismiss="modal">Đóng</button>
                <button class="btn btn-primary confirm-btn" type="button">Xác nhận</button>
            </div>`);

        let inputTime = "";
        <% if !is_dismiss%>
            inputTime = `<div class="p-3">
                <label class="form-label">Thời gian thử thách</label>
                <input class="form-control input" name="probation_period" />
                
            `;
        <%end%>
        $("#popupConfirm .modal-content").html(`
            <div class="modal-header">
                <h5 class="modal-title m-0">Từ chối <%= stype_text%></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="p-3">
                ${inputTime}
                <label class="form-label">Lý do</label>
                <textarea class="form-control input" name="mandocuhandle_contents" rows="3" placeholder="Lý do từ chối"></textarea>
            </div>
            <div class="modal-footer">
                <button class="btn btn-danger confirm-btn" type="button">Từ chối</button>
                <button class="btn btn-secondary close-btn" type="button" data-bs-dismiss="modal">Đóng</button>
            </div>`);
        
        flatpickr('input[name="probation_period"]', {
            dateFormat: "d/m/Y",
            minDate: "today",
        });
    }

    var pdfSign = $("#pdf-container").pdfSign({
        loadSigndocPath: '<%= request.base_url%><%= load_signdoc_appointment_path(params[:appointment_id], signdoc_id: @form_data[:signdoc_id], status: @form_data[:status]).html_safe%>',
    });

    // khi xóa chữ kí
    pdfSign.on('removesign',()=>{
        $("#btn-handle").find('[data-result="finished"]').attr("disabled",true);
        $("#sign-btn").attr("disabled",false);
    });

    // khi ký
    pdfSign.on('dosign',()=>{
        $("#btn-handle").find('[data-result="finished"]').attr("disabled",false);
        $("#sign-btn").attr("disabled",true);
    });

    // khi doc đã load
    pdfSign.on('docloaded',(success)=>{
        $("#sign-btn").attr("disabled",false);
    });

    pdfSign.setUserSign(<%= @form_data[:user_sign].to_json.html_safe%>);
    pdfSign.setSignStatus(<%= @form_data[:can_sign]%>);
    
    function AddSignToPage() {
        pdfSign.doSign();
    }

    function clickSubmitAppointProcess(status,result,next_department_id,next_department_scode,next_status) {
        let popupID = "";
        switch (result) {
            case "stoped":
                popupID = "#popupConfirm";
                break;
            case "finished":
                popupID = "#popupConfirmForm";
                break;
            default:
                break;
        }
        openConfirmPopup(popupID,status,result,next_department_id,next_department_scode,next_status);
    }

    function openConfirmPopup(popupID,status,result,next_department_id,next_department_scode,next_status) {
        let dialog = $(popupID);
        dialog.find(".confirm-btn").off().on('click',()=>{
            submitUpdate(popupID,status,result,next_department_id,next_department_scode,next_status);
        });
        dialog.modal('show');
    }

    function submitUpdate(popupID,status,result,next_department_id,next_department_scode,next_status) {
        let updateForm = $("#form-update-process");
        let wrapinputs = updateForm.find("#extra-inputs");
        wrapinputs.html("");
        let inputs = {};

        // popup input
        let popup = $(popupID);
        popup.find(".input").each((_,element)=>{
            let name = element.getAttribute("name");
            let value = element.value;
            inputs[name] = value;
        });

        <%if !is_dismiss%>
            if(inputs.hasOwnProperty("mandocuhandle_contents")){
                if(inputs.mandocuhandle_contents == ""){
                    alert("Vui lòng nhập lý lo từ chối!");
                    return;
                }
            }
        <%end%>

        if(inputs.hasOwnProperty("probation_period")){
            if(inputs.probation_period == ""){
                alert("Vui lòng chọn thời hạn thử thách!");
                return;
            }
        }

        // step data
        inputs["result"] = result;
        inputs["next_department_id"] = next_department_id;
        inputs["next_department_scode"] = next_department_scode;
        inputs["next_status"] = next_status;

        // result data
        switch (result) {
            case "finished":
                // sign data
                let sign = pdfSign.getData();
                if(!sign){
                    return;
                }
                inputs = {...inputs,...sign};
                break;
            case "stoped":

                break;
            default:
                break;
        }

        // append inputs
        Object.keys(inputs).forEach(key=>{
            if(key == "mandocuhandle_contents"){
                updateForm.append(`<textarea name="${key}" rows="4" cols="50">${inputs[key]}</textarea>`);
            }else{
                wrapinputs.append(`<input name="${key}" value="${inputs[key]}" hidden/>`);
            }
        });
        
        updateForm.submit();

        popup.modal('hide');
    }

    function onSubmitError(message) {
        console.log(message);
    }
    
    function onSubmitSuccess(data,step,message) {
        $("#refresh-btn").click();
    }
    // init confirm popup
    initPopups();

    pdfSign.loadSigndocById('',false);

    // fix modal style
    $("#popupLargeModal").find(".modal-dialog").css({"display": "flex" , "justify-content": "center"});
    $("#popupLargeModal").find(".modal-content").css({"max-width": "fit-content"});
</script>