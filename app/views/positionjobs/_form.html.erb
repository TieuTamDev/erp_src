<style>
    .is-invalid .tox-tinymce {
        border-color: #dc3545;
    }
    
    .invalid-feedback {
        display: block;
        color: #dc3545;
        margin-top: 0.25rem;
    }
</style>

<%= form_for @positionjob,
                         method: (@positionjob.new_record? ? :post : :patch),
                         remote: true do |form| %>
    <div class="modal-body">
        <div class="form-group mb-3">
            <%= form.label :name, 'TГӘn Д‘б»ҷ cбәҘp quyб»Ғn hбәЎn', class: 'form-label' %>
            <%= form.text_field :name, class: "form-control", id: 'tf_name', placeholder: 'Nhбәӯp tГӘn Д‘б»ҷ cбәҘp quyб»Ғn hбәЎn' %>
            <% if @positionjob.errors[:name].any? %>
              <div class="invalid-feedback">
                <%= @positionjob.errors[:name].join(", ") %>
              </div>
            <% end %>
        </div>

        <div class="form-group mb-3">
            <%= form.label :scode, 'MГЈ', class: 'form-label' %>
            <%= form.text_field :scode, class: "form-control", id: 'tf_scode', placeholder: 'Nhбәӯp mГЈ' %>
        </div>

        <div class="form-group mb-3">
            <%= form.label :iorder, 'Quyб»Ғn hбәЎn', class: 'form-label' %>
            <%= form.select :iorder, 
                            options_for_select((1..10), @positionjob.iorder || ''),
                            { include_blank: 'Chб»Қn quyб»Ғn hбәЎn' }, 
                            { class: "form-select", id: 'function_select' } %>
        </div>
        
        <div class="form-group mb-3">
        <%= form.label :ignore_attend, 'ChбәҘm cГҙng', class: 'form-label d-block' %>
        <div class="form-check form-check-inline">
            <%= form.radio_button :ignore_attend, "TRUE", id: "ignore_attend_true", class: "form-check-input" %>
            <%= form.label :ignore_attend_true, "KHГ”NG Bбә®T BUб»ҳC", class: "form-check-label", style: "cursor: pointer" %>
        </div>
        <div class="form-check form-check-inline">
            <%= form.radio_button :ignore_attend, "FALSE", id: "ignore_attend_false", class: "form-check-input" %>
            <%= form.label :ignore_attend_false, "Bбә®T BUб»ҳC", class: "form-check-label", style: "cursor: pointer" %>
        </div>
        </div>

        <div class="form-group mb-3">
            <%= form.label :note, 'Ghi chГә', class: 'form-label' %>
            <%= form.text_area :note, rows: 3, class: "form-control", placeholder: 'Nhбәӯp ghi chГә' %>
        </div>
    </div>

    <div class="modal-footer border-top-0">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">ДҗГіng</button>
        <%= form.submit 'LЖ°u', class: 'btn btn-primary' %>
    </div>
<% end %>

<script>
    function getTextToASCII() {
        var value_name = document.getElementById("tf_name").value;
        var value_scode = document.getElementById("tf_scode");
        if (value_name) {
        var content = removeVietnameseTones(value_name).replace(/ /g, '-');
            if (value_scode) {
                        value_scode.value = content.toUpperCase()
                    }
        }
      }
    function removeVietnameseTones(str) {
        str = str.replace(/Г |ГЎ|бәЎ|бәЈ|ГЈ|Гў|бә§|бәҘ|бәӯ|бә©|бә«|Дғ|бәұ|бәҜ|бә·|бәі|бәө/g,"a"); 
        str = str.replace(/ГЁ|Г©|бә№|бә»|бәҪ|ГӘ|б»Ғ|бәҝ|б»Ү|б»ғ|б»…/g,"e"); 
        str = str.replace(/Г¬|Гӯ|б»Ӣ|б»ү|Д©/g,"i"); 
        str = str.replace(/ГІ|Гі|б»Қ|б»Ҹ|Гө|Гҙ|б»“|б»‘|б»ҷ|б»•|б»—|ЖЎ|б»қ|б»ӣ|б»Ј|б»ҹ|б»Ў/g,"o"); 
        str = str.replace(/Г№|Гә|б»Ҙ|б»§|Е©|Ж°|б»«|б»©|б»ұ|б»ӯ|б»Ҝ/g,"u"); 
        str = str.replace(/б»і|ГҪ|б»ө|б»·|б»№/g,"y"); 
        str = str.replace(/Д‘/g,"d");
        str = str.replace(/ГҖ|ГҒ|бә |бәў|Гғ|ГӮ|бәҰ|бәӨ|бә¬|бәЁ|бәӘ|ДӮ|бә°|бә®|бә¶|бәІ|бәҙ/g, "A");
        str = str.replace(/ГҲ|Гү|бәё|бәә|бәј|ГҠ|б»Җ|бәҫ|б»Ҷ|б»Ӯ|б»„/g, "E");
        str = str.replace(/ГҢ|ГҚ|б»Ҡ|б»Ҳ|ДЁ/g, "I");
        str = str.replace(/Г’|Г“|б»Ң|б»Һ|Г•|Г”|б»’|б»җ|б»ҳ|б»”|б»–|Ж |б»ң|б»ҡ|б»ў|б»һ|б» /g, "O");
        str = str.replace(/Гҷ|Гҡ|б»Ө|б»Ұ|ЕЁ|ЖҜ|б»Ә|б»Ё|б»°|б»¬|б»®/g, "U");
        str = str.replace(/б»І|Гқ|б»ҙ|б»¶|б»ё/g, "Y");
        str = str.replace(/Дҗ/g, "D");
        // Some system encode vietnamese combining accent as individual utf-8 characters
        // Mб»ҷt vГ i bб»ҷ encode coi cГЎc dбәҘu mЕ©, dбәҘu chб»Ҝ nhЖ° mб»ҷt kГӯ tб»ұ riГӘng biб»Үt nГӘn thГӘm hai dГІng nГ y
        str = str.replace(/\u0300|\u0301|\u0303|\u0309|\u0323/g, ""); // МҖ МҒ Мғ Мү МЈ  huyб»Ғn, sбәҜc, ngГЈ, hб»Ҹi, nбә·ng
        str = str.replace(/\u02C6|\u0306|\u031B/g, ""); // ЛҶ МҶ Мӣ  ГӮ, ГҠ, ДӮ, Ж , ЖҜ
        // Remove extra spaces
        // Bб»Ҹ cГЎc khoбәЈng trбәҜng liб»Ғn nhau
        str = str.replace(/ + /g," ");
        str = str.trim();
        // Remove punctuations
        // Bб»Ҹ dбәҘu cГўu, kГӯ tб»ұ Д‘бә·c biб»Үt
        str = str.replace(/!|@|%|\^|\*|\(|\)|\+|\=|\<|\>|\?|\/|,|\.|\:|\;|\'|\"|\&|\#|\[|\]|~|\$|_|`|-|{|}|\||\\/g," ");
        return str;
    }

    document.getElementById("tf_name").addEventListener("keyup", function() {getTextToASCII()} );
</script>