<div class="modal fade" id="modal-notice" aria-labelledby="modal-noticeLabel" tabindex="-1" aria-hidden="true" style="background-color: rgba(0, 0, 0, 0.6);display: none;">
  <div class="modal-dialog  mt-6" role="document" style="max-width:850px">
    <div class="modal-content border-0" style ="max-height: 1000px;overflow: auto;">
      <div class="position-absolute top-0 end-0 mt-3 me-3 z-index-1">
        <button class="btn-close btn btn-sm btn-circle d-flex flex-center transition-base" data-bs-dismiss="modal" aria-label="Close" onclick="closeModal()"></button>
      </div>
      <div class="modal-body p-0">

        <div class="bg-light rounded-top-lg py-3 ps-4 pe-6">
          <h3><%= lib_translate('Notifications')%> </h3>
        </div>
        <div class="ps-3 pe-3 scroll_item css_scroll" >
          <div class="row" id="div-container" >
             <%# process %>
            <% if !@notifications.nil?
            @notifications.sort_by(&:created_at).reverse.each do|noti|%>
            <div style="width:100%;margin:0 auto;cursor: pointer;" class="item_notice mb-1" onclick="seen_notice(this,'<%=noti.created_at.strftime('%H%M%S')%><%=noti.id%>')" id="item-notice-dash_<%=noti.created_at.strftime('%H%M%S')%><%=noti.id%>">
              <% if is_access(session["user_id"], "MANDOCS-PROCESS","READ") %>
                <a style="text-decoration: none;color: #282828;" href="<%= mandocs_process_index_path()%>">
                <%@title= lib_translate('Documents_to_be_processed')%>
              <%else%>
                <a style="text-decoration: none;color: #282828;" href="<%= @url%>">
              <%end%>
                <div style="padding:10px;position: relative;">
                  <div style="display: flex;flex-direction: column;line-height: 20px;" class="col-12 ">
                    <div class="d-flex">
                      <div class="col-9">
                        <h4><%= @title%> </h4>
                        <p><%=@where%></p> 
                      </div> 
                      <div class="col-3">  
                        <div class="ps-3">
                          <div class="col-auto" >
                            <div class="avatar avatar-2xl status-away" style="position: absolute;top: 0px;right: 0px;" >
                            </div>
                            <p class="col-12" style="font-size:14px"><%=noti.created_at.strftime('%H:%M - %d/%m/%Y')  %></p>
                          </div>
                        </div>
                      </div>
                    </div>
                    <div> 
                      <p  style="line-height: 20px;"><%=noti.contents%></p>
                    </div>
                  </div>
                </div>
              </a>
            </div>
            <%end end%> 
              <% @snotifies.each do |snotify|%>
                <div style="width:100%;margin:0 auto;cursor: pointer;" class="item_notice mb-1">
                  <a id="seen_notice" style="text-decoration: none;color: #282828;" onclick="updateSnoticeIsread('<%= snotify.id%>', '<%= session[:user_id]%>')">
                    <div style="padding:10px;position: relative;">
                      <div style="display: flex;flex-direction: column;line-height: 20px;" class="col-12 ">
                        <div class="d-flex">
                          <div class="col-9">
                            <h4><%= snotify.notify&.title%></h4>
                            <p><%= snotify.notify&.senders%></p>  
                          </div> 
                          <div class="col-3">
                            <div class="ps-3">
                              <div class="col-auto" >
                                <div class="avatar avatar-2xl status-away" style="position: absolute;top: 0px;right: 0px;" >
                                </div>
                                <p class="col-12" style="font-size:14px"><%= snotify.created_at.strftime('%H:%M - %d/%m/%Y')%></p>
                              </div>
                            </div> 
                          </div> 
                        </div>  
                        <div>                                   
                          <%= snotify.notify&.contents&.html_safe%>
                        </div>
                      </div>
                    </div>
                  </a>
                </div>
              <%end%>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
