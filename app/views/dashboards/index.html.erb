                      <% end %>
                      <% if page > 4 %>
                        <li class='paginate_button page-item page-link'>...</li>
                      <% end %>
                      <li class='paginate_button page-item'><%= link_to (page - 1), dashboards_index_path(lang: session[:lang],h_page: session[:h_page].to_i - 1, h_per_page: session[:h_per_page], h_search: session[:h_search]), class: 'page-link' %></li>
