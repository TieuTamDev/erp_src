<style>
.dataTables_wrapper {
  margin-top: 0 !important
}
</style>
<!-- Nghỉ phép -->
<% unless session[:show_system] %>
  <% if is_access(session["user_id"], "LEAVE-INDEX","READ")%> 
  <%= render partial: 'leave_request/index.html.erb' %>
  <% end %>
  <% end %>

<!-- Danh sách nhân sự dự kiến nghỉ phép -->
<div class="card mb-3">
  <div class="card-body">
      <div class="row gx-0 border rounded-2 p-3">
        <%= render partial: 'manager_leave/index_leave.html.erb'%>
      </div>
  </div>
</div>
<div class="card mb-3">
  <div class="card-body">
      <div class="row gx-0 border rounded-2 p-3">
        <%= render partial: 'manager_leave/handle_leave.html.erb'%>
      </div>
  </div>
</div>

<!-- Xử lý công việc -->
<div class="row g-0">
  <div class="col-12 mb-3">
    <div class="card ps-3 pe-3 pb-3 pt-2" style="min-height:  352.97px">
      <h5 class="mb-0 mt-1"><%= lib_translate("Xử lý công việc") %></h5>
      <%= render partial: 'notifies/partial/table_notification.html.erb', locals: { is_handle: true } %>
    </div>
  </div>
</div>

<!-- Văn bản cần xử lý -->
<div class="row g-0">
  <div class="col-12 mb-3">
    <div class="card ps-3 pe-3 pb-3 pt-2" style="min-height:  352.97px">
      <h5 class="mb-0 mt-1"><%= lib_translate("Văn bản cần xử lý") %></h5>
      <div class='top mb-2'>
        <div id='positonjob_table_filter' class='dataTables_filter' style='display: flex;flex-direction: row-reverse;'>
          <form class='d-flex' action='<% dashboards_index_path() %>' accept-charset='UTF-8' method='get' style='width: 20%;'><input name='utf8' type='hidden' value='✓'>
            <input type='text' name='mandoc_search'  value='<%= params[:mandoc_search] %>' placeholder='<%= lib_translate('Search') %>' class='form-control form-control-sm'>
            <input class='d-none' name='lang' value='vi'><input type='submit' hidden>
          </form>
        </div>
      </div>
        <table id="table_dashboard_staff_with_birthdays" class="table table-bordered table-sm fs--1 mb-0" style="table-layout: unset !important;">
          <thead class="bg-200 text-900">
            <tr>
              <th class="no-sort" style="width: 26px !important; padding-left: 10px;"><%= lib_translate("STT")  %></th>
              <th class="sort" style="width: fit !important;"><%= lib_translate("Ngày nhận / Độ khẩn")  %></th>
              <th class="sort"><%= lib_translate("Nội dung văn bản")  %></th>
            </tr>
          </thead>
          <tbody class="list">
            <% @Mandoc.each_with_index do |mandoc, index| %>
              <tr>
                <td style="padding-left: 4px; text-align: center; vertical-align: middle;"><%= index + 1 %></td>
                <td style="vertical-align: middle;">
                  <div style="text-align: start;  display: flex; flex-direction: column;">
                      <label style="  white-space: normal; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0" ><%= lib_translate("Received_date")%>: <span style="font-weight: normal;"> <%= mandoc.created_at&.strftime('%k:%M %d/%m/%Y')%></span></label>
                      <label style="  white-space: normal; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0"><%= lib_translate("Urgency")%>: <span style="font-weight: bold; color: <%= Mandocpriority.where(name: mandoc.spriority).first.note%>"><%= mandoc.spriority%></span></label>
                      <label style=" cursor:pointer; white-space: normal; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0 "><%= lib_translate("Type_book")%>: <span style="font-weight: normal;"><%= Mandocbook.where(scode: mandoc.type_book).first&.name %></span></label>
                      <label style=" cursor:pointer; white-space: normal; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0 "><%= lib_translate("Documents_type")%>:
                        <span style="font-weight: normal;">
                            <%= Mandoctype.where(scode: mandoc.stype).first&.name %>
                        </span>
                      </label>
                  </div>
                </td>
                <td class="d-xl-flex align-items-center justify-content-between">
                  <% if !mandoc.sfrom.nil? %>
                    <div style="text-align: start;  display: flex;flex-direction: column;">
                      <label style="  white-space: normal; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0" ><%=lib_translate('Excerpts_from_content')%>: <span style="font-weight: normal;"><%= mandoc.contents %></span></label>
                      <label style="  white-space: normal; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0"><%= lib_translate("Sent_from")%>: <span style="font-weight: normal;"><%= mandoc.sfrom %></span></label>
                      <label style=" cursor:pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0 text-overlap"><%= lib_translate("Incoming_number")%>:<span style="font-weight: normal;"><%= mandoc.sno%></span></label>
                      <label style="  white-space: normal; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0"><span style="font-weight: bold !important;"><%=lib_translate("Sno_book")%>: </span><span style="font-weight: normal;"><%= mandoc.ssymbol%></span></label>
                      <%if !mandoc.effective_date.nil?%>
                        <label style="  white-space: normal; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0"><%= lib_translate('Ngay_ban_hanh')%>: <span style="font-weight: normal;"><%= mandoc.effective_date&.strftime('%d/%m/%Y') %></span></label>
                      <%end%>
                    </div>
                    <div class="p-2 pe-3 ps-0 d-flex justify-content-end"> 
                      <% if mandoc.u_sothers != "VTTIEPNHAN" && mandoc.u_sothers != "TPXULY" && mandoc.u_sothers != "THU_KY_HIEU_TRUONG"%>
                        <button id="btn_handle_vbt_<%= mandoc.id %>" class="btn btn-sm btn-outline-info me-2" type="button" data-toggle="tooltip" data-placement="top" title="Xử lý" onclick="onHandleVBT(<%= mandoc.id %>, '<%= mandoc.d_contents %>', '<%= mandoc.received_at&.in_time_zone('Asia/Ho_Chi_Minh')&.strftime('%d/%m/%Y') %>', '<%= mandoc.effective_date&.in_time_zone('Asia/Ho_Chi_Minh')&.strftime('%d/%m/%Y')%>','<%= mandoc.u_id %>', '<%= Department.where(name: mandoc.mdepartment).first&.id%>', '<%= mandoc.u_deadline%>','<%= mandoc.d_id%>','<%= mandoc.u_sothers%>')">Chuyển xử lý</button>
                      <% end %>
                        <% if mandoc.u_sothers == "VTTIEPNHAN"%>
                        <button id="btn_handle_vbt_<%= mandoc.id %>" class="btn btn-sm btn-outline-info me-2" type="button" data-toggle="tooltip" data-placement="top" title="Xử lý" onclick="onHandleVBTTCHC(<%= mandoc.id %>, '<%= mandoc.d_contents %>', '<%= mandoc.received_at&.in_time_zone('Asia/Ho_Chi_Minh')&.strftime('%d/%m/%Y') %>', '<%= mandoc.effective_date&.in_time_zone('Asia/Ho_Chi_Minh')&.strftime('%d/%m/%Y')%>','<%= mandoc.u_id %>', '<%= Department.where(name: mandoc.mdepartment).first&.id%>', '<%= mandoc.u_deadline%>','<%= mandoc.d_id%>','<%= mandoc.u_sothers%>','<%= mandoc.mdepartment%>')">Chuyển xử lý</button>
                      <% end %> 
                        <% if mandoc.u_sothers == "TPXULY"%>
                          <% @next_nodes_vbt.each do |form| %>
                            <% if @ids_departments_login.include?(form[:department_id]) && @next_nodes_vbt.count < 3 %> 
                              <button id="btn_handle_vbt_<%= mandoc.id %>" class="btn btn-sm btn-outline-info me-2" type="button" data-toggle="tooltip" data-placement="top" title="Xử lý" onclick="onHandleVBTBGH(<%= mandoc.id %>, '<%= mandoc.d_contents %>', '<%= mandoc.received_at&.in_time_zone('Asia/Ho_Chi_Minh')&.strftime('%d/%m/%Y') %>', '<%= mandoc.effective_date&.in_time_zone('Asia/Ho_Chi_Minh')&.strftime('%d/%m/%Y')%>','<%= mandoc.u_id %>', '<%= Department.where(name: mandoc.mdepartment).first&.id%>', '<%= mandoc.u_deadline%>','<%= mandoc.d_id%>','<%= mandoc.u_sothers%>','<%= mandoc.mdepartment%>')">Tham mưu văn bản</button>
                              <% break %> 
                            <% else %> 
                              <% userIdNearEnd = ""
                                oMandocDhandleNearEnd = Mandocdhandle.where(mandoc_id: mandoc.id).offset(1).last 
                                if !oMandocDhandleNearEnd.nil?
                                  oMandocUhandleNearEnd = Mandocuhandle.where(mandocdhandle_id: oMandocDhandleNearEnd.id).first
                                  if !oMandocUhandleNearEnd.nil?
                                    userIdNearEnd = oMandocUhandleNearEnd.user_id
                                  end
                                end
                              %>
                              <button class="btn btn-sm btn-outline-success me-2"
                                  onclick="openLeaderHandle(<%= mandoc.id %>, '<%= mandoc.d_contents %>', '<%= mandoc.received_at&.in_time_zone('Asia/Ho_Chi_Minh')&.strftime('%d/%m/%Y') %>', '<%= mandoc.effective_date&.in_time_zone('Asia/Ho_Chi_Minh')&.strftime('%d/%m/%Y')%>','<%= mandoc.u_id %>', '<%= mandoc.d_department_id%>', '<%= mandoc.u_deadline%>','<%= mandoc.d_id%>','<%= mandoc.u_contents%>','<%= userIdNearEnd %>')"
                                  data-toggle="tooltip" data-placement="top" title="<%=lib_translate('Handle_document')%>"> 
                                  Duyệt văn bản
                              </button>
                              <% break %> 
                              <% end %> 
                          <% end %> 
                        <% end %> 
                        <% if mandoc.u_sothers == "THU_KY_HIEU_TRUONG"%>
                          <%
                            idDepartmant = ''
                            getId = Mandocdhandle.where(mandoc_id:mandoc.id).offset(1).last
                            if !getId.nil?
                                idDepartmant = getId.department_id
                            end                                          
                          %>
                          <button id="btn_handle_vbt_<%= mandoc.id %>" class="btn btn-sm btn-outline-info me-2" type="button" data-toggle="tooltip" data-placement="top" title="Xử lý" onclick="onHandleVBTASSINGPB(<%= mandoc.id %>, '<%= mandoc.d_contents %>', '<%= mandoc.received_at&.in_time_zone('Asia/Ho_Chi_Minh')&.strftime('%d/%m/%Y') %>', '<%= mandoc.effective_date&.in_time_zone('Asia/Ho_Chi_Minh')&.strftime('%d/%m/%Y')%>','<%= mandoc.u_id %>', '<%= Department.where(name: mandoc.mdepartment).first&.id%>', '<%= mandoc.u_deadline%>','<%= mandoc.d_id%>','<%= mandoc.u_sothers%>','<%= mandoc.mdepartment%>','<%= mandoc.contents%>','<%= idDepartmant%>','mandocs/process/assign_departments_with_user_bld')">Phân về đơn vị</button>
                          <button id="btn_handle_vbt_<%= mandoc.id %>" class="btn btn-sm ms-2 btn-outline-info me-2" type="button" data-toggle="tooltip" data-placement="top" title="Xử lý" onclick="onHandleVBTAPPROVE(<%= mandoc.id %>, '<%= mandoc.d_contents %>', '<%= mandoc.received_at&.in_time_zone('Asia/Ho_Chi_Minh')&.strftime('%d/%m/%Y') %>', '<%= mandoc.effective_date&.in_time_zone('Asia/Ho_Chi_Minh')&.strftime('%d/%m/%Y')%>','<%= mandoc.u_id %>', '<%= Department.where(name: mandoc.mdepartment).first&.id%>', '<%= mandoc.u_deadline%>','<%= mandoc.d_id%>','<%= mandoc.u_sothers%>','<%= mandoc.mdepartment%>','<%= mandoc.contents%>','<%= idDepartmant%>')">Tiếp nhận văn bản</button>
                        <% end %> 
                    </div>
                  <% else %>
                    <div style="text-align: start;  display: flex;flex-direction: column;">
                      <% fullNameU = User.select("CONCAT(last_name, ' ', first_name) AS full_name").where(email: mandoc.signed_by).first&.full_name %>
                      <div style="text-align: start; cursor:pointer; display: flex;flex-direction: column; ">
                          <label style=" cursor:pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0 text-overlap" ><%=lib_translate('Excerpts_from_content')%>: <span style="font-weight: normal; white-space: normal !important;"><%= mandoc.notes %></span></label>
                          <label style=" cursor:pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0 text-overlap" ><%=lib_translate('Department')%>: <span style="font-weight: normal; white-space: normal !important;"><%= mandoc.mdepartment %></span></label>
                          <label style=" cursor:pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0 text-overlap" ><%=lib_translate('Signed_by')%>: <span style="font-weight: normal; white-space: normal !important;"><%= fullNameU %></span></label>
                          <label style=" cursor:pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0 text-overlap" ><%=lib_translate('Docs_Writer')%>: <span style="font-weight: normal;white-space: normal !important;"><%= mandoc.created_by %></span></label>
                          <label style=" cursor:pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;font-weight: bold !important;" class="m-0 text-overlap"><%= lib_translate('Documents_date')%>: <span style="font-weight: normal;white-space: normal !important;"><%= mandoc.received_at&.strftime('%d/%m/%Y') %></span>
                      </div>
                    </div>
                    <div class="p-2 pe-3 ps-0 d-flex justify-content-end"> 
                      <% if mandoc.u_sothers == "CHUYENVTXULY"%>
                        <% 
                          organization_id = ''
                          oUserORG = Uorg.where(user_id: session[:user_id]).first
                          if !oUserORG.nil?
                              organization_id = oUserORG.organization_id
                          end
                          value_sno_out = Mandoc.where(stype: mandoc.stype, status: "INACTIVE").where("sfrom is null AND YEAR(created_at) = YEAR(CURRENT_DATE())").where(organization_id: organization_id).order(updated_at: :ASC).last
                          count_out = value_sno_out&.sno.to_i + 1

                          ssymbol_VB = ""
                          ssymbol_note = Mandoctype.where(scode: mandoc.stype).first&.note
                          if @organization_scode == "BMTU"
                              ssymbol_VB = "#{ssymbol_note}-YDBMT"
                          elsif @organization_scode == "BUH"
                              ssymbol_VB = "#{ssymbol_note}-BVYDBMT"

                          end
                        %>
                        <button class="btn btn-sm btn-outline-danger me-2" onclick="openReleaseModal(<%=mandoc.id%>, <%= mandoc.sno.present? ? mandoc.sno : count_out %>, `<%= mandoc.stype.present? ? Mandoctype.where(scode: mandoc.stype).first&.name : '' %>`, `<%= mandoc.stype %>`, `<%= mandoc.ssymbol.present? ? mandoc.ssymbol : '' %>`, `<%=ssymbol_VB%>`)" data-toggle="tooltip" data-placement="top" title="<%=lib_translate('Ban_hanh_VB_VT')%>"> 
                          Ban hành
                        </button>
                        <button type="button" data-toggle="tooltip" data-placement="top" title="<%=lib_translate('Chỉnh sửa văn bản')%>" class="btn btn-sm btn-outline-info me-2" data-bs-toggle="modal" data-bs-target="#MODAL-EDIT-VBD" onclick="openFormEditMandocHandle(<%= mandoc.id%>,'<%= mandoc.type_book %>','<%= mandoc.stype %>', '<%= mandoc.received_at&.strftime("%d/%m/%Y") %>', <%= Department.where(name: mandoc&.mdepartment).first&.id  %>, '<%= mandoc&.mdepartment%>', '<%= mandoc.spriority %>', '<%= mandoc.slink %>', '<%= mandoc.number_pages %>', '<%= mandoc.notes %>', '<%= mandoc.created_by %>')">
                          Sửa văn bản
                        </button>
                      <% end %>
                      <% if mandoc.u_sothers == "DUYETVANBAN"%>
                        <button class="btn btn-sm btn-outline-success me-2"
                            onclick="clickLeaderHandle(<%= mandoc.id %>, '<%= mandoc.d_contents %>', '<%= mandoc.received_at&.in_time_zone('Asia/Ho_Chi_Minh')&.strftime('%d/%m/%Y') %>', '<%= mandoc.effective_date&.in_time_zone('Asia/Ho_Chi_Minh')&.strftime('%d/%m/%Y')%>','<%= mandoc.u_id %>', '<%= mandoc.d_department_id%>', '<%= mandoc.u_deadline%>','<%= mandoc.d_id%>','<%= mandoc.u_contents%>','<%= mandoc.u_sothers%>')"
                            data-bs-toggle="modal" data-bs-target="#MODAL-VBD-APPROVE-MANDOC-LEADER-DEPARTMENT" data-toggle="tooltip" data-placement="top" title="<%=lib_translate('Handle_document')%>"> 
                            Duyệt văn bản
                        </button>
                      <% end %>
                      <% if mandoc.u_sothers != "DUYETVANBAN" && mandoc.u_sothers != "THU_KY_HIEU_TRUONG"%>
                        <button id="btn_handle_vbd_<%= mandoc.id %>" class="btn btn-sm btn-outline-info me-2" type="button" data-toggle="tooltip" data-placement="top" title="Xử lý" onclick="onHandleVBD(<%= mandoc.id %>, '<%= mandoc.d_contents %>', '<%= mandoc.received_at&.in_time_zone('Asia/Ho_Chi_Minh')&.strftime('%d/%m/%Y') %>', '<%= mandoc.effective_date&.in_time_zone('Asia/Ho_Chi_Minh')&.strftime('%d/%m/%Y')%>','<%= mandoc.u_id %>', '<%= Department.where(name: mandoc.mdepartment).first&.id%>', '<%= mandoc.u_deadline%>','<%= mandoc.d_id%>','<%= mandoc.u_sothers%>')">Chuyển xử lý</button>
                      <% end %>
                      <% if mandoc.u_sothers == "THU_KY_HIEU_TRUONG"%>
                        <button id="btn_handle_vbd_<%= mandoc.id %>" class="btn btn-sm btn-outline-info me-2" type="button" data-toggle="tooltip" data-placement="top" title="Xử lý" onclick="onHandleVBDBLD(<%= mandoc.id %>, '<%= mandoc.d_contents %>', '<%= mandoc.received_at&.in_time_zone('Asia/Ho_Chi_Minh')&.strftime('%d/%m/%Y') %>', '<%= mandoc.effective_date&.in_time_zone('Asia/Ho_Chi_Minh')&.strftime('%d/%m/%Y')%>','<%= mandoc.u_id %>', '<%= Department.where(name: mandoc.mdepartment).first&.id%>', '<%= mandoc.u_deadline%>','<%= mandoc.d_id%>','<%= mandoc.u_sothers%>', 'mandocs/process/assign_departments')">Phân công xử lý</button>
                      <% end %>

                    </div>
                  <% end %>
                </td>
              </tr>
            <%end%>
          </tbody>
        </table>
      <div class='d-flex justify-content-between align-items-center'>
          <div class='info fs--1' id='positonjob_table_paginate'>
          <%=lib_translate('Show')%> <%=session[:mandoc_page].to_i == session[:mandoc_total_pages] ? @mandoc_total_records : (session[:mandoc_page].to_i * @userBirthday.size)%> <%=lib_translate('Up_to')%> <%=@mandoc_total_records%> <%=lib_translate('Record')%>
          </div>
          <div class='dataTables_paginate paging_simple_numbers d-flex align-items-center' id='positonjob_table_paginate'>
          <% if session[:mandoc_total_pages] > 1%>
            <ul class='pagination pagination-sm m-0'>
                <% if session[:mandoc_page].to_i > 1 %>
                  <li class='paginate_button page-item'><%= link_to lib_translate("Previous"), dashboards_index_path(lang: session[:lang],mandoc_page: session[:mandoc_page].to_i - 1, mandoc_per_page: session[:mandoc_per_page], mandoc_search: session[:mandoc_search]), class: 'page-link' %></li>
                <% end %>
                <% 1.upto(session[:mandoc_total_pages]) do |page| %>
                  <% if page == session[:mandoc_page].to_i %>
                    <% if page > 1  %>
                      <% if page > 2  %>
                        <li class='paginate_button page-item'><%= link_to "1", dashboards_index_path(lang: session[:lang],mandoc_page: 1, mandoc_per_page: session[:mandoc_per_page], mandoc_search: session[:mandoc_search]), class: 'page-link' %></li>
                      <% end %>
                      <% if page > 3 %>
                        <li class='paginate_button page-item'><%= link_to "2", dashboards_index_path(lang: session[:lang],mandoc_page: 2, mandoc_per_page: session[:mandoc_per_page], mandoc_search: session[:mandoc_search]), class: 'page-link' %></li>
                      <% end %>
                      <% if page > 4 %>
                        <li class='paginate_button page-item page-link'>...</li>
                      <% end %>
                      <li class='paginate_button page-item'><%= link_to (page - 1), dashboards_index_path(lang: session[:lang],mandoc_page: session[:mandoc_page].to_i - 1, mandoc_per_page: session[:mandoc_per_page], mandoc_search: session[:mandoc_search]), class: 'page-link' %></li>
                    <% end %>
                    <li class='paginate_button page-item active'>
                    <%= link_to page, dashboards_index_path(lang: session[:lang],mandoc_page: session[:mandoc_page].to_i, mandoc_per_page: session[:mandoc_per_page], mandoc_search: session[:mandoc_search]), class: 'page-link' %></li>
                    <% if page < session[:mandoc_total_pages] %>
                      <li class='paginate_button page-item'>
                      <%= link_to (page + 1), dashboards_index_path(lang: session[:lang],mandoc_page: session[:mandoc_page].to_i + 1, mandoc_per_page: session[:mandoc_per_page], mandoc_search: session[:mandoc_search]), class: 'page-link' %></li>
                      <% if page < session[:mandoc_total_pages] - 3 %>
                        <li class='paginate_button page-item page-link'>...</li>
                      <% end %>
                      <% if page < session[:mandoc_total_pages] - 2 %>
                        <li class='paginate_button page-item'>
                        <%= link_to (session[:mandoc_total_pages] - 1), dashboards_index_path(lang: session[:lang],mandoc_page: session[:mandoc_total_pages] - 1, mandoc_per_page: session[:mandoc_per_page], mandoc_search: session[:mandoc_search]), class: 'page-link' %></li>
                      <% end %>
                      <% if page < session[:mandoc_total_pages] - 1 %>
                        <li class='paginate_button page-item'>
