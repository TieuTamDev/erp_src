            <%= link_to "50", dashboards_index_path(lang: session[:lang], h_per_page: 50, h_search: session[:h_search]), class: 'dropdown-item' %>
          </div>
          </div>
          </div>
          </div>
          <div class='info' id='positonjob_table_paginate' style='width: 5%;'>
          </div>
      </div>
    </div>
  </div>
  <% end %>
</div>


