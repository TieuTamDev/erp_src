                    <% if page < session[:h_total_pages] %>
                      <li class='paginate_button page-item'>
                      <%= link_to (page + 1), dashboards_index_path(lang: session[:lang],h_page: session[:h_page].to_i + 1, h_per_page: session[:h_per_page], h_search: session[:h_search]), class: 'page-link' %></li>
                      <% if page < session[:h_total_pages] - 3 %>
                        <li class='paginate_button page-item page-link'>...</li>
                      <% end %>
                      <% if page < session[:h_total_pages] - 2 %>
                        <li class='paginate_button page-item'>
                        <%= link_to (session[:h_total_pages] - 1), dashboards_index_path(lang: session[:lang],h_page: session[:h_total_pages] - 1, h_per_page: session[:h_per_page], h_search: session[:h_search]), class: 'page-link' %></li>
                      <% end %>
                      <% if page < session[:h_total_pages] - 1 %>
                        <li class='paginate_button page-item'>
                        <%= link_to session[:h_total_pages], dashboards_index_path(lang: session[:lang],h_page: session[:h_total_pages], h_per_page: session[:h_per_page], h_search: session[:h_search]), class: 'page-link' %></li>
                      <% end %>
                    <% end %>
                  <% end %>
                <% end %>
                <% if session[:h_page].to_i < session[:h_total_pages] %>
                  <li class='paginate_button page-item'>
                  <%= link_to lib_translate("Next"), dashboards_index_path(lang: session[:lang],h_page: session[:h_page].to_i + 1, h_per_page: session[:h_per_page], h_search: session[:h_search]), class: 'page-link' %></li>
                <% end %>
            </ul>
          <% else %>
            <ul class='pagination pagination-sm m-0'>
            <li class='paginate_button page-item active'>
            <%= link_to "1", dashboards_index_path(lang: session[:lang],h_page: 1, h_per_page: session[:h_per_page], h_search: session[:h_search]), class: 'page-link' %></li>
            </ul>
          <% end %>
          <div class='dataTables_length ms-2' id='positonjob_table_length'>
          <div class='btn-group'>
