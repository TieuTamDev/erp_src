                <% if session[:h_page].to_i > 1 %>
                  <li class='paginate_button page-item'><%= link_to lib_translate("Previous"), dashboards_index_path(lang: session[:lang],h_page: session[:h_page].to_i - 1, h_per_page: session[:h_per_page], h_search: session[:h_search]), class: 'page-link' %></li>
                <% end %>
                <% 1.upto(session[:h_total_pages]) do |page| %>
                  <% if page == session[:h_page].to_i %>
                    <% if page > 1  %>
                      <% if page > 2  %>
                        <li class='paginate_button page-item'><%= link_to "1", dashboards_index_path(lang: session[:lang],h_page: 1, h_per_page: session[:h_per_page], h_search: session[:h_search]), class: 'page-link' %></li>
                      <% end %>
                      <% if page > 3 %>
